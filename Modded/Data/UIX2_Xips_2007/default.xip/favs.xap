function setFavEntry(x,y,z)
{
var info = new Settings;
info.file = "E:\\UDATA\\0ffeeff0\\config\\favs.dat";
info.section = x;
info.SetValue(y,z);
}

function getFavListLength(x)
{
 var listlength2 = 0;
 var section2 = x;

 for(var i = 0; i < 100; i = i + 1)
 {
  if(getFavEntry(section2,i) != "")
   listlength2 = listlength2 + 1;
  else if(getFavEntry(section2,i) == "")
   return listlength2;
 }
}
