function SkinMenuFlipUp()
{
  var c = theFavsMenu.children[0].children[0];

  if (MenuDown == true)
      {
        MenuDown = false;
        InMainLevel = true;
        bMusicMenuVisible = true;
       // HideTheInfoPanel();

       // c.theSkinPreview.visible = false;
       // c.theSettingsEqualizer.visible = false;
        clearMenuList();
      }
}

////////begin of favs functions... some of these could be combined with locks
function getFavEntry(x,y)
{
 var info = new Settings;
