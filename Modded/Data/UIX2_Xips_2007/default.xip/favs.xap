function newFavs(x) //x = 1-4, sections
{
	var favsArray = new Array();
	var sLength = getFavListLength(GetSectionPaths(x));
	for(var t = 0; t < sLength; t = t + 1)
	{
		//var mess = getFavEntry(GetSectionPaths(x),t);
		favsArray[t] = getFavEntry(GetSectionPaths(x),t);//mess.substr(9,mess.length());
	}
	favsArray = favsArray.sort();
	return favsArray;
}


function debugFavs()
{
	var theArray = buildFavsID();
	for(var i = 0; i < theArray.length; i = i + 1)
	{
		theConfig.DebugOutput( theArray[i] + "  " );
	}
}

