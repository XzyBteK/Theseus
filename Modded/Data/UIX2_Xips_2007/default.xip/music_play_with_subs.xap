function PassProtect()
{
    var c = theMusicPlayWithSubs.children[0].children[0];
    var passtext;
    theMenuTitle = c.LowerPanelText.text;
    c.LowerPanelText.text = "ENTER PASSWORD";
    InPassProtect = true;
    c.LockIcon.visible = true;
    c.theEnterPass.visible = true;
    c.asterisks.visible = true;
    c.play_buttons.visible = false;
    c.MU_L3_text_davidbowie01.visible = false;
    c.SubMenuHeaderText.visible = false;
    c.TrackNames.visible = false;
	c.theScreenOutput.children[0].appearance.texture.url = "";
	c.theScreenOutput2.children[0].appearance.texture.url = "";
    if (IconMode == "ORB")
        {
        c.theIconCube.fade = 0; 
        c.theScreenOutput.fade = 0;
        c.theIconCube.SetAlpha(0);
        c.theScreenOutput.SetAlpha(0);
        }
    else if (IconMode == "SCREEN")
        {
        c.theScreenOutput.fade = 0;
        c.theScreenOutput.SetAlpha(0);  
        }
    //
    c.LockImages.visible = false;
    
    
    if((lockFunction == "launchentry") | (lockFunction == "removefav") | (lockFunction == "removeentry"))
        passtext = "This title is locked.  Enter pass \ncode with the directional pad, \nX, Y, or left or right triggers.";
    else if(lockFunction == "addentry")
        passtext = "  To lock this item, please enter \n  pass code with the directional \n  pad, X, Y, or left or right tiggers.";
    c.theEnterPassText.text = theTranslator.Translate(passtext);
    
    
}

function ExitPassProtect()
{
    var c = theMusicPlayWithSubs.children[0].children[0];
    InPassProtect = false;
    c.LowerPanelText.text = theMenuTitle;
    c.LockIcon.visible = false;
    c.TrackNames.visible = true;
    c.LockImages.visible = true;
    if (IconMode == "ORB")
        {
        c.theIconCube.fade = 0; 
        c.theScreenOutput.fade = 0;
        c.theIconCube.SetAlpha(1);
        c.theScreenOutput.SetAlpha(1);
        }
    else if (IconMode == "SCREEN")
       {
        c.theScreenOutput.fade = 0;
        c.theScreenOutput.SetAlpha(1);  
        }
    c.asterisks.visible = false;
    c.MU_L3_text_davidbowie01.visible = true;
    c.theEnterPass.visible = false;
    c.play_buttons.visible = true;
    c.PasswordText.text = "";
	c.theScreenOutput.children[0].appearance.texture.url = "xboxlogo.xbx";
	c.theScreenOutput2.children[0].appearance.texture.url = "xboxlogo.xbx";
    asteriskcount = 0;
}

function EnterPassCode()
{
var c = theMusicPlayWithSubs.children[0].children[0];
if(asteriskcount < 4)
   {

    if(asteriskcount == 0)
       {
      firstentry = newentry;
      totalentry = firstentry;
       }
    if(asteriskcount == 1)
       {
       secondentry = newentry;
       totalentry = firstentry + secondentry;
       }
    if(asteriskcount == 2)
       {
       thirdentry = newentry;
       totalentry = firstentry + secondentry + thirdentry;
       }
    if(asteriskcount == 3)
      {
      fourthentry = newentry;
      totalentry = firstentry + secondentry + thirdentry + fourthentry;
      }
   asteriskcount = asteriskcount + 1;
   c.PasswordText.text = c.PasswordText.text + "X";
 //c.PasswordText.text = asteriskcount;
   }
if(asteriskcount == 4)
      {
       CheckPass();
      }
}

function checkMenu()
{
	var curMenu0;
	if(nCurMusicPlayWithSubsItem0 == 0)
		curMenu0 = "games";
	else if(nCurMusicPlayWithSubsItem0 == 1)
		curMenu0 = "apps";
	else if(nCurMusicPlayWithSubsItem0 == 2)
		curMenu0 = "emu";
	else if(nCurMusicPlayWithSubsItem0 == 3)
		curMenu0 = "dash";
		
	return curMenu0;
}

function CheckPass()
{
 var c = theMusicPlayWithSubs.children[0].children[0];
 var userpassword = "UDLR";//getSavedValue("Password", "Passlock"); //need to have Jbone add parental settings pass writing to Passlock in xbe var PassLock=
 if(totalentry == userpassword)
 {
  if(lockFunction == "addentry")
        LockItem();
  else if(lockFunction == "removeentry")
  {
		var curMenu0 = checkMenu();
	removeLockEntry(currentMenu(curMenu0,"GetTitleID",nPlayCursor0));
        //removeLockEntry(theGamesMenu.GetTitleID( nPlayCursor0 ));
  }
  else if(lockFunction == "removefav")
  {
	//NA
  }
  else if(lockFunction == "launchentry")
  {
   if(inFavs == true)
   {
    //launchFav();
   }
   else
   {
    LaunchCurTitle();
   }
  }
  ExitPassProtect();
  updateLockIcons();
 }
    

if(totalentry != userpassword)
   {
   //theConfig.DebugOutput( "wrong pw" );
     asteriskcount = 0;
     c.PasswordText.text = "";
   }
}

function HandlePlayerMenu() //onadown  might want to paste from bsx xaps
{
var c = theMusicPlayWithSubs.children[0].children[0];
///add locks
 if(inFavs == true)
 {
  if(nCurPlayerMenuItem == 0)
  {
   //toggle locks for favs
  }
  else if(nCurPlayerMenuItem == 1)
  {
   //launch fav
  }
  else if(nCurPlayerMenuItem == 2)
  {
   //del fav
  }
 }
 else
 {
  if(nCurPlayerMenuItem == 0)
  {
	//toggle locks
	  if(c.LockImages.children[itemPlaceHolder].visible == false)
	  {
		lockFunction = "addentry";
		PassProtect();
	  }
	  else
	  {
		lockFunction = "removeentry";
		PassProtect();
	  }
  }
  else if(nCurPlayerMenuItem == 1)
  {
	if(c.LockImages.children[itemPlaceHolder].visible == false) { LaunchCurTitle(); }
	else
	{
		lockFunction = "launchentry";
		PassProtect();
	}
  }
  else if(nCurPlayerMenuItem == 2)
  {
  var sectionName = GetSectionPaths(nCurMusicPlayWithSubsItem0 + 1);
