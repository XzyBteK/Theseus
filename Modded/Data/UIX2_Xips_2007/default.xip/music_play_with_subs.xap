function currentMenu( cMenu, mFunc, mItem ) //favs shit
{
	var rValue = "";
	if(mFunc == "SetPath")
	{
		if(cMenu == "games")
			theGamesMenu.SetPath(mItem);
		else if(cMenu == "apps")
			theApplicationsMenu.SetPath(mItem);
		else if(cMenu == "emu")
			theDashboardsMenu.SetPath(mItem);
		else if(cMenu == "dash")
			theEmulatorsMenu.SetPath(mItem);
	}
	else if(mFunc == "GetTitleName")
	{
		if(cMenu == "games")
			rValue = theGamesMenu.GetTitleName(mItem);
		else if(cMenu == "apps")
			rValue = theApplicationsMenu.GetTitleName(mItem);
		else if(cMenu == "emu")
			rValue = theDashboardsMenu.GetTitleName(mItem);
		else if(cMenu == "dash")
			rValue = theEmulatorsMenu.GetTitleName(mItem);
	}
	else if(mFunc == "SetMenuName")
	{
		if(cMenu == "games")
			theGamesMenu.SetMenuName(mItem);
		else if(cMenu == "apps")
			theApplicationsMenu.SetMenuName(mItem);
		else if(cMenu == "emu")
			theDashboardsMenu.SetMenuName(mItem);
		else if(cMenu == "dash")
			theEmulatorsMenu.SetMenuName(mItem);
	}
	else if(mFunc == "GetMenuName")
	{
		if(cMenu == "games")
			rValue = theGamesMenu.GetMenuName();
		else if(cMenu == "apps")
			rValue = theApplicationsMenu.GetMenuName();
		else if(cMenu == "emu")
			rValue = theDashboardsMenu.GetMenuName();
		else if(cMenu == "dash")
			rValue = theEmulatorsMenu.GetMenuName();
	}
	else if(mFunc == "GetTitleID")
	{
		if(cMenu == "games")
			rValue = theGamesMenu.GetTitleID(mItem);
		else if(cMenu == "apps")
			rValue = theApplicationsMenu.GetTitleID(mItem);
		else if(cMenu == "emu")
			rValue = theDashboardsMenu.GetTitleID(mItem);
		else if(cMenu == "dash")
			rValue = theEmulatorsMenu.GetTitleID(mItem);
	}
	else if(mFunc == "LaunchTitle")
	{
		if(cMenu == "games")
			theGamesMenu.LaunchTitle(mItem);
		else if(cMenu == "apps")
			theApplicationsMenu.LaunchTitle(mItem);
		else if(cMenu == "emu")
			theDashboardsMenu.LaunchTitle(mItem);
		else if(cMenu == "dash")
			theEmulatorsMenu.LaunchTitle(mItem);
	}
	else if(mFunc == "titleCount")
	{
		if(cMenu == "games")
			rValue = theGamesMenu.titleCount;
		else if(cMenu == "apps")
			rValue = theApplicationsMenu.titleCount;
		else if(cMenu == "emu")
			rValue = theDashboardsMenu.titleCount;
		else if(cMenu == "dash")
			rValue = theEmulatorsMenu.titleCount;
	}
	return rValue;
}