function GetCellWallType()
{
    var IniFile = new Settings;
	IniFile.SetIniSection( "Dashboard Settings" );
	var a = IniFile.GetIniValue( "Current Skin" );
	theCellWallMesh.url = "A:/skins/" + a + "/cellwall.xm"; 
}

function initialize()
{
GetCellWallType();

    MenuDown = false;
    InMainLevel = false;
    InSkinsMenu = false;

    bMusicPlayerReady = false;
    bMusicMenuVisible = true;
    nCurPlayerMenuItem = 0;
    nCurMusicMenuItem = 0;
    playlist = new Array;
    copyflag = new Array;
    nPlayCursor = 0;
    nPreviousPlayCursor = 0;
    nPlayScroll = 0;
    bPlayerRandom = false;
    bPlayerRepeat = false;
    nPlayVisible = 9;
    g_bFullVis = false;
//new vars
    selectedItem = 0;
itemPlaceHolder = 0;
HDMenuHolder = 0;
fromSubMenu = false;
}

