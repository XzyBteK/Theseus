function updateSkinMenu()
{

clearMenuList();
getSkins();
fillSkinsMenu();

}

function SkinMenuFlipUp()
{
  var c = theMSSkinsMenu.children[0].children[0];

  if (MenuDown == true)
      {
        MenuDown = false;
        InMainLevel = true;
        bMusicMenuVisible = true;
       // HideTheInfoPanel();

       // c.theSkinPreview.visible = false;
       // c.theSettingsEqualizer.visible = false;
        clearMenuList();
      }
}

function cacheSkinXBX() //will cache the first 9 screenshots, need to do the rest onmovedown, so loading time isnt a bitch with alot of skins
{
	theHardDrive.CreateThisDirectory( "E:\\UDATA\\0ffeeff0\\skins" );
	var loopCount = SkinMenuList.length;
	if(loopCount > 8)
		loopCount = 8;
	for(var i = 0; i < loopCount; i = i + 1)
	{
		theHardDrive.CopyThisFile( "A:\\skins\\" + SkinMenuList[i] + "\\screenshot.xbx", "E:\\UDATA\\0ffeeff0\\skins\\" +  SkinMenuList[i] + ".xbx");
	}
}