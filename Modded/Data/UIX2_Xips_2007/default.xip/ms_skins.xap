function SetMusicPlayPos(nPos) //could use this as a scrolling bar for the menu
{
    var nNewPos = nPos;     // There is a bug with the engine which prevents passed in vars from being changed
    if (nNewPos < 0)
        nNewPos = 0;
    else if (nNewPos > 1)
        nNewPos = 1;

    var x = -1.579 + ( 0.730 * nNewPos );   //   -1.528 /*-47.09*/ + 0.74 * nPos;
    var y = -0.6701;                        //   54.410000;
    var z =  0.1081;                        // -204.399994;
    theMSSkinsMenu.children[0].children[0].MU_L3_timeslider.SetTranslation(x, y, z);

    var m = theMusicPlayer.getMinutes();
    if (m < 10)
        m = "0" + m;
    var s = theMusicPlayer.getSeconds();
    if (s < 10)
        s = "0" + s;
    theMSSkinsMenu.children[0].children[0].MusicTimeText.text = m + ":" + s;
}

function UpdatePlayerMenu()
{
    var c = theMSSkinsMenu.children[0].children[0];
    c.MU_L3_button_gameinfo.children[0].appearance.material.name = "FlatSurfaces";
    c.MU_L3_text_gameinfo.children[0].children[0].appearance.material.name = "NavType";
    c.MU_L3_button_launch.children[0].appearance.material.name = "FlatSurfaces";
    c.MU_L3_text_launch.children[0].children[0].appearance.material.name = "NavType";
    c.MU_L3_button_delfav.children[0].appearance.material.name = "FlatSurfaces";
    c.MU_L3_text_delfav.children[0].children[0].appearance.material.name = "NavType";
    c.MU_L3_button_addfav.children[0].appearance.material.name = "FlatSurfaces";
    c.MU_L3_text_addfav.children[0].children[0].appearance.material.name = "NavType";


    if (nCurPlayerMenuItem == 0)
    {
        c.MU_L3_button_gameinfo.children[0].appearance.material.name = "GameHilite";
        c.MU_L3_text_gameinfo.children[0].children[0].appearance.material.name = "Material #133";
    }
    else if (nCurPlayerMenuItem == 1)
    {
        c.MU_L3_button_launch.children[0].appearance.material.name = "GameHilite";
        c.MU_L3_text_launch.children[0].children[0].appearance.material.name = "Material #133";
    }
    else if (nCurPlayerMenuItem == 2)
    {
        c.MU_L3_button_addfav.children[0].appearance.material.name = "GameHilite";
        c.MU_L3_text_addfav.children[0].children[0].appearance.material.name = "Material #133";
    }
}


