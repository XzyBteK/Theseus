DEF theMainMenu Level
{
    archive "main_menu_ms.xip"
    unloadable false

    children
    [
        Inline
        {
            url "main_menu_ms/default.xap"

            function onLoad()
            {
				var c = theMainMenu.children[0].children[0];
				//c.theDNA1.visible = false;
				//c.theDNA3.visible = false;
				//c.theDNA5.visible = false;
				//LoadBGMeshValues();
				theScreen.MotionStart();
				theScreenSaver.StartAfter( 600 );
				theConfig.SetAutoOffTime( 3.0 );
			
                mainTabs = StringtoInteger( GetConfigValue( "default","MainMenuTabs" ) );
                if( mainTabs > 3 )
                {
                    c.Main_memory_ringpin_3.SetTranslation(62.779999, 13.892000, 102.000000);   // Memory
                    c.Main_memory_ringpin_2.SetTranslation(56.830002, 33.290001, 101.900002);   // Music
                    c.Main_Online_ringpin.SetTranslation(62.779999, -6.092000, 102.000000);     // Online
                    c.Main_memory_ringpin_4.SetTranslation(57.430000, -24.379999, 101.500000);  // Settings
                    c.theSkinsTab.visible = false;
                    if(mainTabs > 4) { c.theSkinsTab.visible = true; }
                }
                else if( mainTabs == 3 )
                {
                    c.Main_Online_ringpin.visible = false;
                    c.theSkinsTab.visible = false;
                    c.Main_memory_ringpin_3.SetTranslation(62.779999, 4.492000, 102.000000);    // Memory
                    c.Main_memory_ringpin_2.SetTranslation(56.830002, 32.290001, 101.900002);   // Music
                    c.Main_memory_ringpin_4.SetTranslation(57.430000, -23.379999, 101.500000);  // Settings
                }
                UpdateMainMenu();
                UpDateMainMenuButtonsText();
                MainMenuAttract();
				loadBGMesh();
				infoPanelVis = true;
				UpdateDVDIconStatus();
            }
        }
    ]

    shell Transform
    {
        scale 150 150 150
        translation 0 -20 80
        children
        [
            Waver
            {
                rpm 0.75
                children
                [
                    Shape
                    {
                        appearance Appearance
                        {
                            material MaxMaterial { name "InnerWall_01" }
                            texture ImageTexture
                            {
                                alpha true
                                url "shell.xbx"
                            }
                        }
                       geometry USE theCellWallMesh
                    }
                    Shape
                    {
                        appearance Appearance
                        {
                            material MaxMaterial { name "InnerWall_02" }
                        }
                        geometry Sphere { radius 1 }
                    }
                ]
            }
        ]
    }


    path Viewpoint
    {
        fieldOfView 1.300000
        orientation -0.177400 -0.983500 -0.036250 -0.045440
        position 11.180000 -32.299999 174.300003
        jump false
    }

    control DEF joy Joystick
    {
        function OnADown()
        {
			fromSettings = false;
			PlaySoundA();
			var tabFunction = GetConfigValue("MainMenuTab" + (nCurMainMenuItem + 1),"Function");
			if(tabFunction == "GoToHD()")
			{
				var useHDt = GetConfigValue("default","Use Memory HD Menus");
				if(useHDt.toLowerCase() == "false")
					GoToHD();
				else
					GoToMemHardDrive();
			}
			else
				eval( tabFunction );
        }

		function OnYDown()
		{
			firstBoot = false;
			currentStyle = "REZN8";
			InitializeREZN8();
			UpdateDVDIconStatus();
		}

		function OnRightDown()
		{
           rightTrigger = true;
		}

		function OnRightUp()
		{
			rightTrigger = false;
		}

		function OnLeftDown()
		{
			leftTrigger = true;
		}

		function OnLeftUp()
		{
			leftTrigger = false;
		}

function OnXDown() 
        { 
           if((rightTrigger == true) & (leftTrigger == true) & (WireframeStatus == false)) 
                  { 
                theScreen.WireFrameStart(); 
                WireframeStatus = true;                
                } 
           else if((rightTrigger == true) & (leftTrigger == true) & (WireframeStatus == true)) 
                  { 
                theScreen.WireFrameStop(); 
                WireframeStatus = false; 
                } 
           else if(BackgroundMusicON == true) 
                BackgroundMusicOff(); 
            else if(BackgroundMusicON == false) 
                BackgroundMusicOn(); 
        
        }
         
function OnWhiteDown() 
    { 
         theScreen.TakeScreenShot(); 
    } 

		function OnBlackDown()
		{
          GoToFavs();
		}

        function OnLeftThumbMoveUp()
        {
            if ((nCurMainMenuItem > 0) & (rightTrigger == false))
            {
                nCurMainMenuItem = nCurMainMenuItem - 1;
                theMainMenuBackward.Play();
                UpdateMainMenu();
            }
        }

        function OnLeftThumbMoveDown()
        {
            if ((nCurMainMenuItem < mainTabs - 1) & (rightTrigger == false))
            {
                nCurMainMenuItem = nCurMainMenuItem + 1;
                theMainMenuForward.Play();
                UpdateMainMenu();
            }
        }

		function OnDPadPressUp()
		{
           if(rightTrigger == true) 
			  ChangeSongUp();
		}	

		function OnDPadPressDown()
		{
           if(rightTrigger == true)
			ChangeSongDown();
		}

		function OnDPadPressLeft()
		{
           if(rightTrigger == true)
			ChangeAlbumLeft();
		}

		function OnDPadPressRight()
		{
           if(rightTrigger == true)
			ChangeAlbumRight();
		}
    }

    function OnActivate()
    {
        //EnableAmbientAudio();
    }
}

var OnComplete;
var InMainLevel;

var secondhour;
var secondmins;
var secondsecs;
var firsthour;
var firstmins;
var firstsecs;
var MenuItem;
var initialmove;

///vars added for flip downs...BobMcGee..move to sep. xap later
var InHDLevel1;
var InHDLevel2;
var b_one;	//get button names from LV1 titlemenus
var b_two;
var b_three;
var b_four;
var b_five;
var bMusicPlayWithSubsVisible0; //true/false referring to whether you are in LV1
var nCurMusicPlayWithSubsItem0; //holds value 0-4 referring to tab position in LV1
var subTitle0; //holds title for LV2 menu
var nPlayCursor0; //holds position of LV2 title starting with 0 for title launching
var m_submenucount;
var m_itemcount;
var nPreviousPlayCursor0;
var nPlayScroll0;
var nPlayVisible0;
var nCurPlayerMenuItem;
var b_onScreen;   
var tempIconPath;
var IconMode;

function InitializeREZN8() 
{
//flip down initialization//will need to move all this into sep. xap
InHDLevel1 = false;
InHDLevel2 = false;
b_one = theGamesMenu.GetMenuName();	//get button names from titlemenus
b_two = theApplicationsMenu.GetMenuName();
b_three = theDashboardsMenu.GetMenuName();
b_four = theEmulatorsMenu.GetMenuName();
b_five = "none";
bMusicPlayWithSubsVisible0 = false; //redundant with InHDLevel1
nCurMusicPlayWithSubsItem0 = 0; 
nPlayCursor0 = 0; 
m_itemcount = 0;
nPreviousPlayCursor0 = 0;
nPlayScroll0 = 0;
nPlayVisible0 = 9;
nCurPlayerMenuItem = 1;
m_submenucount = 4;	
IconMode = "ORB";
//end flip down area//
	currentStyle = "REZN8";
	b_InWireFrame = false;
	bInScreenSaverView = false;
	rightTrigger = false;
	leftTrigger = false;
    bBackToDVDPlayer = false;
    bGoToCDPlayer = false;
    bBackToLauncher = false;
    bShowErrorPanel = false;
    bShowInvalidDisc = false;
    g_bKeyboardDisplayed = false;
    g_bPanelDisplayed = false;
    g_bAboutToReboot = false;
    bShowDVDStopBackground = true;
    bCleanupSpecifiedDrive = false;
    nSettingArea = 0;
    g_nRec = 0;
    strMessageYesFunction = "";
    strMessageNoFunction = "";
    strKeyboardDoneFunction = "";
    strKeyboardCancelFunction = "";
	OnComplete = true;
	InMainLevel = true;
	var tempmins = new Date;
	firsthour = tempmins.getHours() * 3600;
	firstmins = tempmins.getMinutes() * 60;
	firstsecs = tempmins.getSeconds();
	MenuItem = 1;
	initialmove = true;
	fromSettings = false;
	theMainREZN8Menu.GoTo();
}

DEF theMainREZN8Menu Level
{
	archive "main_menu_rezn8.xip"
	unloadable false

	children
	[
		Inline
		{
			url "main_menu_rezn8/default.xap"

			function onLoad()
			{
				var c = theMainREZN8Menu.children[0].children[0];
				//c.theDNA1.visible = true;
				//c.theDNA3.visible = true;
				//c.theDNA5.visible = true;
				//LoadBGMeshValues();
				theScreen.MotionStart();
				theScreenSaver.StartAfter( 600 );
				theConfig.SetAutoOffTime( 3.0 );
				c.theDateTimeText.text =  "<clock>";
				c.theSettingsEqualizer.visible = false;
				c.theGames_inner.visible = false;
				c.theMusic_inner.visible = false;
				c.theMovies_inner.visible = true;
				c.theMemory_inner.visible = false;
				c.theSettings_inner.visible = false;
				c.theGamesUnit.fade = 1;
				c.theMovieUnit.fade = 1;
				c.theMemoryUnit.fade = 1;
				c.theSettingsUnit.fade = 1;
				c.theMusicUnit.fade = 1;
				infoPanelVis = true;
				loadBGMesh();
				UpDateMainMenuButtonsText();
				UpdateDVDIconStatus();
			}
		}
	]
	shell DEF theMainREZN8MenuShell Transform
	{
		scale 150 150 150
		translation 0 -20 80
		children
		[
			DEF theMainREZN8MenuSpinner Spinner
			{
				rpm 0
				axis 0 1 0

				children
				[
					Waver
					{
						rpm 0.75
						children
						[
							Shape
							{
								appearance Appearance
								{
									material MaxMaterial { name "InnerWall_01" }
									texture ImageTexture 
									{ 
										alpha true
										url "shell.xbx"
									}
								}
								geometry USE theCellWallMesh
							}
							Shape
							{
								appearance Appearance
								{
									material MaxMaterial { name "InnerWall_02" }
								}	
								geometry Sphere { radius 1 }
							}
						]
					}
				]
			}
		]
	}

	path DEF theMainREZN8MenuViewpoint Viewpoint
	{
		fieldOfView 1.2
		orientation -0.177400 -1.983500 -0.036250 -0.045440
		position 000000 -30.299999 120.300003
		jump false
	}

	control DEF theMainREZN8MenuJoy Joystick
	{
		function OnADown()
		{
			PlaySoundA();
			theMainREZN8Menu.children[0].children[0].select_pod_HL.children[0].appearance.material.param = 1;
			fromSettings = false;
			var fixedMenuItem;
			if(MenuItem == 1) { fixedMenuItem = 3; }
			else if(MenuItem == 2) { fixedMenuItem = 1; }
			else if(MenuItem == 3) { fixedMenuItem = 2; }
			else if(MenuItem == 4) { fixedMenuItem = 4; }
			else if(MenuItem == 5) { fixedMenuItem = 5; }
			var tabFunction = GetConfigValue("MainMenuTab" + fixedMenuItem,"Function");
            if (tabFunction == "GoToHD()")
		{
				var useHDt = GetConfigValue("default","Use Memory HD Menus");
				if(useHDt.toLowerCase() == "false")
					REZN8OnADown();
				else
					GoToMemHardDrive();
		}		
            else   
			   eval(tabFunction);
		}

		function OnBDown()
		{
          if(InMainLevel == false)
		    REZN8OnBDown();
		}

function OnXDown() 
        { 
           if((rightTrigger == true) & (leftTrigger == true) & (WireframeStatus == false)) 
                  { 
                theScreen.WireFrameStart(); 
                WireframeStatus = true;                
                } 
           else if((rightTrigger == true) & (leftTrigger == true) & (WireframeStatus == true)) 
                  { 
                theScreen.WireFrameStop(); 
                WireframeStatus = false; 
                } 
           else if(BackgroundMusicON == true) 
                BackgroundMusicOff(); 
            else if(BackgroundMusicON == false) 
                BackgroundMusicOn(); 
        
        }
         
function OnWhiteDown() 
    { 
         theScreen.TakeScreenShot(); 
    } 

		function OnYDown()
		{
			firstBoot = false;
			currentStyle = "MS";
			InitializeMS();
			UpdateDVDIconStatus();
		}

		function OnLeftThumbMoveLeft()
		{
			if ((OnComplete == true) & (InMainLevel == true) & (rightTrigger == false))
			{
				var d = new Date;
				secondhour = d.getHours() * 3600;
				secondmins = d.getMinutes() * 60;
				secondsecs = d.getSeconds();
				if (((secondhour + secondmins + secondsecs) - (firsthour + firstmins + firstsecs)) > .8)
				{
					theMainMenuBackward.Play();
					var c = theMainREZN8Menu.children[0].children[0];
					c.theGamesUnit.fade = 1;
					c.theMovieUnit.fade = 1;
					c.theMemoryUnit.fade = 1;
					c.theSettingsUnit.fade = 1;
					c.theMusicUnit.fade = 1;
					firstmins = d.getMinutes() * 60;
					firstsecs = d.getSeconds();
					OnMenuLeft();
					return;
				}
			}
		}

		function OnLeftThumbMoveRight()
		{
			if ((OnComplete == true) & (InMainLevel == true) & (rightTrigger == false))
			{
				var d = new Date;
				secondhour = d.getHours() * 3600;
				secondmins = d.getMinutes() * 60;
				secondsecs = d.getSeconds();
				if (((secondhour + secondmins + secondsecs) - (firsthour + firstmins + firstsecs)) > .8)
				{
					theMainMenuForward.Play();
					var c = theMainREZN8Menu.children[0].children[0];
					c.theGamesUnit.fade = 1;
					c.theMovieUnit.fade = 1;
					c.theMemoryUnit.fade = 1;
					c.theSettingsUnit.fade = 1;
					c.theMusicUnit.fade = 1;
					firstmins = d.getMinutes() * 60;
					firstsecs = d.getSeconds();
					OnMenuRight();
					return;
				}
			}
		}

		function OnLeftThumbMoveUp()
		{
		}

		function OnLeftThumbMoveDown()
		{
		}

		function OnRightThumbMoveLeft()
		{
		}

		function OnRightThumbMoveRight()
		{
		}

		function OnRightThumbMoveUp()
		{
		}

		function OnRightThumbMoveDown()
		{
		}

		function OnDPadPressLeft()
		{
           if(rightTrigger == true)
			ChangeAlbumLeft();
		}

		function OnDPadPressRight()
		{
           if(rightTrigger == true)
			ChangeAlbumRight();
		}

		function OnDPadPressUp()
		{
           if(rightTrigger == true)
			ChangeSongUp();
		}

		function OnDPadPressDown()
		{
           if(rightTrigger == true)
			ChangeSongDown();
		}


		function OnBlackDown()
		{
			GoToFavs();
		}

		function OnRightDown()
		{
			rightTrigger = true;
		}

		function OnRightUp()
		{
			rightTrigger = false;
		}

		function OnLeftDown()
		{
			leftTrigger = true;
		}

		function OnLeftUp()
		{
			leftTrigger = false;
		}
	}
}


function OnMenuRight()
{
	var c = theMainREZN8Menu.children[0].children[0];
	MenuItem = MenuItem + 1;
	if (initialmove == true)
	{
		initialmove = false;
		MenuItem = 2;
	}
	if (MenuItem == 6)
	{
		MenuItem = 1;
	}

	if (MenuItem == 1)
	{
		c.theMovieUnit.SetTranslation(0,0,0);
		c.theMemoryUnit.SetTranslation(0,0,0);
		c.theSettingsUnit.SetTranslation(0,0,0);
		c.theGamesUnit.SetTranslation(0,0,0);
		c.theMusicUnit.SetTranslation(0,0,0);
		c.theGames_inner.visible = false;
		c.theMusic_inner.visible = false;
		c.theMovies_inner.visible = true;
		c.theMemory_inner.visible = false;
		c.theSettings_inner.visible = false;
	}
	else if (MenuItem == 2)
	{
		c.theMovieUnit.SetTranslation(100,15,-10);
		c.theMemoryUnit.SetTranslation(-100,5,-10);
		c.theSettingsUnit.SetTranslation(-50,20,-10);
		c.theGamesUnit.SetTranslation(100,-10,10);
		c.theMusicUnit.SetTranslation(-50,-30,20);
		c.theGames_inner.visible = true;
		c.theMusic_inner.visible = false;
		c.theMovies_inner.visible = false;
		c.theMemory_inner.visible = false;
		c.theSettings_inner.visible = false;
	}
	else if (MenuItem == 3)
	{
		c.theMovieUnit.SetTranslation(50,35,-20);
		c.theMemoryUnit.SetTranslation(-150,-25,10);
		c.theSettingsUnit.SetTranslation(-150,25,-20);
		c.theGamesUnit.SetTranslation(200,5,0);
		c.theMusicUnit.SetTranslation(50,-40,30);
		c.theGames_inner.visible = false;
		c.theMusic_inner.visible = true;
		c.theMovies_inner.visible = false;
		c.theMemory_inner.visible = false;
		c.theSettings_inner.visible = false;
		}
	else if (MenuItem == 4)
	{
		c.theMovieUnit.SetTranslation(-50,40,-30);
		c.theMemoryUnit.SetTranslation(-50,-35,20);
		c.theSettingsUnit.SetTranslation(-200,-5,0);
		c.theGamesUnit.SetTranslation(150,25,-10);
		c.theMusicUnit.SetTranslation(150,-25,20);
		c.theGames_inner.visible = false;
		c.theMusic_inner.visible = false;
		c.theMovies_inner.visible = false;
		c.theMemory_inner.visible = true;
		c.theSettings_inner.visible = false;
	}
	else if (MenuItem == 5)
	{
		c.theMovieUnit.SetTranslation(-100,10,-10);
		c.theMemoryUnit.SetTranslation(50,-20,10);
		c.theSettingsUnit.SetTranslation(-100,-15,10);
		c.theGamesUnit.SetTranslation(50,30,-20);
		c.theMusicUnit.SetTranslation(100,-5,10);
		c.theGames_inner.visible = false;
		c.theMusic_inner.visible = false;
		c.theMovies_inner.visible = false;
		c.theMemory_inner.visible = false;
		c.theSettings_inner.visible = true;
	}
}

function OnMenuLeft()
{
	var c = theMainREZN8Menu.children[0].children[0];
	MenuItem = MenuItem - 1;
	initialmove = false;
	if((MenuItem == -1) | (MenuItem == 0))
	{
        MenuItem = 5;
	}
	if (MenuItem == 5)
	{
		c.theMovieUnit.SetTranslation(-100,10,-10);
		c.theMemoryUnit.SetTranslation(50,-20,10);
		c.theSettingsUnit.SetTranslation(-100,-15,10);
		c.theGamesUnit.SetTranslation(50,30,-20);
		c.theMusicUnit.SetTranslation(100,-5,10);
		c.theGames_inner.visible = false;
		c.theMusic_inner.visible = false;
		c.theMovies_inner.visible = false;
		c.theMemory_inner.visible = false;
		c.theSettings_inner.visible = true;
	}
	else if (MenuItem == 4)
	{
		c.theMovieUnit.SetTranslation(-50,40,-30);
		c.theMemoryUnit.SetTranslation(-50,-35,20);
		c.theSettingsUnit.SetTranslation(-200,-5,0);
		c.theGamesUnit.SetTranslation(150,25,-10);
		c.theMusicUnit.SetTranslation(150,-25,20);
		c.theGames_inner.visible = false;
		c.theMusic_inner.visible = false;
		c.theMovies_inner.visible = false;
		c.theMemory_inner.visible = true;
		c.theSettings_inner.visible = false;
	}
	else if (MenuItem == 3)
	{
		c.theMovieUnit.SetTranslation(50,35,-20);
		c.theMemoryUnit.SetTranslation(-150,-25,10);
		c.theSettingsUnit.SetTranslation(-150,25,-20);
		c.theGamesUnit.SetTranslation(200,5,0);
		c.theMusicUnit.SetTranslation(50,-40,30);
		c.theGames_inner.visible = false;
		c.theMusic_inner.visible = true;
		c.theMovies_inner.visible = false;
		c.theMemory_inner.visible = false;
		c.theSettings_inner.visible = false;
	}
	else if (MenuItem == 2)
	{
		c.theMovieUnit.SetTranslation(100,15,-10);
		c.theMemoryUnit.SetTranslation(-100,5,-10);
		c.theSettingsUnit.SetTranslation(-50,20,-10);
		c.theGamesUnit.SetTranslation(100,-10,10);
		c.theMusicUnit.SetTranslation(-50,-30,20);
		c.theGames_inner.visible = true;
		c.theMusic_inner.visible = false;
		c.theMovies_inner.visible = false;
		c.theMemory_inner.visible = false;
		c.theSettings_inner.visible = false;
	}
	else if (MenuItem == 1)
	{
		c.theMovieUnit.SetTranslation(0,0,0);
		c.theMemoryUnit.SetTranslation(0,0,0);
		c.theSettingsUnit.SetTranslation(0,0,0);
		c.theGamesUnit.SetTranslation(0,0,0);
		c.theMusicUnit.SetTranslation(0,0,0);
		c.theGames_inner.visible = false;
		c.theMusic_inner.visible = false;
		c.theMovies_inner.visible = true;
		c.theMemory_inner.visible = false;
		c.theSettings_inner.visible = false;
	}
}
