function LaunchCurTitle()
{
	if (nCurMusicPlayWithSubsItem0 == 0)
		theGamesMenu.LaunchTitle( nPlayCursor0 );

	else if (nCurMusicPlayWithSubsItem0 == 1)
		theApplicationsMenu.LaunchTitle( nPlayCursor0 );

	else if (nCurMusicPlayWithSubsItem0 == 2)
		theDashboardsMenu.LaunchTitle( nPlayCursor0 );

	else if (nCurMusicPlayWithSubsItem0 == 3)
		theEmulatorsMenu.LaunchTitle( nPlayCursor0 );

	else if (nCurMusicPlayWithSubsItem0 == 4)
		return;
}

///the below lock funcions straight from bsx, none tested with uix yet
// now uses title ID numbers to avoid weird chars
function getLockEntry(x,y)
{
 var info = new Settings;
 info.file = "E:\\UDATA\\0ffeeff0\\config\\locks.dat";
 info.section = x;
 var b = info.GetValue(y);
 return b;
}

function addLockEntry(x,y)
{
//theConfig.DebugOutput( "addlockentry" + x + y );
 var info = new Settings;
 info.file = "E:\\UDATA\\0ffeeff0\\config\\locks.dat";
 info.section = x;
 info.SetValue(getLockListLength(x),y);
}

function setLockEntry(x,y,z)
{
var info = new Settings;
info.file = "E:\\UDATA\\0ffeeff0\\config\\locks.dat";
info.section = x;
info.SetValue(y,z);
}

function getLockListLength(x)
{
 var listlength2 = 0;
 var section2 = x;

 for(var i = 0; i < 100; i = i + 1)
 {
  if(getLockEntry(section2,i) != "")
   listlength2 = listlength2 + 1;
  else if(getLockEntry(section2,i) == "")
   return listlength2;
 }
}

function LockItem()
{
	var curMenu0 = checkMenu();
	var thetitleid = currentMenu(curMenu0,"GetTitleID",nPlayCursor0);//theGamesMenu.GetTitleID( nPlayCursor0 );
		//theConfig.DebugOutput(thetitleid);
	addLockEntry(GetSectionPaths(nCurMusicPlayWithSubsItem0 + 1), thetitleid);
}

function removeLockEntry(x) //x is the selected items name, ie "Halo"
{
 var sectionPath = GetSectionPaths(nCurMusicPlayWithSubsItem0 + 1);
 var step1;
 var step2;
 var step3;

  for(var t = 0; t < getLockListLength(sectionPath); t = t + 1)
  {
   step1 = getLockEntry(sectionPath,t);
   if(step1 == x)
   {
    fixLocksData(sectionPath,t);
    return;
   }
  }
}

function fixLocksData(x,y)
{
 var sectionPath = x;
 var deletedEntry = y;
 var nextEntry;
 for(var i = deletedEntry; i < getLockListLength(sectionPath); i = i + 1)
 {
  nextEntry = getLockEntry(sectionPath, i + 1);
  setLockEntry(sectionPath,i,nextEntry);
 }
}

function buildLocksArray()
{
 var sectionPath = GetSectionPaths(nCurMusicPlayWithSubsItem0 + 1);
 var theLocksArray = new Array(); 

 for(var i = 0; i < getLockListLength(sectionPath); i = i + 1)
 {
  theLocksArray[i] = getLockEntry(sectionPath,i);
 }

return theLocksArray;
}


function updateLockIcons() //might be best to just use the item names from the actual def (tracknames)
{
 clearLockIcons();
 var c = theMainREZN8Menu.children[0].children[0];
 c.LockImages.visible = true;
 var theLocksArray = buildLocksArray();
var curMenu0 = checkMenu();

 for(var t = (nPlayCursor0 - itemPlaceHolder); t < (nPlayCursor0 - itemPlaceHolder) + 9; t = t + 1)
 {
  for(var i = 0; i < theLocksArray.length; i = i + 1)
  {
   if(currentMenu(curMenu0,"GetTitleID",t) == theLocksArray[i]) //theGamesMenu.GetTitleID( t )
   {
    c.LockImages.children[t - (nPlayCursor0 - itemPlaceHolder)].visible = true;
   }
  }
 }
}

function clearLockIcons()
{
 var c = theMainREZN8Menu.children[0].children[0];
 for(var i = 0; i < 9; i = i + 1)
 {
  c.LockImages.children[i].visible = false;
 }
}
