DEF theBackgroundMusicCollection MusicCollection

DEF theBackgroundMusicPlayer AudioClip
{
	volume .70
    sendProgress true

	function OnEndOfAudio()  //need to add cd support shit to this
    {
	  BackgroundMusicOn();			
	}

    function OnProgressChanged()
    {

	}
}

DEF audioVisualizerOne DynamicTexture
{
    palette Palette { type 7 changePeriod 3 }

    size 352
    erase false
    fps 60

    children
    [
        ImageFader { changePeriod 10 }
        DotField
        AudioVisualizer
        {
            source USE theBackgroundMusicPlayer
            type "circle"
            scale 1.5
        }
        AudioVisualizer
        {
            source USE theBackgroundMusicPlayer
            type "ambience"
        }
    ]
}

var BGMVolume; //make sure to put in new build...music player depends on it...I set it manaully to .84 will get it to read from xbx later BMG

function GetBGMStatus() 
{ 
    var IniFile = new Settings; 
    IniFile.SetIniSection( "default" ); 
    var a = IniFile.GetIniValue( "Background Music" ); 
    var b = IniFile.GetIniValue( "Background Music Volume" ); 
    var c = StringtoInteger(b); 
    BGMVolume = c; 
    theBackgroundMusicPlayer.volume = BGMVolume; 
    if(a == "True") 
    { 
        BackgroundMusicOn(); 
        BackgroundMusicON = true; 
    } 
    else if(a == "False") 
    { 
        BackgroundMusicOff(); 
        BackgroundMusicON = false; 
    } 
    return; 
}


function BackgroundMusicOn()
{
	BackgroundMusicON = true;
	theAlbumTotal = theBackgroundMusicCollection.GetSoundtrackCount();
	theAlbum = NewRandom() * theAlbumTotal;
	theSongTotal = theBackgroundMusicCollection.GetSoundtrackSongCount(theAlbum);
	theSong = NewRandom() * theSongTotal;

	DisableAmbientAudio();
	theBackgroundMusicPlayer.url = "st:" + theBackgroundMusicCollection.GetSoundtrackSongID(theAlbum, theSong);
	theBackgroundMusicPlayer.Play();

	theAlbumPlaying = theBackgroundMusicCollection.GetSoundtrackName(theAlbum);
	theSongPlaying = theBackgroundMusicCollection.GetSoundtrackSongName(theAlbum, theSong);

	var c = DefineVarC();
	c.theSoundtrackAlbumInfoText.text = theAlbumPlaying;
	c.theSoundtrackSongInfoText.text = theSongPlaying;
}

function BackgroundMusicOff()
{
	BackgroundMusicON = false;
	var c = DefineVarC();
	theAlbumPlaying = "";
	theSongPlaying = "";
	c.theSoundtrackAlbumInfoText.text = theAlbumPlaying;
	c.theSoundtrackSongInfoText.text = theSongPlaying;

	theBackgroundMusicPlayer.Stop();
	EnableAmbientAudio();
    
}

function ChangeAlbumRight()
{
	var c = DefineVarC();
	theSong = 0;
	if (theAlbum < theAlbumTotal - 1)
	{
		theAlbum = theAlbum + 1;
		theSongTotal = theBackgroundMusicCollection.GetSoundtrackSongCount(theAlbum);
	}
	else if (theAlbum == theAlbumTotal - 1)
	{
		theAlbum = 0;
		theSongTotal = theBackgroundMusicCollection.GetSoundtrackSongCount(theAlbum);
	}
	theAlbumPlaying = theBackgroundMusicCollection.GetSoundtrackName(theAlbum);
	theSongPlaying = theBackgroundMusicCollection.GetSoundtrackSongName(theAlbum, theSong);
    c.theSoundtrackAlbumInfoText.text = theAlbumPlaying;
	c.theSoundtrackSongInfoText.text = theSongPlaying;
	theBackgroundMusicPlayer.url = "st:" + theBackgroundMusicCollection.GetSoundtrackSongID(theAlbum, theSong);
	theBackgroundMusicPlayer.Play();
}

function ChangeAlbumLeft()
{
	var c = DefineVarC();
	theSong = 0;
	if (theAlbum > 0)
	{
		theAlbum = theAlbum - 1;
		theSongTotal = theBackgroundMusicCollection.GetSoundtrackSongCount(theAlbum);
	}
	else if (theAlbum == 0)
	{
		theAlbum = theAlbumTotal - 1;
		theSongTotal = theBackgroundMusicCollection.GetSoundtrackSongCount(theAlbum);
	}

	theAlbumPlaying = theBackgroundMusicCollection.GetSoundtrackName(theAlbum);
	theSongPlaying = theBackgroundMusicCollection.GetSoundtrackSongName(theAlbum, theSong);
	c.theSoundtrackAlbumInfoText.text = theAlbumPlaying;
	c.theSoundtrackSongInfoText.text = theSongPlaying;
	theBackgroundMusicPlayer.url = "st:" + theBackgroundMusicCollection.GetSoundtrackSongID(theAlbum, theSong);
	theBackgroundMusicPlayer.Play();
}

function ChangeSongUp()
{
	var c = DefineVarC();
	if (theSong > 0) { theSong = theSong - 1; }
	else if (theSong == 0) { theSong = theSongTotal - 1; }

	theAlbumPlaying = theBackgroundMusicCollection.GetSoundtrackName(theAlbum);
	theSongPlaying = theBackgroundMusicCollection.GetSoundtrackSongName(theAlbum, theSong);
    c.theSoundtrackAlbumInfoText.text = theAlbumPlaying;
	c.theSoundtrackSongInfoText.text = theSongPlaying;
	theBackgroundMusicPlayer.url = "st:" + theBackgroundMusicCollection.GetSoundtrackSongID(theAlbum, theSong);
	theBackgroundMusicPlayer.Play();
}

function ChangeSongDown()
{
	var c = DefineVarC();
	if (theSong < theSongTotal - 1 ) { theSong = theSong + 1; }
	else if (theSong == theSongTotal -1 ) { theSong = 0; }
	theAlbumPlaying = theBackgroundMusicCollection.GetSoundtrackName(theAlbum);
	theSongPlaying = theBackgroundMusicCollection.GetSoundtrackSongName(theAlbum, theSong);
	c.theSoundtrackAlbumInfoText.text = theAlbumPlaying;
	c.theSoundtrackSongInfoText.text = theSongPlaying;
	theBackgroundMusicPlayer.url = "st:" + theBackgroundMusicCollection.GetSoundtrackSongID(theAlbum, theSong);
	theBackgroundMusicPlayer.Play();
}
/////////////////////////////////////END BGM FUNCTIONS/////////////////////////////////

function loadBGMesh()
{
	var BGMeshOn = GetConfigValue("default","Use BG Mesh");
	if(BGMeshOn.toLowerCase() == "true")
		theBGMeshTransform.SetAlpha(1);
	else if(BGMeshOn.toLowerCase() == "false")
		theBGMeshTransform.SetAlpha(0);
}