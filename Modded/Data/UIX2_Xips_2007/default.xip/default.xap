DEF theBGMesh Layer
{
    viewpoint Viewpoint
    {
        fieldOfView 1.2
		position -500 0 0
    }

    children
    [
        DEF theBGMeshTransform Transform
        {
            children
            [
                DEF theBGMeshInline Inline
                {
                    preload true //false
                    url "bg_mesh/DNA.xap" //sorry about this, it was put together in a few seconds, so no config option.
									// to change bg meshes, use these values:
									// url "bg_mesh/DNA.xap"
									// url "bg_mesh/CHAINS.xap"
									// url "bg_mesh/SPIRALS.xap"
                }
            ]
        }
    ]
}

