function UpDateMainMenuButtonsText() //will also refresh text after a setting change
{	
	var tab1Text = GetConfigValue("MainMenuTab1","Text");
	var tab2Text = GetConfigValue("MainMenuTab2","Text");
	var tab3Text = GetConfigValue("MainMenuTab3","Text");
	var tab4Text = GetConfigValue("MainMenuTab4","Text");
	var tab5Text = GetConfigValue("MainMenuTab5","Text");

	if(currentStyle == "MS")
	{
		var c = theMainMenu.children[0].children[0];
		c.Button_01_Text.geometry.text = tab1Text;
		c.Button_02_Text.geometry.text = tab2Text;
		c.Button_03_Text.geometry.text = tab3Text;
		if(mainTabs == 3) { c.Button_05_Text.geometry.text = tab3Text; }
		else { c.Button_05_Text.geometry.text = tab4Text; }
		c.theMainTab04.text = tab5Text;  
	}
	else if(currentStyle == "REZN8")
	{
		var c = theMainREZN8Menu.children[0].children[0];
		c.theOrb01Title_text.text = tab1Text;
		c.theOrb02Title_text.text = tab2Text;
		c.theOrb03Title_text.text = tab3Text;
		c.theOrb04Title_text.text = tab4Text;
		c.theOrb05Title_text.text = tab5Text;
	}
}

function InitializeMenus() //use this to setpaths for any TitleMenu objects you create
{

	theGamesMenu.SetMenuName(GetSectionTitles(1));
	theGamesMenu.SetPath(GetSectionPaths(1));
	theApplicationsMenu.SetMenuName(GetSectionTitles(2));
	theApplicationsMenu.SetPath(GetSectionPaths(2));
	theEmulatorsMenu.SetMenuName(GetSectionTitles(3));
	theEmulatorsMenu.SetPath(GetSectionPaths(3));
	theDashboardsMenu.SetMenuName(GetSectionTitles(4));
	theDashboardsMenu.SetPath(GetSectionPaths(4));
}

function MainMenuAttract()
{
	var a = 3;
	var c = theMainMenu.children[0].children[0];
	var d = theMainMenu.children[0].children[0].theMainMenuCam.children[0];
	d.fade = a;
	c.Rotating_Large_X.fade = a; 
	c.ring.fade = a; 
	c.main_pod1.fade = a; 
	c.main_poda.fade = a; 
	c.main_podb.fade = a; 
	c.main_pod2.fade = a; 
	c.Main_pod_backing02.fade = a; 

	d.SetRotation(0,0,0,0);
	d.SetTranslation(0,0,0);
	c.Rotating_Large_X.SetTranslation(0,0,0);
	c.ring.SetTranslation(-57.980000,-13.690000,-84.760002);
	c.main_pod1.SetTranslation(-61.689999 ,-13.400000 ,0.337400); 
	c.main_poda.SetTranslation(-61.689999 ,-13.400000 ,0.337400); 
	c.main_podb.SetTranslation(-61.689999 ,-13.400000 ,0.337400); 
	c.main_pod2.SetTranslation(-61.689999 ,-13.400000 ,0.337400); 
	c.Main_pod_backing02.SetScale(43,43,43); //orb
}

function QuickLaunchA()
{
	
}

function QuickLaunchB()
{

}

function QuickLaunchX()
{
	theScreen.TakeScreenShot();
}

function QuickLaunchY()
{
	if( true == b_InWireFrame )
	{		
		theScreen.WireFrameStop();
		b_InWireFrame = false;
	}
	else
	{
		theScreen.WireFrameStart();
		b_InWireFrame = true;
	}
}

function StartScreenSaverView()
{
	bInScreenSaverView = true;
	if(CurrentViewpoint != theMainMenuViewpoint) { theMainMenu.GoTo(); }
	else { DoScreenSaverView(); }
}

function DoScreenSaverView()
{
	var c = theMainMenu.children[0].children[0];
	var d = c.theMainMenuCam.children[0];
	d.fade = 2;
	theMainMenuSpinner.rpm = 3;
	c.theMenuItems.SetAlpha(0);
	EnableCurrentAlternateViewpoint();
	d.SetRotation(0,-0.000440,0,0.576000);
	d.SetTranslation(60,-70,40);
}

function StopScreenSaverView()
{
	bInScreenSaverView = false;
	var c = theMainMenu.children[0].children[0];
	var d = c.theMainMenuCam.children[0];
	d.fade = 0.6;
	theMainMenuSpinner.rpm = 0;
	d.SetRotation(0,0,0,0);
	d.SetTranslation(0,0,0);
	c.theMenuItems.SetAlpha(1);
	DisableCurrentAlternateViewpoint();
}

