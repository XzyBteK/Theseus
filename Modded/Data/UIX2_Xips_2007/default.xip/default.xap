	function OnDPadPressLeft()
	{
		if(( bMusicPlayWithSubsVisible0 == false ) & (InPassProtect == false))
				IconsOnCube();
				
            if(InPassProtect == true)
            {
            newentry = "L";
            EnterPassCode();
            return;
