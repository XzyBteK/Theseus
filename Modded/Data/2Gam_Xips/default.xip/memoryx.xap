DEF theGameBoardJoy Joystick
{

function OnADown()
{

if (PickOneFlag == true)
{
PickTwoFlag = true;
PickTwo = GameIcon;
PickTwoValue = RandomArray[GameIcon - 1];
ShowBottom();

if (Matches == 7)
{
HideIconsWithPicks();
}


}

else
{
PickOneFlag = true;
PickOne = GameIcon;
PickOneValue = RandomArray[GameIcon - 1];
ShowBottom();

}

}


function OnBDown()
{

if (InScoreBoard == true)
{
HideScoreBoard();
InScoreBoard = false;

}

else if (InScoreBoard == false)
{

ShowScoreBoard();
InScoreBoard = true;

}

}

function OnYDown()
{
theGameBoardInline.children[0].theGameBoardDisplay.SetTranslation(0, -550, -60 );

if (InScoreBoard == true)
{
HideScoreBoard();
InScoreBoard = false;
}

InQuestionScreen = true;
var txt = ReadValue(28, "default", "Datas\\Langues\\"+lang+".ini");
AskQuestion("\n \n" + txt, "theGameBoardControlsInline.children[0].NewGame()", "theGameBoardControlsInline.children[0].ReturnToGame()", 1);
}


    function OnBlackDown()
    {
    HideGameBoard();
    LeftTrigger = false;
    RightTrigger = false;
    PlaySoundMenuChange();
    }


        function OnMoveUp()
       {

            GetRowPosition();
            GetColumnPosition();
            MoveUp();
            PlaySoundMenuChange();
            UpdateGameIconHilight();
       }


    function OnMoveDown()
      {

            GetRowPosition();
            GetColumnPosition();
            MoveDown();
            PlaySoundMenuChange();
            UpdateGameIconHilight();
       }

    function OnMoveLeft()
    {

            GetRowPosition();
            GetColumnPosition();
            MoveLeft();
            PlaySoundMenuChange();
            UpdateGameIconHilight();

    }

    function OnMoveRight()
    {

            GetRowPosition();
            GetColumnPosition();
            MoveRight();
            PlaySoundMenuChange();
            UpdateGameIconHilight();
     }
	function OnPower()
	{
			Action("ShutDown_2GAM","Bouton");
	}
	function OnPlay()
	{
		if(BGMon == false | bgmpause == true)
		{
			theControlPanelControlsInline.children[0].MusicPlayerPlay();
		}
	}
	function OnStop()
	{
		if(BGMon == true)
		{
			theControlPanelControlsInline.children[0].MusicPlayerStop();
		}
	}
	function OnPause()
	{
		SSaver = 0;
		if (BGMon == true & bgmpause == false)
		{
			theControlPanelControlsInline.children[0].MusicPlayerPause();
			bgmpause = true;
		}
	}
	function OnSkipBack()
	{
		SSaver = 0;
		if(currentMusicPlayerMode == "Continuous")
		{
			theControlPanelControlsInline.children[0].MusicPlayerRewind();
		}
		else if(currentMusicPlayerMode == "Playlist")
		{
			theControlPanelControlsInline.children[0].PlaylistREW();
		}
		else if(currentMusicPlayerMode == "Random")
		{
			theControlPanelControlsInline.children[0].MusicPlayerRandom();
		}
	}
	function OnSkipForward()
	{
		SSaver = 0;
		if(currentMusicPlayerMode == "Continuous")
		{
			theControlPanelControlsInline.children[0].MusicPlayerFastForward();
		}
		else if(currentMusicPlayerMode == "Playlist")
		{
			theControlPanelControlsInline.children[0].PlaylistFFW();
		}
		else if(currentMusicPlayerMode == "Random")
		{
			theControlPanelControlsInline.children[0].MusicPlayerRandom();
		}
	}
	function OnMenu()
	{
		SSaver = 0;
		StartControlPanel();
	}
	function OnReverse()
	{
		SSaver = 0;
		if (BGMon == true & bgmpause == false)
		{
			theControlPanelControlsInline.children[0].MusicPlayerVolumeDown();
			var a = Math.round(theControlPanelControlsInline.children[0].theBGMusicPlayer.volume * 100);
			var txt = ReadValue(18, "default", "Datas\\Langues\\"+lang+".ini");
			var aa = txt + " : " + a;
			SetStatusText(aa);
		}
	}
	function OnForward()
	{
		SSaver = 0;
		if (BGMon == true & bgmpause == false)
		{
			theControlPanelControlsInline.children[0].MusicPlayerVolumeUp();
			var a = Math.round(theControlPanelControlsInline.children[0].theBGMusicPlayer.volume * 100);
			var txt = ReadValue(18, "default", "Datas\\Langues\\"+lang+".ini");
			var aa = txt + " : " + a;
			SetStatusText(aa);
		}
	}
	function On1()
	{
		SSaver = 0;
    		HideGameBoard();
    		LeftTrigger = false;
    		RightTrigger = false;
    		PlaySoundMenuChange();
	}
	function On2()
	{
		SSaver = 0;
		Action("ShowHideClock_2GAM","Bouton");
	}
	function On3()
	{
		SSaver = 0;
		Action("AffTitre_2GAM","Bouton");
	}
	function On4()
	{
		SSaver = 0;
		Action("NextBackground_2GAM","Bouton");
	}
	function On5()
	{
		SSaver = tmpSaver + 1;
	}
	function On6()
	{
		SSaver = 0;
		Action("ChangeSkins_2GAM","Bouton");
	}
	function OnRightThumbDown()
	{
		SSaver = 0;
		theConfig.screenshot();
	}
}

