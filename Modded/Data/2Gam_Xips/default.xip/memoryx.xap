/////////////////flag for game board view initial///////////
function InitializeGame()
{
GeneraleMT("memoryx");
PickOne = 20;
PickTwo = 20;
theGameBoardJoy.isBound = true;
GameBoardPreviousControl = previousControlType;
previousControlType = theGameBoardJoy;
GameBoardCurrentControl = currentControlType;
GameIcon = 1;
PickOneFlag = false;
PickTwoFlag = false;
Attempts = 0;
Matches = 0;
Score = 0;
InScoreBoard = true;
resetscore = false;
InQuestionScreen = false;
UsedTileArray = new Array(16);
UsedTileArray[0] = 0;
UsedTileArray[1] = 0;
UsedTileArray[2] = 0;
UsedTileArray[3] = 0;
UsedTileArray[4] = 0;
UsedTileArray[5] = 0;
UsedTileArray[6] = 0;
UsedTileArray[7] = 0;
UsedTileArray[8] = 0;
UsedTileArray[9] = 0;
UsedTileArray[10] = 0;
UsedTileArray[11] = 0;
UsedTileArray[12] = 0;
UsedTileArray[13] = 0;
UsedTileArray[14] = 0;
UsedTileArray[15] = 0;

RandomArray = new Array(16);
RandomArray[0] = 1;
RandomArray[1] = 2;
RandomArray[2] = 3;
RandomArray[3] = 4;
RandomArray[4] = 5;
RandomArray[5] = 6;
RandomArray[6] = 7;
RandomArray[7] = 8;
RandomArray[8] = 9;
RandomArray[9] = 10;
RandomArray[10] = 11;
RandomArray[11] = 12;
RandomArray[12] = 13;
RandomArray[13] = 14;
RandomArray[14] = 15;
RandomArray[15] = 16;

ReinitializeAlpha();
RandomArrayGenerator();
UpdateGameIconHilight();
GetScoreInfo();
UpdateScoreBoard();
ShowScoreBoard();

}
//////////////////end initial game board flag///////////////




function HideGameBoard()
{
thePlayerPanelIn.Play();
if (InScoreBoard == true)
{
HideScoreBoard();
InScoreBoard = false;
}
StopGameBoard();
theGameBoardJoy.isBound = false;
previousControlType = GameBoardPreviousControl;
previousControlType.isBound = true;
}

                                                    

function ShowScoreBoard()
{
 thePlayerPanelIn.Play();
 theGameBoardInline.children[0].theScoreBoardUnit.fade = 2;
 theGameBoardInline.children[0].theScoreBoardUnit.SetTranslation(150, 80, -20);
}

function HideScoreBoard()
{

 thePlayerPanelIn.Play();
 theGameBoardInline.children[0].theScoreBoardUnit.fade = 2;
 theGameBoardInline.children[0].theScoreBoardUnit.SetTranslation(350, 80, -20);
}

function ReturnToGame()
{
theGameBoardInline.children[0].theGameBoardDisplay.SetTranslation(-47.5,47.5,-20);
ShowScoreBoard();
InScoreBoard = true;
InQuestionScreen = false;
}

function GetScoreInfo()
{
    var info = new Settings;
    info.file = pathdash + "\\Datas\\memoryx.xbx";
    NameOne = info.GetValue("NameOne");
    NameTwo = info.GetValue("NameTwo");
    NameThree = info.GetValue("NameThree");
    ScoreOne = info.GetValue("ScoreOne");
    ScoreTwo = info.GetValue("ScoreTwo");
    ScoreThree = info.GetValue("ScoreThree");
}



function HideIconsHilight()
{
    theGameBoardInline.children[0].OneOneSquare_texture.url = "cube.xbx";
    theGameBoardInline.children[0].OneTwoSquare_texture.url = "cube.xbx";
