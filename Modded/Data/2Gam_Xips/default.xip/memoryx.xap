function MatchCheck()
{
if (Math.abs(PickOneValue - PickTwoValue) == 8)      ///Pics in two sets of 8 = 16  (eg pair 9-1 = 8. 10 -2 = 8, 11- 3 = 8)
    {
    Matches = Matches + 1;
    Attempts = Attempts + 1;
    ClearPickOneMatch();
    ClearPickTwoMatch();
    EndGame();
    }

else
  {
        Attempts = Attempts + 1;
        PickOne = 20;
        PickTwo = 20;
  }
}

function ClearPickOneMatch()
{       if (PickOne == 1)
        {theGameBoardInline.children[0].OneOneSquare.SetAlpha(0);
         UsedTileArray[PickOne - 1] = 1;
        }
