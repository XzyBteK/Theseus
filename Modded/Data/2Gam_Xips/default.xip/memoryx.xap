}

function UpdateGameIconHilight()
{

////////ROW ONE//////////

    HideIconsWithPicks();

    if(GameIcon == 1)
    {
    theGameBoardInline.children[0].OneOneSquare_texture.url = "hilight.xbx";
    }

    else if(GameIcon == 2)
    {
    theGameBoardInline.children[0].OneTwoSquare_texture.url = "hilight.xbx";
    }

    else if(GameIcon == 3)
    {
    theGameBoardInline.children[0].OneThreeSquare_texture.url = "hilight.xbx";
    }

    else if(GameIcon == 4)
    {
    theGameBoardInline.children[0].OneFourSquare_texture.url = "hilight.xbx";
    }
////////////END ROW ONE///////////
/////////////ROW TWO///////////////
    else if(GameIcon == 5)
    {
    theGameBoardInline.children[0].TwoOneSquare_texture.url = "hilight.xbx";
    }

    else if(GameIcon == 6)
    {
    theGameBoardInline.children[0].TwoTwoSquare_texture.url = "hilight.xbx";
    }

    else if(GameIcon == 7)
    {
    theGameBoardInline.children[0].TwoThreeSquare_texture.url = "hilight.xbx";
    }

    else if(GameIcon == 8)
    {
    theGameBoardInline.children[0].TwoFourSquare_texture.url = "hilight.xbx";
    }
/////////////END ROW TWO//////////////
/////////////ROW THREE/////////////////
    else if(GameIcon == 9)
    {
    theGameBoardInline.children[0].ThreeOneSquare_texture.url = "hilight.xbx";
    }

    else if(GameIcon == 10)
    {
    theGameBoardInline.children[0].ThreeTwoSquare_texture.url = "hilight.xbx";
    }

    else if(GameIcon == 11)
    {
    theGameBoardInline.children[0].ThreeThreeSquare_texture.url = "hilight.xbx";
    }

    else if(GameIcon == 12)
    {
    theGameBoardInline.children[0].ThreeFourSquare_texture.url = "hilight.xbx";
    }
////////////END ROW THREE//////////////////
/////////////ROW FOUR////////////////////////
    else if(GameIcon == 13)
    {
    theGameBoardInline.children[0].FourOneSquare_texture.url = "hilight.xbx";
    }

    else if(GameIcon == 14)
    {
    theGameBoardInline.children[0].FourTwoSquare_texture.url = "hilight.xbx";
    }

    else if(GameIcon == 15)
    {
    theGameBoardInline.children[0].FourThreeSquare_texture.url = "hilight.xbx";
    }

    else if(GameIcon == 16)
    {
    theGameBoardInline.children[0].FourFourSquare_texture.url = "hilight.xbx";
    }

///////////END ROW FOUR//////////



}

