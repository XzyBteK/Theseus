function EndGame()
{
var b = "";
var one = ReturnInteger(ScoreOne);
var two = ReturnInteger(ScoreTwo);
var three = ReturnInteger(ScoreThree);
if (Matches == 8)
{      if (InScoreBoard == true)
            {
            HideScoreBoard();
            theGameBoardInline.children[0].theGameBoardDisplay.SetTranslation(0, -550, -60 );
            InScoreBoard = false;
            //function ShowKeyboard(strTitle, strEdit, strDoneFunction, strCancelFunction)
            }

           if (Score > one)
            {
		var txt = ReadValue(19, "default", "Datas\\Langues\\"+lang+".ini");
             ShowKeyboard(txt, b, "theGameBoardControlsInline.children[0].NewScoreOne(strKeyboardEdit)", "theGameBoardControlsInline.children[0].PlayAgain()");
            }

            else if ((Score > two) & (Score <= one))
            {
		var txt = ReadValue(20, "default", "Datas\\Langues\\"+lang+".ini");
            ShowKeyboard(txt, b, "theGameBoardControlsInline.children[0].NewScoreTwo(strKeyboardEdit)", "theGameBoardControlsInline.children[0].PlayAgain()");
            }

            else if ((Score > three) & (Score <= two) )
            {
		var txt = ReadValue(21, "default", "Datas\\Langues\\"+lang+".ini");
            ShowKeyboard(txt, b, "theGameBoardControlsInline.children[0].NewScoreThree(strKeyboardEdit)", "theGameBoardControlsInline.children[0].PlayAgain()");
            }

           else
            {
             InQuestionScreen = true;
		var txt = ReadValue(22, "default", "Datas\\Langues\\"+lang+".ini");
		var txt2 = ReadValue(23, "default", "Datas\\Langues\\"+lang+".ini");
 		var txt3 = ReadValue(24, "default", "Datas\\Langues\\"+lang+".ini");
            AskQuestion("\n" + txt + "\n" + txt2 + Score + "% \n" + txt3, "theGameBoardControlsInline.children[0].NewGame()", "theGameBoardControlsInline.children[0].HideGameBoard()", 1);
            }
}
else
  { Return; }

}


function NewScoreOne(x)
{
var a = x;
var info = new Settings;
info.file = pathdash + "\\Datas\\memoryx.xbx";
var OldNameOne = info.GetValue("NameOne");
var OldNameTwo = info.GetValue("NameTwo");
var OldNameThree = info.GetValue("NameThree");
var OldScoreOne = info.GetValue("ScoreOne");
var OldScoreTwo = info.GetValue("ScoreTwo");
var OldScoreThree = info.GetValue("ScoreThree");
            info.SetValue("NameTwo", OldNameOne);
            info.SetValue("ScoreTwo", OldScoreOne);

            info.SetValue("NameThree", OldNameTwo);
            info.SetValue("ScoreThree", OldScoreTwo);

            info.SetValue("NameOne", a);
            info.SetValue("ScoreOne", Score);
GetScoreInfo(); 
PlayAgain();
}

function NewScoreTwo(x)
{
var a = x;
var info = new Settings;
info.file = pathdash + "\\Datas\\memoryx.xbx";
var OldNameTwo = info.GetValue("NameTwo");
var OldNameThree = info.GetValue("NameThree");
var OldScoreTwo = info.GetValue("ScoreTwo");
var OldScoreThree = info.GetValue("ScoreThree");

            info.SetValue("NameThree", OldNameTwo);
            info.SetValue("ScoreThree", OldScoreTwo);

              info.SetValue("NameTwo", a);
              info.SetValue("ScoreTwo", Score);
GetScoreInfo();
PlayAgain();
}

function NewScoreThree(x)
{
var a = x;
var info = new Settings;
info.file = pathdash + "\\Datas\\memoryx.xbx";

            info.SetValue("NameThree", a);
            info.SetValue("ScoreThree", Score);
GetScoreInfo();
PlayAgain();
}


function PlayAgain()
{
GetScoreInfo();
InQuestionScreen = true;
var txt = ReadValue(22, "default", "Datas\\Langues\\"+lang+".ini");
var txt2 = ReadValue(23, "default", "Datas\\Langues\\"+lang+".ini");
var txt3 = ReadValue(24, "default", "Datas\\Langues\\"+lang+".ini");
AskQuestion("\n" + txt + "\n" + txt2 + Score + "% \n" + txt3, "theGameBoardControlsInline.children[0].NewGame()", "theGameBoardControlsInline.children[0].HideGameBoard()", 1);

}


function NewGame()

{
	GetScoreInfo();
      theGameBoardInline.children[0].HighScoreOne_text.text ="1. " + NameOne + "    " + ScoreOne + "%";
      theGameBoardInline.children[0].HighScoreTwo_text.text ="2. " + NameTwo + "    " + ScoreTwo + "%";
      theGameBoardInline.children[0].HighScoreThree_text.text ="3. " + NameThree + "    " + ScoreThree + "%";
      InQuestionScreen = false;
      theGameBoardInline.children[0].theGameBoardDisplay.SetTranslation( -47.5, 47.5, -20);
      ShowScoreBoard();
      InScoreBoard = true;
      ReinitializeAlpha();
      RandomArrayGenerator();
      GameIcon = 1;
      UpdateGameIconHilight();
      Attempts = 0;
      Matches = 0;
      resetscore = true;
      Score = 100;
      Remaining = 8;
      PickOne = 20;
      PickTwo = 20;
      UpdateScoreBoard();


      UsedTileArray[0] = 0;
      UsedTileArray[1] = 0;
      UsedTileArray[2] = 0;
      UsedTileArray[3] = 0;
      UsedTileArray[4] = 0;
      UsedTileArray[5] = 0;
      UsedTileArray[6] = 0;
      UsedTileArray[7] = 0;
      UsedTileArray[8] = 0;
      UsedTileArray[9] = 0;
      UsedTileArray[10] = 0;
      UsedTileArray[11] = 0;
      UsedTileArray[12] = 0;
      UsedTileArray[13] = 0;
      UsedTileArray[14] = 0;
      UsedTileArray[15] = 0;
}


function ReinitializeAlpha()
{
        theGameBoardInline.children[0].OneOneSquare.SetAlpha(1);
        theGameBoardInline.children[0].OneTwoSquare.SetAlpha(1);
        theGameBoardInline.children[0].OneThreeSquare.SetAlpha(1);
        theGameBoardInline.children[0].OneFourSquare.SetAlpha(1);
        theGameBoardInline.children[0].TwoOneSquare.SetAlpha(1);
        theGameBoardInline.children[0].TwoTwoSquare.SetAlpha(1);
        theGameBoardInline.children[0].TwoThreeSquare.SetAlpha(1);
        theGameBoardInline.children[0].TwoFourSquare.SetAlpha(1);
        theGameBoardInline.children[0].ThreeOneSquare.SetAlpha(1);
        theGameBoardInline.children[0].ThreeTwoSquare.SetAlpha(1);
        theGameBoardInline.children[0].ThreeThreeSquare.SetAlpha(1);
        theGameBoardInline.children[0].ThreeFourSquare.SetAlpha(1);
        theGameBoardInline.children[0].FourOneSquare.SetAlpha(1);
        theGameBoardInline.children[0].FourTwoSquare.SetAlpha(1);
        theGameBoardInline.children[0].FourThreeSquare.SetAlpha(1);
        theGameBoardInline.children[0].FourFourSquare.SetAlpha(1);
}


function UpdateScoreBoard()
{
Score = Math.floor((Matches / Attempts) * 100);
Remaining = (8 - Matches);
var txt = ReadValue(25, "default", "Datas\\Langues\\"+lang+".ini");
var txt2 = ReadValue(26, "default", "Datas\\Langues\\"+lang+".ini");
var txt3 = ReadValue(27, "default", "Datas\\Langues\\"+lang+".ini");
theGameBoardInline.children[0].Remaining_text.text = txt + Remaining;
theGameBoardInline.children[0].Matches_text.text =   txt2 + Matches;
theGameBoardInline.children[0].Attempts_text.text =  txt3 + Attempts;

if (Attempts > 0)
{
theGameBoardInline.children[0].Score_text.text =     "SCORE  " + Score + "%";
}

else if (Attempts == 0)
{
theGameBoardInline.children[0].Score_text.text =     "SCORE   100%";
}

theGameBoardInline.children[0].HighScoreOne_text.text ="1. " + NameOne + "    " + ScoreOne + "%";
theGameBoardInline.children[0].HighScoreTwo_text.text ="2. " + NameTwo + "    " + ScoreTwo + "%";
theGameBoardInline.children[0].HighScoreThree_text.text ="3. " + NameThree + "    " + ScoreThree + "%";


}


function GetRowPosition()
{

if ((GameIcon == 1) | (GameIcon == 2) | (GameIcon == 3) | (GameIcon == 4))
   {
   rowposition = 1;
   }
 else  if ((GameIcon == 5) | (GameIcon == 6) | (GameIcon == 7) | (GameIcon == 8))
   {
   rowposition = 2;
   }
 else if ((GameIcon == 9) | (GameIcon == 10) | (GameIcon == 11) | (GameIcon == 12))
   {
   rowposition = 3;
   }
 else if ((GameIcon == 13) | (GameIcon == 14) | (GameIcon == 15) | (GameIcon == 16))
   {
   rowposition = 4;
   }
}

function GetColumnPosition()
{
if ((GameIcon == 1) | (GameIcon == 5) | (GameIcon == 9) | (GameIcon == 13))
   {
   colposition = 1;
   }
 else  if ((GameIcon == 2) | (GameIcon == 6) | (GameIcon == 10) | (GameIcon == 14))
   {
   colposition = 2;
   }
 else if ((GameIcon == 3) | (GameIcon == 7) | (GameIcon == 11) | (GameIcon == 15))
   {
   colposition = 3;
   }
 else if ((GameIcon == 4) | (GameIcon == 8) | (GameIcon == 12) | (GameIcon == 16))
   {
   colposition = 4;
   }
}


function MoveRight()
{

if (colposition == 1)
{
     if ((UsedTileArray[GameIcon] == 0) & (GameIcon + 1 != PickOne))
           {
            GameIcon = GameIcon + 1;
           }

       else if ((UsedTileArray[GameIcon + 1] == 0) & (GameIcon + 2 != PickOne) )
           {
          GameIcon = GameIcon + 2;
           }

       else if ((UsedTileArray[GameIcon + 2] == 0) & (GameIcon + 3 != PickOne) )
           {
           GameIcon = GameIcon + 3;
           }


       else
        {
        FindNextFreeSquareDown();
        }   ///make function to loop to find next spot and put it here
}

else if (colposition == 2)
{
     if ((UsedTileArray[GameIcon] == 0 ) & (GameIcon + 1 != PickOne))
           {
           GameIcon = GameIcon + 1;
           }

      else if ((UsedTileArray[GameIcon + 1] == 0) & (GameIcon + 2 != PickOne) )
           {
           GameIcon = GameIcon + 2;
           }

        else
        {
        FindNextFreeSquareDown();
        }
}
else if (colposition == 3)
{
      if ((UsedTileArray[GameIcon] == 0) & (GameIcon + 1 != PickOne))
           {
           GameIcon = GameIcon + 1;
           }

       else
        {
        FindNextFreeSquareDown();
        }
}
else if (colposition == 4)
{
    return;
}
}

function MoveLeft()
{
if (colposition == 4)
{
     if ((UsedTileArray[GameIcon - 2] == 0) & (GameIcon - 1 != PickOne))
           {
           GameIcon = GameIcon - 1;
           }

      else if((UsedTileArray[GameIcon - 3] == 0)  & (GameIcon - 2 != PickOne))
           {
          GameIcon = GameIcon - 2;
           }

       else if ((UsedTileArray[GameIcon - 4] == 0) & (GameIcon - 3 != PickOne))
           {
           GameIcon = GameIcon - 3;
           }

        else
        {
        FindNextFreeSquareUp();
        }
}
else if (colposition == 3)
{
      if ((UsedTileArray[GameIcon - 2] == 0) & (GameIcon - 1 != PickOne))
           {
           GameIcon = GameIcon - 1;
           }

      else if((UsedTileArray[GameIcon - 3] == 0) & (GameIcon - 2 != PickOne))
           {
          GameIcon = GameIcon - 2;
           }

        else
        {
        FindNextFreeSquareUp();
        }
}
else if (colposition == 2)
{
     if ((UsedTileArray[GameIcon - 2] == 0) & (GameIcon - 1 != PickOne))
           {
           GameIcon = GameIcon - 1;
           }
        else
        {
        FindNextFreeSquareUp();
        }
}
else if (colposition == 1)
{
    return;
}
}

function MoveDown()
{
if (rowposition == 1)
{
     if ((UsedTileArray[GameIcon + 3] == 0) & (GameIcon + 4  != PickOne))
           {
           GameIcon = GameIcon + 4;
           }

           else if ((UsedTileArray[GameIcon + 7] == 0) & (GameIcon + 8 != PickOne))
           {
          GameIcon = GameIcon + 8;
           }

           else if ((UsedTileArray[GameIcon + 11] == 0) & (GameIcon + 12 != PickOne))
           {
           GameIcon = GameIcon + 12;
           }

      else
        {
        FindNextFreeSquareDown();
        }   ///make function to loop to find next spot and put it here
}
else if (rowposition == 2)
{
       if ((UsedTileArray[GameIcon + 3] == 0) & (GameIcon + 4  != PickOne))
           {
            GameIcon = GameIcon +4;
           }

       else if ((UsedTileArray[GameIcon + 7] == 0) & (GameIcon + 8 != PickOne))
           {
          GameIcon = GameIcon + 8;
           }

        else
        {
        FindNextFreeSquareDown();
        }
}
else if (rowposition == 3)
{
       if ((UsedTileArray[GameIcon + 3] == 0) & (GameIcon + 4  != PickOne))
           {
            GameIcon = GameIcon + 4;
           }


        else
        {
        FindNextFreeSquareDown();
        }
}
else if (rowposition == 4)
{
    return;
}
}

function MoveUp()
{
if (rowposition == 4)
{
     if ((UsedTileArray[GameIcon - 5] == 0) & (GameIcon - 4  != PickOne))
           {
           GameIcon = GameIcon - 4;
           }

      else if ((UsedTileArray[GameIcon - 9] == 0) & (GameIcon - 8  != PickOne))
           {
          GameIcon = GameIcon - 8;
           }

       else if ((UsedTileArray[GameIcon - 13] == 0) & (GameIcon - 12  != PickOne))
           {
           GameIcon = GameIcon - 12;
           }

    else
        {
        FindNextFreeSquareUp();
        }
}
else if (rowposition == 3)
{
      if ((UsedTileArray[GameIcon - 5] == 0) & (GameIcon - 4  != PickOne))
           {
           GameIcon = GameIcon - 4;
           }

      else if ((UsedTileArray[GameIcon - 9] == 0) & (GameIcon - 8  != PickOne))
           {
          GameIcon = GameIcon - 8;
           }

       else
            {
