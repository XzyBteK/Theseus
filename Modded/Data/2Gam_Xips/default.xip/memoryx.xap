       }
     else if ((UsedTileArray[GameIcon + 9] == 0) & (GameIcon + 10  != PickOne))
       {
       GameIcon = GameIcon + 10;
       UpdateGameIconHilight();

       }
     else if ((UsedTileArray[GameIcon + 10] == 0) & (GameIcon + 11  != PickOne))
       {
