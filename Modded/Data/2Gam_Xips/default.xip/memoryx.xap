           }
        else
        {
        FindNextFreeSquareUp();
        }
}
else if (rowposition == 1)
{
    return;
}
}

function FindNextFreeSquareUp()
{
     if ((UsedTileArray[GameIcon - 2] == 0) & (GameIcon - 1  != PickOne))
        {
        GameIcon = GameIcon - 1;
        UpdateGameIconHilight();
        }
     else if ((UsedTileArray[GameIcon - 3] == 0) & (GameIcon - 2  != PickOne))
        {
        GameIcon = GameIcon -  2;
        UpdateGameIconHilight();
        }
     else if ((UsedTileArray[GameIcon - 4] == 0) & (GameIcon - 3  != PickOne))
        {
        GameIcon = GameIcon - 3;
        UpdateGameIconHilight();
        }
     else if ((UsedTileArray[GameIcon - 5] == 0) & (GameIcon - 4  != PickOne))
        {
        GameIcon = GameIcon -4;
        UpdateGameIconHilight();
        }
     else if ((UsedTileArray[GameIcon - 6] == 0) & (GameIcon - 5  != PickOne))
        {
        GameIcon = GameIcon -5;
        UpdateGameIconHilight();
        }
     else if ((UsedTileArray[GameIcon - 7] == 0) & (GameIcon - 6  != PickOne))
        {
        GameIcon = GameIcon - 6;
        UpdateGameIconHilight();
        }
     else if ((UsedTileArray[GameIcon - 8] == 0) & (GameIcon - 7  != PickOne))
        {
        GameIcon = GameIcon - 7;
        UpdateGameIconHilight();
        }
     else if ((UsedTileArray[GameIcon - 9] == 0) & (GameIcon - 8  != PickOne))
        {
        GameIcon = GameIcon - 8;
        UpdateGameIconHilight();
        }
     else if ((UsedTileArray[GameIcon - 10] == 0) & (GameIcon - 9  != PickOne))
        {
        GameIcon = GameIcon - 9;
        UpdateGameIconHilight();
        }
     else if ((UsedTileArray[GameIcon - 11] == 0) & (GameIcon - 10  != PickOne))
        {
        GameIcon = GameIcon - 9;
        UpdateGameIconHilight();
        }
      else if ((UsedTileArray[GameIcon - 12] == 0) & (GameIcon - 11 != PickOne))
        {
        GameIcon = GameIcon - 11;
        UpdateGameIconHilight();
        }
      else if ((UsedTileArray[GameIcon - 13] == 0) & (GameIcon - 12  != PickOne))
        {
        GameIcon = GameIcon -12;
        UpdateGameIconHilight();
        }
      else if ((UsedTileArray[GameIcon - 14] == 0) & (GameIcon - 13  != PickOne))
        {
        GameIcon = GameIcon - 13;
        UpdateGameIconHilight();
        }
      else if ((UsedTileArray[GameIcon - 15] == 0) & (GameIcon - 14  != PickOne))
        {
        GameIcon = GameIcon - 14;
        UpdateGameIconHilight();
        }
       else if ((UsedTileArray[GameIcon - 16] == 0) & (GameIcon - 15  != PickOne))
        {
        GameIcon = GameIcon - 15;
        UpdateGameIconHilight();
        }
       else
        {
        return;
        }
}

function FindNextFreeSquareDown()
{
     if ((UsedTileArray[GameIcon] == 0) & (GameIcon + 1  != PickOne))
       {
       GameIcon = GameIcon + 1;
       UpdateGameIconHilight();

       }
      else if ((UsedTileArray[GameIcon + 1] == 0) & (GameIcon + 2  != PickOne))
       {
       GameIcon = GameIcon + 2;
       UpdateGameIconHilight();

       }
