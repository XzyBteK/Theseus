///////////ABOVE TESTED OK///////

function HideIconsWithPicks()
{

if (PickOneFlag == true)
{

    if (PickTwoFlag == true)
         {
         HideIconsHilight();
         PickOneFlag = false;
         PickTwoFlag = false;
         MatchCheck();
         UpdateScoreBoard();
         }

    else
         {
         HideAllExceptPickOne();
         }

}

else
    {
    HideIconsHilight();
    }

}




function RandomArrayGenerator()
{

var RandomNumber;
var temp;

for(var ArrayPlace = 0; ArrayPlace < 16; ArrayPlace = ArrayPlace + 1)
{
                 RandomNumber = Math.floor(Math.random() * 16);
                 temp = RandomArray[ArrayPlace];
                 RandomArray[ArrayPlace] = RandomArray[RandomNumber];  ///transfers randomly chosen array position value to array position///
                 RandomArray[RandomNumber] = temp;      //places the initial value of the array position to the place it was swapped for
}

}



