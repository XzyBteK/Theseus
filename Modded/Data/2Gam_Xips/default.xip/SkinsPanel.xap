	function OnLeftDown()
	{
		SSaver = 0;
		onleft = true;
		AfficheShift();
	}

	function OnLeftUp()
	{
		SSaver = 0;
		onleft = false;
		AfficheShift();
	}
	function OnRightDown()
	{
		SSaver = 0;
		onright = true;
		AfficheShift();
	}

	function OnRightUp()
	{
		SSaver = 0;
		onright = false;
		AfficheShift();
	}
        function OnMoveRight()
        {
		SSaver = 0;
		ButtonMode = ButtonMode + 1;
		if( ButtonMode > 3)
			ButtonMode = 1;

            PlaySoundMenuChange();
		UpdateMode();
        }
        function OnMoveLeft()
        {
		SSaver = 0;
		ButtonMode = ButtonMode - 1;
		if( ButtonMode < 1)
			ButtonMode = 3;

            PlaySoundMenuChange();
		UpdateMode();
        }
        function OnMoveUp()
        {
		SSaver = 0;
            if (CurSkinsPanelItem <= 0 | ButtonMode != 3)
                return;

            PlaySoundMenuChange();

            CurSkinsPanelItem = CurSkinsPanelItem - 1;

            if (CurSkinsPanelSelected == 0)
            {
                SkinsPanelItemScroll = SkinsPanelItemScroll - 1;
                UpdateSkinsPanelMenuText();
            }
            else
            {
                CurSkinsPanelSelected = CurSkinsPanelSelected - 1;
                UpdateSkinsPanelHighlight();
            }
        }

        function OnMoveDown()
        {
		SSaver = 0;
            if (CurSkinsPanelItem == SkinsPanelItemCount - 1 | ButtonMode != 3)
                return;

            PlaySoundMenuChange();

            CurSkinsPanelItem = CurSkinsPanelItem + 1;

            if (CurSkinsPanelSelected == 5)
            {
                SkinsPanelItemScroll = SkinsPanelItemScroll + 1;
                UpdateSkinsPanelMenuText();
            }
            else
            {
                CurSkinsPanelSelected = CurSkinsPanelSelected + 1;
                UpdateSkinsPanelHighlight();
            }
        }
	function OnPower()
	{
			Action("ShutDown_2GAM","Bouton");
	}
	function OnPlay()
	{
		if(BGMon == false | bgmpause == true)
		{
			theControlPanelControlsInline.children[0].MusicPlayerPlay();
		}
	}
	function OnStop()
	{
		if(BGMon == true)
		{
			theControlPanelControlsInline.children[0].MusicPlayerStop();
		}
	}
	function OnPause()
	{
		SSaver = 0;
		if (BGMon == true & bgmpause == false)
		{
			theControlPanelControlsInline.children[0].MusicPlayerPause();
			bgmpause = true;
		}
	}
	function OnSkipBack()
	{
		SSaver = 0;
		if(currentMusicPlayerMode == "Continuous")
		{
			theControlPanelControlsInline.children[0].MusicPlayerRewind();
		}
		else if(currentMusicPlayerMode == "Playlist")
		{
			theControlPanelControlsInline.children[0].PlaylistREW();
		}
		else if(currentMusicPlayerMode == "Random")
		{
			theControlPanelControlsInline.children[0].MusicPlayerRandom();
		}
	}
	function OnSkipForward()
	{
		SSaver = 0;
		if(currentMusicPlayerMode == "Continuous")
		{
			theControlPanelControlsInline.children[0].MusicPlayerFastForward();
		}
		else if(currentMusicPlayerMode == "Playlist")
		{
			theControlPanelControlsInline.children[0].PlaylistFFW();
		}
		else if(currentMusicPlayerMode == "Random")
		{
			theControlPanelControlsInline.children[0].MusicPlayerRandom();
		}
	}
	function OnMenu()
	{
		SSaver = 0;
		StartControlPanel();
	}
	function OnReverse()
	{
		SSaver = 0;
		if (BGMon == true & bgmpause == false)
		{
			theControlPanelControlsInline.children[0].MusicPlayerVolumeDown();
			var a = Math.round(theControlPanelControlsInline.children[0].theBGMusicPlayer.volume * 100);
			var txt = ReadValue(18, "default", "Datas\\Langues\\"+lang+".ini");
			var aa = txt + " : " + a;
			SetStatusText(aa);
		}
	}
	function OnForward()
	{
		SSaver = 0;
		if (BGMon == true & bgmpause == false)
		{
			theControlPanelControlsInline.children[0].MusicPlayerVolumeUp();
			var a = Math.round(theControlPanelControlsInline.children[0].theBGMusicPlayer.volume * 100);
			var txt = ReadValue(18, "default", "Datas\\Langues\\"+lang+".ini");
			var aa = txt + " : " + a;
			SetStatusText(aa);
		}
	}
	function On1()
	{
		SSaver = 0;
		Action("MemoryX_2GAM","Bouton");
	}
	function On2()
	{
		SSaver = 0;
		Action("ShowHideClock_2GAM","Bouton");
	}
	function On3()
	{
		SSaver = 0;
		Action("AffTitre_2GAM","Bouton");
	}
	function On4()
	{
		SSaver = 0;
		Action("NextBackground_2GAM","Bouton");
	}
	function On5()
	{
		SSaver = tmpSaver + 1;
	}
    }

    function OnActivate()
    {
	CurrentViewpoint = theSkinsPanelMenuView;
	CurrentAltViewpoint = theSkinsPanelMenuAlternateView;
	previousControlType = theSkinsPanelMenuJoy;
	MenuBoutons = true;
	if (BGMon == false)
		EnableAmbientAudio();

	if (children[0].children.length() > 0)
		EnterSkinsPanelMenu();
    }
	behavior
	{
		sleep 0.2;
		if ( SetSkins == true)
		{
			SetSkins = false;
			EnterSkinsPanelMenu();
		}
		if( SetSkins == false & AuteurScroll == true)
		{
			ScrollTextAuteur();
		}
	}
}
function ScrollTextAuteur()
{
	var c = theSkinsPanelMenu.children[0].children[0];
	TextMenuAuteur = c.Auteur.text;
	var lgt = TextMenuAuteur.length();
	if( lgt > 20)
	{
		c.Auteur.text = TextMenuAuteur.substring(1,lgt)+TextMenuAuteur.substring(0,1);
	}
}
function Options()
{
	var c = theSkinsPanelMenu.children[0].children[0];
	if(ConfigSysteme[19] == "Original")
		c.BackgroundPanel.url = "Psnd.xbx";
	else if(ConfigSysteme[19] == "Verre")
		c.BackgroundPanel.url = "Fond.xbx";

	var txt = ReadValue(87, "default", "Datas\\Langues\\"+lang+".ini");
	c.MU_text_modify.children[0].geometry.text = txt;
	txt = ReadValue(86, "default", "Datas\\Langues\\"+lang+".ini");
	c.MU_Text_refresh.children[0].geometry.text = txt;
	if (MatGen != "")
	{
		c.GenMat01.name = MatGen;
		c.GenMat02.name = MatGen;
		c.GenMat03.name = MatGen;
		c.GenMat04.name = MatGen;
	}
	if (TexGen != "")
	{
		c.GenTex01.url = TexGen+".xbx";
