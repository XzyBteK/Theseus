var CurSkinsPanelItem;
var SkinsPanelItemCount;
var UseDep;
var SkinActuel;
var SkinAnim;
var Coche;
var TextMenuAuteur;
var AuteurScroll;
var ButtonMode;
function EnterSkinsPanelMenu()
{
	var c = theSkinsPanelMenu.children[0].children[0];
	var txt = ReadValue(31, "default", "Datas\\Langues\\"+lang+".ini");
	c.PanelString.text = txt;
	c.destinationString.text = "";

	SkinActuel = NSkins[CurentSkin];
	SkinAnim = ReadValue("UseOptions", "default", "Skins\\"+NSkins[CurentSkin]+"\\Skin.ini");
	if ( SkinAnim == "")
		SkinAnim = ReadValue("UseDeplacement", "default", "Skins\\"+NSkins[CurentSkin]+"\\Skin.ini");

	CurSkinsPanelItem = 0;
	SkinsPanelItemScroll = 0;
	SkinsPanelItemCount = NbSkins;
	CurSkinsPanelSelected = 0;
	Coche = "";
	TextMenuAuteur = "";
	AuteurScroll = false;
	ButtonMode = 3;
	UpdateSkinsPanelMenuText();
	UpdateSkinsPanelHighlight();
	UpdateButtonMode();
}
function UpdateSkinsPanelMenuText()
{
	var c = theSkinsPanelMenu.children[0].children[0];
	
	c.SOUND1_icon_scroll_up.visible = false;
	c.SOUND1_icon_scroll_down.visible = false;

	// test arrow visibility
	if (SkinsPanelItemScroll > 0)
		c.SOUND1_icon_scroll_up.visible = true;
	if (SkinsPanelItemScroll + 6 < SkinsPanelItemCount)
		c.SOUND1_icon_scroll_down.visible = true;


	for (var i = 0; i < 6; i = i + 1)
	{
		if (SkinsPanelItemScroll + i >= SkinsPanelItemCount)
		{
            	c.theSoundtrackMenu.children[i].visible = false;
            	c.theSoundtrackMenu.children[i].children[1].children[0].geometry.text = "";
		}
		else
		{
			if (SkinActuel == NSkins[i+1+SkinsPanelItemScroll] & SkinAnim == UseDep)
				Coche = ">> ";
			else
				Coche = "   ";

            	c.theSoundtrackMenu.children[i].visible = true;
            	c.theSoundtrackMenu.children[i].children[1].children[0].geometry.text = Coche + NSkins[i+1+SkinsPanelItemScroll];
		}
	}
	UpdateMetaPanel();
}
function UpdateSkinsPanelHighlight()
{
	var c = theSkinsPanelMenu.children[0].children[0];

	// set scroll arrows color
	c.SOUND1_icon_scroll_up.children[0].children[0].appearance.material.name = "NavType";
	c.SOUND1_icon_scroll_down.children[0].children[0].appearance.material.name = "NavType";

	for (var i = 0; i < 6; i = i + 1)
	{
		Coche = "   ";
		if (SkinActuel == NSkins[i+1+SkinsPanelItemScroll])
		{
			UseDep = ReadValue("UseOptions", "default", "Skins\\"+SkinActuel+"\\Skin.ini");
			if (UseDep == "")
				UseDep = ReadValue("UseDeplacement", "default", "Skins\\"+SkinActuel+"\\Skin.ini");

			 if (SkinAnim == UseDep)
				Coche = ">> ";
			else
				Coche = "   ";
		}
		if (i == CurSkinsPanelSelected & ButtonMode == 3)
		{
     			c.theSoundtrackMenu.children[i].children[1].children[0].geometry.text = Coche + NSkins[i+1+SkinsPanelItemScroll];
            	c.theSoundtrackMenu.children[i].children[0].appearance.material.name = BOnMatGen;
			c.theSoundtrackMenu.children[i].children[0].appearance.texture.url = BOnTexGen+".xbx";
            	c.theSoundtrackMenu.children[i].children[1].children[0].appearance.name = "Material #133";
			// hilite scroll arrows as well
			if(i == 0)
				c.SOUND1_icon_scroll_up.children[0].children[0].appearance.material.name = "Material #133";
			else if(i == 7)
				c.SOUND1_icon_scroll_down.children[0].children[0].appearance.material.name = "Material #133";
		}
		else
		{
	     		c.theSoundtrackMenu.children[i].children[1].children[0].geometry.text = Coche + NSkins[i+1+SkinsPanelItemScroll];
            	c.theSoundtrackMenu.children[i].children[0].appearance.material.name = BOffMatGen;
			c.theSoundtrackMenu.children[i].children[0].appearance.texture.url = BOffTexGen+".xbx";
            	c.theSoundtrackMenu.children[i].children[1].children[0].appearance.name = "NavType";
		}
	}
	UpdateMetaPanel();
}
function UpdateMode()
{
	if(ButtonMode == 1)
		SaveSetting("Skin","rnd","default", "Datas\\data.xbc");
	else if(ButtonMode == 2)
		SaveSetting("Skin","cont","default", "Datas\\data.xbc");
	else if(ButtonMode == 3)
		SaveSetting("Skin","fixe","default", "Datas\\data.xbc");

	UpdateButtonMode();
}
function UpdateButtonMode()
{
	var c = theSkinsPanelMenu.children[0].children[0];
	c.button_1.children[0].appearance.material.name = BOffMatGen;
	c.button_1.children[0].appearance.texture.url = BOffTexGen+".xbx";
	c.button_1.children[1].children[0].appearance.name = "NavType";
	c.button_2.children[0].appearance.material.name = BOffMatGen;
	c.button_2.children[0].appearance.texture.url = BOffTexGen+".xbx";
	c.button_2.children[1].children[0].appearance.name = "NavType";
	c.button_3.children[0].appearance.material.name = BOffMatGen;
	c.button_3.children[0].appearance.texture.url = BOffTexGen+".xbx";
	c.button_3.children[1].children[0].appearance.name = "NavType";
	Temp = ReadValue("Skin", "default", "Datas\\data.xbc");
	if( Temp == "rnd")
	{
		c.button_1.children[0].appearance.material.name = BOnMatGen;
		c.button_1.children[0].appearance.texture.url = BOnTexGen+".xbx";
		c.button_1.children[1].children[0].appearance.name = "Material #133";
		ButtonMode = 1;
	}
	else if( Temp == "cont")
	{
		c.button_2.children[0].appearance.material.name = BOnMatGen;
		c.button_2.children[0].appearance.texture.url = BOnTexGen+".xbx";
		c.button_2.children[1].children[0].appearance.name = "Material #133";
		ButtonMode = 2;
	}
	else
	{
		c.button_3.children[0].appearance.material.name = BOnMatGen;
		c.button_3.children[0].appearance.texture.url = BOnTexGen+".xbx";
		c.button_3.children[1].children[0].appearance.name = "Material #133";
		ButtonMode = 3;
	}
	UpdateSkinsPanelHighlight();
}
function UpdateMetaPanel()
{
	var c = theSkinsPanelMenu.children[0].children[0];
	c.Auteur.text = "";
	c.DateCreation.text = "";
	c.text_Auteur_panel.text = "";
	var txt = ReadValue(93, "default", "Datas\\Langues\\"+lang+".ini");
	c.text_Skin_Mode.text = txt+":";
	UseDep = ReadValue("UseOptions", "default", "Skins\\"+NSkins[CurSkinsPanelSelected+1+SkinsPanelItemScroll]+"\\Skin.ini");
	if (UseDep == "")
		UseDep = ReadValue("UseDeplacement", "default", "Skins\\"+NSkins[CurSkinsPanelSelected+1+SkinsPanelItemScroll]+"\\Skin.ini");

	if ( UseDep == "oui")
	{
		txt = ReadValue(33, "default", "Datas\\Langues\\"+lang+".ini");
		c.destinationString.text = txt;
	}
	else
	{
		txt = ReadValue(32, "default", "Datas\\Langues\\"+lang+".ini");
		c.destinationString.text = txt;
	}
	if ( SkinInfo[CurSkinsPanelSelected+1+SkinsPanelItemScroll] != "")
	{
		c.Auteur.text = SkinInfo[CurSkinsPanelSelected+1+SkinsPanelItemScroll]+" ";
		AuteurScroll = true;
		txt = ReadValue(82, "default", "Datas\\Langues\\"+lang+".ini");
		c.text_Auteur_panel.text = txt + ": ";
	}
	if ( SkinCreat[CurSkinsPanelSelected+1+SkinsPanelItemScroll] != "")
	{
		txt = ReadValue(83, "default", "Datas\\Langues\\"+lang+".ini");
		c.DateCreation.text = txt + ":    " + SkinCreat[CurSkinsPanelSelected+1+SkinsPanelItemScroll];
	}
}
function ConfirmeSkin()
{
	if(ButtonMode == 3)
	{
		if (SkinActuel == NSkins[CurSkinsPanelSelected+1+SkinsPanelItemScroll] & SkinAnim == ReadValue("UseOptions", "default", "Skins\\"+NSkins[CurSkinsPanelSelected+1+SkinsPanelItemScroll]+"\\Skin.ini"))
			theMainMenu.GoTo();
		else
		{
			var txt = ReadValue(30, "default", "Datas\\Langues\\"+lang+".ini");
			AskQuestion(txt+NSkins[CurSkinsPanelSelected+1+SkinsPanelItemScroll]+" ?", "ModeUnique()", "", 0);
		}
	}
	else
	{
		var txt = ReadValue(94, "default", "Datas\\Langues\\"+lang+".ini");
		TellUser(txt,"");
	}
}
DEF theSkinsPanelMenuAlternateView Viewpoint
{
	fieldOfView 1.342000
	orientation 0.088340 0.00100 -0.000514 -0.960500
	position -46.759998 54.430000 -215.899994
	jump false
}

DEF theSkinsPanelMenu Level
{
    archive "Music_Copy3.xip"

    children
    [
        Inline
        {
            url "Music_Copy3/default2.xap"

            function onLoad()
            {
			Options();
			EnterSkinsPanelMenu();
            }
        }
    ]

    path DEF theSkinsPanelMenuView Viewpoint
    {
		fieldOfView 1.342000
		orientation -0.088340 -0.996100 -0.000514 -0.160500
		position -46.759998 54.430000 -215.899994
		jump false
    }

    control DEF theSkinsPanelMenuJoy Joystick
    {
        function OnADown()
        {
		SSaver = 0;
		if(shift == "")
		{
			PlaySoundA();
           		theSkinsPanelMenu.children[0].children[0].MU_select_pod_HL.children[0].appearance.material.param = 1;
			ConfirmeSkin();
		}
		if(shift == "¤-")
		{
			if ( ConfigBoutonsMainMenu[8] != "0")
			Action(ConfigBoutonsMainMenu[8],"Bouton");
		}
		if(shift == "-¤")
		{
			if ( ConfigBoutonsMainMenu[16] != "0")
			Action(ConfigBoutonsMainMenu[16],"Bouton");
		}
		if(shift == "¤¤")
		{
			if ( ConfigBoutonsMainMenu[24] != "0")
			Action(ConfigBoutonsMainMenu[24],"Bouton");
		}
        }
        function OnBDown()
        {
		SSaver = 0;
		if(shift == "")
		{
            	theSkinsPanelMenu.children[0].children[0].MU_back_pod_HL.children[0].appearance.material.param = 1;
			PlaySoundB();
			theSettingsSubMenuOut.Play();
			if(backlauncher != "")
				Launcher = backlauncher;
			backlauncher = "";
			if( Launcher == "MenuConfig")
				GoToSettings();
			else if( Launcher == "MainMenu")
				theMainMenu.GoTo();
		}
		if(shift == "¤-")
		{
			if ( ConfigBoutonsMainMenu[9] != "0")
			Action(ConfigBoutonsMainMenu[9],"Bouton");
		}
		if(shift == "-¤")
		{
			if ( ConfigBoutonsMainMenu[17] != "0")
			Action(ConfigBoutonsMainMenu[17],"Bouton");
		}
		if(shift == "¤¤")
		{
			if ( ConfigBoutonsMainMenu[25] != "0")
			Action(ConfigBoutonsMainMenu[25],"Bouton");
		}
	}
	function OnXDown()
	{
		SSaver = 0;
		if(shift == "")
		{
            	theSkinsPanelMenu.children[0].children[0].MU_modify_pod_HL.children[0].appearance.material.param = 1;
			PlaySoundA();
			if (UseDep == "oui")
				UseDep = "non";
			else
				UseDep = "oui";

			Temp = ReadValue("UseOptions", "default", "Skins\\"+NSkins[CurSkinsPanelSelected+1+SkinsPanelItemScroll]+"\\Skin.ini");
			if (Temp == "")
				SaveSetting("UseDeplacement",UseDep,"default", "Skins\\"+NSkins[CurSkinsPanelSelected+1+SkinsPanelItemScroll]+"\\Skin.ini");
			else
				SaveSetting("UseOptions",UseDep,"default", "Skins\\"+NSkins[CurSkinsPanelSelected+1+SkinsPanelItemScroll]+"\\Skin.ini");

			UpdateSkinsPanelHighlight();
			UpdateMetaPanel();
		}
		if(shift == "¤-")
		{
			if ( ConfigBoutonsMainMenu[10] != "0")
			Action(ConfigBoutonsMainMenu[10],"Bouton");
		}
		if(shift == "-¤")
		{
			if ( ConfigBoutonsMainMenu[18] != "0")
			Action(ConfigBoutonsMainMenu[18],"Bouton");
		}
		if(shift == "¤¤")
		{
			if ( ConfigBoutonsMainMenu[26] != "0")
			Action(ConfigBoutonsMainMenu[26],"Bouton");
		}
	}

