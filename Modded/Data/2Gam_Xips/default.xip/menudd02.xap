	function OnRightUp()
	{
		SSaver = 0;
		onright = false;
		AfficheShift();
	}
	function OnMoveUp()
	{
		SSaver = 0;
		if (bMusicsubMenuVisible)
            {
			if (nNumMusicsubMenuItems <= 0)
				return;
                    PlaySoundMenuChange();
                    nNumMusicsubMenuItems = nNumMusicsubMenuItems - 1;
	            if (nCurMusicsubMenuItem == 0)
			{
				nCurMusicsubMenuXScroll = nCurMusicsubMenuXScroll - 1;
			}
			else
			{
				nCurMusicsubMenuItem = nCurMusicsubMenuItem - 1;
			}
			UpdateMusicsubMenu();
            }
            else
            {
    		if (nPlayCursor <= 0)
		{
    		    nPlayCursor = 0;
		}
		else
		{
			if(nPlayCursor != 0)
			{
                	    PlaySoundMenuChange();
    			    nPlayCursor = nPlayCursor - 1;
			}
		}
    		UpdateTrackList();
            }
        }

        function OnMoveDown()
        {
		SSaver = 0;
            if (bMusicsubMenuVisible)
            {
			if (nNumMusicsubMenuItems == nXItemCount - 1)
				return;
			PlaySoundMenuChange();
			nNumMusicsubMenuItems = nNumMusicsubMenuItems + 1;
			if (nCurMusicsubMenuItem == nNumXMenuItems - 1)
			{
				nCurMusicsubMenuXScroll = nCurMusicsubMenuXScroll + 1;
			}
			else
			{
				nCurMusicsubMenuItem = nCurMusicsubMenuItem + 1;
			}
			UpdateMusicsubMenu();
            }
            else
            {
			if (nPlayCursor < 0)
			nPlayCursor = 0;
			if (nPlayCursor == taille -1)
			{
				return;
			}
			else
			{
				PlaySoundMenuChange();
				nPlayCursor = nPlayCursor + 1;
			}
			UpdateTrackList();
            }
        }
	function OnPower()
	{
			Action("ShutDown_2GAM","Bouton");
	}
	function OnPlay()
	{
		if(BGMon == false | bgmpause == true)
		{
			theControlPanelControlsInline.children[0].MusicPlayerPlay();
		}
	}
	function OnStop()
	{
		if(BGMon == true)
		{
			theControlPanelControlsInline.children[0].MusicPlayerStop();
		}
	}
	function OnPause()
	{
		SSaver = 0;
		if (BGMon == true & bgmpause == false)
		{
			theControlPanelControlsInline.children[0].MusicPlayerPause();
			bgmpause = true;
		}
	}
	function OnSkipBack()
	{
		SSaver = 0;
		if(currentMusicPlayerMode == "Continuous")
		{
			theControlPanelControlsInline.children[0].MusicPlayerRewind();
		}
		else if(currentMusicPlayerMode == "Playlist")
		{
			theControlPanelControlsInline.children[0].PlaylistREW();
		}
		else if(currentMusicPlayerMode == "Random")
		{
			theControlPanelControlsInline.children[0].MusicPlayerRandom();
		}
	}
	function OnSkipForward()
	{
		SSaver = 0;
		if(currentMusicPlayerMode == "Continuous")
		{
			theControlPanelControlsInline.children[0].MusicPlayerFastForward();
		}
		else if(currentMusicPlayerMode == "Playlist")
		{
			theControlPanelControlsInline.children[0].PlaylistFFW();
		}
		else if(currentMusicPlayerMode == "Random")
		{
			theControlPanelControlsInline.children[0].MusicPlayerRandom();
		}
	}
	function OnMenu()
	{
		SSaver = 0;
		StartControlPanel();
	}
	function OnReverse()
	{
		SSaver = 0;
		if (BGMon == true & bgmpause == false)
		{
			theControlPanelControlsInline.children[0].MusicPlayerVolumeDown();
			var a = Math.round(theControlPanelControlsInline.children[0].theBGMusicPlayer.volume * 100);
			var txt = ReadValue(18, "default", "Datas\\Langues\\"+lang+".ini");
			var aa = txt + " : " + a;
			SetStatusText(aa);
		}
	}
	function OnForward()
	{
		SSaver = 0;
		if (BGMon == true & bgmpause == false)
		{
			theControlPanelControlsInline.children[0].MusicPlayerVolumeUp();
			var a = Math.round(theControlPanelControlsInline.children[0].theBGMusicPlayer.volume * 100);
			var txt = ReadValue(18, "default", "Datas\\Langues\\"+lang+".ini");
			var aa = txt + " : " + a;
			SetStatusText(aa);
		}
	}
	function On1()
	{
		SSaver = 0;
		Action("MemoryX_2GAM","Bouton");
	}
	function On2()
	{
		SSaver = 0;
		Action("ShowHideClock_2GAM","Bouton");
	}
	function On3()
	{
		SSaver = 0;
		Action("AffTitre_2GAM","Bouton");
	}
	function On4()
	{
		SSaver = 0;
		Action("NextBackground_2GAM","Bouton");
	}
	function On5()
	{
		SSaver = tmpSaver + 1;
	}
	function On6()
	{
		SSaver = 0;
		Action("ChangeSkins_2GAM","Bouton");
	}
    }

    function OnActivate()
    {
	previousControlType = theSubMenu1Joystick;
	MenuBoutons = true;
	MajMenu = DisqueType;
        if (children[0].children.length() > 0)
	{
            EnterMusicPlay();
	}
    }
    behavior
    {
        sleep 0.2;
	if (MenuSubDD == true & loadfinish == true)
	{
		if (backlauncher == "")
			backlauncher = Launcher;

		SMN = magicnumber;
		StartMusicEditor();
	}

	if (DisqueType != MajMenu & bMusicsubMenuVisible == true)
		EnterMusicPlay();

	if (ApparenceMenusDD[12] == "oui" & bMusicsubMenuVisible == true & loadfinish == true)
		AFFDD();

	if ( GetDD == true & SetDD == true)
	{
		GetDD = false;
		StartMusicEditor();
	}
    }
}
