function ShowMusicsubMenu()
{
    	var c = theSubMenu1.children[0].children[0];
	c.MU_L3_text_tracklist01.visible = false;
	c.CD_STACK.SetAlpha(0);
	OptionsMenuDD();
    	c.back1.SetTranslation(-48.990000, 52.450001, -205.000000);	
    	c.back1.SetRotation(0.000000, 1.000000, 0.000000, -0.130900);
	c.select1.SetTranslation(-45.280000, 52.339999, -204.000000);	
	c.select1.SetRotation(0.000000, 1.000000, 0.000000, -0.497400);

    	c.theMenuArm.SetRotation(0, 1, 0, 0);
    	c.audio_panel.SetRotation(-1, 0, 0, -3.246000);
    	c.audio_panel.SetTranslation(-45.549999, 57.18, -203.800003);
	c.theMenuButtons.children[0].visible = true;
	c.theMenuButtons.children[1].visible = true;
	c.theMenuButtons.children[2].visible = true;
	c.theMenuButtons.children[3].visible = true;
	c.theMenuButtons.children[4].visible = true;

	if(nXItemCount == 1)
	{
		c.theMenuButtons.children[1].visible = false;
		c.theMenuButtons.children[2].visible = false;
		c.theMenuButtons.children[3].visible = false;
		c.theMenuButtons.children[4].visible = false;
	}
	else if(nXItemCount == 2)
	{
		c.theMenuButtons.children[2].visible = false;
		c.theMenuButtons.children[3].visible = false;
		c.theMenuButtons.children[4].visible = false;
	}
	else if(nXItemCount == 3)
	{
		c.theMenuButtons.children[3].visible = false;
		c.theMenuButtons.children[4].visible = false;
	}
	else if(nXItemCount == 4)
	{
		c.theMenuButtons.children[4].visible = false;
	}
	UpdateMusicsubMenu();
	MusicsubMenuViewpoint.isBound = true;
	CurrentViewpoint = MusicsubMenuViewpoint;
	bMusicsubMenuVisible = true;
}

function StartMusicEditor()
{
	DisqueBack = "";
      nPlayCursor = 0;
	magicnumber = SMN;
	taille = TailleDD[magicnumber]/4;
	OptionsMenuDD02();
    	var c = theSubMenu1.children[0].children[0];
	c.MU_L3_text_tracklist01.visible = false;
	c.CD_STACK.SetAlpha(0);
	c.back1.SetTranslation(-47.340000, 52.809999, -204.300003);	
	c.back1.SetRotation(0.000000, -1.000000, 0.000000, -0.340300);
	c.select1.SetTranslation(-43.539999, 52.740002, -204.800003);	
	c.select1.SetRotation(-0.014820, 0.970100, -0.242300, -0.143900);
    	c.theMenuArm.SetRotation(0, 1, 0, 2);
    	c.audio_panel.SetRotation(1, 0, 0, -0.02618);
    	c.audio_panel.SetTranslation(-45.549999, 55.07, -204.5);

	nPlayScroll = 0;
	c.TitleText.text = "";
	nPlayCursor = 0;
	if (taille < 9)
	{
		nPlayVisible = taille;
	}
	else
	{
		nPlayVisible = 9;
	}
	MenuDeb = 0;
	var str = "";
	if (AjDvd == true & MenuSubDD == true)
		c.LowerPanelText.text = sMusicsubElements[magicnumber];
	else
		c.LowerPanelText.text = sMusicsubElements[magicnumber - 1];

	MenuSubDD = false;
	astrxbuttontext = new Array;
	for (var i = magicnumber-1; i > 0 ; i = i - 1)
	{
		MenuDeb=MenuDeb+TailleDD[i]/4;
	}
	for (var iii = MenuDeb; iii < MenuDeb+taille; iii = iii + 1)
	{

		var dossier = ScanneDD[iii*4];
		ScanneDD[iii*4] = "";
		var lgt = dossier.length();
		for(var nd = 0; nd < lgt; nd = nd +1)
		{
			if (nd == 0)
			{
				ScanneDD[iii*4] = dossier.substring(nd ,nd + 1);
				ScanneDD[iii*4] = ScanneDD[iii*4].toUpperCase();
			}
			else
			{
				ScanneDD[iii*4] = ScanneDD[iii*4] + dossier.substring(nd ,nd + 1);
			}
		}
		astrxbuttontext[iii-MenuDeb]=ScanneDD[iii*4];

	}
	astrxbuttontext = astrxbuttontext.sort();
	musicPlayerMenuViewpoint.isBound = true;
	CurrentViewpoint = musicPlayerMenuViewpoint;
	bMusicsubMenuVisible = false;
	UpdateTrackList();
}

function EnterMusicPlay()
{
	var c = theSubMenu1.children[0].children[0];
	CurrentViewpoint = MusicsubMenuViewpoint;
	CurrentAltViewpoint = theMusicPlayWithSubsAlternateViewpoint;
	nPlayScroll = 0;
	nCurMusicsubMenuItem = 0;
	nSoundtrack = 0;
	strTitle = "";
	MajMenu = DisqueType;
	if (AjDvd == true)
		MenusDD[1] = ReadValue(16, "default", "Datas\\Langues\\"+lang+".ini");

	if( ApparenceMenusDD[2] == "Disque Dur")
		c.TitleText1.text = ReadValue(63, "default", "Datas\\Langues\\"+lang+".ini");
	else
		c.TitleText1.text = ApparenceMenusDD[2];

	nNumMusicsubMenuItems = 0;
	if (Nbmenudd < 5)
	{
		nNumXMenuItems = Nbmenudd;
	}
	else
	{
		nNumXMenuItems = 5;
	}
	nCurMusicsubMenuItem = 0;
	nCurMusicsubMenuXScroll = 0;

	sXMenu = new Array;

	// Build the Settings Menu array
	for (var g = 1; g < Nbmenudd + 1; g = g +1)
	{
		if( MenusDD[g] == "Jeux")
			sXMenu[g-1] = ReadValue(78, "default", "Datas\\Langues\\"+lang+".ini");
		else if( MenusDD[g] == "Applications")
			sXMenu[g-1] = ReadValue(79, "default", "Datas\\Langues\\"+lang+".ini");
		else if( MenusDD[g] == "Emulateurs")
			sXMenu[g-1] = ReadValue(80, "default", "Datas\\Langues\\"+lang+".ini");
		else if( MenusDD[g] == "Dashboards")
			sXMenu[g-1] = ReadValue(81, "default", "Datas\\Langues\\"+lang+".ini");
		else
			sXMenu[g-1] = MenusDD[g];

	}
	nXItemCount = Nbmenudd;
	sMusicsubElements = sXMenu;
	ShowMusicsubMenu();
}

function UpdateMusicsubMenu()
{
    var c = theSubMenu1.children[0].children[0];

	c.MU_up.children[0].appearance.material.name = "NavType";
	c.MU_down.children[0].appearance.material.name = "NavType";

	if (nCurMusicsubMenuXScroll > 0)
		c.MU_up.visible = true;
	else
		c.MU_up.visible = false;

	if (nCurMusicsubMenuXScroll + nNumXMenuItems < nXItemCount)
		c.MU_down.visible = true;
	else
		c.MU_down.visible = false;

    for (var i = 0; i < nNumXMenuItems; i = i + 1)
    {
        if (i == nCurMusicsubMenuItem)
        {
            c.theMenuButtons.children[i].children[0].appearance.material.name = "GameHilite";
	    c.theMenuButtons.children[i].children[0].appearance.texture.url = "GameHilite_01.bmp";
            c.theMenuButtons.children[i].children[1].children[0].appearance.name = "HilightedType";
        }
        else
        {
            c.theMenuButtons.children[i].children[0].appearance.material.name = "GameHilite";
	    c.theMenuButtons.children[i].children[0].appearance.texture.url = "outline.tga";
            c.theMenuButtons.children[i].children[1].children[0].appearance.name = "NavType";
        }
		if(nXItemCount > i)
			c.theMenuButtons.children[i].children[1].children[0].geometry.text = sMusicsubElements[nCurMusicsubMenuXScroll + i];
    }

	c._button_surround.visible = true;
	c.New_Line11.visible = true;
	c._button_surround_0.visible = false;

      c.MenuMetaText.text = sMusicsubElements[nNumMusicsubMenuItems];
	if(ApparenceMenusDD[12] == "oui")
	{
		CalculSpace();
		c.DDText1.text = "";
		c.DDText2.text = "";
            c.DDText1.text = ReadValue(11, "default", "Datas\\Langues\\"+lang+".ini");
		c.DDText2.text = ReadValue(12, "default", "Datas\\Langues\\"+lang+".ini");
		AFFDD();
	}
}
function AFFDD()
{
	var c = theSubMenu1.children[0].children[0];
	c.DDText3.text = "";
	c.DDText4.text = "";
	c.DDText5.text = "";
	c.DDTailleLibre01.text = "";
	c.DDTailleLibre02.text = "";
	c.DDTailleLibre03.text = "";
	c.DDTailleTotal01.text = "";
	c.DDTailleTotal02.text = "";
	c.DDTailleTotal03.text = "";
	c.DDText3.text = "E:";
	c.DDTailleLibre01.text = DDSpace[1];
	c.DDTailleTotal01.text = DDSpace[4];
	if (DDSpace[5] != "0.00Ko" & DDSpace[5] != "0.00KB")
	{			
		c.DDText4.text = "F:";
		c.DDTailleLibre02.text = DDSpace[2];
		c.DDTailleTotal02.text = DDSpace[5];
	}
	if (DDSpace[6] != "0.00Ko" & DDSpace[6] != "0.00KB")
	{
		c.DDText5.text = "G:";
		c.DDTailleLibre03.text = DDSpace[3];
		c.DDTailleTotal03.text = DDSpace[6];
	}
}
function LaunchItem()
{
	Action(astrxbuttontext[nPlayCursor],"Disque");
}

DEF theSubMenu1 Level
{
    archive "Music_PlayEdit2.xip"

    children
    [
        Inline
        {
            url "Music_PlayEdit2/default2.xap"

            function onLoad()
            {
			loadfinish = true;
			EnterMusicPlay();
            }
        }
    ]

    tunnel Transform
    {
        children
        [
            Shape
            {
                appearance Appearance { material MaxMaterial { name "Tubes" } }
                geometry Mesh { url "Music/Tunnel_02-FACES.xm" }
            }
        ]
    }

    path USE MusicsubMenuViewpoint

    control DEF theSubMenu1Joystick Joystick
    {
        function OnADown()
        {
		SSaver = 0;
		if(shift == "")
		{
			MenuBoutons = false;
			PlaySoundA();
			theSubMenu1.children[0].children[0].MU_select_pod_HL.children[0].appearance.material.param = 1;
			if (bMusicsubMenuVisible)
			{
				if (backlauncher == "")
					backlauncher = Launcher;

				magicnumber = nNumMusicsubMenuItems + 1;
				if (AjDvd == true)
					magicnumber = magicnumber - 1;

				Launcher = "MusicPlay";
				SMN = magicnumber;
				Action("MenuLancementDD_"+magicnumber+"_2GAM","Menu2");
			}
			else
			{
				LaunchItem();
			}
		}
		if(shift == "Ê-")
		{
			if ( ConfigBoutonsMainMenu[8] != "0")
			Action(ConfigBoutonsMainMenu[8],"Bouton");
		}
		if(shift == "-Ê")
		{
			if ( ConfigBoutonsMainMenu[16] != "0")
			Action(ConfigBoutonsMainMenu[16],"Bouton");
		}
		if(shift == "ÊÊ")
		{
			if ( ConfigBoutonsMainMenu[24] != "0")
			Action(ConfigBoutonsMainMenu[24],"Bouton");
		}
        }
	function OnBDown()
	{
		SSaver = 0;
		if(shift == "")
		{
			if (bMusicsubMenuVisible)
			{
				theSubMenu1.children[0].children[0].MU_back_pod_HL.children[0].appearance.material.param = 1;
				theGamesMenuOut.Play();
				bMusicsubMenuVisible = false;
				if( backlauncher != "")
				{
					Launcher = backlauncher;
					backlauncher = "";
				}
				if( Launcher == "MainMenu")
					theMainMenu.GoBackTo();
				else if( Launcher == "MenuConfig")
					GoToSettings();
			}
			else
			{
				theSubMenu1.children[0].children[0].MU_back_pod_HL.children[0].appearance.material.param = 1;
				thePlayerPanelOut.Play();
				if( Launcher == "MusicPlay")
					ShowMusicsubMenu();
				else if( Launcher == "MainMenu")
					theMainMenu.GoBackTo();
				else if( Launcher == "MenuConfig")
					GoToSettings();
            	}
        	}
		if(shift == "Ê-")
		{
			if ( ConfigBoutonsMainMenu[9] != "0")
			Action(ConfigBoutonsMainMenu[9],"Bouton");
		}
		if(shift == "-Ê")
		{
			if ( ConfigBoutonsMainMenu[17] != "0")
			Action(ConfigBoutonsMainMenu[17],"Bouton");
		}
		if(shift == "ÊÊ")
		{
			if ( ConfigBoutonsMainMenu[25] != "0")
			Action(ConfigBoutonsMainMenu[25],"Bouton");
		}
	}
	function OnXDown()
	{
		SSaver = 0;
		if(shift == "")
		{
			if ( ConfigBoutonsMainMenu[2] != "0")
			Action(ConfigBoutonsMainMenu[2],"Bouton");
		}
		if(shift == "Ê-")
		{
			if ( ConfigBoutonsMainMenu[10] != "0")
			Action(ConfigBoutonsMainMenu[10],"Bouton");
		}
		if(shift == "-Ê")
		{
			if ( ConfigBoutonsMainMenu[18] != "0")
			Action(ConfigBoutonsMainMenu[18],"Bouton");
		}
		if(shift == "ÊÊ")
		{
			if ( ConfigBoutonsMainMenu[26] != "0")
			Action(ConfigBoutonsMainMenu[26],"Bouton");
		}
	}

	function OnYDown()
	{
		SSaver = 0;
