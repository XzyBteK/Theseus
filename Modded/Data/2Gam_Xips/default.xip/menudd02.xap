var bMusicsubMenuVisible;
var nPreviousPlayCursor;
var nPlayScroll;
var nPlayCursor;
var nPlayVisible;
var nCurMusicsubMenuItem;
var nCurMusicsubMenuXScroll;
var nNumMusicsubMenuItems;
var sMusicsubElements;
var nXItemCount;
var nNumXMenuItems;
var strTitle;
var sXMenu;
var nSoundtrack;
var loadfinish;
var astrxbuttontext;
var Panel;
var MajMenu;
var SMN;
function initialize()
{
	bMusicsubMenuVisible = true;
	nCurMusicsubMenuItem = 0;
	nPreviousPlayCursor = 0;
	nPlayScroll = 0;
	nPlayVisible = 0;
	loadfinish = false;
	backlauncher = "";
	SMN = 0;
}

function UpdateTrackList()
{
	var c = theSubMenu1.children[0].children[0];
    if (nPlayCursor < 0)
        nPlayScroll = 0;
    else if ( (nPlayCursor >= (nPlayVisible - 1)) & (nPreviousPlayCursor < nPlayCursor) & (nPlayCursor > (nPlayScroll + (nPlayVisible - 1)) ))
        nPlayScroll = nPlayCursor - (nPlayVisible - 1);
    else if (nPlayCursor < nPlayScroll)
	    nPlayScroll = nPlayCursor;
	nPreviousPlayCursor = nPlayCursor;

    var nTracks;
    nSoundtrack = taille - 1;
	nTracks = taille;
	if(ApparenceMenusDD02[7] == "gauche")
	{
		c.MU_morearrow_up.SetTranslation(1.580000, 0.568100, 0.129800);
		c.MU_morearrow_down.SetTranslation(1.580000, -0.625100, 0.129800);
	}
	else if(ApparenceMenusDD02[7] == "droite")
	{
		c.MU_morearrow_up.SetTranslation(-0.380000, 0.568100, 0.129800);
		c.MU_morearrow_down.SetTranslation(-0.380000, -0.625100, 0.129800);
	}

	// scrollbars
	if (nPlayScroll > 0)
		c.MU_morearrow_up.visible = true;
	else
		c.MU_morearrow_up.visible = false;

	if ((nPlayScroll + nPlayVisible) < nTracks)
		c.MU_morearrow_down.visible = true;
	else
		c.MU_morearrow_down.visible = false;


    // Hilite the first item when nothing is selected...
    var nHiliteItem = nPlayCursor;
    if (nHiliteItem == -1)
        nHiliteItem = 0;
	for (var ii = 0; ii < 9; ii = ii +1)
	{
		if( ii > nPlayVisible - 1)
		{
			c.TrackNames.children[ii].visible = false;
			c.TrackNumbers.children[ii].visible = false;
		}
		else
		{
			c.TrackNames.children[ii].visible = true;
			c.TrackNumbers.children[ii].visible = true;
		}
	}

    for (var i = 0; i < nPlayVisible; i = i + 1)
    {
        var n = nPlayScroll + i;
        if (n >= nTracks)
		{
			c.TrackNames.children[i].children[0].geometry.text = "";
			c.TrackNumbers.children[i].children[0].geometry.text = "";
		}
		else
		{
			var nSong = n+nCurMusicsubMenuXScroll;
			lng=astrxbuttontext[n].length();
			ind=astrxbuttontext[n].indexOf("Ê");
			if (ind < 1)
				ind = lng;

			nom=astrxbuttontext[n].substring(0,ind);
			dos=astrxbuttontext[n].substring(ind+1,lng);
			var strName, strTime;
			if(ApparenceMenusDD02[7] == "gauche")
			{
				strName = nom;
				strTime = "";
			}
			else if(ApparenceMenusDD02[7] == "droite")
			{
				strName = "";
				strTime = nom;
			}

			c.TrackNames.children[i].children[0].geometry.text = strName;
			c.TrackNumbers.children[i].children[0].geometry.text = strTime;

			if (n == nHiliteItem)
			{
				c.TrackNames.children[i].SetScale(0.17, 0.17, 0.17);
				c.TrackNumbers.children[i].SetScale(0.17, 0.17, 0.17);
				c.TrackNames.children[i].children[0].appearance.name = "CellEgg/Partsz";
				c.TrackNumbers.children[i].children[0].appearance.name = "CellEgg/Partsz";
				c.IconCube.children[0].children[0].appearance.texture.url = dos+".tga";

			}
			else
			{
				c.TrackNames.children[i].SetScale(0.13, 0.13, 0.13);
				c.TrackNumbers.children[i].SetScale(0.13, 0.13, 0.13);
				c.TrackNames.children[i].children[0].appearance.name = "NavType";
				c.TrackNumbers.children[i].children[0].appearance.name = "NavType";
			}
		}
	}
	if (nTracks == 1)
	{
		var txt = ReadValue(6, "default", "Datas\\Langues\\"+lang+".ini");
		c.SubMenuHeaderText.text = nTracks + " " + txt;
	}
	else
	{
		var txt = ReadValue(5, "default", "Datas\\Langues\\"+lang+".ini");
		c.SubMenuHeaderText.text = nTracks + " " + txt;
	}
}

