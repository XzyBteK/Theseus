function UpdateListClockHands()
{
    var c = theChooseClockMenu.children[0].children[0];
    var d = new Date;

    nClockHourC = d.getHours();
    nClockMinuteC = d.getMinutes();

    c.ClockHourHand.SetRotation(0, 0, -1, (nClockHourC + nClockMinuteC / 60) * 6.283 / 12);
    c.ClockMinuteHand.SetRotation(0, 0, -1, (nClockMinuteC - 15) * 6.283 / 60);
}

