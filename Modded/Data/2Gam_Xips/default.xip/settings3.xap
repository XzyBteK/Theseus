DEF theSetPanelMenu Level
{
	archive "Settings_Panel.xip"

	children
	[
		Inline
		{
			url "Settings_Panel/default.xap"

			function onLoad()
			{
				StartPanelMenu();
			}
		}
	]

	path DEF theSetPanelMenuView Viewpoint
	{
		fieldOfView 1.287000
