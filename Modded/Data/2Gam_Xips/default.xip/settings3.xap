function SetDateTimeYYMMDD( c )
{
    if (nClockYearC < 10)
        c.txtMonth.text = "0" + nClockYearC;
    else
        c.txtMonth.text = nClockYearC;

    if (nClockDayC < 10)
        c.txtYear.text = "0" + nClockDayC;
    else
        c.txtYear.text = nClockDayC;

    if (nClockMonthC < 10)
        c.txtDay.text = "0" + nClockMonthC;
    else
        c.txtDay.text = nClockMonthC;
}

function UpdateTime()
{
    var c = theSetClockMenu.children[0].children[0];

    c.ClockHourHand.SetRotation(0, 0, -1, (nClockHourC + nClockMinuteC / 60) * 6.283 / 12);
    c.ClockMinuteHand.SetRotation(0, 0, -1, (nClockMinuteC - 15) * 6.283 / 60);

    c.MonthText.text = theTranslator.Translate(monthnames[nClockMonthC - 1]);
    c.DayText.text = nClockDayC;

    c.txtHour.text = nClockHourC;

    if (nClockMinuteC < 10)
        c.txtMinute.text = "0" + nClockMinuteC;
    else
        c.txtMinute.text = nClockMinuteC;

    if (b24hour == false)
        c.txtAMPM.text = nClockAMPMC;

    // Everywhere else is dd mm yyyy
    if (nClockDayC < 10)
        c.txtMonth.text = "0" + nClockDayC;
    else
        c.txtMonth.text = nClockDayC;

    if (nClockMonthC < 10)
        c.txtDay.text = "0" + nClockMonthC;
    else
        c.txtDay.text = nClockMonthC;

    if (nClockYearC < 10)
        c.txtYear.text = "0" + nClockYearC;
    else
        c.txtYear.text = nClockYearC;
        
}

function CheckClockDay(bIgnoreLeapYear)
{
    var dt = new Date;
    var d = dt.getDaysInMonth(nClockMonthC, nClockYearC);

    if (bIgnoreLeapYear)
    {
        if (nClockMonthC == 2)
            d = 29;
    }

    if (nClockDayC >= d)
        nClockDayC = d;
}

function IncrementClock()
{
    var nClockPart = nCurClockMenuItem;

        // Everywhere else -- dd mm yyyy

    if (nCurClockMenuItem == 3)
        nClockPart = 4;
    else if (nCurClockMenuItem == 4)
        nClockPart = 3;

    if (nClockPart == 0)
    {
        // Hour

        if (b24hour)
        {
            if (nClockHourC >= 23)
                nClockHourC = 0;
            else
                nClockHourC = nClockHourC + 1;
        }
        else
        {
            if (nClockHourC == 12)
                nClockHourC = 1;
            else
                nClockHourC = nClockHourC + 1;
        }
    }
    else if (nClockPart == 1)
    {
        // Minute

        if (nClockMinuteC == 59)
            nClockMinuteC = 0;
        else
            nClockMinuteC = nClockMinuteC + 1;
    }
    else if (nClockPart == 2)
    {
        // AM/PM

        if (nClockAMPMC == "AM")
            nClockAMPMC = "PM";
        else
            nClockAMPMC = "AM";
    }
    else if (nClockPart == 3)
    {
        // Month

        if (nClockMonthC == 12)
            nClockMonthC = 1;
        else
            nClockMonthC = nClockMonthC + 1;

        CheckClockDay(true);
    }
    else if (nClockPart == 4)
    {
        // Day

        var d;

        if (nClockMonthC == 2)
        {
            d = 29;
        }
        else
        {
            var dt = new Date;
            d = dt.getDaysInMonth(nClockMonthC, nClockYearC);
        }

        if (nClockDayC >= d)
            nClockDayC = 1;
        else
            nClockDayC = nClockDayC + 1;
    }
    else if (nClockPart == 5)
    {
        // Year

        if (nClockYearC == 99)
            nClockYearC = 1;
        else
            nClockYearC = nClockYearC + 1;

//      CheckClockDay(true);
    }

    UpdateTime();
}

function DecrementClock()
{
    var nClockPart = nCurClockMenuItem;
        // Everywhere but US and Japan -- dd mm yyyy
    if (nCurClockMenuItem == 3)
        nClockPart = 4;
    else if (nCurClockMenuItem == 4)
        nClockPart = 3;

    if (nClockPart == 0)
    {
        // Hour

        if (b24hour)
        {
            if (nClockHourC <= 0)
                nClockHourC = 23;
            else
                nClockHourC = nClockHourC - 1;
        }
        else
        {
            if (nClockHourC == 1)
                nClockHourC = 12;
            else
                nClockHourC = nClockHourC - 1;
        }
    }
    else if (nClockPart == 1)
    {
        // Minute

        if (nClockMinuteC == 0)
            nClockMinuteC = 59;
        else
            nClockMinuteC = nClockMinuteC - 1;
    }
    else if (nClockPart == 2)
    {
        // AM/PM

        if (nClockAMPMC == "AM")
            nClockAMPMC = "PM";
        else
            nClockAMPMC = "AM";
    }
    else if (nClockPart == 3)
    {
        // Month

        if (nClockMonthC == 1)
            nClockMonthC = 12;
        else
            nClockMonthC = nClockMonthC - 1;

        CheckClockDay(true);
    }
    else if (nClockPart == 4)
    {
        // Day

        var d;

        if (nClockMonthC == 2)
        {
            d = 29;
        }
        else
        {
            var dt = new Date;
            d = dt.getDaysInMonth(nClockMonthC, nClockYearC);
        }

        if (nClockDayC == 1)
            nClockDayC = d;
        else
            nClockDayC = nClockDayC - 1;
    }
    else if (nClockPart == 5)
    {
        // Year

        if (nClockYearC == 1)
            nClockYearC = 99;
        else
            nClockYearC = nClockYearC - 1;

//      CheckClockDay(true);
    }

    UpdateTime();
}

function GetCurrentTime()
{
    var d = new Date;

    nClockHourC = d.getHours();
    nClockMinuteC = d.getMinutes();

    if (b24hour == false)
    {
        nClockAMPMC = "AM";
        if (nClockHourC >= 12)
        {
            nClockHourC = nClockHourC - 12;
            nClockAMPMC = "PM";
        }
        if (nClockHourC == 0)
            nClockHourC = 12;
    }

    nClockMonthC = d.getMonth() + 1;
    nClockDayC = d.getDate();

    nClockYearC = d.getFullYear();

    if (nClockYearC < 2001)
    {
        nClockYearC = 2001;
    }
    else if (nClockYearC > 2099)
    {
        nClockYearC = 2001;
        nClockMonthC = 11;
        nClockDayC = 15;
        nClockMinuteC = 0;

        if (b24hour)
        {
            nClockHourC = 0;
        }
        else
        {
            nClockAMPMC = "AM";
            nClockHourC = 12;
        }
    }

    nClockYearC = nClockYearC - 2000;
}

function StartClockSettings()
{
    var c = theSetClockMenu.children[0].children[0];

	c.theBackButton.visible = 1 - bForceSetClock;

    nCurClockMenuItem = 0;

    c.txtDateSep.text = theTranslator.GetDateSeparator();

    MenuVisible = "theSetClockMenu";
    Option();
    GetCurrentTime();
    UpdateTime();
    UpdateClockMenu();
}
