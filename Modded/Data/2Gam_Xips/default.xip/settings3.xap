		function OnMoveDown()
		{
		SSaver = 0;
			if (nCurModeMenuItem < 2)
			{
				PlaySoundMenuChange();
				nCurModeMenuItem = nCurModeMenuItem + 1;
			}

			UpdateModeMenu();
		}
		function OnPower()
		{
			Action("ShutDown_2GAM","Bouton");
		}
		function OnPlay()
		{
			if ( DVDLaunch == false)
			{
				SSaver = 0;
				if(BGMon == false | bgmpause == true)
				{
					theControlPanelControlsInline.children[0].MusicPlayerPlay();
				}
			}
		}
		function OnStop()
		{
			if ( DVDLaunch == false)
			{
				SSaver = 0;
				if(BGMon == true)
				{
					theControlPanelControlsInline.children[0].MusicPlayerStop();
				}
			}
		}
		function OnPause()
		{
			if ( DVDLaunch == false)
			{
				SSaver = 0;
				if (BGMon == true & bgmpause == false)
				{
					theControlPanelControlsInline.children[0].MusicPlayerPause();
					bgmpause = true;
				}
			}
		}
		function OnSkipBack()
		{
			if ( DVDLaunch == false)
			{
				SSaver = 0;
				if(currentMusicPlayerMode == "Continuous")
				{
					theControlPanelControlsInline.children[0].MusicPlayerRewind();
				}
				else if(currentMusicPlayerMode == "Playlist")
				{
					theControlPanelControlsInline.children[0].PlaylistREW();
				}
				else if(currentMusicPlayerMode == "Random")
				{
					theControlPanelControlsInline.children[0].MusicPlayerRandom();
				}
			}
		}
		function OnSkipForward()
		{
			if ( DVDLaunch == false)
			{
				SSaver = 0;
				if(currentMusicPlayerMode == "Continuous")
				{
					theControlPanelControlsInline.children[0].MusicPlayerFastForward();
				}
				else if(currentMusicPlayerMode == "Playlist")
				{
					theControlPanelControlsInline.children[0].PlaylistFFW();
				}
				else if(currentMusicPlayerMode == "Random")
				{
					theControlPanelControlsInline.children[0].MusicPlayerRandom();
				}
			}
		}
		function OnMenu()
		{
			if ( DVDLaunch == false)
			{
				SSaver = 0;
				StartControlPanel();
			}
		}
		function OnReverse()
		{
			if ( DVDLaunch == false)
			{
				SSaver = 0;
				if (BGMon == true & bgmpause == false)
				{
					theControlPanelControlsInline.children[0].MusicPlayerVolumeDown();
					var a = Math.round(theControlPanelControlsInline.children[0].theBGMusicPlayer.volume * 100);
					var txt = ReadValue(18, "default", "Datas\\Langues\\"+lang+".ini");
					var aa = txt + " : " + a;
					SetStatusText(aa);
				}
			}
		}
		function OnForward()
		{
			if ( DVDLaunch == false)
			{
				SSaver = 0;
				if (BGMon == true & bgmpause == false)
				{
					theControlPanelControlsInline.children[0].MusicPlayerVolumeUp();
					var a = Math.round(theControlPanelControlsInline.children[0].theBGMusicPlayer.volume * 100);
					var txt = ReadValue(18, "default", "Datas\\Langues\\"+lang+".ini");
					var aa = txt + " : " + a;
					SetStatusText(aa);
				}
			}
		}
		function On1()
		{
			if ( DVDLaunch == false)
			{
				SSaver = 0;
				Action("MemoryX_2GAM","Bouton");
			}
		}
		function On2()
		{
			SSaver = 0;
			Action("ShowHideClock_2GAM","Bouton");
		}
		function On3()
		{
			if ( DVDLaunch == false)
			{
				SSaver = 0;
				Action("AffTitre_2GAM","Bouton");
			}
		}
		function On4()
		{
			if ( DVDLaunch == false)
			{
				SSaver = 0;
				Action("NextBackground_2GAM","Bouton");
			}
		}
		function On5()
		{
			if ( DVDLaunch == false)
			{
				SSaver = tmpSaver + 1;
			}
		}
		function On6()
		{
			if ( DVDLaunch == false)
			{
				SSaver = 0;
				Action("ChangeSkins_2GAM","Bouton");
			}
		}
	}

	function OnActivate()
	{
		CurrentViewpoint = theSetModeMenuView;
		CurrentAltViewpoint = theSetModeMenuAlternateView;
		previousControlType = theSetModeMenuJoy;
		MenuBoutons = true;
		if (children[0].children.length() > 0)
		{
			StartModeMenu();
		}
	}
}

function UpdateClockHands()
{
    var c = theSettingsMenu.children[0].children[0];
    var d = new Date;

    nClockHourC = d.getHours();
    nClockMinuteC = d.getMinutes();

    c.ClockHourHand.SetRotation(0, 0, -1, (nClockHourC + nClockMinuteC / 60) * 6.283 / 12);
    c.ClockMinuteHand.SetRotation(0, 0, -1, (nClockMinuteC - 15) * 6.283 / 60);
}


function UpdateSettingsMenu()
{
	var c = theSettingsMenu.children[0].children[0];

	c.movearrow_up.visible = false;
	c.movearrow_dn.visible = false;

	c.movearrow_up.children[0].appearance.material.name = "NavType";
	c.movearrow_dn.children[0].appearance.material.name = "NavType";

	// test arrow visibility
	if (nSettingsScroll > 0)
		c.movearrow_up.visible = true;
	if (nSettingsScroll + nNumSettingsMenuItems < nSettingsItemCount)
		c.movearrow_dn.visible = true;

	for (var i = 0; i < nNumSettingsMenuItems; i = i + 1)
	{
		if(i == nCurSettingsMenuButton)
		{
			c.MenuButtons.children[i].children[0].appearance.material.name = BOnMatGen;
			c.MenuButtons.children[i].children[0].appearance.texture.url = BOnTexGen+".xbx";
			c.MenuText.children[i].children[0].appearance.material.name = "Material #133";
			
			// hilite scroll arrows as well
			if(i == 0)
				c.movearrow_up.children[0].appearance.material.name = "Material #133";
			else if(i == 5)
				c.movearrow_dn.children[0].appearance.material.name = "Material #133";

		}
		else
		{
			c.MenuButtons.children[i].children[0].appearance.material.name = BOffMatGen;
			c.MenuButtons.children[i].children[0].appearance.texture.url = BOffTexGen+".xbx";
			c.MenuText.children[i].children[0].appearance.material.name = "NavType";
		}

		if(nSettingsItemCount > i)
			c.MenuText.children[i].children[0].geometry.text = sSettingsElements[nSettingsScroll + i];
	}
	
	UpdateRootMeta();
	MenuIcon();
}

