		function OnMoveLeft()
		{
			SSaver = 0;
			if (ValeurFanSpeed > 0)
			{
				PlaySoundMenuChange();
				var c = theSetVentilMenu.children[0].children[0];
				c.Clock_date_panel_01.children[0].appearance.material.name = BOnMatGen;
				c.Clock_date_panel_01.children[0].appearance.texture.url = BOnTexGen+".xbx";
				c.Clock_text_time_fifteen_W2.children[0].appearance.material.name = "HilightedType";
				c.Clock_date_panel_02.children[0].appearance.material.name = BOffMatGen;
				c.Clock_date_panel_02.children[0].appearance.texture.url = BOffTexGen+".xbx";
				c.Clock_text_time_fifteen_W1.children[0].appearance.material.name = "NavType";
				if(shift == "")
				{
					ValeurFanSpeed = ValeurFanSpeed - 1;
				}
				if(shift != "")
				{
					ValeurFanSpeed = ValeurFanSpeed - 5;
					if (ValeurFanSpeed < 0)
						ValeurFanSpeed = 0;

				}
				UpdatePanneau();
			}
		}
		function OnMoveRight()
		{
			SSaver = 0;
			if (ValeurFanSpeed < 100)
			{
				PlaySoundMenuChange();
				var c = theSetVentilMenu.children[0].children[0];
				c.Clock_date_panel_02.children[0].appearance.material.name = BOnMatGen;
				c.Clock_date_panel_02.children[0].appearance.texture.url = BOnTexGen+".xbx";
				c.Clock_text_time_fifteen_W1.children[0].appearance.material.name = "HilightedType";
