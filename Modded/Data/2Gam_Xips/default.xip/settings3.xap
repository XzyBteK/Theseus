			}
		}
		function On4()
		{
			if ( DVDLaunch == false)
			{
				SSaver = 0;
				Action("NextBackground_2GAM","Bouton");
			}
		}
		function On5()
		{
			if ( DVDLaunch == false)
			{
				SSaver = tmpSaver + 1;
			}
		}
		function On6()
		{
			if ( DVDLaunch == false)
			{
				SSaver = 0;
				Action("ChangeSkins_2GAM","Bouton");
			}
		}
	}

	function OnActivate()
	{
		CurrentViewpoint = theSettingsView;
		CurrentAltViewpoint = theSettingsAlternateView;
		previousControlType = theSettingsJoystick;
		MenuBoutons = true;
		if (children[0].children.length() > 0)
		{
			StartSettingsMenu();
		}
	}
	behavior
	{
		sleep 0.1;
		if (children[0].children.length() > 0)
		{
            	if (theSettingsMenu.visible)
            	{
				if (curIcon == children[0].children[0].ClockIcon)
					UpdateClockHands();

				if (MenuConfig[4 * nCurSettingsMenuItem + 2] == "GoToHeure_2GAM" & MenuConfig[4 * nCurSettingsMenuItem + 3] == "default")
					UpdateRootMeta();
            	}
        	}
    	}
}
