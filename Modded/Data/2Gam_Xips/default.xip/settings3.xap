function SetAudioModeIcon(nMode)
{
    var c = theSettingsMenu.children[0].children[0];

    if (nMode == 0)
        ShowIcon(c.MonoIcon);
    else if (nMode == 1)
        ShowIcon(c.StereoIcon);
    else if (nMode == 2)
        ShowIcon(c.StereoIcon);
}

function SetVideoModeIcon(nMode)
{
    var c = theSettingsMenu.children[0].children[0];

    if (nMode == 0)
        ShowIcon(c.FullscreenIcon);
    else if (nMode == 1)
        ShowIcon(c.LetterboxIcon);
    else if (nMode == 2)
        ShowIcon(c.WidescreenIcon);
}

function MenuIcon()
{
	var c = theSettingsMenu.children[0].children[0];
	var a = 4 * nCurSettingsMenuItem + 2;
	var b = 4 * nCurSettingsMenuItem + 3;

	if(MenuConfig[a] == "GoToMemory_2GAM")
	{
		if(MenuConfig[b] == "default")
		{
			ShowIcon(c.ConsoleIcon);
		}
		else
		{
			MenuIcon2();
		}
	}
	if(MenuConfig[a] == "GoToMusic_2GAM")
	{
		if(MenuConfig[b] == "default")
		{
			ShowIcon(c.ConsoleIcon);
		}
		else
		{
			MenuIcon2();
		}
	}
	else if(MenuConfig[a] == "GoToHeure_2GAM")
	{
		if(MenuConfig[b] == "default")
		{
			UpdateClockHands();
			ShowIcon(c.ClockIcon);
		}
		else
		{
			MenuIcon2();
		}
	}
	else if (MenuConfig[a] == "GotoLangue_2GAM")
	{
		if(MenuConfig[b] == "default")
		{
			ShowIcon(c.GlobeIcon);
		}
		else
		{
			MenuIcon2();
		}
	}
	else if (MenuConfig[a] == "GotoAudio_2GAM")
	{
		if(MenuConfig[b] == "default")
		{
			SetAudioModeIcon(nCurAudioMode);
		}
		else
		{
			MenuIcon2();
		}
	}
	else if (MenuConfig[a] == "GotoVideo_2GAM")
	{
		if(MenuConfig[b] == "default")
		{
			SetVideoModeIcon(nCurVideoMode);
		}
		else
		{
			MenuIcon2();
		}
	}
	else if (MenuConfig[a] == "GotoVideoMode_2GAM")
	{
		if(MenuConfig[b] == "default")
		{
			SetVideoModeIcon(2);
		}
		else
		{
			MenuIcon2();
		}
	}
	else if (MenuConfig[a] == "GotoControl_2GAM")
	{
		if(MenuConfig[b] == "default")
		{
			ShowIcon(c.LockIcon);
		}
		else
		{
			MenuIcon2();
		}
	}
	else if (MenuConfig[a] == "ChangeSkins_2GAM")
	{
		if(MenuConfig[b] == "default")
		{
			ShowIcon(c.DaGoN_BrushIcon);
		}
		else
		{
			MenuIcon2();
		}
	}
	else if (MenuConfig[a] == "GotoVentilo_2GAM")
	{
		if(MenuConfig[b] == "default")
		{
			ShowIcon(c.DaGoN_FanIcon);
		}
		else
		{
			MenuIcon2();
		}
	}
	else if(MenuConfig[a] == "GotoFTP_2GAM")
	{
		if(MenuConfig[b] == "default")
		{
			ShowIcon(c.network_icon);
		}
		else
		{
			MenuIcon2();
		}
	}
	else if (MenuConfig[a] == "GotoInfo_2GAM")
	{
		if(MenuConfig[b] == "default")
		{
			ShowIcon(c.DaGoN_GearsIcon);
		}
		else
		{
			MenuIcon2();
		}
	}
	else if (MenuConfig[a] == "Reboot_2GAM")
	{
		if(MenuConfig[b] == "default")
		{
			ShowIcon(c.ConsoleIcon);
		}
		else
		{
			MenuIcon2();
		}
	}
	else if (MenuConfig[a] == "ShutDown_2GAM")
	{
		if(MenuConfig[b] == "default")
		{
			ShowIcon(c.AutoOffIcon);
		}
		else
		{
			MenuIcon2();
		}
	}
	else
	{
		MenuIcon2();
	}
}
function MenuIcon2()
{
	var c = theSettingsMenu.children[0].children[0];
	var a = 4 * nCurSettingsMenuItem + 2;
	var b = 4 * nCurSettingsMenuItem + 4;

	if(MenuConfig[b] == "heure")
	{
		UpdateClockHands();
		ShowIcon(c.ClockIcon);
	}
	else if(MenuConfig[b] == "globe")
	{
		ShowIcon(c.GlobeIcon);
	}
	else if(MenuConfig[b] == "audio")
	{
		SetAudioModeIcon(nCurAudioMode);
	}
	else if(MenuConfig[b] == "video")
	{
		SetVideoModeIcon(nCurVideoMode);
	}
	else if(MenuConfig[b] == "lock")
	{
		ShowIcon(c.LockIcon);
	}
	else if(MenuConfig[b] == "inter")
	{
		ShowIcon(c.AutoOffIcon);
	}
	else if(MenuConfig[b] == "xbox")
	{
		ShowIcon(c.ConsoleIcon);
	}
	else if(MenuConfig[b] == "gears")
	{
		ShowIcon(c.DaGoN_GearsIcon);
	}
	else if(MenuConfig[b] == "fan")
	{
		ShowIcon(c.DaGoN_FanIcon);
	}
	else if(MenuConfig[b] == "brush")
	{
		ShowIcon(c.DaGoN_BrushIcon);
	}
	else
	{
		ShowIcon(c.ConsoleIcon);
	}
}

function UpdateRootMeta()
{
    var c = theSettingsMenu.children[0].children[0];
	var metaString = "";
	var a = 4 * nCurSettingsMenuItem + 2;
	var b = 4 * nCurSettingsMenuItem + 3;

	if(MenuConfig[a] == "GoToMemory_2GAM")
	{
		if(MenuConfig[b] == "default")
		{
			metaString = theTranslator.Translate("MEMORY");
		}
		else
		{
			metaString = MenuConfig[b];
		}
	}
	else if(MenuConfig[a] == "GoToMusic_2GAM")
	{
		if(MenuConfig[b] == "default")
		{
			metaString = theTranslator.Translate("MUSIC");
		}
		else
		{
			metaString = MenuConfig[b];
		}
	}
	else if(MenuConfig[a] == "GoToHeure_2GAM")
	{
		if(MenuConfig[b] == "default")
		{
			var d = new Date;
			nClockHourC = d.getHours();
			nClockMinuteC = d.getMinutes();
			if (b24hour == false)
			{
				nClockAMPMC = "AM";
				if (nClockHourC >= 12)
				{
					nClockHourC = nClockHourC - 12;
					nClockAMPMC = "PM";
				}
				if (nClockHourC == 0)
					nClockHourC = 12;
			}

			nClockDayC = d.getDate();
			nClockMonthC = d.getMonth() + 1;
			nClockYearC = d.getFullYear();

			if (nClockHourC < 10)
				nClockHourC = "0" + nClockHourC;
			if (nClockMinuteC < 10)
				nClockMinuteC = "0" + nClockMinuteC;
			if (nClockDayC < 10)
				nClockDayC = "0" + nClockDayC;
			if (nClockMonthC < 10)
				nClockMonthC = "0" + nClockMonthC;

			if (b24hour == false)
				metaString = nClockDayC+"/"+nClockMonthC+"/"+nClockYearC+" "+nClockHourC+":"+nClockMinuteC+" "+nClockAMPMC;
			else
				metaString = nClockDayC+"/"+nClockMonthC+"/"+nClockYearC+" "+nClockHourC+":"+nClockMinuteC;

		}
		else
		{
			metaString = MenuConfig[b];
		}
	}
	else if(MenuConfig[a] == "GotoLangue_2GAM")
	{
		if(MenuConfig[b] == "default")
		{
			var nLanguage = theConfig.GetLanguage();
			if (nLanguage == 1)
				metaString = "ENGLISH";                     // English
			else if (nLanguage == 2)
				metaString = "PORTUGUĘS";         		  // PORTUGUĘS
			else if (nLanguage == 3)
				metaString = "DEUTSCH";                     // German
			else if (nLanguage == 4)
				metaString = "FRANÇAIS";                    // French
			else if (nLanguage == 5)
				metaString = "ESPAŃOL";                     // Spanish
			else if (nLanguage == 6)
				metaString = "ITALIANO";                    // Italian
			else if (nLanguage == 7)
			    metaString = "\uD55C\uAD6D\uC5B4";          // Korean
			else if (nLanguage == 8)
			    metaString = "\u7E41\u9AD4\u4E2D\u6587";    // Traditional Chinese
			else if (nLanguage == 9)
			    metaString = "PORTUGUĘS";                   // Portugues
			else
				metaString = "";
		}
		else
		{
			metaString = MenuConfig[b];
		}
	}
	else if(MenuConfig[a] == "GotoAudio_2GAM")
	{
		if(MenuConfig[b] == "default")
		{
			if (nCurAudioMode == 0)
				metaString = theTranslator.Translate("MONO");
			else if (nCurAudioMode == 1)
				metaString = theTranslator.Translate("STEREO");
			else if (nCurAudioMode == 2)
				metaString = theTranslator.Translate("DOLBY SURROUND");
			else
				metaString = "";
		}
		else
		{
			metaString = MenuConfig[b];
		}
	}

	else if(MenuConfig[a] == "GotoVideo_2GAM")
	{
		if(MenuConfig[b] == "default")
		{
			if (nCurVideoMode == 0)
				metaString = theTranslator.Translate("NORMAL");
			else if (nCurVideoMode == 1)
				metaString = theTranslator.Translate("LETTERBOX");
			else if (nCurVideoMode == 2)
				metaString = theTranslator.Translate("WIDESCREEN");
			else
				metaString = "";
		}
		else
		{
			metaString = MenuConfig[b];
		}
	}
	else if(MenuConfig[a] == "GotoVideoMode_2GAM")
	{
		if(MenuConfig[b] == "default")
		{
			metaString = "Xbox";
		}
		else
		{
			metaString = MenuConfig[b];
		}
	}
	else if(MenuConfig[a] == "GotoControl_2GAM")
	{
		if(MenuConfig[b] == "default")
		{
			if (nMoviePCLevel + nGamePCLevel == 13)
				metaString = theTranslator.Translate("OFF");
			else
				metaString = theTranslator.Translate("ON");
		}
		else
		{
			metaString = MenuConfig[b];
		}
	}
	else if(MenuConfig[a] == "ChangeSkins_2GAM")
	{
		if(MenuConfig[b] == "default")
		{
			metaString = NSkins[CurentSkin];
		}
		else
		{
			metaString = MenuConfig[b];
		}
	}
	else if(MenuConfig[a] == "GotoVentilo_2GAM")
	{
		if(MenuConfig[b] == "default")
		{
			metaString = theConfig.GetFanSpeed();
			FanSpeed = theConfig.GetFanSpeed();
			var lgt = FanSpeed.length();
			var Speed = FanSpeed.substring(0,lgt-2);
			ValeurFanSpeed = ReturnInteger(Speed);
			c.FanIcon.rpm = ValeurFanSpeed;
		}
		else
		{
			metaString = MenuConfig[b];
		}
	}
	else if(MenuConfig[a] == "GotoFTP_2GAM")
	{
		if(MenuConfig[b] == "default")
		{
			metaString = AdresseIP;
		}
		else
		{
			metaString = MenuConfig[b];
		}
	}
	else if(MenuConfig[a] == "GotoInfo_2GAM")
	{
		if(MenuConfig[b] == "default")
		{
			metaString = "Xbox";
		}
		else
		{
			metaString = MenuConfig[b];
		}
	}
	else if(MenuConfig[a] == "Reboot_2GAM")
	{
		if(MenuConfig[b] == "default")
		{
			metaString = ReadValue(76, "default", "Datas\\Langues\\"+lang+".ini");
		}
		else
		{
			metaString = MenuConfig[b];
		}
	}
	else if(MenuConfig[a] == "ShutDown_2GAM")
	{
		if(MenuConfig[b] == "default")
		{
			metaString = ReadValue(77, "default", "Datas\\Langues\\"+lang+".ini");
		}
		else
		{
			metaString = MenuConfig[b];
		}
	}
	else if(MenuConfig[b] == "default")
		{
			metaString = "Xbox";
		}
		else
		{
			metaString = MenuConfig[b];
		}

	c.metaPanel.children[0].geometry.text = metaString;
}
////////////////////////////////////////////////////////////////////////////////////////////////////////////////

DEF theSettingsAlternateView Viewpoint
{
	fieldOfView 1.287000
	orientation 0.130300 -0.001400 -0.007829 -0.821100
	position 123.300003 -0.918000 -152.600006
      jump false
}

DEF theSettingsMenu Level
{
    archive "Settings3.xip"

    children
    [
        Inline
        {
            url "Settings3/default.xap"

            function onLoad()
            {
			var nLanguage = theConfig.GetLanguage();
			if (nLanguage != 0)
				nLanguage = nLanguage - 1;

				// Initalize settings
			nMoviePCLevel = theConfig.GetMoviePCFlags();
			nGamePCLevel = theConfig.GetGamePCFlags();
			bDolbyDigital = theConfig.GetDolbyDigitalSupport();
			bDTS = theConfig.GetDTSSupport();
			b480p = theConfig.Get480Support();
			b720p = theConfig.Get720Support();
			b1080i = theConfig.Get1080Support();
			bPAL60 = theConfig.GetPAL60Support();
			nCurAudioMode = theConfig.GetAudioMode();
			nCurVideoMode = theConfig.GetVideoMode();
			nTimeZone = theConfig.GetTimeZone();
			bDaylightSavingsTime = theConfig.GetDST();
			strCurMenu = "SETTINGS";
			strPrevMenu = "SETTINGS";

                //
                // This used to be the very last option at the end of the if..else if statement below
                // I moved it here, so that if a user is forced to set a specific setting, and an Audio CD or
                // no CD is in the drive, we can properly return to the Dash menu WITHOUT rebooting
                //

                if (bForceSetLanguage)
                {
					strCurMenu = "LANGUAGE";
					theSetLanguageMenu.GoTo();
                }
                else if (bForceSetTimeZone)
                {
					strCurMenu = "TIME ZONE";
					theSetTimezoneMenu.GoTo();
                }
                else if (bForceSetClock)
                {
					strCurMenu = "TIME DATE";
					theSetClockMenu.GoTo();
                }
                StartSettingsMenu();
            }
        }
    ]

    path DEF theSettingsView Viewpoint
    {
	fieldOfView 1.287000
	orientation 0.130300 -0.991400 -0.007829 -0.121100
	position 123.300003 -0.918000 -152.600006
	jump false
    }

	control DEF theSettingsJoystick Joystick
	{
		function OnADown()
		{
			SSaver = 0;
			if(shift == "")
			{
				MenuBoutons = false;
				PlaySoundA();
				var c = theSettingsMenu.children[0].children[0];
				c.MU_select_pod_HL.children[0].appearance.material.param = 1;
				var b = 4 * nCurSettingsMenuItem + 2;
				strPrevMenu = "SETTINGS";
            		if (MenuConfig[b] == "GoToHeure_2GAM")
				{
					strCurMenu = "CLOCK";
					theChooseClockMenu.GoTo();
				}
            		else if (MenuConfig[b] == "GotoFTP_2GAM")
				{
					strCurMenu = "FTP";
					theChooseClockMenu.GoTo();
				}
           			else if (MenuConfig[b] == "GotoLangue_2GAM")
				{
					strCurMenu = "LANGUAGE";
					theSetLanguageMenu.GoTo();
				}
            		else if (MenuConfig[b] == "GotoAudio_2GAM")
            		{
                			if ((theConfig.GetAVPackType() == "HDTV") + (theConfig.GetAVPackType() == "SVIDEO") + (theConfig.GetAVPackType() == "VGA") + (theConfig.GetAVPackType() == "SCART"))
					{
						strCurMenu = "AUDIO";
						theChooseClockMenu.GoTo();
					}
                			else
					{
						strCurMenu = "AUDIO MODE";
						theSetModeMenu.GoTo();
					}
            		}
            		else if (MenuConfig[b] == "GotoVideo_2GAM")
            		{
					strCurMenu = "VIDEO";
					theSetModeMenu.GoTo();
					theSettingsSubMenuIn.Play();
            		}
            		else if (MenuConfig[b] == "GotoVideoMode_2GAM")
            		{
					strCurMenu = "VIDEO MODE";
					theChooseClockMenu.GoTo();
            		}
            		else if (MenuConfig[b] == "GotoControl_2GAM")
            		{
                			if (theConfig.CheckParentPassword(""))
					{
						strCurMenu = "PARENTAL CONTROL";
						theChooseClockMenu.GoTo();
					}
                			else
					{
						strCurMenu = "ENTER PASSWORD";
						theSetPanelMenu.GoTo();
					}
            		}
            		else if (MenuConfig[b] == "GotoInfo_2GAM")
				{
					strCurMenu = "SYSTEM INFO";
					theSetPanelMenu.GoTo();
				}
            		else if (MenuConfig[b] == "GotoVentilo_2GAM")
				{
					strCurMenu = "GET VENTILO";
					theSetVentilMenu.GoTo();
				}
				else
				{
					Launcher = "MenuConfig";
					Action(MenuConfig[b],"Menu");
				}
				theSettingsSubMenuIn.Play();
			}
			if ( DVDLaunch == false)
			{
				if(shift == "¤-")
				{
					if ( ConfigBoutonsMainMenu[8] != "0")
					Action(ConfigBoutonsMainMenu[8],"Bouton");
				}
				if(shift == "-¤")
				{
					if ( ConfigBoutonsMainMenu[16] != "0")
					Action(ConfigBoutonsMainMenu[16],"Bouton");
				}
				if(shift == "¤¤")
				{
					if ( ConfigBoutonsMainMenu[24] != "0")
					Action(ConfigBoutonsMainMenu[24],"Bouton");
				}
			}
		}
		function OnBDown()
		{
			SSaver = 0;
			if(shift == "")
			{
				PlaySoundB();
				theSettingsMenu.children[0].children[0].MU_back_pod_HL.children[0].appearance.material.param = 1;
				if (bBackToDVDPlayer == true)
           			{
					thePanelLayer.visible = false;
               			theSettingsMenu.visible = false;
//					theDVDPlayerInline.visible = true;
					theDVDPlayerInline.children[0].theDVDLevel.GoBackTo();
           			}
           			else if (bBackToLauncher == true)
            		{
					theLauncherLevel.GoTo();
            		}
           			else
