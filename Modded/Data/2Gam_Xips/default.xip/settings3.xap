function SetupListSettings()
{
    var c = theChooseClockMenu.children[0].children[0];


    ShowIcon(c.ClockIcon);
    ShowIcon(c.GlobeIcon);
    ShowIcon(c.StereoIcon);
    ShowIcon(c.MonoIcon);
    ShowIcon(c.FullscreenIcon);
    ShowIcon(c.LetterboxIcon);
    ShowIcon(c.WidescreenIcon);
    ShowIcon(c.LockIcon);
    ShowIcon(c.network_icon);

	// reset focus on entry
	if(strPrevMenu == "SETTINGS")
		nCurListItems = 0;

	SetupListMenu();

}
function SauveAffHeure()
{
	var txt = "non";
	if (b24hour)
		txt = "oui";

	SaveSetting(22,txt,"default", "Datas\\Config\\ConfigSysteme.xbc");
}

function UpdateClock()
{
	var c = theChooseClockMenu.children[0].children[0];
	var d = new Date;
	nClockHourC = d.getHours();
	nClockMinuteC = d.getMinutes();
	if (b24hour == false)
	{
		nClockAMPMC = "AM";
		if (nClockHourC >= 12)
		{
			nClockHourC = nClockHourC - 12;
			nClockAMPMC = "PM";
		}
		if (nClockHourC == 0)
			nClockHourC = 12;
	}

	nClockDayC = d.getDate();
	nClockMonthC = d.getMonth() + 1;
	nClockYearC = d.getFullYear();

	if (nClockHourC < 10)
		nClockHourC = "0" + nClockHourC;
	if (nClockMinuteC < 10)
		nClockMinuteC = "0" + nClockMinuteC;
	if (nClockDayC < 10)
		nClockDayC = "0" + nClockDayC;
	if (nClockMonthC < 10)
		nClockMonthC = "0" + nClockMonthC;

	if (b24hour == false)
		c.Menu_Buttons.children[1].children[0].children[0].geometry.text = nClockDayC+"/"+nClockMonthC+"/"+nClockYearC+" "+nClockHourC+":"+nClockMinuteC+" "+nClockAMPMC;
	else
		c.Menu_Buttons.children[1].children[0].children[0].geometry.text = nClockDayC+"/"+nClockMonthC+"/"+nClockYearC+" "+nClockHourC+":"+nClockMinuteC;
}

function SetupListMenu()
{
	var c = theChooseClockMenu.children[0].children[0];
	var txt = "";
	if(strCurMenu == "CLOCK")
	{

		c.Menu_Buttons.children[0].children[0].children[0].geometry.text = theTranslator.Translate("TIME DATE");
		UpdateClock();

		txt = ReadValue(91, "default", "Datas\\Langues\\"+lang+".ini");
		c.Menu_Buttons.children[2].children[0].children[0].geometry.text = txt;
		txt = "YES";
		if (b24hour)
			txt = "NO";

		c.Menu_Buttons.children[3].children[0].children[0].geometry.text = theTranslator.Translate(txt);
		c.Menu_Buttons.children[4].children[0].children[0].geometry.text = theTranslator.Translate("TIME ZONE");
		c.Menu_Buttons.children[5].children[0].children[0].geometry.text = theTranslator.GetTimeZoneText(nTimeZone);
		c.Menu_Buttons.children[6].children[0].children[0].geometry.text = theTranslator.Translate("DAYLIGHT SAVINGS");

		if (bDaylightSavingsTime)
			c.Menu_Buttons.children[7].children[0].children[0].geometry.text = theTranslator.Translate("YES");
		else
			c.Menu_Buttons.children[7].children[0].children[0].geometry.text = theTranslator.Translate("NO");

		if(theConfig.GetDSTAllowed())
		{
			nCurListItemCount = 4;
			ShowFourListItems();
		}
		else
		{
			nCurListItemCount = 3;
			ShowThreeListItems();
		}
		UpdateListHighlight();
		UpdateListClockHands();
	}
	if(strCurMenu == "FTP")
	{
		nCurListItemCount = 4;
		txt = ReadValue(42, "default", "Datas\\Langues\\"+lang+".ini");
		c.Menu_Buttons.children[0].children[0].children[0].geometry.text = txt;
		c.Menu_Buttons.children[1].children[0].children[0].geometry.text = AdresseIP;
		txt = ReadValue(43, "default", "Datas\\Langues\\"+lang+".ini");
		c.Menu_Buttons.children[2].children[0].children[0].geometry.text = txt;
		c.Menu_Buttons.children[3].children[0].children[0].geometry.text = MasqueReseau;
		txt = ReadValue(44, "default", "Datas\\Langues\\"+lang+".ini");
		c.Menu_Buttons.children[4].children[0].children[0].geometry.text = txt;
		c.Menu_Buttons.children[5].children[0].children[0].geometry.text = Passerelle;
		txt = ReadValue(45, "default", "Datas\\Langues\\"+lang+".ini");
		c.Menu_Buttons.children[6].children[0].children[0].geometry.text = txt;
		c.Menu_Buttons.children[7].children[0].children[0].geometry.text = Utilisateur;

		ShowFourListItems();
		UpdateListHighlight();
	}
	if(strCurMenu == "AUDIO")
	{
		nCurListItemCount = 3;

		// setup audio menu text
		c.Menu_Buttons.children[0].children[0].children[0].geometry.text = theTranslator.Translate("AUDIO MODE");
		c.Menu_Buttons.children[2].children[0].children[0].geometry.text = theTranslator.Translate("DOLBY DIGITAL");
		c.Menu_Buttons.children[4].children[0].children[0].geometry.text = theTranslator.Translate("DTS");

		if (nCurAudioMode == 0)
			c.Menu_Buttons.children[1].children[0].children[0].geometry.text = theTranslator.Translate("MONO");
		else if (nCurAudioMode == 1)
			c.Menu_Buttons.children[1].children[0].children[0].geometry.text = theTranslator.Translate("STEREO");
		else if (nCurAudioMode == 2)
			c.Menu_Buttons.children[1].children[0].children[0].geometry.text = theTranslator.Translate("DOLBY SURROUND");

		if (bDolbyDigital)
			c.Menu_Buttons.children[3].children[0].children[0].geometry.text = theTranslator.Translate("ENABLED");
		else
			c.Menu_Buttons.children[3].children[0].children[0].geometry.text = theTranslator.Translate("DISABLED");

		if (bDTS)
			c.Menu_Buttons.children[5].children[0].children[0].geometry.text = theTranslator.Translate("ENABLED");
		else
			c.Menu_Buttons.children[5].children[0].children[0].geometry.text = theTranslator.Translate("DISABLED");

		ShowThreeListItems();
		UpdateListHighlight();
	}
	if(strCurMenu == "VIDEO MODE")
	{		
		if (theConfig.GetAVRegion() == "PAL I")
		{
			nCurListItemCount = 4;
			ShowFourListItems();

			c.Menu_Buttons.children[0].children[0].children[0].geometry.text = theTranslator.Translate("PAL 60");
			if (theConfig.GetPAL60Support())
				c.Menu_Buttons.children[1].children[0].children[0].geometry.text = theTranslator.Translate("YES");
			else
				c.Menu_Buttons.children[1].children[0].children[0].geometry.text = theTranslator.Translate("NO");

			c.Menu_Buttons.children[2].children[0].children[0].geometry.text = theTranslator.Translate("480p");
			if (theConfig.Get480Support())
				c.Menu_Buttons.children[3].children[0].children[0].geometry.text = theTranslator.Translate("YES");
			else
				c.Menu_Buttons.children[3].children[0].children[0].geometry.text = theTranslator.Translate("NO");

			c.Menu_Buttons.children[4].children[0].children[0].geometry.text = theTranslator.Translate("720p");
			if (theConfig.Get720Support())
				c.Menu_Buttons.children[5].children[0].children[0].geometry.text = theTranslator.Translate("YES");
			else
				c.Menu_Buttons.children[5].children[0].children[0].geometry.text = theTranslator.Translate("NO");

			c.Menu_Buttons.children[6].children[0].children[0].geometry.text = theTranslator.Translate("1080i");
			if (theConfig.Get1080Support())
				c.Menu_Buttons.children[7].children[0].children[0].geometry.text = theTranslator.Translate("YES");
			else
				c.Menu_Buttons.children[7].children[0].children[0].geometry.text = theTranslator.Translate("NO");

		}
		else
		{
			nCurListItemCount = 3;
			ShowThreeListItems();

			c.Menu_Buttons.children[0].children[0].children[0].geometry.text = theTranslator.Translate("480p");
			if (theConfig.Get480Support())
				c.Menu_Buttons.children[1].children[0].children[0].geometry.text = theTranslator.Translate("YES");
			else
				c.Menu_Buttons.children[1].children[0].children[0].geometry.text = theTranslator.Translate("NO");

			c.Menu_Buttons.children[2].children[0].children[0].geometry.text = theTranslator.Translate("720p");
			if (theConfig.Get720Support())
				c.Menu_Buttons.children[3].children[0].children[0].geometry.text = theTranslator.Translate("YES");
			else
				c.Menu_Buttons.children[3].children[0].children[0].geometry.text = theTranslator.Translate("NO");

			c.Menu_Buttons.children[4].children[0].children[0].geometry.text = theTranslator.Translate("1080i");
			if (theConfig.Get1080Support())
				c.Menu_Buttons.children[5].children[0].children[0].geometry.text = theTranslator.Translate("YES");
			else
				c.Menu_Buttons.children[5].children[0].children[0].geometry.text = theTranslator.Translate("NO");

		}
		UpdateListHighlight();
	}
	if(strCurMenu == "PARENTAL CONTROL")
	{
		c.Menu_Buttons.children[0].children[0].children[0].geometry.text = theTranslator.Translate("SET PASSWORD");
		c.Menu_Buttons.children[2].children[0].children[0].geometry.text = theTranslator.Translate("MOVIES");
		c.Menu_Buttons.children[4].children[0].children[0].geometry.text = theTranslator.Translate("GAMES");

		if (theConfig.CheckParentPassword(""))
			c.Menu_Buttons.children[1].children[0].children[0].geometry.text = theTranslator.Translate("DISABLED");
		else
			c.Menu_Buttons.children[1].children[0].children[0].geometry.text = "****";

		var v = new Array(theTranslator.Translate("MOVIE LEVEL 0"), theTranslator.Translate("MOVIE LEVEL 1"), theTranslator.Translate("MOVIE LEVEL 2"), theTranslator.Translate("MOVIE LEVEL 3"), theTranslator.Translate("MOVIE LEVEL 4"), theTranslator.Translate("MOVIE LEVEL 5"), theTranslator.Translate("MOVIE LEVEL 6"), theTranslator.Translate("MOVIE LEVEL 7"));
		c.Menu_Buttons.children[3].children[0].children[0].geometry.text = v[nMoviePCLevel];

		v = new Array(theTranslator.Translate("GAME LEVEL 0"), theTranslator.Translate("GAME LEVEL 1"), theTranslator.Translate("GAME LEVEL 2"), theTranslator.Translate("GAME LEVEL 3"), theTranslator.Translate("GAME LEVEL 4"), theTranslator.Translate("GAME LEVEL 5"), theTranslator.Translate("GAME LEVEL 6"));
		c.Menu_Buttons.children[5].children[0].children[0].geometry.text = v[nGamePCLevel];

		if(theConfig.GetGameRegion() == "NA")
		{
			nCurListItemCount = 3;
			ShowThreeListItems();
		}
		else
		{
			nCurListItemCount = 2;
			ShowTwoListItems();
		}

		UpdateListHighlight();
	}

	UpdateListIcons();
}

function UpdateListIcons()
{
	var c = theChooseClockMenu.children[0].children[0];

	if(strCurMenu == "CLOCK")
	{
		if(nCurListItems == 0 | nCurListItems == 1)
			ShowIcon(c.ClockIcon);
		else
			ShowIcon(c.GlobeIcon);
	}
	else if(strCurMenu == "FTP")
	{
		ShowIcon(c.network_icon);
	}
	else if(strCurMenu == "AUDIO")
	{
		if (nCurAudioMode == 0)
			ShowIcon(c.MonoIcon);
		else if (nCurAudioMode == 1)
			ShowIcon(c.StereoIcon);
		else if (nCurAudioMode == 2)
			ShowIcon(c.StereoIcon);
	}
	else if(strCurMenu == "VIDEO MODE")
	{
		ShowIcon(c.WidescreenIcon);
	}
	else if(strCurMenu == "PARENTAL CONTROL")
	{
		ShowIcon(c.LockIcon);
	}

	MenuVisible = "theChooseClockMenu";
	Option();
}

function UpdateListHighlight()
{
	var c = theChooseClockMenu.children[0].children[0];
	var buttons = new Array(c.button1.children[0].children[0],
					c.button2.children[0].children[0],
					c.button3.children[0].children[0],
					c.button4.children[0].children[0]);
						

	// update selection of the list
	for (var i = 0; i < nCurListItemCount; i = i + 1)
	{
		// hilite panels
		if (nCurListItems == i)
		{
			buttons[i].appearance.material.name = BOnMatGen;
			buttons[i].appearance.texture.url = BOnTexGen+".xbx";
			c.Menu_Buttons.children[i * 2].children[0].children[0].appearance.material.name = "Material #133";

		}
		else
		{
			buttons[i].appearance.material.name = BOffMatGen;
			buttons[i].appearance.texture.url = BOffTexGen+".xbx";
			c.Menu_Buttons.children[i * 2].children[0].children[0].appearance.material.name = "NavType";
		}
	}
	UpdateListIcons();
	
}
DEF theChooseClockMenuAlternateView Viewpoint
{
    fieldOfView 1.287000
    orientation -0.280200 -0.001800 -0.016980 0.833900
    position 98.209999 3.905000 -218.899994
    jump false
}

DEF theChooseClockMenu Level
{
    archive "Settings_List.xip"

    children
    [
        Inline
        {
            url "Settings_List/default.xap"

            function onLoad()
            {
                SetupListSettings();
            }
        }
    ]

    path USE threeButtonViewpoint
    control DEF theChooseClockMenuJoy Joystick
    {
        function OnADown()
        {
		SSaver = 0;
		if(shift == "")
		{
            PlaySoundA();

			theChooseClockMenu.children[0].children[0].MU_select_pod_HL.children[0].appearance.material.param = 1;
			
			if(strCurMenu == "CLOCK")
			{
				strPrevMenu = "CLOCK";
				if(nCurListItems == 0)
				{
					strCurMenu = "TIME DATE";
					theSetClockMenu.GoTo();
					theSettingsSubMenuIn.Play();
				}
				else if(nCurListItems == 1)
				{
					if (b24hour)
						b24hour = false;
					else
						b24hour = true;

					SetupListMenu();
					SauveAffHeure();
				}
				else if(nCurListItems == 2)
				{
					strCurMenu = "TIME ZONE";
					theSetTimezoneMenu.GoTo();
					theSettingsSubMenuIn.Play();
				}
				else if(nCurListItems == 3)
				{
					strCurMenu = "DAYLIGHT SAVINGS TIME";
					theSetPanelMenu.GoTo();
					theSettingsSubMenuIn.Play();
				}
			}
			else if(strCurMenu == "FTP")
			{
				strPrevMenu = "FTP";
				ChangeValues();
			}
			else if(strCurMenu == "AUDIO")
			{
				strPrevMenu = "AUDIO";
