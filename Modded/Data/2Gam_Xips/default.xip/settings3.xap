        function OnMoveLeft()
        {
		SSaver = 0;
            if (nCurClockMenuItem > 0)
            {
                PlaySoundMenuChange();

                nCurClockMenuItem = nCurClockMenuItem - 1;

                if (b24hour)
                {
                    if (nCurClockMenuItem == 2)
                        nCurClockMenuItem = nCurClockMenuItem - 1;
                }

                UpdateClockMenu();
            }
        }

        function OnMoveRight()
        {
		SSaver = 0;
            if (nCurClockMenuItem < 5)
            {
                PlaySoundMenuChange();

                nCurClockMenuItem = nCurClockMenuItem + 1;

                if (b24hour)
                {
                    if (nCurClockMenuItem == 2)
                        nCurClockMenuItem = nCurClockMenuItem + 1;
                }

                UpdateClockMenu();
            }
        }

        function OnMoveUp()
        {
		SSaver = 0;
            theSetClockMenu.children[0].children[0].Clock_morearrow_up.children[0].appearance.material.name = "Typesdsafsda";
            theSetClockMenu.children[0].children[0].Clock_morearrow_down.children[0].appearance.material.name = "HilightedType";

            IncrementClock();
            PlaySoundMenuChange();
        }

        function OnMoveDown()
        {
		SSaver = 0;
            theSetClockMenu.children[0].children[0].Clock_morearrow_down.children[0].appearance.material.name = "Typesdsafsda";
            theSetClockMenu.children[0].children[0].Clock_morearrow_up.children[0].appearance.material.name = "HilightedType";

            DecrementClock();
            PlaySoundMenuChange();
        }

        function OnMoveCenter()
        {
		SSaver = 0;
            theSetClockMenu.children[0].children[0].Clock_morearrow_up.children[0].appearance.material.name = "HilightedType";
            theSetClockMenu.children[0].children[0].Clock_morearrow_down.children[0].appearance.material.name = "HilightedType";
        }
		function OnPower()
		{
			Action("ShutDown_2GAM","Bouton");
		}
		function OnPlay()
		{
			if ( DVDLaunch == false)
			{
				SSaver = 0;
				if(BGMon == false | bgmpause == true)
				{
					theControlPanelControlsInline.children[0].MusicPlayerPlay();
				}
			}
		}
		function OnStop()
		{
			if ( DVDLaunch == false)
			{
				SSaver = 0;
				if(BGMon == true)
				{
					theControlPanelControlsInline.children[0].MusicPlayerStop();
				}
			}
		}
		function OnPause()
		{
			if ( DVDLaunch == false)
			{
				SSaver = 0;
				if (BGMon == true & bgmpause == false)
				{
					theControlPanelControlsInline.children[0].MusicPlayerPause();
					bgmpause = true;
				}
			}
		}
		function OnSkipBack()
		{
			if ( DVDLaunch == false)
			{
				SSaver = 0;
				if(currentMusicPlayerMode == "Continuous")
				{
					theControlPanelControlsInline.children[0].MusicPlayerRewind();
				}
				else if(currentMusicPlayerMode == "Playlist")
				{
					theControlPanelControlsInline.children[0].PlaylistREW();
				}
				else if(currentMusicPlayerMode == "Random")
				{
					theControlPanelControlsInline.children[0].MusicPlayerRandom();
				}
			}
		}
		function OnSkipForward()
		{
			if ( DVDLaunch == false)
			{
				SSaver = 0;
				if(currentMusicPlayerMode == "Continuous")
				{
					theControlPanelControlsInline.children[0].MusicPlayerFastForward();
				}
				else if(currentMusicPlayerMode == "Playlist")
				{
					theControlPanelControlsInline.children[0].PlaylistFFW();
				}
				else if(currentMusicPlayerMode == "Random")
				{
					theControlPanelControlsInline.children[0].MusicPlayerRandom();
				}
			}
		}
		function OnMenu()
		{
			if ( DVDLaunch == false)
			{
				SSaver = 0;
				StartControlPanel();
			}
		}
		function OnReverse()
		{
			if ( DVDLaunch == false)
			{
				SSaver = 0;
				if (BGMon == true & bgmpause == false)
				{
					theControlPanelControlsInline.children[0].MusicPlayerVolumeDown();
					var a = Math.round(theControlPanelControlsInline.children[0].theBGMusicPlayer.volume * 100);
					var txt = ReadValue(18, "default", "Datas\\Langues\\"+lang+".ini");
					var aa = txt + " : " + a;
					SetStatusText(aa);
				}
			}
		}
		function OnForward()
		{
			if ( DVDLaunch == false)
			{
				SSaver = 0;
				if (BGMon == true & bgmpause == false)
				{
					theControlPanelControlsInline.children[0].MusicPlayerVolumeUp();
					var a = Math.round(theControlPanelControlsInline.children[0].theBGMusicPlayer.volume * 100);
					var txt = ReadValue(18, "default", "Datas\\Langues\\"+lang+".ini");
					var aa = txt + " : " + a;
					SetStatusText(aa);
				}
			}
		}
		function On1()
		{
			if ( DVDLaunch == false)
			{
				SSaver = 0;
				Action("MemoryX_2GAM","Bouton");
			}
		}
		function On2()
		{
			SSaver = 0;
			Action("ShowHideClock_2GAM","Bouton");
		}
		function On3()
		{
			if ( DVDLaunch == false)
			{
				SSaver = 0;
				Action("AffTitre_2GAM","Bouton");
			}
		}
		function On4()
		{
			if ( DVDLaunch == false)
			{
				SSaver = 0;
				Action("NextBackground_2GAM","Bouton");
			}
		}
		function On5()
		{
			if ( DVDLaunch == false)
			{
				SSaver = tmpSaver + 1;
			}
		}
		function On6()
		{
			if ( DVDLaunch == false)
			{
				SSaver = 0;
				Action("ChangeSkins_2GAM","Bouton");
			}
		}
    }

    function OnActivate()
    {
		CurrentViewpoint = theSetClockMenuView;
		CurrentAltViewpoint = theSetClockMenuAlternateView;
		previousControlType = theSetClockMenuJoy;
		MenuBoutons = true;
        	EnableAmbientAudio();
        	if (children[0].children.length() > 0)
        	{
            	StartClockSettings();
        	}
    }
}

// Time Zones Menu //////////////////////////////////////////////////////////////////////

var nCurTimezoneMenuItem;
var nStartTimezoneMenuItem;
var nNumTimezoneMenuItems;
var nCurTimezoneMenuButton;

var nTimezoneScroll;
var nTimezoneItemCount;

var sTimeZoneElements;

function UpdateTimezoneMenu()
{
	var c = theSetTimezoneMenu.children[0].children[0];

	c.movearrow_up.visible = false;
	c.movearrow_dn.visible = false;

	c.movearrow_up.children[0].appearance.material.name = "NavType";
	c.movearrow_dn.children[0].appearance.material.name = "NavType";

	// test arrow visibility
	if (nTimezoneScroll > 0)
		c.movearrow_up.visible = true;
	if (nTimezoneScroll + nNumTimezoneMenuItems < nTimezoneItemCount)
		c.movearrow_dn.visible = true;

	for (var i = 0; i < nNumTimezoneMenuItems; i = i + 1)
	{
		if(i == nCurTimezoneMenuButton)
		{
			c.MenuButtons.children[i].children[0].appearance.material.name = BOnMatGen;
			c.MenuButtons.children[i].children[0].appearance.texture.url = BOnTexGen+".xbx";
			c.MenuButtonText.children[i].children[0].appearance.material.name = "Material #133";
			
			// hilite scroll arrows as well
			if(i == 0)
				c.movearrow_up.children[0].appearance.material.name = "Material #133";
			else if(i == 7)
				c.movearrow_dn.children[0].appearance.material.name = "Material #133";
		}
		else
		{
			c.MenuButtons.children[i].children[0].appearance.material.name = BOffMatGen;
			c.MenuButtons.children[i].children[0].appearance.texture.url = BOffTexGen+".xbx";
			c.MenuButtonText.children[i].children[0].appearance.material.name = "NavType";
		}

		c.MenuButtonText.children[i].children[0].geometry.text = sTimeZoneElements[nTimezoneScroll + i];
	}
}


function StartTimezoneMenu()
{
	var c = theSetTimezoneMenu.children[0].children[0];
	var bBackVisible = 1 - bForceSetTimeZone;

	if (AffButtonB == true)
		c.Group06.visible = bBackVisible;
	else
		c.Group06.visible = false;

	nNumTimezoneMenuItems = 8;
	nCurTimezoneMenuButton = 0;
	nTimezoneScroll = 0;
	nTimezoneItemCount = 75;

	nStartTimezoneMenuItem = theConfig.GetTimeZone();
	nCurTimezoneMenuItem = theConfig.GetTimeZone();

	MenuVisible = "theSetTimezoneMenu";
	Option();

	sTimeZoneElements = new Array(  theTranslator.Translate("GMT-12"),
									theTranslator.Translate("GMT-11"),
