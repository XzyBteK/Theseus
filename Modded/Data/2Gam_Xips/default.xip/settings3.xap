{
	fieldOfView 1.287000
	orientation -0.201100 -0.001500 0.014710 0.849100
	position 101.199997 3.965000 -250.500000
	jump false
}

DEF theSetClockMenu Level
{
    archive "Settings_Clock.xip"

    children
    [
        Inline
        {
            url "Settings_Clock/default.xap"

            function onLoad()
            {
                StartClockSettings();
            }
        }
    ]

    path DEF theSetClockMenuView Viewpoint
    {
		fieldOfView 1.287000
		orientation -0.201100 -0.979500 0.014710 -0.149100
		position 101.199997 3.965000 -250.500000
        jump false
    }
    control DEF theSetClockMenuJoy Joystick
    {
        function OnADown()
        {
		SSaver = 0;
		if(shift == "")
		{
            theSetClockMenu.children[0].children[0].Clock_select_pod_HL.children[0].appearance.material.param = 1;

            PlaySoundA();

            // Now we check for Feb 29 on a non-leap year...
            CheckClockDay(false);
            UpdateTime();

            // Accept the setting change
            var nHour = nClockHourC;
            if (b24hour == false)
            {
                if (nHour == 12)
                    nHour = 0;
                if (nClockAMPMC == "PM")
                    nHour = nHour + 12;
            }

            var d = new Date(nClockYearC + 2000, nClockMonthC - 1, nClockDayC, nHour, nClockMinuteC);
            d.SetSystemClock();

            if (bForceSetClock)
            {
                bForceSetClock = false;
                ProcessDiscOnForceSettings();
            }
            else
            {
			strPrevMenu = "TIME DATE";
			strCurMenu = "CLOCK";
			theChooseClockMenu.GoBackTo();
			theSettingsSubMenuOut.Play();
            }
		}
			if ( DVDLaunch == false)
			{
				if(shift == "¤-")
				{
					if ( ConfigBoutonsMainMenu[8] != "0")
					Action(ConfigBoutonsMainMenu[8],"Bouton");
				}
				if(shift == "-¤")
				{
					if ( ConfigBoutonsMainMenu[16] != "0")
					Action(ConfigBoutonsMainMenu[16],"Bouton");
				}
				if(shift == "¤¤")
				{
					if ( ConfigBoutonsMainMenu[24] != "0")
					Action(ConfigBoutonsMainMenu[24],"Bouton");
				}
			}
        }

        function OnBDown()
        {
		SSaver = 0;
		if(shift == "")
		{
            if (bForceSetClock)
                return;

            theSetClockMenu.children[0].children[0].Clock_back_pod_HL.children[0].appearance.material.param = 1;

            PlaySoundB();

            // Cancel the setting change
            GetCurrentTime();
            UpdateTime();

		strPrevMenu = "TIME DATE";
		strCurMenu = "CLOCK";
            theChooseClockMenu.GoBackTo();
            theSettingsSubMenuOut.Play();
		}
			if ( DVDLaunch == false)
			{
