		function OnMoveUp()
		{
		SSaver = 0;
			if (nCurTimezoneMenuItem <= 0)
				return;

			PlaySoundMenuChange();
			nCurTimezoneMenuItem = nCurTimezoneMenuItem - 1;
            if (nCurTimezoneMenuButton == 0)
            {
                nTimezoneScroll = nTimezoneScroll - 1;
            }
            else
            {
                nCurTimezoneMenuButton = nCurTimezoneMenuButton - 1;
            }

			UpdateTimezoneMenu();
		}

		function OnMoveDown()
		{
		SSaver = 0;
			if (nCurTimezoneMenuItem == nTimezoneItemCount - 1)
                return;

			PlaySoundMenuChange();
			nCurTimezoneMenuItem = nCurTimezoneMenuItem + 1;
			if (nCurTimezoneMenuButton == nNumTimezoneMenuItems - 1)
            {
                nTimezoneScroll = nTimezoneScroll + 1;
            }
            else
            {
                nCurTimezoneMenuButton = nCurTimezoneMenuButton + 1;
            }

			UpdateTimezoneMenu();
		}
		function OnPower()
		{
			Action("ShutDown_2GAM","Bouton");
		}
		function OnPlay()
		{
			if ( DVDLaunch == false)
			{
				SSaver = 0;
				if(BGMon == false | bgmpause == true)
				{
					theControlPanelControlsInline.children[0].MusicPlayerPlay();
				}
			}
		}
		function OnStop()
		{
			if ( DVDLaunch == false)
			{
				SSaver = 0;
				if(BGMon == true)
				{
					theControlPanelControlsInline.children[0].MusicPlayerStop();
				}
			}
		}
		function OnPause()
		{
			if ( DVDLaunch == false)
			{
				SSaver = 0;
				if (BGMon == true & bgmpause == false)
				{
					theControlPanelControlsInline.children[0].MusicPlayerPause();
					bgmpause = true;
				}
			}
		}
		function OnSkipBack()
		{
			if ( DVDLaunch == false)
			{
				SSaver = 0;
				if(currentMusicPlayerMode == "Continuous")
				{
					theControlPanelControlsInline.children[0].MusicPlayerRewind();
				}
				else if(currentMusicPlayerMode == "Playlist")
				{
					theControlPanelControlsInline.children[0].PlaylistREW();
				}
				else if(currentMusicPlayerMode == "Random")
				{
					theControlPanelControlsInline.children[0].MusicPlayerRandom();
				}
			}
		}
		function OnSkipForward()
		{
			if ( DVDLaunch == false)
			{
				SSaver = 0;
				if(currentMusicPlayerMode == "Continuous")
				{
					theControlPanelControlsInline.children[0].MusicPlayerFastForward();
				}
				else if(currentMusicPlayerMode == "Playlist")
				{
					theControlPanelControlsInline.children[0].PlaylistFFW();
				}
				else if(currentMusicPlayerMode == "Random")
				{
					theControlPanelControlsInline.children[0].MusicPlayerRandom();
				}
			}
		}
		function OnMenu()
		{
			if ( DVDLaunch == false)
			{
				SSaver = 0;
				StartControlPanel();
			}
		}
		function OnReverse()
		{
			if ( DVDLaunch == false)
			{
				SSaver = 0;
				if (BGMon == true & bgmpause == false)
				{
					theControlPanelControlsInline.children[0].MusicPlayerVolumeDown();
					var a = Math.round(theControlPanelControlsInline.children[0].theBGMusicPlayer.volume * 100);
					var txt = ReadValue(18, "default", "Datas\\Langues\\"+lang+".ini");
					var aa = txt + " : " + a;
					SetStatusText(aa);
				}
			}
		}
		function OnForward()
		{
			if ( DVDLaunch == false)
			{
				SSaver = 0;
				if (BGMon == true & bgmpause == false)
				{
					theControlPanelControlsInline.children[0].MusicPlayerVolumeUp();
					var a = Math.round(theControlPanelControlsInline.children[0].theBGMusicPlayer.volume * 100);
					var txt = ReadValue(18, "default", "Datas\\Langues\\"+lang+".ini");
					var aa = txt + " : " + a;
					SetStatusText(aa);
				}
			}
		}
		function On1()
		{
			if ( DVDLaunch == false)
			{
				SSaver = 0;
				Action("MemoryX_2GAM","Bouton");
			}
		}
		function On2()
		{
			SSaver = 0;
			Action("ShowHideClock_2GAM","Bouton");
		}
		function On3()
		{
			if ( DVDLaunch == false)
			{
				SSaver = 0;
				Action("AffTitre_2GAM","Bouton");
			}
		}
		function On4()
		{
			if ( DVDLaunch == false)
			{
				SSaver = 0;
				Action("NextBackground_2GAM","Bouton");
			}
		}
		function On5()
		{
			if ( DVDLaunch == false)
			{
				SSaver = tmpSaver + 1;
			}
		}
		function On6()
		{
			if ( DVDLaunch == false)
			{
				SSaver = 0;
				Action("ChangeSkins_2GAM","Bouton");
			}
		}
	}

	function OnActivate()
	{
		CurrentViewpoint = theSetTimezoneMenuView;
		CurrentAltViewpoint = theSetTimezoneMenuAlternateView;
		previousControlType = theSetTimezoneMenuJoy;
		MenuBoutons = true;
		if (children[0].children.length() > 0)
		{
			StartTimezoneMenu();
		}
	}
}

