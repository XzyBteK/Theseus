    function OnActivate()
    {
		CurrentViewpoint = threeButtonViewpoint;
		CurrentAltViewpoint = theChooseClockMenuAlternateView;
		previousControlType = theChooseClockMenuJoy;
		MenuBoutons = true;
		if(strCurMenu == "FTP" | strCurMenu == "CLOCK" |(strCurMenu == "VIDEO MODE" & theConfig.GetAVRegion() == "PAL I"))
		{
			fourButtonViewpoint.isBound = true;
			CurrentViewpoint = fourButtonViewpoint;
		}
		if (children[0].children.length() > 0)
		{
			UpdateListIcons();
            	SetupListSettings();
		}

	}
	behavior
	{
		sleep 0.1;
		if (children[0].children.length() > 0)
		{
            	if (strCurMenu == "CLOCK" & strPrevMenu != "CLOCK")
            	{
				UpdateClock();
            	}
        	}
    	}
}
function ChangeValues()
{
	if(nCurListItems == 0)
	{
		ShowKeyboard("Adresse IP", AdresseIP, "theSettingsInline.children[0].SauveFTP(strKeyboardEdit)", "");
		theSettingsSubMenuIn.Play();
	}
	else if(nCurListItems == 1)
	{
		ShowKeyboard("Masque sous Reseau", MasqueReseau, "theSettingsInline.children[0].SauveFTP(strKeyboardEdit)", "");
		theSettingsSubMenuIn.Play();
	}
	else if(nCurListItems == 2)
	{
		ShowKeyboard("Passerelle Reseau", Passerelle, "theSettingsInline.children[0].SauveFTP(strKeyboardEdit)", "");
		theSettingsSubMenuIn.Play();
	}
	else if(nCurListItems == 3)
	{
		ShowKeyboard("Nom Utilisateur", Utilisateur, "theSettingsInline.children[0].SauveFTP(strKeyboardEdit)", "");
		theSettingsSubMenuIn.Play();
	}
}
function SauveFTP(x)
{
	var value = x;
	if( nCurListItems == 0)
		AdresseIP = value;
	else if( nCurListItems == 1)
		MasqueReseau = value;
	else if( nCurListItems == 2)
		Passerelle = value;
	else if( nCurListItems == 3)
		Utilisateur = value;

    var info = new Settings;
    info.file =  "X:\\2GAM.data\\config_pro.ini";
    info.section = "FTP";
    var c = info.SetValue("LocalIP" , AdresseIP );
    var c = info.SetValue("SubMaskIP", MasqueReseau );
    var c = info.SetValue("GateWayIP", Passerelle );
    var c = info.SetValue("Login", Utilisateur );
    SetupListMenu();
}
// Vitesse Ventilo ////////////////////////////////////////////////////////////////////
function StartVentilSettings()
{
	MenuVisible = "theSetVentilMenu";
	Option();
	var txt = "";
	var c = theSetVentilMenu.children[0].children[0];
	c.Clock_date_panel_01.children[0].appearance.material.name = BOffMatGen;
	c.Clock_date_panel_01.children[0].appearance.texture.url = BOffTexGen+".xbx";
	c.Clock_text_time_fifteen_W1.children[0].appearance.material.name = "NavType";
	c.Clock_date_panel_02.children[0].appearance.material.name = BOffMatGen;
	c.Clock_date_panel_02.children[0].appearance.texture.url = BOffTexGen+".xbx";
	c.Clock_text_time_fifteen_W2.children[0].appearance.material.name = "NavType";
	FanSpeed = theConfig.GetFanSpeed();
	var lgt = FanSpeed.length();
	var Speed = FanSpeed.substring(0,lgt-2);
	ValeurFanSpeed = ReturnInteger(Speed);
	txt = ReadValue(55, "default", "Datas\\Langues\\"+lang+".ini");
	c.Titre.text = txt;
	txt = ReadValue(56, "default", "Datas\\Langues\\"+lang+".ini");
	c.Notice.text = txt;
	txt = ReadValue(57, "default", "Datas\\Langues\\"+lang+".ini");
	c.BoutonA.text = txt;
	UpdatePanneau();
}
function UpdatePanneau()
{
	var txt = ReadValue(54, "default", "Datas\\Langues\\"+lang+".ini");
	theSetVentilMenu.children[0].children[0].ValeurText.text = txt + " " + ValeurFanSpeed + " %";
	theSetVentilMenu.children[0].children[0].FanIcon.rpm = ValeurFanSpeed;
	SetVentilPos(ValeurFanSpeed);
}
function SetVentilPos(nPos)
{
    var nNewPos = nPos;
    if (nNewPos < 0)
        nNewPos = 0;
    else if (nNewPos > 100)
        nNewPos = 100;

    var x = 0.15 + ( 0.0268 * nNewPos );
    var y = -0.943;
    var z =  1.791;
    theSetVentilMenu.children[0].children[0].MU_L3_timeslider.SetTranslation(x, y, z);
}
function SauvegardeFanSpeed()
{
	SaveSetting(17,ValeurFanSpeed,"default", "Datas\\Config\\ConfigSysteme.xbc");
}
