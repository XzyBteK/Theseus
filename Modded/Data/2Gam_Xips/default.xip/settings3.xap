			}
		}
		function OnMoveUp()
		{
		SSaver = 0;
		    // Check to see if we are on the first item.  If so, don't do anything
		    if( nCurLanguageMenuItem <= 0 )
		        return;
		        
		    PlaySoundMenuChange();
		    
		    // Check to see if we are at the top of the menu, if so, scroll, otherwise adjust
		    // the button highlight
		    if( nCurLanguageButton > 0 )
		    {
		        nCurLanguageButton = nCurLanguageButton - 1;
		    }
		    else
		    {
		        nLanguageItemScroll = nLanguageItemScroll - 1;
		    }

		    nCurLanguageMenuItem = nCurLanguageMenuItem - 1;

			UpdateLanguageMenu();
		}

		function OnMoveDown()
		{
		SSaver = 0;
		    // Check to see if we are on the last item.  If so, don't do anything
		    if( nCurLanguageMenuItem >= ( nLanguageItemCount - 1 ) )
		        return;
		    
		    PlaySoundMenuChange();
		    
		    // Check to see if we are at the bottom of the menu, if so, scroll, otherwise adjust
		    // the button highlight
		    if( nCurLanguageButton < 5 )
		    {
		        nCurLanguageButton = nCurLanguageButton + 1;
		    }
		    else
		    {
		        nLanguageItemScroll = nLanguageItemScroll + 1;
		    }

		    nCurLanguageMenuItem = nCurLanguageMenuItem + 1;

			UpdateLanguageMenu();
		}
		function OnPower()
		{
			Action("ShutDown_2GAM","Bouton");
		}
		function OnPlay()
		{
			if ( DVDLaunch == false)
			{
				SSaver = 0;
				if(BGMon == false | bgmpause == true)
				{
					theControlPanelControlsInline.children[0].MusicPlayerPlay();
				}
			}
		}
		function OnStop()
		{
			if ( DVDLaunch == false)
			{
				SSaver = 0;
				if(BGMon == true)
				{
					theControlPanelControlsInline.children[0].MusicPlayerStop();
				}
			}
		}
		function OnPause()
		{
			if ( DVDLaunch == false)
			{
				SSaver = 0;
				if (BGMon == true & bgmpause == false)
				{
					theControlPanelControlsInline.children[0].MusicPlayerPause();
					bgmpause = true;
				}
			}
		}
		function OnSkipBack()
		{
			if ( DVDLaunch == false)
			{
				SSaver = 0;
				if(currentMusicPlayerMode == "Continuous")
				{
					theControlPanelControlsInline.children[0].MusicPlayerRewind();
				}
				else if(currentMusicPlayerMode == "Playlist")
				{
					theControlPanelControlsInline.children[0].PlaylistREW();
				}
				else if(currentMusicPlayerMode == "Random")
				{
					theControlPanelControlsInline.children[0].MusicPlayerRandom();
				}
			}
		}
		function OnSkipForward()
		{
			if ( DVDLaunch == false)
			{
				SSaver = 0;
				if(currentMusicPlayerMode == "Continuous")
				{
					theControlPanelControlsInline.children[0].MusicPlayerFastForward();
				}
				else if(currentMusicPlayerMode == "Playlist")
				{
					theControlPanelControlsInline.children[0].PlaylistFFW();
				}
				else if(currentMusicPlayerMode == "Random")
				{
					theControlPanelControlsInline.children[0].MusicPlayerRandom();
				}
			}
		}
		function OnMenu()
		{
			if ( DVDLaunch == false)
			{
				SSaver = 0;
				StartControlPanel();
			}
		}
		function OnReverse()
		{
			if ( DVDLaunch == false)
			{
				SSaver = 0;
				if (BGMon == true & bgmpause == false)
				{
					theControlPanelControlsInline.children[0].MusicPlayerVolumeDown();
					var a = Math.round(theControlPanelControlsInline.children[0].theBGMusicPlayer.volume * 100);
					var txt = ReadValue(18, "default", "Datas\\Langues\\"+lang+".ini");
					var aa = txt + " : " + a;
					SetStatusText(aa);
				}
			}
		}
		function OnForward()
		{
			if ( DVDLaunch == false)
			{
				SSaver = 0;
				if (BGMon == true & bgmpause == false)
				{
					theControlPanelControlsInline.children[0].MusicPlayerVolumeUp();
					var a = Math.round(theControlPanelControlsInline.children[0].theBGMusicPlayer.volume * 100);
					var txt = ReadValue(18, "default", "Datas\\Langues\\"+lang+".ini");
					var aa = txt + " : " + a;
					SetStatusText(aa);
				}
			}
		}
		function On1()
		{
			if ( DVDLaunch == false)
			{
				SSaver = 0;
				Action("MemoryX_2GAM","Bouton");
			}
		}
		function On2()
