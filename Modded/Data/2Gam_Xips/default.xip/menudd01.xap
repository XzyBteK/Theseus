	function OnLeftDown()
	{
		SSaver = 0;
		onleft = true;
		AfficheShift();
	}

	function OnLeftUp()
	{
		SSaver = 0;
		onleft = false;
		AfficheShift();
	}
	function OnRightDown()
	{
		SSaver = 0;
		onright = true;
		AfficheShift();
	}

	function OnRightUp()
	{
		SSaver = 0;
		onright = false;
		AfficheShift();
	}
	function OnMoveUp()
	{
		SSaver = 0;
		if (nCurXMenuItem <= 0)
			return;

		PlaySoundMenuChange();
		nCurXMenuItem = nCurXMenuItem - 1;
            if (nCurXMenuButton == 0)
            {
                nXScroll = nXScroll - 1;
            }
            else
            {
                nCurXMenuButton = nCurXMenuButton - 1;
            }
		UpdateSubMenu();
	}
	function OnMoveDown()
	{
		SSaver = 0;
		if (nCurXMenuItem == nXItemCount - 1)
		return;

		PlaySoundMenuChange();
		nCurXMenuItem = nCurXMenuItem + 1;
		if (nCurXMenuButton == nNumXMenuItems - 1)
            {
                nXScroll = nXScroll + 1;
            }
            else
            {
                nCurXMenuButton = nCurXMenuButton + 1;
            }
		UpdateSubMenu();
	}
	function OnPower()
	{
			Action("ShutDown_2GAM","Bouton");
	}
	function OnPlay()
	{
		if(BGMon == false | bgmpause == true)
		{
			theControlPanelControlsInline.children[0].MusicPlayerPlay();
		}
	}
	function OnStop()
	{
		if(BGMon == true)
		{
			theControlPanelControlsInline.children[0].MusicPlayerStop();
		}
	}
	function OnPause()
	{
		SSaver = 0;
		if (BGMon == true & bgmpause == false)
		{
			theControlPanelControlsInline.children[0].MusicPlayerPause();
			bgmpause = true;
		}
	}
	function OnSkipBack()
	{
		SSaver = 0;
		if(currentMusicPlayerMode == "Continuous")
		{
			theControlPanelControlsInline.children[0].MusicPlayerRewind();
		}
		else if(currentMusicPlayerMode == "Playlist")
		{
			theControlPanelControlsInline.children[0].PlaylistREW();
		}
		else if(currentMusicPlayerMode == "Random")
		{
			theControlPanelControlsInline.children[0].MusicPlayerRandom();
		}
	}
	function OnSkipForward()
	{
		SSaver = 0;
		if(currentMusicPlayerMode == "Continuous")
		{
			theControlPanelControlsInline.children[0].MusicPlayerFastForward();
		}
		else if(currentMusicPlayerMode == "Playlist")
		{
			theControlPanelControlsInline.children[0].PlaylistFFW();
		}
		else if(currentMusicPlayerMode == "Random")
		{
			theControlPanelControlsInline.children[0].MusicPlayerRandom();
		}
	}
	function OnMenu()
	{
		SSaver = 0;
		StartControlPanel();
	}
	function OnReverse()
	{
		SSaver = 0;
		if (BGMon == true & bgmpause == false)
		{
			theControlPanelControlsInline.children[0].MusicPlayerVolumeDown();
			var a = Math.round(theControlPanelControlsInline.children[0].theBGMusicPlayer.volume * 100);
			var txt = ReadValue(18, "default", "Datas\\Langues\\"+lang+".ini");
			var aa = txt + " : " + a;
			SetStatusText(aa);
		}
	}
	function OnForward()
	{
		SSaver = 0;
		if (BGMon == true & bgmpause == false)
		{
			theControlPanelControlsInline.children[0].MusicPlayerVolumeUp();
			var a = Math.round(theControlPanelControlsInline.children[0].theBGMusicPlayer.volume * 100);
			var txt = ReadValue(18, "default", "Datas\\Langues\\"+lang+".ini");
			var aa = txt + " : " + a;
			SetStatusText(aa);
		}
	}
	function On1()
	{
		SSaver = 0;
		Action("MemoryX_2GAM","Bouton");
	}
	function On2()
	{
		SSaver = 0;
		Action("ShowHideClock_2GAM","Bouton");
	}
	function On3()
	{
		SSaver = 0;
		Action("AffTitre_2GAM","Bouton");
	}
	function On4()
	{
		SSaver = 0;
		Action("NextBackground_2GAM","Bouton");
	}
	function On5()
	{
		SSaver = tmpSaver + 1;
	}
	function On6()
	{
		SSaver = 0;
		Action("ChangeSkins_2GAM","Bouton");
	}
	}
	function OnActivate()
	{
		CurrentViewpoint = theSubMenuViewpoint;
		CurrentAltViewpoint = theSubMenuAlternateViewpoint;
		previousControlType = theSubMenujoy;
		MajMenu = DisqueType;
		MenuBoutons = true;
		if (children[0].children.length() > 0)
		{
            	StartSubMenu();
		}
	}
	behavior
	{
		sleep 0.2;
		if (DisqueType != MajMenu & bmenudd01 == true)
			StartSubMenu();
	}
}
// End Settings SubMenu by Gcue ///////////////////////////////////////
function Option()
{
	var x = theSubMenu.children[0].children[0];
	if(ConfigSysteme[19] == "Original")
		x.BackgroundPanel.url = "Pset.xbx";
	else if(ConfigSysteme[19] == "Verre")
		x.BackgroundPanel.url = "Fond.xbx";

	x.Spinning_Support2_r.visible = false;
	x.Spinning_Support2.visible = false;
	x.Spinning_Support_r.visible = false;
	x.Spinning_Support.visible = false;
	if (MatGen != "")
	{
		x.GenMat01.name = MatGen;
		x.GenMat02.name = MatGen;
		x.GenMat03.name = MatGen;
	}
	if (TexGen != "")
	{
		x.GenTex01.url = TexGen+".xbx";
		x.GenTex02.url = TexGen+".xbx";
		x.GenTex03.url = TexGen+".xbx";
	}

	if (ApparenceMenusDD[3] == "non")
	{
		x.affcell.visible = false;
	}
	else
	{
		x.affcell.visible = true;
	}
	if (ApparenceMenusDD[4] == "non")
	{
		x.Group07.visible = false;
	}
	else
	{
		x.Group07.visible = true;
	}
	if (ApparenceMenusDD[5] == "non")
	{
		x.Group06.visible = false;
	}
	else
	{
		x.Group06.visible = true;
	}
	if (ApparenceMenusDD[6] == "non")
	{
		x.Orbite.visible = false;
	}
	else
	{
		x.Orbite.visible = true;
	}
	if (ApparenceMenusDD[7] == "rien")
	{
		x.videoPodMode1.visible = false;
		x.videoPodMode2.visible = false;
		x.ConsoleIcon.visible = false;
		x.IconCube.visible = false;
	}
	if (ApparenceMenusDD[7] == "xbox4")
	{
		x.videoPodMode1.visible = true;
		x.videoPodMode2.visible = false;
		x.ConsoleIcon.visible = false;
		x.IconCube.visible = false;
	}
	if (ApparenceMenusDD[7] == "jbone")
	{
		x.videoPodMode1.visible = false;
		x.videoPodMode2.visible = true;
		x.ConsoleIcon.visible = false;
		x.IconCube.visible = false;
	}
	if (ApparenceMenusDD[7] == "xbox4+jbone")
	{
		x.videoPodMode1.visible = true;
		x.videoPodMode2.visible = true;
		x.ConsoleIcon.visible = false;
		x.IconCube.visible = false;
	}
	if (ApparenceMenusDD[7] == "icon")
	{
		x.videoPodMode1.visible = false;
		x.videoPodMode2.visible = false;
		x.IconCube.visible = true;
		x.ConsoleIcon.visible = false;
		x.IconCube.visible = false;
	}
	if (ApparenceMenusDD[7] == "icon+jbone")
	{
		x.videoPodMode1.visible = false;
		x.videoPodMode2.visible = true;
		x.IconCube.visible = true;
		x.ConsoleIcon.visible = false;
	}
	if (ApparenceMenusDD[7] == "xbox")
	{
		x.videoPodMode1.visible = false;
		x.videoPodMode2.visible = false;
		x.ConsoleIcon.visible = true;
		x.IconCube.visible = false;
	}
	if (ApparenceMenusDD[7] == "xbox+jbone")
	{
		x.videoPodMode1.visible = false;
		x.videoPodMode2.visible = true;
		x.ConsoleIcon.visible = true;
		x.IconCube.visible = false;
	}
	if(ApparenceMenusDD[8] == "oui")
	{
		if(ApparenceMenusDD[9] == "oui")
		{
			x.Spinning_Support_r.visible = true;
		}
		else
		{
			x.Spinning_Support.visible = true;
		}
	}
	if(ApparenceMenusDD[10] == "oui")
	{
		if(ApparenceMenusDD[11] == "oui")
		{
			x.Spinning_Support2_r.visible = true;
		}
		else
		{
			x.Spinning_Support2.visible = true;
		}
	}
}
