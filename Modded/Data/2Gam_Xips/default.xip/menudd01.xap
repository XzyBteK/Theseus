// Settings Sub Menu by Gcue ///////////////////////////////////////////////////////////////////
//////////////////////////////////////////////////////////////////////////////////

var nCurXMenuItem;
var nNumXMenuItems;
var nCurXMenuButton;
var nXScroll;
var nXItemCount;
var sXElements;
var rtsm;
var MajMenu;
var bmenudd01;
var sXMenu;

function initialize()
{
	bmenudd01 = false;
	nCurXMenuItem = 0;
	nXScroll = 0;
	nCurXMenuButton = 0;
}
function UpdateSubMenu()
{
	var x = theSubMenu.children[0].children[0];

	x.movearrow_up.visible = false;
	x.movearrow_dn.visible = false;

	x.movearrow_up.children[0].appearance.material.name = "NavType";
	x.movearrow_dn.children[0].appearance.material.name = "NavType";

	// test arrow visibility
	if (nXScroll > 0)
		x.movearrow_up.visible = true;
	if (nXScroll + nNumXMenuItems < nXItemCount)
		x.movearrow_dn.visible = true;

	for (var i = 0; i < nNumXMenuItems; i = i + 1)
	{
		if(i == nCurXMenuButton)
		{
			x.MenuButtons.children[i].children[0].appearance.material.name = BOnMatGen;
			x.MenuButtons.children[i].children[0].appearance.texture.url = BOnTexGen+".xbx";
			x.MenuText.children[i].children[0].appearance.material.name = "Material #133";
			
			// hilite scroll arrows as well
			if(i == 0)
				x.movearrow_up.children[0].appearance.material.name = "Material #133";
			else if(i == 5)
				x.movearrow_dn.children[0].appearance.material.name = "Material #133";

		}
		else
		{
			x.MenuButtons.children[i].children[0].appearance.material.name = BOffMatGen;
			x.MenuButtons.children[i].children[0].appearance.texture.url = BOffTexGen+".xbx";
			x.MenuText.children[i].children[0].appearance.material.name = "NavType";
		}

		if(nXItemCount > i)
			x.MenuText.children[i].children[0].geometry.text = sXElements[nXScroll + i];
	}
	UpdateRootMeta();
}
function StartSubMenu()
{
	bmenudd01 = true;
	MajMenu = DisqueType;
	var x = theSubMenu.children[0].children[0];
	if (AjDvd == true)
		MenusDD[1] = ReadValue(16, "default", "Datas\\Langues\\"+lang+".ini");

	if( ApparenceMenusDD[2] == "Disque Dur")
		x.SubMenuHead.geometry.text = ReadValue(63, "default", "Datas\\Langues\\"+lang+".ini");
	else
		x.SubMenuHead.geometry.text = ApparenceMenusDD[2];

	nCurXMenuItem = 0;
	if (Nbmenudd < 6)
	{
		nNumXMenuItems = Nbmenudd;
	}
	else
	{
		nNumXMenuItems = 6;
	}
	nCurXMenuButton = 0;
	nXScroll = 0;
	sXMenu = new Array;
	// Build the Settings Menu array
	for (var g = 1; g < Nbmenudd + 1; g = g +1)
	{
		if( MenusDD[g] == "Jeux")
			sXMenu[g-1] = ReadValue(78, "default", "Datas\\Langues\\"+lang+".ini");
		else if( MenusDD[g] == "Applications")
			sXMenu[g-1] = ReadValue(79, "default", "Datas\\Langues\\"+lang+".ini");
		else if( MenusDD[g] == "Emulateurs")
			sXMenu[g-1] = ReadValue(80, "default", "Datas\\Langues\\"+lang+".ini");
		else if( MenusDD[g] == "Dashboards")
			sXMenu[g-1] = ReadValue(81, "default", "Datas\\Langues\\"+lang+".ini");
		else
			sXMenu[g-1] = MenusDD[g];

	}
	nXItemCount = Nbmenudd;
	sXElements = sXMenu;
	x.S_Home_menubutton_04.visible = true;
	x.S_Home_text_01.visible = true;
	x.S_Home_menubutton_02.visible = true;
	x.S_Home_text_02.visible = true;
	x.S_Home_menubutton_03.visible = true;
	x.S_Home_text_03.visible = true;
	x.S_Home_menubutton_01.visible = true;
	x.S_Home_text_04.visible = true;
	x.S_Home_menubutton_07.visible = true;
	x.S_Home_text_05.visible = true;
	x.S_Home_menubutton_06.visible = true;
	x.S_Home_text_06.visible = true;

	// show/hide buttons as appropriate
	if(nXItemCount == 1)
	{
		x.S_Home_menubutton_02.visible = false;
		x.S_Home_text_02.visible = false;
		x.S_Home_menubutton_03.visible = false;
		x.S_Home_text_03.visible = false;
		x.S_Home_menubutton_01.visible = false;
		x.S_Home_text_04.visible = false;
		x.S_Home_menubutton_07.visible = false;
		x.S_Home_text_05.visible = false;
		x.S_Home_menubutton_06.visible = false;
		x.S_Home_text_06.visible = false;
	}
	else if(nXItemCount == 2)
	{
		x.S_Home_menubutton_03.visible = false;
		x.S_Home_text_03.visible = false;
		x.S_Home_menubutton_01.visible = false;
		x.S_Home_text_04.visible = false;
		x.S_Home_menubutton_07.visible = false;
		x.S_Home_text_05.visible = false;
		x.S_Home_menubutton_06.visible = false;
		x.S_Home_text_06.visible = false;
	}
	else if(nXItemCount == 3)
	{
		x.S_Home_menubutton_01.visible = false;
		x.S_Home_text_04.visible = false;
		x.S_Home_menubutton_07.visible = false;
		x.S_Home_text_05.visible = false;
		x.S_Home_menubutton_06.visible = false;
		x.S_Home_text_06.visible = false;
	}
	else if(nXItemCount == 4)
	{
		x.S_Home_menubutton_07.visible = false;
		x.S_Home_text_05.visible = false;
		x.S_Home_menubutton_06.visible = false;
		x.S_Home_text_06.visible = false;
	}
	else if(nXItemCount == 5)
	{
		x.S_Home_menubutton_06.visible = false;
		x.S_Home_text_06.visible = false;
	}
	UpdateSubMenu();
}

function UpdateRootMeta()
{
	var c = theSubMenu.children[0].children[0];
	var metaString = "";
	metaString = sXElements[nCurXMenuItem];
	c.metaPanel.children[0].geometry.text = metaString;
}

DEF theSubMenuAlternateViewpoint Viewpoint
{
	fieldOfView 1.287000
	orientation 0.130300 -0.000001 -0.000001 -0.700
	position 203.300003 -0.918000 -22.600006
	jump false
}
DEF theSubMenu Level
{
    archive "Settings4.xip"

    children
    [
        Inline
        {
            url "Settings4/default2.xap"

            function onLoad()
            {
			Option();
			StartSubMenu();
		}

	  }
    ]
    path DEF theSubMenuViewpoint Viewpoint
    {
	fieldOfView 1.287000
	orientation 0.130300 -0.991400 -0.007829 -0.121100
	position 203.300003 -0.918000 -52.600006
      jump false
    }

    control DEF theSubMenujoy Joystick
    {
        function OnADown()
        {
		SSaver = 0;
		if(shift == "")
		{
 			if( musicsaver == true)
			{
				return;
			}
			PlaySoundA();
			theSubMenu.children[0].children[0].MU_select_pod_HL.children[0].appearance.material.param = 1;
			magicnumber = nCurXMenuItem + 1;
			bmenudd01 = false;
			if (AjDvd == true)
				magicnumber = magicnumber - 1;

			if( backlauncher == "")
				backlauncher = Launcher;

			Launcher = "MenuDD";
			MenuBoutons = false;
			Action("MenuLancementDD_"+magicnumber+"_2GAM","Menu");
		}
		if(shift == "¤-")
		{
			if ( ConfigBoutonsMainMenu[8] != "0")
			Action(ConfigBoutonsMainMenu[8],"Bouton");
		}
		if(shift == "-¤")
		{
			if ( ConfigBoutonsMainMenu[16] != "0")
			Action(ConfigBoutonsMainMenu[16],"Bouton");
		}
		if(shift == "¤¤")
		{
			if ( ConfigBoutonsMainMenu[24] != "0")
			Action(ConfigBoutonsMainMenu[24],"Bouton");
		}
        }
	function OnBDown()
	{
		SSaver = 0;
		if(shift == "")
		{
			PlaySoundB();
			theSubMenu.children[0].children[0].MU_back_pod_HL.children[0].appearance.material.param = 1;
			bmenudd01 = false;
			theSettingsSubMenuOut.Play();
			if(backlauncher != "")
				Launcher = backlauncher;

			backlauncher = "";
			if( Launcher == "MenuConfig")
				GoToSettings();
			else if( Launcher == "MainMenu")
				theMainMenu.GoTo();
		}
		if(shift == "¤-")
		{
			if ( ConfigBoutonsMainMenu[9] != "0")
			Action(ConfigBoutonsMainMenu[9],"Bouton");
		}
		if(shift == "-¤")
		{
			if ( ConfigBoutonsMainMenu[17] != "0")
			Action(ConfigBoutonsMainMenu[17],"Bouton");
		}
		if(shift == "¤¤")
		{
			if ( ConfigBoutonsMainMenu[25] != "0")
			Action(ConfigBoutonsMainMenu[25],"Bouton");
		}
	}
