	function OnLeftDown()
	{
		SSaver = 0;
		onleft = true;
		AfficheShift();
	}

	function OnLeftUp()
	{
		SSaver = 0;
		onleft = false;
		AfficheShift();
	}
	function OnRightDown()
	{
		SSaver = 0;
		onright = true;
		AfficheShift();
	}

	function OnRightUp()
	{
		SSaver = 0;
		onright = false;
		AfficheShift();
	}

        function OnMoveUp()
        {
		SSaver = 0;
            if (musicSelect == 0)
                return;

            PlaySoundMenuChange();

            musicSelect = musicSelect - 1;

            if (musicButton == 0)
                musicScroll = musicScroll - 1;
            else
                musicButton = musicButton - 1;

            UpdateSubMenu2List();
        }

        function OnMoveDown()
        {
		SSaver = 0;
            if (musicSelect == taille - 1)
                return;

            PlaySoundMenuChange();

            musicSelect = musicSelect + 1;

            if (musicButton == 7)
                musicScroll = musicScroll + 1;
            else
                musicButton = musicButton + 1;

            UpdateSubMenu2List();
        }
	function OnPower()
	{
			Action("ShutDown_2GAM","Bouton");
	}
	function OnPlay()
	{
		if(BGMon == false | bgmpause == true)
		{
			theControlPanelControlsInline.children[0].MusicPlayerPlay();
		}
	}
	function OnStop()
	{
		if(BGMon == true)
		{
			theControlPanelControlsInline.children[0].MusicPlayerStop();
		}
	}
	function OnPause()
	{
		SSaver = 0;
		if (BGMon == true & bgmpause == false)
		{
			theControlPanelControlsInline.children[0].MusicPlayerPause();
			bgmpause = true;
		}
	}
	function OnSkipBack()
	{
		SSaver = 0;
		if(currentMusicPlayerMode == "Continuous")
		{
			theControlPanelControlsInline.children[0].MusicPlayerRewind();
		}
		else if(currentMusicPlayerMode == "Playlist")
		{
			theControlPanelControlsInline.children[0].PlaylistREW();
		}
		else if(currentMusicPlayerMode == "Random")
		{
			theControlPanelControlsInline.children[0].MusicPlayerRandom();
		}
	}
	function OnSkipForward()
	{
		SSaver = 0;
		if(currentMusicPlayerMode == "Continuous")
		{
			theControlPanelControlsInline.children[0].MusicPlayerFastForward();
		}
		else if(currentMusicPlayerMode == "Playlist")
		{
			theControlPanelControlsInline.children[0].PlaylistFFW();
		}
		else if(currentMusicPlayerMode == "Random")
		{
			theControlPanelControlsInline.children[0].MusicPlayerRandom();
		}
	}
	function OnMenu()
	{
		SSaver = 0;
		StartControlPanel();
	}
	function OnReverse()
	{
		SSaver = 0;
		if (BGMon == true & bgmpause == false)
		{
			theControlPanelControlsInline.children[0].MusicPlayerVolumeDown();
			var a = Math.round(theControlPanelControlsInline.children[0].theBGMusicPlayer.volume * 100);
			var txt = ReadValue(18, "default", "Datas\\Langues\\"+lang+".ini");
			var aa = txt + " : " + a;
			SetStatusText(aa);
		}
	}
	function OnForward()
	{
		SSaver = 0;
		if (BGMon == true & bgmpause == false)
		{
			theControlPanelControlsInline.children[0].MusicPlayerVolumeUp();
			var a = Math.round(theControlPanelControlsInline.children[0].theBGMusicPlayer.volume * 100);
			var txt = ReadValue(18, "default", "Datas\\Langues\\"+lang+".ini");
			var aa = txt + " : " + a;
			SetStatusText(aa);
		}
	}
	function On1()
	{
		SSaver = 0;
		Action("MemoryX_2GAM","Bouton");
	}
	function On2()
	{
		SSaver = 0;
		Action("ShowHideClock_2GAM","Bouton");
	}
	function On3()
	{
		SSaver = 0;
		Action("AffTitre_2GAM","Bouton");
	}
	function On4()
	{
		SSaver = 0;
		Action("NextBackground_2GAM","Bouton");
	}
	function On5()
	{
		SSaver = tmpSaver + 1;
	}
	function On6()
	{
		SSaver = 0;
		Action("ChangeSkins_2GAM","Bouton");
	}
    }

    function OnActivate()
    {
		CurrentViewpoint = theSubMenu2Viewpoint;
		CurrentAltViewpoint = theSubMenu2AlternateViewpoint;
		previousControlType = theSubMenu2joy;
		MenuBoutons = true;
		EnableAmbientAudio();
            StartSubMenu2Level();
    }

    function OnArrival()
    {
		musicScroll = 0;
		musicSelect = 0;
		musicButton = 0;
		StartSubMenu2Level();
    }
    behavior
    {
		sleep 0.2;
		if ( GetDD == true & SetDD == true)
		{
			GetDD = false;
			StartSubMenu2Level();
		}
    }
}
////////////////////////////////////////////////////////////////////////////
function Options()
{
	var c = theSubMenu2.children[0].children[0];
	if(ConfigSysteme[19] == "Original")
		c.BackgroundPanel.url = "Pmu.xbx";
	else if(ConfigSysteme[19] == "Verre")
		c.BackgroundPanel.url = "Fond.xbx";

	var txt = ReadValue(86, "default", "Datas\\Langues\\"+lang+".ini");
	c.MU_text_refresh.children[0].geometry.text = txt;
	if (MatGen != "")
	{
		c.GenMat01.name = MatGen;
		c.GenMat02.name = MatGen;
		c.GenMat03.name = MatGen;
	}
	if (TexGen != "")
	{
		c.GenTex01.url = TexGen+".xbx";
		c.GenTex02.url = TexGen+".xbx";
		c.GenTex03.url = TexGen+".xbx";
	}
	c.Spinning_Support_r.visible = false;
	c.Spinning_Support.visible = false;
	c.Spinning_Support2.visible = false;
	c.Spinning_Support2_r.visible = false;
	c.Spinning_Support3.visible = false;
	c.Spinning_Support3_r.visible = false;

	if(ApparenceMenusDD02[1] == "oui")
	{
		c.Affcell.visible = true;
	}
	if(ApparenceMenusDD02[1] == "non")
	{
		c.Affcell.visible = false;
	}
	if(ApparenceMenusDD02[2] == "oui")
	{
		c.Group07.visible = true;
	}
	if(ApparenceMenusDD02[2] == "non")
	{
		c.Group07.visible = false;
	}
	if(ApparenceMenusDD02[3] == "oui")
	{
		c.Group06.visible = true;
	}
	if(ApparenceMenusDD02[3] == "non")
	{
		c.Group06.visible = false;
	}
	if(ApparenceMenusDD02[4] == "oui")
	{
		c.Group08.visible = true;
	}
	if(ApparenceMenusDD02[4] == "non")
	{
		c.Group08.visible = false;
	}
	if(ApparenceMenusDD02[5] == "oui")
	{
		c.actual_orb.visible = true;
	}
	if(ApparenceMenusDD02[5] == "non")
	{
		c.actual_orb.visible = false;
	}
	if(ApparenceMenusDD02[6] == "rien")
	{
		c.Pod_backing01.visible = false;
		c.Pod_backing02.visible = false;
		c.ConsoleIcon.visible = false;
		c.IconCube.visible = false;
	}
	if(ApparenceMenusDD02[6] == "xbox4")
	{
		c.Pod_backing01.visible = true;
		c.Pod_backing02.visible = false;
		c.ConsoleIcon.visible = false;
		c.IconCube.visible = false;
	}
	if(ApparenceMenusDD02[6] == "jbone")
	{
		c.Pod_backing01.visible = false;
		c.Pod_backing02.visible = true;
		c.ConsoleIcon.visible = false;
		c.IconCube.visible = false;
	}
	if(ApparenceMenusDD02[6] == "xbox4+jbone")
	{
		c.Pod_backing01.visible = true;
		c.Pod_backing02.visible = true;
		c.ConsoleIcon.visible = false;
		c.IconCube.visible = false;
	}
	if(ApparenceMenusDD02[6] == "icon")
	{
		c.Pod_backing01.visible = false;
		c.Pod_backing02.visible = false;
		c.ConsoleIcon.visible = false;
		c.IconCube.visible = true;
	}
	if(ApparenceMenusDD02[6] == "icon+jbone")
	{
		c.Pod_backing01.visible = false;
		c.Pod_backing02.visible = true;
		c.ConsoleIcon.visible = false;
		c.IconCube.visible = true;
	}
	if(ApparenceMenusDD02[9] == "oui")
	{
		if(ApparenceMenusDD02[10] == "oui")
		{
			c.Spinning_Support_r.visible = true;
		}
		else
		{
			c.Spinning_Support.visible = true;
		}
	}
	if(ApparenceMenusDD02[11] == "oui")
	{
		if(ApparenceMenusDD02[12] == "oui")
		{
			c.Spinning_Support2_r.visible = true;
			c.Spinning_Support3_r.visible = true;
		}
		else
		{
			c.Spinning_Support2.visible = true;
			c.Spinning_Support3.visible = true;
		}
	}
}
