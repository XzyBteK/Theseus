// Start Music SubMenu ////////////////////////////////////////////////

var musicSelect;
var musicButton;
var musicScroll;
var astrxbuttontext;

//DEF theConfig Config

function FillSubMenu2List()
{
	MenuDeb = 0;
	var c = theSubMenu2.children[0].children[0];
	if (AjDvd == true)
	{
		if( MenusDD[magicnumber + 1] == "Jeux")
		{
			c.head_text.geometry.text = ReadValue(78, "default", "Datas\\Langues\\"+lang+".ini");
			c.MusicType.text = ReadValue(78, "default", "Datas\\Langues\\"+lang+".ini");
		}
		else if( MenusDD[magicnumber + 1] == "Applications")
		{
			c.head_text.geometry.text = ReadValue(79, "default", "Datas\\Langues\\"+lang+".ini");
			c.MusicType.text = ReadValue(79, "default", "Datas\\Langues\\"+lang+".ini");
		}
		else if( MenusDD[magicnumber + 1] == "Emulateurs")
		{
			c.head_text.geometry.text = ReadValue(80, "default", "Datas\\Langues\\"+lang+".ini");
			c.MusicType.text = ReadValue(80, "default", "Datas\\Langues\\"+lang+".ini");
		}
		else if( MenusDD[magicnumber + 1] == "Dashboards")
		{
			c.head_text.geometry.text = ReadValue(81, "default", "Datas\\Langues\\"+lang+".ini");
			c.MusicType.text = ReadValue(81, "default", "Datas\\Langues\\"+lang+".ini");
		}
		else
		{
			c.head_text.geometry.text = MenusDD[magicnumber + 1];
			c.MusicType.text = MenusDD[magicnumber + 1];
		}
	}
	else
	{
		if( MenusDD[magicnumber] == "Jeux")
		{
			c.head_text.geometry.text = ReadValue(78, "default", "Datas\\Langues\\"+lang+".ini");
			c.MusicType.text = ReadValue(78, "default", "Datas\\Langues\\"+lang+".ini");
		}
		else if( MenusDD[magicnumber] == "Applications")
		{
			c.head_text.geometry.text = ReadValue(79, "default", "Datas\\Langues\\"+lang+".ini");
			c.MusicType.text = ReadValue(79, "default", "Datas\\Langues\\"+lang+".ini");
		}
		else if( MenusDD[magicnumber] == "Emulateurs")
		{
			c.head_text.geometry.text = ReadValue(80, "default", "Datas\\Langues\\"+lang+".ini");
			c.MusicType.text = ReadValue(80, "default", "Datas\\Langues\\"+lang+".ini");
		}
		else if( MenusDD[magicnumber] == "Dashboards")
		{
			c.head_text.geometry.text = ReadValue(81, "default", "Datas\\Langues\\"+lang+".ini");
			c.MusicType.text = ReadValue(81, "default", "Datas\\Langues\\"+lang+".ini");
		}
		else
		{
			c.head_text.geometry.text = MenusDD[magicnumber];
			c.MusicType.text = MenusDD[magicnumber];
		}
	}
	astrxbuttontext = new Array;
	for (var i = magicnumber-1; i > 0 ; i = i - 1)
	{
		MenuDeb=MenuDeb+TailleDD[i]/4;
	}
	for (var iii = MenuDeb; iii < MenuDeb+taille; iii = iii + 1)
	{
		var dossier = ScanneDD[iii*4];
		ScanneDD[iii*4] = "";
		var lgt = dossier.length();
		for(var nd = 0; nd < lgt; nd = nd +1)
		{
			if (nd == 0)
			{
				ScanneDD[iii*4] = dossier.substring(nd ,nd + 1);
				ScanneDD[iii*4] = ScanneDD[iii*4].toUpperCase();
			}
			else
			{
				ScanneDD[iii*4] = ScanneDD[iii*4] + dossier.substring(nd ,nd + 1);
			}
		}
		astrxbuttontext[iii-MenuDeb]=ScanneDD[iii*4];

	}
	astrxbuttontext = astrxbuttontext.sort();
	UpdateSubMenu2List();
}
function UpdateSubMenu2MetaData()
{
	var c = theSubMenu2.children[0].children[0];
	lng=astrxbuttontext[musicSelect].length();
	ind=astrxbuttontext[musicSelect].indexOf("Ê");
	if (ind < 1)
		ind = lng;

	nom=astrxbuttontext[musicSelect].substring(0,ind);
	dos=astrxbuttontext[musicSelect].substring(ind+1,lng);
	c.TrackNum.text = nom;
	if ( taille > 1 )
	{
		var txt = ReadValue(5, "default", "Datas\\Langues\\"+lang+".ini");
		c.MusicCountText.text = taille + " " + txt;
	}
	else
	{
		var txt = ReadValue(6, "default", "Datas\\Langues\\"+lang+".ini");
		c.MusicCountText.text = taille + " " + txt;
	}
}

function UpdateSubMenu2List()
{
    var c = theSubMenu2.children[0].children[0];

    for (var i = 0; i < 8; i = i + 1)
    {
        var nSoundtrack = musicScroll + i;

        if (nSoundtrack >= taille)
        {
            c.MenuButtons.children[i].visible = false;
        }
        else
        {
		var str = "";
		lng=astrxbuttontext[nSoundtrack].length();
		ind=astrxbuttontext[nSoundtrack].indexOf("Ê");
		if (ind < 1)
			ind = lng;

		nom=astrxbuttontext[nSoundtrack].substring(0,ind);
		dos=astrxbuttontext[nSoundtrack].substring(ind+1,lng);

            str = nom;

            c.MenuButtons.children[i].children[1].children[0].geometry.text = str;
            c.MenuButtons.children[i].visible = true;
            if (i == musicButton)
            {
				//hilite the scroll arrows
				if(i == 0)
					c.MU_morearrow_up.children[0].appearance.material.name = "HilightedType";
				else
					c.MU_morearrow_up.children[0].appearance.material.name = "NavType";

				if(i == 7)
					c.MU_morearrow_down.children[0].appearance.material.name = "HilightedType";
				else
					c.MU_morearrow_down.children[0].appearance.material.name = "NavType";

                c.MenuButtons.children[i].children[0].children[0].appearance.material.name = BOnMatGen;
		    c.MenuButtons.children[i].children[0].children[0].appearance.texture.url = BOnTexGen+".xbx";
                c.MenuButtons.children[i].children[1].children[0].appearance.name = "HilightedType";
		    c.IconCube.children[0].children[0].appearance.texture.url=dos+".tga";
            }
            else
            {
                c.MenuButtons.children[i].children[0].children[0].appearance.material.name = BOffMatGen;
		    c.MenuButtons.children[i].children[0].children[0].appearance.texture.url = BOffTexGen+".xbx";
                c.MenuButtons.children[i].children[1].children[0].appearance.name = "NavType";
            }
        }
    }

    c.MU_morearrow_down.visible = (taille - musicScroll > 8);
    c.MU_morearrow_up.visible = (musicScroll > 0);

    UpdateSubMenu2MetaData();
}

function StartSubMenu2Level()
{
	taille = TailleDD[magicnumber]/4;
	Options();
	FillSubMenu2List();
}

function LaunchItem()
{
	Action(astrxbuttontext[musicSelect],"Disque");
}
DEF theSubMenu2AlternateViewpoint Viewpoint
{
	fieldOfView 1.287000
	orientation 0.999900 0.001 0.001474 -1.00000
	position -47.840000 53.889999 -172.199997
	jump false
}

DEF theSubMenu2 Level
{
    archive "Music2.xip"

    children
    [
        Inline
        {
            url "Music2/default2.xap"

            function onLoad()
            {
		    var c = theSubMenu2.children[0].children[0];
		    musicScroll = 0;
                musicSelect = 0;
                musicButton = 0;
		    c.CdIcon.visible = false;
                StartSubMenu2Level();
            }
        }
    ]

    tunnel Transform
    {
        children
        [
            Shape
            {
                appearance Appearance { material MaxMaterial { name "Tubes" } }
                geometry Mesh { url "Music/Tunnel_01-FACES.xm" }
            }
        ]
    }

    path DEF theSubMenu2Viewpoint Viewpoint
    {
		fieldOfView 1.287000
		orientation 0.015660 0.999900 0.001474 -0.187700
		position -47.840000 53.889999 -172.199997
		jump false
    }

    control DEF theSubMenu2joy Joystick
    {
        function OnADown()
        {
		SSaver = 0;
		if(shift == "")
		{
      	      var c = theSubMenu2.children[0].children[0];
			c.MU_select_pod_HL.children[0].appearance.material.param = 1;
			PlaySoundA();
			LaunchItem();
		}
		if(shift == "Ê-")
		{
			if ( ConfigBoutonsMainMenu[8] != "0")
			Action(ConfigBoutonsMainMenu[8],"Bouton");
		}
		if(shift == "-Ê")
		{
			if ( ConfigBoutonsMainMenu[16] != "0")
			Action(ConfigBoutonsMainMenu[16],"Bouton");
		}
		if(shift == "ÊÊ")
		{
			if ( ConfigBoutonsMainMenu[24] != "0")
			Action(ConfigBoutonsMainMenu[24],"Bouton");
		}
        }

        function OnBDown()
        {
		SSaver = 0;
		if(shift == "")
		{
			var c = theSubMenu2.children[0].children[0];
			c.MU_back_pod_HL.children[0].appearance.material.param = 1;
			PlaySoundB();
			musicScroll = 0;
			musicSelect = 0;
			musicButton = 0;
			if( Launcher == "MainMenu")
				theMainMenu.GoTo();
			else if( Launcher == "MenuDD")
				GoToMenuDD();
			else if( Launcher == "MenuConfig")
				GoToSettings();
		}
		if(shift == "Ê-")
		{
			if ( ConfigBoutonsMainMenu[9] != "0")
			Action(ConfigBoutonsMainMenu[9],"Bouton");
		}
		if(shift == "-Ê")
		{
			if ( ConfigBoutonsMainMenu[17] != "0")
			Action(ConfigBoutonsMainMenu[17],"Bouton");
		}
		if(shift == "ÊÊ")
		{
			if ( ConfigBoutonsMainMenu[25] != "0")
			Action(ConfigBoutonsMainMenu[25],"Bouton");
		}
	}
	function OnXDown()
	{
		SSaver = 0;
		if(shift == "")
		{
			if ( ConfigBoutonsMainMenu[2] != "0")
			Action(ConfigBoutonsMainMenu[2],"Bouton");
		}
		if(shift == "Ê-")
		{
			if ( ConfigBoutonsMainMenu[10] != "0")
			Action(ConfigBoutonsMainMenu[10],"Bouton");
		}
		if(shift == "-Ê")
		{
			if ( ConfigBoutonsMainMenu[18] != "0")
			Action(ConfigBoutonsMainMenu[18],"Bouton");
		}
		if(shift == "ÊÊ")
		{
			if ( ConfigBoutonsMainMenu[26] != "0")
			Action(ConfigBoutonsMainMenu[26],"Bouton");
		}
	}
	function OnYDown()
	{
		SSaver = 0;
		if(shift == "")
		{
			theSubMenu2.children[0].children[0].MU_refresh_pod_HL.children[0].appearance.material.param = 1;
			PlaySoundA();
			DDStart = 0;
			SetDD = false;
			GetDD = true;
		}
		if(shift == "Ê-")
		{
			if ( ConfigBoutonsMainMenu[11] != "0")
			Action(ConfigBoutonsMainMenu[11],"Bouton");
		}
		if(shift == "-Ê")
		{
			if ( ConfigBoutonsMainMenu[19] != "0")
			Action(ConfigBoutonsMainMenu[19],"Bouton");
		}
		if(shift == "ÊÊ")
