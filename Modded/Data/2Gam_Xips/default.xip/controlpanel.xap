		theControlPanelInline.children[0].theDropDown2Text.children[9].children[0].appearance.material.name = "CellEgg/Partsz";
		theControlPanelInline.children[0].theDropDown2Text.children[9].SetScale(1, 1.3, 1);
	}

}
DEF thePlaylistJoy Joystick
{
	function OnADown()
	{
		SSaver = 0;
		if(LeftTrigger == false  & RightTrigger == false)
		{
			if(PlaylistActive)
			{
				if(PlaylistTitleMenu)
				{
					if(ccurMenuItem == 0)
					{
						var b = "";
						if (PlaylistTotal+1 < 10)
							b = "Playlist0"+(PlaylistTotal+1);
						else
							b = "Playlist"+(PlaylistTotal+1);

						theControlPanelInline.children[0].theControlPanelDisplay.visible = false;
						theControlPanelInline.children[0].theDropDownPanels.visible = false;
						var txt = ReadValue(85, "default", "Datas\\Langues\\"+lang+".ini");
						ShowKeyboard(txt, b, "theControlPanelControlsInline.children[0].AddPlaylist(strKeyboardEdit)", "theControlPanelControlsInline.children[0].ExitRename()");
					}
					else
					{
						PlaylistNumber = ccurMenuItem - 1;
						ShowPlaylistSongMenu(PlaylistNumber);
					}
				}
				else if(PlaylistSongMenu)
				{
					PlayPlaylistSong(ccurMenuItem);
				}
			}
			else if(SoundtrackActive)
			{
				if(SoundtrackTitleMenu)
				{
					ShowSoundtrackSongMenu();
				}
				else if(SoundtrackSongMenu)
				{
					PlaySoundtrackSong();
				}
			}
		}
		if(LeftTrigger == true  & RightTrigger == false)
		{
			if ( ConfigBoutonsMainMenu[8] == "Photo_2GAM")
			Action(ConfigBoutonsMainMenu[8],"Bouton");
		}
		if(LeftTrigger == false  & RightTrigger == true)
		{
			if ( ConfigBoutonsMainMenu[16] == "Photo_2GAM")
			Action(ConfigBoutonsMainMenu[16],"Bouton");
		}
		if(LeftTrigger == true  & RightTrigger == true)
		{
			if ( ConfigBoutonsMainMenu[24] == "Photo_2GAM")
			Action(ConfigBoutonsMainMenu[24],"Bouton");
		}
	}
	function OnBDown()
	{
		SSaver = 0;
		if(LeftTrigger == false  & RightTrigger == false)
		{
			if(PlaylistActive)
			{
				if(PlaylistTitleMenu)
