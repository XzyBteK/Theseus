function testpanel1()
{
	if( Panel == CurrentPanelBack1 | Panel == 0)
	{
		loadpanel1();
	}
	else if( Panel == curentbackground & ApparenceMainMenu[23] == "non")
	{
		Panel = Panel + 1;
		if( Panel > NbBackground)
			Panel = 1;
	}
	PanelBack1 = "xboxbg"+Panel+".xbx";
	CurrentPanelBack1 = Panel;
}

