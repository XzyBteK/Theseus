function InitializeControlPanel()
{
	GeneraleMT("controlpanel");
	CurrentIcon = 2;
	theControlPanelLayer.visible = true;
	theInLine = theControlPanelInline.children[0];
	theInLine.theControlPanelDisplay.fade = 1;
	theInLine.theControlPanelDisplay.SetAlpha(0);
	ShowControlPanel();
	InitDropDown1();
	InitDropDown2();
	HideDropDown1();
	HideDropDown2();
	DropDown1On = false;
	DropDown2On = false;
	GetMode();
	UpdateModeText();
	GetPlaylists();
}

function ShowControlPanel()
{
	PanelBack1 = "";
	PanelBack2 = "";
	PanelBack3 = "";
	Options();
	theInLine.theControlPanelDisplay.fade = 1;
	theControlPanelLayer.transparency = 0.75;
	ControlPanelOut = true;
	thePlayerPanelIn.Play();
	currentControlType = theMainControlPanelJoy;
	bInMusicPlayerMode = true;
	theMainControlPanelJoy.isBound = true;
	theInLine.theControlPanelDisplay.SetTranslation(10,-39,1);
	theInLine.theControlPanelDisplay.SetRotation(-1,0,0,0.8);
	theInLine.theControlPanelDisplay.SetAlpha(1);
	UpdateMainIconHilite();
	UpdateMusicPlayerDisplayText();
	theInLine.theSongNameText_Title.text = ReadValue(10, "default", "Datas\\Langues\\"+lang+".ini");
}

function HideControlPanel()
{
	thePlayerPanelOut.Play();
	ControlPanelOut = false;
	theInLine.theControlPanelDisplay.fade = 1;
	theControlPanelLayer.transparency = 1;
	theMainControlPanelJoy.isBound = false;
	currentControlType = "";
	previousControlType.isBound = true;
	bInMusicPlayerMode = false;
	theInLine.theControlPanelDisplay.SetTranslation(10,-250,-60);
	theInLine.theControlPanelDisplay.SetRotation(1.0,0,0,3.17);
	theInLine.theControlPanelDisplay.SetAlpha(0);
	DisableCurrentAlternateViewpoint();
	if(DropDown1On == true)
	{
		HideDropDown1();
	}
	if(DropDown2On == true)
	{
		HideDropDown2();
	}
}

DEF theMainControlPanelJoy Joystick
{
        function OnADown()
        {
		SSaver = 0;
		if(LeftTrigger == false  & RightTrigger == false)
		{
			if(CurrentIcon == 1)
			{
				if(currentMusicPlayerMode == "Continuous")
				{
					MusicPlayerRewind();
				}
				else if(currentMusicPlayerMode == "Playlist")
				{
					PlaylistREW();
				}
				else if(currentMusicPlayerMode == "Random")
				{
					MusicPlayerRandom();
				}
			}
			else if(CurrentIcon == 2)
			{
				MusicPlayerPlay(); 
			}
			else if(CurrentIcon == 3)
			{
				MusicPlayerStop();
			}
			else if(CurrentIcon == 4)
			{
				if(currentMusicPlayerMode == "Continuous")
				{
					MusicPlayerFastForward();
				}
				else if(currentMusicPlayerMode == "Playlist")
				{
					PlaylistFFWD();
				}
				else if(currentMusicPlayerMode == "Random")
				{
					MusicPlayerRandom();
				}
			}
			else if(CurrentIcon == 5)
			{
				currentMusicPlayerMode = "Repeat";
				bgPlayerRepeat = true;
				bgPlayerRandom = false;
				UpdateModeText();
			}
			else if(CurrentIcon == 6)
			{
				currentMusicPlayerMode = "Random";
				bgPlayerRandom = true;
				bgPlayerRepeat = false;
				UpdateModeText();
				SaveMode();
			}
			else if(CurrentIcon == 7)
			{
				currentMusicPlayerMode = "Continuous";
				bgPlayerRandom = false;
				bgPlayerRepeat = false;
				UpdateModeText();
				SaveMode();
			}
		}
		if(LeftTrigger == true  & RightTrigger == false)
		{
			if ( ConfigBoutonsMainMenu[8] != "0")
			Action(ConfigBoutonsMainMenu[8],"Bouton");
		}
		if(LeftTrigger == false  & RightTrigger == true)
		{
			if ( ConfigBoutonsMainMenu[16] != "0")
			Action(ConfigBoutonsMainMenu[16],"Bouton");
		}
		if(LeftTrigger == true  & RightTrigger == true)
		{
			if ( ConfigBoutonsMainMenu[24] != "0")
			Action(ConfigBoutonsMainMenu[24],"Bouton");
		}
        }

