function UpdateMainIconHilite()
{
//	theInLine.controlpanel_inscreen.fade = 0.3;
	theInLine.theLeftSideText.fade = 0.3;
	HideIconsHilite();
	if( Version == "2.4B" | Version == "2.41B" | Version == "3.0B")
	{
		if(CurrentIcon == 1)
		{
			theInLine.controlpanel_icon_01_hilite.SetAlpha(0);
			theInLine.controlpanel_icon_01.SetAlpha(1);
		}
		else if(CurrentIcon == 2)
		{
			theInLine.controlpanel_icon_02_hilite.SetAlpha(0);
			theInLine.controlpanel_icon_02.SetAlpha(1);
		}
		else if(CurrentIcon == 3)
		{
			theInLine.controlpanel_icon_03_hilite.SetAlpha(0);
			theInLine.controlpanel_icon_03.SetAlpha(1);
		}
		else if(CurrentIcon == 4)
		{
			theInLine.controlpanel_icon_04_hilite.SetAlpha(0);
			theInLine.controlpanel_icon_04.SetAlpha(1);
		}
		else if(CurrentIcon == 5)
		{
			theInLine.controlpanel_icon_05_hilite.SetAlpha(0);
			theInLine.controlpanel_icon_05.SetAlpha(1);
		}
		else if(CurrentIcon == 6)
		{
			theInLine.controlpanel_icon_06_hilite.SetAlpha(0);
			theInLine.controlpanel_icon_06.SetAlpha(1);
		}
		else if(CurrentIcon == 7)
		{
			theInLine.controlpanel_icon_07_hilite.SetAlpha(0);
			theInLine.controlpanel_icon_07.SetAlpha(1);
		}
	}
	else
	{
		if(CurrentIcon == 1)
		{
			theInLine.controlpanel_icon_012_hilite.SetAlpha(0);
			theInLine.controlpanel_icon_012.SetAlpha(1);
		}
		else if(CurrentIcon == 2)
		{
			theInLine.controlpanel_icon_022_hilite.SetAlpha(0);
			theInLine.controlpanel_icon_022.SetAlpha(1);
		}
		else if(CurrentIcon == 3)
		{
			theInLine.controlpanel_icon_032_hilite.SetAlpha(0);
			theInLine.controlpanel_icon_032.SetAlpha(1);
		}
		else if(CurrentIcon == 4)
		{
			theInLine.controlpanel_icon_042_hilite.SetAlpha(0);
			theInLine.controlpanel_icon_042.SetAlpha(1);
		}
		else if(CurrentIcon == 5)
		{
			theInLine.controlpanel_icon_052_hilite.SetAlpha(0);
			theInLine.controlpanel_icon_052.SetAlpha(1);
		}
		else if(CurrentIcon == 6)
		{
			theInLine.controlpanel_icon_062_hilite.SetAlpha(0);
			theInLine.controlpanel_icon_062.SetAlpha(1);
		}
		else if(CurrentIcon == 7)
		{
			theInLine.controlpanel_icon_072_hilite.SetAlpha(0);
			theInLine.controlpanel_icon_072.SetAlpha(1);
		}
	}
}

