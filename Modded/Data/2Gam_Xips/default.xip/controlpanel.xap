      function OnMoveUp()
      {
		SSaver = 0;
	    if(RightTrigger)
	    {
		MusicPlayerVolumeUp();
	    }
      }

      function OnMoveDown()
      {
		SSaver = 0;
	    if(RightTrigger)
	    {
		MusicPlayerVolumeDown();
	    }
      }
	
	function OnMoveLeft()
	{
		SSaver = 0;
		if(RightTrigger == true)
		{
			CPWidth = CPWidth - 0.01;
			UpdateCPSize();
		}
		else
		{
		if(CurrentIcon == 1)
		{
			return;
		}
		else
		{
			PlaySoundMenuChange();
			CurrentIcon = CurrentIcon - 1;
		}
		UpdateMainIconHilite();
		}
	}
	
	function OnMoveRight()
	{
		SSaver = 0;
		if(RightTrigger == true)
		{
			CPWidth = CPWidth + 0.01;
			UpdateCPSize();
		}
		else
		{
		if(CurrentIcon == 7)
		{
			return;
		}
		else
		{
			PlaySoundMenuChange();
			CurrentIcon = CurrentIcon + 1;
		}
		UpdateMainIconHilite();
		}
	}

