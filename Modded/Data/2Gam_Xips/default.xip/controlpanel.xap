				{
					PlaylistSongMenu = false;
					PlaylistTitleMenu = true;
					bcurMenuItem = 0;
					ccurMenuItem = 0;
					dcurMenuItem = 0;
					UpdatePlaylistTitleMenu();
				}
			}
			else if(SoundtrackActive)
			{
				if(SoundtrackTitleMenu)
				{
					return;
