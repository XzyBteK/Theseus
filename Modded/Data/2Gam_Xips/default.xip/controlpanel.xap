}
function incrementBGMtext()
{
	var s = theBGMusicPlayer.getMinutes()*60;
	s = s + theBGMusicPlayer.getSeconds();
	if(BGMalwayson == false)
	{
		if (affsound == 0)
		{
			var c = thePanel.children[0].children[0];
			c.theNowPlaying_text.text = "";
			c.theNowPlaying_text2.text = "";
			c.theNowPlaying_text3.text = "";
			theSSaverPanel.children[0].children[0].info.text = "";
			AffSelect = true;
		}
		if (s > (BGMDisplay + BGMtimetodisplay))
		{
			var c = thePanel.children[0].children[0];
			c.theNowPlaying_text.text = "";
			c.theNowPlaying_text2.text = "";
			c.theNowPlaying_text3.text = "";
			theSSaverPanel.children[0].children[0].info.text = "";
			affsound = 0;
			AffSelect = true;
		}
		if (affsound == 1)
		{
			setBGMtext();
		}
	}
	if(BGMalwayson == true)
	{
		setBGMtext();
	}
}
function setBGMtext()
{
	if (theBGMusicCollection.GetSoundtrackCount() < 1)
		BGMon = false;

	if (BGMon == false & bgmpause == false)
	{
		vCurAlbum = "";
		vCurSong = "";
		vTtSong = "00:00";
	}
	else
	{
		vCurAlbum = theBGMusicCollection.GetSoundtrackName(BGMst);
		vCurSong = theBGMusicCollection.GetSoundtrackSongName(BGMst, BGMtr);
		vTtSong = theBGMusicCollection.FormatSoundtrackSongTime(BGMst, BGMtr);
	}
	var c = thePanel.children[0].children[0];
	var secs;
	var mins;
	mins = theBGMusicPlayer.getMinutes();
	if (theBGMusicPlayer.getSeconds() < 10)
	{
		secs = "0" + theBGMusicPlayer.getSeconds();
	}
	else
	{
		secs = theBGMusicPlayer.getSeconds();
	}
	var affalb = "";
	var afftit = "";
	var affdur = "";
	if (ConfigMusic[4] == "oui")
	{
		affalb = vCurAlbum;
	}
	if (ConfigMusic[5] == "oui")
	{
		afftit = vCurSong;
	}
	if (ConfigMusic[6] == "oui")
	{
		if (bgmpause == true)
			affdur = "Pause";
		else
			affdur = mins + ":" + secs + "/" + vTtSong;
	}
	if (affsound == 1 & BGMon == true)
	{
		c.theNowPlaying_text.text = affalb;
		c.theNowPlaying_text2.text = afftit;
		c.theNowPlaying_text3.text = affdur;
		AffSelect = true;
		if (SSaverVisu == false)
			theSSaverPanel.children[0].children[0].info.text = affalb + " - " + afftit + " - " + affdur;
	}
	else if (affsound == 0)
	{
		c.theNowPlaying_text.text = "";
		c.theNowPlaying_text2.text = "";
		c.theNowPlaying_text3.text = "";
		theSSaverPanel.children[0].children[0].info.text = "";
		AffSelect = true;
	}
	if (ApparenceMainMenu[14] == "oui")
	{
		theMainMenu.children[0].children[0].Main_pod_backing03.SetAlpha(1);
	}
	theMainMenu.children[0].children[0].Main_pod_backing03.children[0].appearance.texture = audioVisualizer;
	AudiovizuBack.children[0].appearance.texture = audioVisualizer2;
	if (ConfigSysteme[20] == "oui")
		AudiovizuBack.visible = true;
	else
		AudiovizuBack.visible = false;

	if (SSaverVisu == false)
		theSSaverPanel.children[0].children[0].AudioVizu.children[0].appearance.texture = audioVisualizer;
}
function setBGMdisplay()
{
	setBGMtext();
	if(BGMalwayson == false)
	{
		BGMDisplay = theBGMusicPlayer.getMinutes()*60;
		BGMDisplay = BGMDisplay + theBGMusicPlayer.getSeconds();
	}
}
function GetMode()
{
	if (currentMusicPlayerMode == "")
	{
		var info = new Settings;
		info.file = pathdash+"Playlists\\PlaylistInfo.xbx";
		currentMusicPlayerMode = info.GetValue("Music Play Mode");
		theBGMusicPlayer.volume = info.GetValue("Music Play Volume");
	}
}

function ChangeMode()
{
	if(currentMusicPlayerMode == "Continuous")
	{
		currentMusicPlayerMode = "Playlist";
		PlayPlaylistSong(0);
	}
	else if(currentMusicPlayerMode == "Playlist")
	{
		currentMusicPlayerMode = "Random";
		MusicPlayerRandom();
	}
	else if(currentMusicPlayerMode == "Random")
	{
		currentMusicPlayerMode = "Continuous";
	}
	SaveMode();
	UpdateModeText();
}

function SaveMode()
{
	var info = new Settings;
	info.file = pathdash+"Playlists\\PlaylistInfo.xbx";
	info.SetValue("Music Play Mode", currentMusicPlayerMode);
	info.SetValue("Music Play Volume", theBGMusicPlayer.volume);
}

function UpdateModeText()
{
	if (ControlPanelOut == true)
	{
		theInLine.theModeNameText.text = currentMusicPlayerMode;
	}
}

function UpdateTrackTime()
{
	incrementBGMtext();
    var m = theBGMusicPlayer.getMinutes();
    if (m < 10)
        m = "0" + m;
    var s = theBGMusicPlayer.getSeconds();
    if (s < 10)
        s = "0" + s;
	if (bgmpause == true)
	{
		theInLine.theTrackTimeText.text = "Pause";
	}
	else
	{
		if (BGMon == false & bgmpause == false)
		{
			vTtSong = "00:00";
		}
		else
		{
    			theInLine.theTrackTimeText.text = m + ":" + s + "/" + vTtSong;
		}
	}
}

function MusicPlayerVolumeUp()
{
	if(theBGMusicPlayer.volume >= 0.99)
	{
		theBGMusicPlayer.volume = 1.0;
	}
	else
	{
		theBGMusicPlayer.volume = theBGMusicPlayer.volume + 0.01;
	}
	UpdateVolumeOnScreen();
}

function MusicPlayerVolumeDown()
{
	if(theBGMusicPlayer.volume <= 0.01)
	{
		theBGMusicPlayer.volume = 0.01;
	}
	else
	{
		theBGMusicPlayer.volume = theBGMusicPlayer.volume - 0.01;
	}
	UpdateVolumeOnScreen();
}

function MusicPlayerStart()
{
	InitializeMusicPlayerValues();
	DisableAmbientAudio();
	if(currentMusicPlayerMode == "Random")
	{
		MusicPlayerRandom();
	}
	else if(currentMusicPlayerMode == "Playlist")
	{
		if(PlaylistTotal == 0)
		{
			MusicPlayerRandom();
		}
		else
		{
			GetPlaylistSongs(0);
			PlayPlaylistSong(0);
		}
	}
	else if(currentMusicPlayerMode == "Continuous")
	{
		PlaySong(0,0);
	}
	else
	{
		MusicPlayerRandom();
	}
}

function InitializeMusicPlayerValues()
{
	beInCDPlayer = false;
	beInSoundtracks = false;
	beInPlaylists = false;
	PlaylistActive = false;
	SoundtrackActive = false;
	SoundtrackTitleMenu = false;
	SoundtrackSongMenu = false;
	PlaylistNumber = 0;
	acurMenuItem = 0;
	BGMst = 0;
	BGMtr = 0;
	vTtSong = 0;
	GetPlaylists();
	GetMode();
	setBGMdisplay();
}

function MusicPlayerPause()
{
	if (bgmpause == false)
	{
		thePanel.children[0].children[0].theNowPlaying_text3.text = "Pause";
		theBGMusicPlayer.Pause();
		vCurSongTmp = BGMst;
		vCurAlbumTmp = BGMtr;
	}
	else if (bgmpause == true)
	{
		setBGMdisplay();
		UpdateMusicPlayerDisplayText();
		theBGMusicPlayer.Pause();
		bgmpause = false;
	}
}

function MusicPlayerStop()
{
	BGMon = false;
	EnableAmbientAudio();
	theInLine.theTrackTimeText.text = "00:00";
	theBGMusicPlayer.Stop();
	thePanel.children[0].children[0].theNowPlaying_text.text = "";
	thePanel.children[0].children[0].theNowPlaying_text2.text = "";
	thePanel.children[0].children[0].theNowPlaying_text3.text = "";
	bgmpause = false;
	affsound = 0;
	AffSelect = true;
}

function PlaySong(x,y)
{
	if (SSaverVisu == true)
	{
		nCurPlayerMenuItem = 2;
		theMusicInline.children[0].HandlePlayerMenu();
		theMusicInline.children[0].theMusicPlayer.Stop();
	}
	BGMst = x;
	BGMtr = y;
	DisableAmbientAudio();
	currentMusicPlayerMode = "Continuous";
	if (bgmpause == true & BGMst == vCurSongTmp & BGMtr == vCurAlbumTmp)
	{
		theBGMusicPlayer.Pause();
	}
	else
	{		
		theBGMusicPlayer.Stop();
		theBGMusicPlayer.url = "st:" + theBGMusicCollection.GetSoundtrackSongID(BGMst, BGMtr);
		theBGMusicPlayer.Play();
		vCurAlbum = theBGMusicCollection.GetSoundtrackName(BGMst);
		vCurSong = theBGMusicCollection.GetSoundtrackSongName(BGMst, BGMtr);
		vTtSong = theBGMusicCollection.FormatSoundtrackSongTime(BGMst, BGMtr);
	}
	SSaverVisu = false;
	bgmpause = false;
	SaveMode();
	affsound = 1;
	setBGMdisplay();
	UpdateMusicPlayerDisplayText();
}

function MusicPlayerPlay()
{
	if (SSaverVisu == true)
	{
		nCurPlayerMenuItem = 2;
		theMusicInline.children[0].HandlePlayerMenu();
		theMusicInline.children[0].theMusicPlayer.Stop();
	}
	BGMon = true;
	DisableAmbientAudio();
	if (bgmpause == true & BGMst == vCurSongTmp & BGMtr == vCurAlbumTmp)
	{
		theBGMusicPlayer.Pause();
	}
	else
	{
		theBGMusicPlayer.Stop();
		theBGMusicPlayer.url = "st:" + theBGMusicCollection.GetSoundtrackSongID(BGMst, BGMtr);
		theBGMusicPlayer.Play();
		vCurAlbum = theBGMusicCollection.GetSoundtrackName(BGMst);
		vCurSong = theBGMusicCollection.GetSoundtrackSongName(BGMst, BGMtr);
		vTtSong = theBGMusicCollection.FormatSoundtrackSongTime(BGMst, BGMtr);
	}
	SSaverVisu = false;
	bgmpause = false;
	affsound = 1;
	setBGMdisplay();
	UpdateMusicPlayerDisplayText();
}

function MusicPlayerRandom()
{
	currentMusicPlayerMode = "Random";
	DisableAmbientAudio();//todo - make it not needed
	BGMCount = theBGMusicCollection.GetSoundtrackCount() - 1;
	var a = Math.random() * BGMCount;
	BGMst = Math.round(a);
	BGMTracks = theBGMusicCollection.GetSoundtrackSongCount(BGMst) - 1;
	var b = Math.random() * BGMTracks;
	BGMtr = Math.round(b);
	MusicPlayerPlay();
}

function MusicPlayerRewind()
{
	BGMTracks = theBGMusicCollection.GetSoundtrackSongCount(BGMst) - 1;
	if(BGMtr == 0)
	{
		BGMtr = BGMTracks;
		MusicPlayerPlay();
	}
	else
	{
		BGMtr = BGMtr - 1;
		MusicPlayerPlay();
	}
}

function MusicPlayerFastForward()
{
	BGMTracks = theBGMusicCollection.GetSoundtrackSongCount(BGMst) - 1;
	if(BGMtr == BGMTracks)
	{
		BGMtr = 0;
		MusicPlayerPlay();
	}
	else
	{
		BGMtr = BGMtr + 1;
		MusicPlayerPlay();
	}
}

function InitDropDown2()
{
	theInLine.DropDownMenu2.visible = true;
	DropDown2On = true;
	ShowDropDown2();
}

function InitDropDown1()
{
	theInLine.DropDownMenu1.visible = true;
	DropDown1On = true;
	ShowDropDown1();
}

