DEF theBGMusicCollection MusicCollection
DEF theBGMusicPlayer AudioClip
{
    url "st:"
	volume 1.0

    function OnTrackChanged()
    {
		UpdateMusicPlayerDisplayText();
    }

    function OnEndOfAudio()
    {
	  if(currentMusicPlayerMode == "Playlist")
	  {
		PlaylistFFWD();
	  }
	  else if(currentMusicPlayerMode == "Continuous")
	  {
		SoundtrackFFW();
	  }
	  else if(currentMusicPlayerMode == "Random")
	  {
		MusicPlayerRandom();
	  }
	  else if(currentMusicPlayerMode == "Repeat")
	  {
		MusicPlayerRepeat();
	  }
    }
}
DEF audioVisualizer DynamicTexture
{
	palette Palette { type 7 changePeriod 3 } 
	size 400 
