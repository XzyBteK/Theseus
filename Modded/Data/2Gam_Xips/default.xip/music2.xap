function DoMusicPlayPause()
{
    if (playlist.length == 0)
    {
        PlaySoundError();
        return;
    }

    if (theMusicPlayer.transportMode == 0) // stopped
    {
	if (BGMon == true)
		theControlPanelControlsInline.children[0].MusicPlayerPause();

        PlayCurrentSong();
	SSaverVisu = true;
	bgmpause = true;
	theSSaverPanel.children[0].children[0].AudioVizu.children[0].appearance.texture = audioVisualizer;
    }
    else
	{
        theMusicPlayer.Pause();
	}
}

function DoMusicStop()
{
    theMusicPlayer.Stop();
    theMusicPlayer.url = "";
	SSaverVisu = false;
	if (BGMon == true & bgmpause == true)
		theControlPanelControlsInline.children[0].MusicPlayerPause();

}

function SelectNextTrack(bPlaySong)
{
    if (playlist.length == 0)
    {
        PlaySoundError();
        return;
    }

    log("bPlayerRepeat - " + bPlayerRepeat );
    log("nPlayCursor   - " + nPlayCursor );

    // If we're on the bottom of the list, and we press the right trigger
    // check to see if we're in repeat mode.  If so, wrap the list
    if( bPlayerRepeat == false )
    {
        if( nPlayCursor == ( playlist.length - 1 ) )
        {
            return;
        }
    }

    if( theMusicPlayer.transportMode == 2 ) // paused
        theMusicPlayer.Stop();

    if (nPlayCursor < 0)
        nPlayCursor = 0;

    nPlayCursor = nPlayCursor + 1;

    if (nPlayCursor >= playlist.length)
        nPlayCursor = 0;

    UpdateTrackList();

    if (bPlaySong)
    {
        if (theMusicPlayer.transportMode == 1) // playing
        {
            theMusicPlayer.Stop();
            PlayCurrentSong();
        }
    }
}

function SelectPrevTrack(bCheckTime, bPlaySong)
{
    if (playlist.length == 0)
    {
        PlaySoundError();
        return;
    }

    if (bCheckTime)
    {
        var t = theMusicPlayer.getMinutes() * 60 + theMusicPlayer.getSeconds();

        if (theMusicPlayer.transportMode == 1) // playing
        {
            // If we are more than a second into a song, just start it over...
            if (t > 1)
            {
                if( bPlaySong )
                {
                    theMusicPlayer.Stop();
                    PlayCurrentSong();
                }
                return;
            }
        }
        else if (theMusicPlayer.transportMode == 2) // paused
        {
            theMusicPlayer.Stop();

            // If we are more than a second into a song, just Stop it and return...
            if (t > 1)
            {
                return;
            }
        }
    }
    else // If we are in paused mode, and the user didn't care about the time, we should stop
    {
        if (theMusicPlayer.transportMode == 2) // paused
        theMusicPlayer.Stop();
    }

    // If we're on the top of the list, and we press the
    if( bPlayerRepeat == false )
    {
        if( nPlayCursor <= 0 )
        {
            return;
        }
    }

    if (nPlayCursor > 0)
        nPlayCursor = nPlayCursor - 1;
    else
        nPlayCursor = playlist.length - 1;

    // Check to if we are currently playing the track (transport mode)
    // Check to see if we care about playing the track (bPlaySong)
    // If we care about playing the track, and we are currently playing, we should play the current song
    if (theMusicPlayer.transportMode == 1)
    {
        if (bPlaySong)
        {
            theMusicPlayer.Stop();
            PlayCurrentSong();
        }
    }

    UpdateTrackList();
}

function UpdateTrackList()
{
    var c = theMusicPlayMenu.children[0].children[0];
    var str = "";
    var strTrack = theTranslator.Translate("TRACK");

    if (bGoToCDPlayer)
    {
        musicSelect = 0;
        musicButton = 0;
        musicScroll = 0;
    }

    if (nPlayCursor < 0)
        nPlayScroll = 0;
    else if ( (nPlayCursor >= (nPlayVisible - 1)) & (nPreviousPlayCursor < nPlayCursor) & (nPlayCursor > (nPlayScroll + (nPlayVisible - 1)) ))
        nPlayScroll = nPlayCursor - (nPlayVisible - 1);
    else if (nPlayCursor < nPlayScroll)
	    nPlayScroll = nPlayCursor;

	nPreviousPlayCursor = nPlayCursor;

    var nTracks;
    var nSoundtrack = musicSelect - 1;
    if (nSoundtrack < 0)
        nTracks = theDiscDrive.getTrackCount();
    else
        nTracks = theMusicCollection.GetSoundtrackSongCount(nSoundtrack);

	// scrollbars
	if (nPlayScroll > 0)
		c.MU_morearrow_up.visible = true;
	else
		c.MU_morearrow_up.visible = false;

	if ((nPlayScroll + nPlayVisible) < nTracks)
		c.MU_morearrow_down.visible = true;
	else
		c.MU_morearrow_down.visible = false;


    // Hilite the first item when nothing is selected...
    var nHiliteItem = nPlayCursor;
    if (nHiliteItem == -1)
        nHiliteItem = 0;

    for (var i = 0; i < nPlayVisible; i = i + 1)
    {
        var n = nPlayScroll + i;
        if (n >= nTracks)
		{
			c.TrackNames.children[i].children[0].geometry.text = "";
			c.TrackNumbers.children[i].children[0].geometry.text = "";
            //break;
		}
		else
		{
			var nSong = playlist[n];

			var strHL = "";

			var strName, strTime;
			if (nSoundtrack < 0)
			{
				strName = strTrack + " " + (nSong + 1);
				strTime = theDiscDrive.FormatTrackTime(nSong);
			}
			else
			{
				strName = theMusicCollection.GetSoundtrackSongName(nSoundtrack, nSong);
				if (strName == "")
					strName = strTrack + " " + (i + 1);
				strTime = theMusicCollection.FormatSoundtrackSongTime(nSoundtrack, nSong);
			}

			strName = (nSong + 1) + ". " + strName;

			if (strMusicPlayerMode == "copy")
			{
				if (copyflag[n])
					strName = "\u00bb\u00a0" + strName;
				else
					strName = "\u00a0\u00a0\u00a0" + strName;
			}

			c.TrackNames.children[i].children[0].geometry.text = strName;
			c.TrackNumbers.children[i].children[0].geometry.text = strTime;

			if (n == nHiliteItem)
			{
				c.TrackNames.children[i].SetScale(0.13, 0.17, 0.13);
				c.TrackNumbers.children[i].SetScale(0.13, 0.17, 0.13);
				c.TrackNames.children[i].children[0].appearance.name = "CellEgg/Partsz";
				c.TrackNumbers.children[i].children[0].appearance.name = "CellEgg/Partsz";
			}
			else
			{
				c.TrackNames.children[i].SetScale(0.13, 0.13, 0.13);
				c.TrackNumbers.children[i].SetScale(0.13, 0.13, 0.13);
				c.TrackNames.children[i].children[0].appearance.name = "NavType";
				c.TrackNumbers.children[i].children[0].appearance.name = "NavType";
			}

			str = str + strHL + strName + strHL;
			str = str + "\t";
			str = str + strHL + strTime + strHL;
			str = str + "\r";
		}
	}

    if (nTracks == 1)
        c.TrackCountText.text = nTracks + " " + theTranslator.Translate("TRACK");
    else
        c.TrackCountText.text = nTracks + " " + theTranslator.Translate("TRACKS");
}

function UpdateTransportIndicators()
{
    var c = theMusicPlayMenu.children[0].children[0];

    c.MU_L3_panel_playicon.visible = false;
	c.MU_L3_icon_repeat.visible = false;
	c.MU_L3_text_random_0.visible = false;
	c.MU_L3_icon_stop_02.visible = false;
	c.MU_L3_icon_pause_0.visible = false;


    if (theMusicPlayer.transportMode == 0) // Stop
    {
        SetMusicPlayPos(0);
        c.MusicTimeText.visible = false;
        c.MusicTimeText.text = "00:00";

		//c.MU_L3_icon_stop_02.visible = true;

		// edit screen
		c.MU_L3_icon_play_01.visible = true;
		c.MU_L3_edit_icon_pause.visible = false;
		//copy screen
		c.MU_L3_icon_play_0.visible = true;
		c.MU_L3_copy_icon_pause.visible = false;
		//play screen
		c.MU_L3_icon_play.visible = true;
		c.MU_L3_play_icon_pause.visible = false;

    }
    else
    {
        c.MusicTimeText.visible = true;

        if (theMusicPlayer.transportMode == 1) // Play
        {
            c.MU_L3_panel_playicon.visible = true;

			// edit screen
			c.MU_L3_icon_play_01.visible = false;
			c.MU_L3_edit_icon_pause.visible = true;
			//copy screen
			c.MU_L3_icon_play_0.visible = false;
			c.MU_L3_copy_icon_pause.visible = true;
			//play screen
			c.MU_L3_icon_play.visible = false;
			c.MU_L3_play_icon_pause.visible = true;

        }
        else if (theMusicPlayer.transportMode == 2) // Pause
        {
            c.MU_L3_icon_pause_0.visible = true;

			// edit screen
			c.MU_L3_icon_play_01.visible = true;
			c.MU_L3_edit_icon_pause.visible = false;
			//copy screen
			c.MU_L3_icon_play_0.visible = true;
			c.MU_L3_copy_icon_pause.visible = false;
			//play screen
			c.MU_L3_icon_play.visible = true;
			c.MU_L3_play_icon_pause.visible = false;

        }
    }

	if (bPlayerRandom)
	{
		c.MU_L3_text_random_0.visible = true;
		currentMusicPlayerMode = "Random";
	}
    if (bPlayerRepeat)
	{
		c.MU_L3_icon_repeat.visible = true;
		currentMusicPlayerMode = "Repeat";
	}
}

