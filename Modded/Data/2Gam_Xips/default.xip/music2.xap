        function OnMoveLeft()
        {
		SSaver = 0;
            NoVisualizer();
            if (bMusicMenuVisible)
            {
            }
            else if (nCurPlayerMenuItem > 0)
            {
                if (theMusicPlayer.transportMode != 1) // playing
                    PlaySoundMenuChange();
                nCurPlayerMenuItem = nCurPlayerMenuItem - 1;
                UpdatePlayerMenu();
            }
        }

        function OnMoveRight()
        {
		SSaver = 0;
            NoVisualizer();
            if (bMusicMenuVisible)
            {
            }
            else if (nCurPlayerMenuItem < nPlayerMenuItemCount - 1)
            {
                if (theMusicPlayer.transportMode != 1) // playing
                    PlaySoundMenuChange();
                nCurPlayerMenuItem = nCurPlayerMenuItem + 1;
                UpdatePlayerMenu();
            }
        }

        function OnMoveUp()
        {
		SSaver = 0;
            NoVisualizer();
            if (bMusicMenuVisible)
            {
                if (nCurMusicMenuItem > 0)
                {
                    PlaySoundMenuChange();
                    nCurMusicMenuItem = nCurMusicMenuItem - 1;
                    UpdateMusicMenu();
                }
            }
            else
            {
                if (nPlayCursor > 0)
                {
                    if (theMusicPlayer.transportMode != 1) // playing
                        PlaySoundA();
                    SelectPrevTrack(false, true);
                }
            }
        }

        function OnMoveDown()
        {
		SSaver = 0;
            NoVisualizer();
            if (bMusicMenuVisible)
            {
                var nMenuItemCount = 5;

                if (musicSelect == 0)
                    nMenuItemCount = 2; // audio cd

                if (nCurMusicMenuItem < nMenuItemCount - 1)
                {
                    PlaySoundMenuChange();
                    nCurMusicMenuItem = nCurMusicMenuItem + 1;
                    UpdateMusicMenu();
                }
            }
            else
            {
                if (nPlayCursor < playlist.length - 1)
                {
                    if (theMusicPlayer.transportMode != 1) // playing
                        PlaySoundA();
                    SelectNextTrack(true);  // TODO: Remove below code
                    // DoMusicNextTrack();
                }
            }
        }

        function OnPlay()
        {
		SSaver = 0;
            NoVisualizer();
            if (bMusicMenuVisible)
                return;

            if (strMusicPlayerMode == "play")
            {
                var nCurPlayerMenuItemSave = nCurPlayerMenuItem;
                nCurPlayerMenuItem = 1;
                UpdatePlayerMenu();
                nCurPlayerMenuItem = nCurPlayerMenuItemSave;
            }

            if (theMusicPlayer.transportMode != 1) // playing
                PlaySoundA();

            DoMusicPlayPause();
        }

        function OnPause()
        {
		SSaver = 0;
            if (theMusicPlayer.transportMode != 0) // stopped
                theMusicPlayer.Pause();
        }

        function OnStop()
        {
		SSaver = 0;
            DoMusicStop();
        }

        function OnSkipForward()
        {
		SSaver = 0;
            SelectNextTrack(true);  // TODO: Remove below code
            //DoMusicNextTrack();
        }

        function OnSkipBack()
        {
		SSaver = 0;
            SelectPrevTrack(true, true);
        }
	function OnPower()
	{
			Action("ShutDown_2GAM","Bouton");
	}
	function OnMenu()
	{
		SSaver = 0;
		StartControlPanel();
	}
