	}
	function On4()
	{
		SSaver = 0;
		Action("NextBackground_2GAM","Bouton");
	}
	function On5()
	{
		SSaver = tmpSaver + 1;
	}
	function On6()
	{
		SSaver = 0;
		Action("ChangeSkins_2GAM","Bouton");
	}
    }

    function OnActivate()
    {
		CurrentViewpoint = theMusicMenuView;
		CurrentAltViewpoint = theMusicMenuAlternateView;
		previousControlType = theMusicMenuJoy;
        if (children[0].children.length() > 0)
            StartMusicLevel();
    }
}
function Options1()
