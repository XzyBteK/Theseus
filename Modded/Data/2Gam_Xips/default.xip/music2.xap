		Action("ChangeSkins_2GAM","Bouton");
	}
    }

    function OnActivate()
    {
	previousControlType = theMusicPlayJoystick;
	CurrentViewpoint = musicMenuViewpoint;
	CurrentAltViewpoint = theMusicPlayAlternateViewpoint;
        if (children[0].children.length() > 0)
        {
            EnterMusicPlay();
        }
    }

    function OnDeactivate()
    {
        DoMusicStop();
	  if(BGMon == false)
        	EnableAmbientAudio();

        g_bFullVis = false;
    }
}

