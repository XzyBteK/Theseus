    function OnActivate()
    {
	if (BGMon == false)
        EnableAmbientAudio();

        if (children[0].children.length() > 0)
            EnterCopyDestMenu();

	previousControlType = theMusicCopyJoy;
	CurrentViewpoint = theMusicCopyMenuView;
	CurrentAltViewpoint = theMusicCopyMenuAlternateView;
    }

    function OnDeactive()
    {
        if (g_bKeyboardDisplayed)
        {
            CloseKeyboard();
        }
    }
}

DEF theMusicPlayer AudioClip
{
    url "cd:"
    sendProgress true

    function OnProgressChanged()
    {
        if (bMusicPlayerReady)
        {
            SetMusicPlayPos(progress);
        }
    }

    function OnTransportModeChanged()
    {
        if (bMusicPlayerReady)
        {
            UpdateTransportIndicators();
        }
    }

    function OnTrackChanged()
    {
        if (bMusicPlayerReady)
            UpdateTrackList();
    }

    function OnEndOfAudio()
    {
        nPlayCursor = nPlayCursor + 1;
        if (nPlayCursor >= playlist.length)
        {
            if (bPlayerRepeat == false)
            {
                log("Finished playing all songs...");

                DoMusicStop();
                nPlayCursor = 0;
                UpdateTrackList();
                NoVisualizer();
                return;
            }

            nPlayCursor = 0;
            log("Played all songs; looping...");
        }

        PlayCurrentSong();
        UpdateTrackList();
    }
}

DEF audioVisualizer DynamicTexture
{
    palette Palette { type 7 changePeriod 3 }

    size 352
    erase false
    fps 60

    children
    [

        ImageFader { changePeriod 10 }
        StarField

        AudioVisualizer
        {
            source USE theMusicPlayer
            type "circle"
            scale 1.5
        }

        AudioVisualizer
        {
            source USE theMusicPlayer
            type "analyzer"
        }
    ]
}

function ShufflePlaylist()
{
    var oldID = playlist[nPlayCursor];

    var len = playlist.length;
    for (var i = 0; i < len; i = i + 1)
    {
        var j = Math.random() * (len - 1);

        var t = playlist[i];
        playlist[i] = playlist[j];
        playlist[j] = t;
    }

    for (i = 0; i < len; i = i + 1)
    {
        if (playlist[i] == oldID)
        {
            nPlayCursor = i;
            break;
        }
    }
}

function InitPlaylist()
{
    playlist = new Array;
    copyflag = new Array;
    nPlayCursor = 0;

    if (bGoToCDPlayer)
    {
        musicSelect = 0;
        musicButton = 0;
        musicScroll = 0;
    }

    if (musicSelect == 0)
    {
        // audio cd
        var nTracks = theDiscDrive.getTrackCount();
        for (var i = 0; i < nTracks; i = i + 1)
        {
            playlist[playlist.length] = i;
            copyflag[copyflag.length] = false;
        }
    }
    else
    {
        // soundtrack
        var nSoundtrack = musicSelect - 1;
        var nTracks = theMusicCollection.GetSoundtrackSongCount(nSoundtrack);
        for (var i = 0; i < nTracks; i = i + 1)
        {
            playlist[playlist.length] = i;
            copyflag[copyflag.length] = false;
        }
    }
}

function PlayCurrentSong()
{
    if (playlist.length == 0)
    {
        PlaySoundError();
        return;
    }

    if (musicSelect == 0)
    {
        theMusicPlayer.url = "cd:" + (playlist[nPlayCursor] + 1);
    }
    else
    {
        var nSoundtrack = musicSelect - 1;
        theMusicPlayer.url = "st:" + theMusicCollection.GetSoundtrackSongID(nSoundtrack, playlist[nPlayCursor]);
    }

    log("Playing " + theMusicPlayer.url);
    theMusicPlayer.Play();

    DisableAmbientAudio();
}

function SetMusicPlayPos(nPos)
{
    var album = " ";
    var titre = " ";
    var duree = " ";
    var nSong = 0;
    var nSoundtrack = 0;
    var nNewPos = nPos;     // There is a bug with the engine which prevents passed in vars from being changed
    if (nNewPos < 0)
        nNewPos = 0;
    else if (nNewPos > 1)
        nNewPos = 1;

    var x = -1.579 + ( 0.730 * nNewPos );   //   -1.528 /*-47.09*/ + 0.74 * nPos;
    var y = -0.6701;                        //   54.410000;
    var z =  0.1081;                        // -204.399994;
    theMusicPlayMenu.children[0].children[0].MU_L3_timeslider.SetTranslation(x, y, z);

    var m = theMusicPlayer.getMinutes();
    if (m < 10)
        m = "0" + m;
    var s = theMusicPlayer.getSeconds();
    if (s < 10)
        s = "0" + s;
    theMusicPlayMenu.children[0].children[0].MusicTimeText.text = m + ":" + s;

	var display = theMusicPlayer.getMinutes()*60;
	display = display + theMusicPlayer.getSeconds();
	if (CdPlayer == false)
	{
		nSong = playlist[nPlayCursor];
		nSoundtrack = musicSelect - 1;
		album = theMusicCollection.GetSoundtrackName(nSoundtrack);
		titre = theMusicCollection.GetSoundtrackSongName(nSoundtrack, nSong);
		duree = theMusicCollection.FormatSoundtrackSongTime(nSoundtrack, nSong);
	}
	if (CdPlayer == true)
	{
		nSong = playlist[nPlayCursor] + 1;
		album = strTitle;
		titre = strTrack + " " + nSong;
		duree = theDiscDrive.FormatTrackTime(nSong - 1);
	}
	var affd = m + ":" + s + "/" + duree;
	if ((BGMalwayson == true | BGMtimetodisplay > display) & SSaverVisu == true)
		theSSaverPanel.children[0].children[0].info.text = album + " - " + titre + " - " + affd;
	else	if (BGMalwayson == false & SSaverVisu == true)
		theSSaverPanel.children[0].children[0].info.text = "";
}

