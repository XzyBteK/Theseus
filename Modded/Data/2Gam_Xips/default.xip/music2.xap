function loadpanelmusic() 
{
	if (NbBackground == 0)
	{
		MusicBack = "rien";
		return;
	}
	if (NbBackground == 1)
	{
		MusicBack = "xboxbg1.xbx";
		return;
	}
	if (NbBackground == 2)
	{
		Panel = Math.round(Math.random() * 1) + 1;
	}
	if (NbBackground == 3)
	{
		Panel = Math.round(Math.random() * 2) + 1;
	}
	if (NbBackground == 4)
	{
		Panel = Math.round(Math.random() * 3) + 1;
	}
	if (NbBackground == 5)
	{
		Panel = Math.round(Math.random() * 4) + 1;
	}
	if (NbBackground == 6)
	{
		Panel = Math.round(Math.random() * 5) + 1;
	}
	if (NbBackground == 7)
	{
		Panel = Math.round(Math.random() * 6) + 1;
	}
	if (NbBackground == 8)
	{
		Panel = Math.round(Math.random() * 7) + 1;
	}
	if (NbBackground == 9)
	{
		Panel = Math.round(Math.random() * 8) + 1;
	}
	if (NbBackground == 10)
	{
		Panel = Math.round(Math.random() * 9) + 1;
	}
	testmusicpanel();
}
function testmusicpanel()
{
	if( Panel == CurrentMusicBack | Panel == 0)
	{
		loadpanelmusic();
	}
	else if( Panel == curentbackground & ApparenceMainMenu[23] == "non")
	{
		Panel = Panel + 1;
		if( Panel > NbBackground)
			Panel = 1;
	}
	MusicBack = "xboxbg"+Panel+".xbx";
	CurrentMusicBack = Panel;
}


