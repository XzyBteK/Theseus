DEF DaGoNspheremap Transform
    {
        scale 1500 1500 1500 
        translation 0 0 0
        children
        [
            DEF spheremapWav01 Waver
            {
     			rpm 1
     			axis 0 1 0
     			field 4
			children
			[
				Shape
				{
					appearance Appearance
					{
						material MaxMaterial
						{
							name "GameIcon_01"
						}
						texture DEF EnvMap ImageTexture
						{
							url ""
						}
					}
					geometry Mesh { url "DaGoN-spheremap.xm" }
				}
			]
		}
	]
}
