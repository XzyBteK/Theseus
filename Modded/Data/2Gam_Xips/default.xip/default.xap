{
    theConfig.XBOXPOWER();
}
function ConfReboot()
{
	var txt = ReadValue(8, "default", "Datas\\Langues\\"+lang+".ini");
	AskQuestion(txt, "Reboot()", "", 0);
}

function Reboot()
{
	theConfig.XBOXResetHard();
}
function Restart()
{
	launch(Systeme[1]+".xbe",ExePath);
}
function LanceAppli(disque, chemin, exe)
{
	exec = exe;
	var path2 = disque;
	if ( disque == "C:" )
	{
		path = "\\Device\\Harddisk0\\Partition2";
	}
	else if ( disque == "E:" )
	{
		path = "\\Device\\Harddisk0\\Partition1";
	}
	else if ( disque == "F:" )
	{
		path = "\\Device\\Harddisk0\\Partition6";
	}
	else if ( disque == "G:" )
	{
		path = "\\Device\\Harddisk0\\Partition7";
	}
	if ( chemin == "root" )
	{
		path = path + "";
	}
	else
	{
		path = path + "\\" + chemin + "";
		path2 = path2 + "\\" + chemin;
	}
	var FileExists = theConfig.NtFileExists( path2 + "\\" + exec );
	if ( FileExists == true )
	{
		if ( ConfigSysteme[2] == "oui" & sty == 1)
		{
			var txt = ReadValue(3, "default", "Datas\\Langues\\"+lang+".ini")+Applications[NumAppli]+"' ?";
			AskQuestion(txt, "Lance()", "", 0);
		}
		else
		{
			launch(exec,path);
		}
	}
	else if ( FileExists == false )
	{
		var c = thePanel.children[0].children[0];
		c.shift_text.text = "";
		shift = "";
		onleft = false;
		onright = false;
		var txt = ReadValue(4, "default", "Datas\\Langues\\"+lang+".ini");
		TellUser(txt,"");
	}
}
function Lance()
{
	launch(exec,path);
}
function AfficheShift()
{
	var c = thePanel.children[0].children[0];
	if( onleft == true & onright == false )
	{
		shift = "¤-";
	}
	if( onleft == false & onright == true )
	{
		shift = "-¤";
	}
	if( onleft == true & onright == true )
	{
		shift = "¤¤";
	}
	if( onleft == false & onright == false )
	{
		shift = "";
	}
	if( ConfigSysteme[8] == "oui")
	{
		c.shift_text.text = shift;
	}
	var w = thePanel.children[0].children[0];
}

function AffTitre()
{
	AffSelect = true;
	if( affsound == 1)
	{
		affsound = 0;
		BGMalwayson = false;
	}
	else if (affsound == 0 & (BGMon == true | SSaverVisu == true))
	{
		affsound = 1;
		BGMalwayson = true;
	}
	theControlPanelControlsInline.children[0].setBGMdisplay();
}
function AffInfos()
{
	var a = "";
	var b = 0;
	var langue = "";
	var videomode = "";
	var audiomode = "";
	CalculSpace();
	b = theConfig.GetLanguage();
	if( b == 1)
		langue = "English";
	if( b == 2)
		langue = "Portuguęs";
	if( b == 3)
		langue = "Deutsch";
	if( b == 4)
		langue = "Francais";
	if( b == 5)
		langue = "Espańol";
	if( b == 6)
		langue = "Italiano";

	b = theConfig.GetVideoMode();
	if( b == 0)
		videomode = theTranslator.Translate("NORMAL");
	if( b == 1)
		videomode = theTranslator.Translate("LETTERBOX");
	if( b == 2)
		videomode = theTranslator.Translate("WIDESCREEN");

	b = theConfig.GetAudioMode();
	if( b == 0)
		audiomode = theTranslator.Translate("MONO");
	if( b == 1)
		audiomode = theTranslator.Translate("STEREO");
	if( b == 2)
		audiomode = theTranslator.Translate("DOLBY SURROUND");

	var txt = "";
	txt = ReadValue(35, "default", "Datas\\Langues\\"+lang+".ini");
	a = "\n" + txt;
	txt = ReadValue(36, "default", "Datas\\Langues\\"+lang+".ini");
	a = a +"\r" + txt + " :" + langue;
	txt = ReadValue(52, "default", "Datas\\Langues\\"+lang+".ini");
	a = a +"\r" + txt + " :" + theConfig.GetXBOXVersion();  
	txt = ReadValue(53, "default", "Datas\\Langues\\"+lang+".ini");
	a = a +"\r" + txt + " :" + theConfig.GetENCODER();
	txt = ReadValue(37, "default", "Datas\\Langues\\"+lang+".ini");
	a = a +"\r" + txt + " :" + theConfig.GetROMVersion();
	a = a +"\rCPU :" + theConfig.GetCPUFrequence();
	txt = ReadValue(38, "default", "Datas\\Langues\\"+lang+".ini");
	a = a +"\r" + txt + " :" + theConfig.GetMODVersion();
	txt = ReadValue(39, "default", "Datas\\Langues\\"+lang+".ini");
	a = a +"\r" + txt + " :" + theConfig.GetGameRegion();
	txt = ReadValue(60, "default", "Datas\\Langues\\"+lang+".ini");
	a = a +"\r" + txt + " :" + theConfig.GetFanSpeed();
	txt = ReadValue(40, "default", "Datas\\Langues\\"+lang+".ini");
	a = a +"\r" + txt + " :" + NSkins[CurentSkin];
	txt = ReadValue(41, "default", "Datas\\Langues\\"+lang+".ini");
	a = a +"\n" + txt;
	txt = ReadValue(42, "default", "Datas\\Langues\\"+lang+".ini");
	a = a +"\r" + txt + " :" + AdresseIP;
	txt = ReadValue(43, "default", "Datas\\Langues\\"+lang+".ini");
	a = a +"\r" + txt + " :" + MasqueReseau;
	txt = ReadValue(44, "default", "Datas\\Langues\\"+lang+".ini");
	a = a +"\r" + txt + " :" + Passerelle;
	txt = ReadValue(45, "default", "Datas\\Langues\\"+lang+".ini");
	a = a +"\r" + txt + " :" + Utilisateur;
	txt = ReadValue(59, "default", "Datas\\Langues\\"+lang+".ini");
	a = a +"\r" + txt + " :" + theConfig.GetNETWORKSTATUS();
	txt = ReadValue(46, "default", "Datas\\Langues\\"+lang+".ini");
	a = a +"\n" + txt;
	txt = ReadValue(47, "default", "Datas\\Langues\\"+lang+".ini");
	a = a +"\r" + txt + " :" + theConfig.GetAVPackType();
	txt = ReadValue(48, "default", "Datas\\Langues\\"+lang+".ini");
	a = a +"\r" + txt + " :" + theConfig.GetAVRegion();
	txt = ReadValue(49, "default", "Datas\\Langues\\"+lang+".ini");
	a = a +"\r" + txt + " :" + videomode;
	txt = ReadValue(50, "default", "Datas\\Langues\\"+lang+".ini");
	a = a +"\n" + txt;
	txt = ReadValue(51, "default", "Datas\\Langues\\"+lang+".ini");
	a = a +"\r" + txt + " :" + audiomode;
	txt = ReadValue(58, "default", "Datas\\Langues\\"+lang+".ini");
	a = a +"\n" + txt;

	a = a +"\rE: " + DDSpace[1] + " / " + DDSpace[4];
	if (DDSpace[5] != "0.00Ko")
	{			
		a = a +"\rF: " + DDSpace[2] + " / " + DDSpace[5];
	}
	if (DDSpace[6] != "0.00Ko")
	{
		a = a +"\rG: " + DDSpace[3] + " / " + DDSpace[6];
	}
	TellUser(a,"");
}
function ExecDvd()
{
	IntExt();
}
function NextBackground()
{
	curentbackground = curentbackground + 1;
	if( curentbackground > NbBackground)
	{
		curentbackground = 0;
	}
	myBackgroundList.children[curentbackground].isBound = true;
	var w = thePanel.children[0].children[0];
	if (curentbackground == 0)
	{
		var txt = ReadValue(29, "default", "Datas\\Langues\\"+lang+".ini");
		SetStatusText(txt);
	}
	else
		SetStatusText("xboxbg"+curentbackground);
}
function ShowHideClock()
{
	if(bClockVisable == false)
	{
		ShowClock();
	}
	else
	{
		HideClock();
	}
}
function MusicSaver()
{
	if(musicsaver == false)
	{
		ShowMusicSaver();
		musicsaver = true;
	}
	else
	{
		HideMusicSaver();
		musicsaver = false;
	}
}
