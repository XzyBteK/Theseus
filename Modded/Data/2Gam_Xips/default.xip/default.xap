function UpdateMessageButtonHighlight()
{
    var c = theMessageInline.children[0];

    if (nCurMessageButton == 0)
    {
        c.button_yes.children[0].appearance.material.name = BOnMatGen;
	  c.button_yes.children[0].appearance.texture.url = BOnTexGen+".xbx";
        c.text_yes.children[0].appearance.material.name = "Material #133";
        c.text_no.children[0].appearance.material.name = "NavType";
        c.button_no.children[0].appearance.material.name = BOffMatGen;
	  c.button_no.children[0].appearance.texture.url = BOffTexGen+".xbx";
    }
    else
    {
        c.button_no.children[0].appearance.material.name = BOnMatGen;
	  c.button_no.children[0].appearance.texture.url = BOnTexGen+".xbx";
        c.text_no.children[0].appearance.material.name = "Material #133";
        c.text_yes.children[0].appearance.material.name = "NavType";
        c.button_yes.children[0].appearance.material.name = BOffMatGen;
	  c.button_yes.children[0].appearance.texture.url = BOffTexGen+".xbx";
    }
}

