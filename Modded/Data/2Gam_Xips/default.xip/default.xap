function GoPassword()
{
	var c = thePasswordInline.children[0];
	c.thePassword.children[0].fade = 1;
	c.thePassword.children[0].SetTranslation(1.00, 0.3570, 0.000000);
	c.thePassword.children[0].SetAlpha(1);
	thePasswordLayer.transparency = 0.25;
	PasswordHeading = ReadValue(1, "default", "Datas\\Langues\\"+lang+".ini");
	PasswordQuestion = ReadValue(9, "default", "Datas\\Langues\\"+lang+".ini");
	MenuInit();
}

function MenuInit()
{
	var c = thePasswordInline.children[0];
	c.PanelHeading.text = PasswordHeading;
	c.QuestionText.text = PasswordQuestion;
	c.ButtonGroup.visible = false;
	c.asterisks.visible = true;
	c.LockIcon.visible = true;
	TempString = "";
	CurrentPassword = "";
	CorrectPasswordEntered = "false";
	thePasswordJoystick.isBound = true;
	currentControlType = thePasswordJoystick;
	c.PasswordText.text = "******";
	GeneraleMT("Password");
}

function PassChar(TempString)
{
	var c = thePasswordInline.children[0];
	CurrentPassword = CurrentPassword + TempString;
	var passlen = CurrentPassword.length();
	var correctpasslen = CorrectPassword.length();
	var Nike1 = "**** ***  **   *    ";
	var passlen2 = passlen;

	passlen2 = passlen + passlen;
	passlen2 = passlen2 + passlen;
	passlen2 = passlen2 + passlen;
	c.PasswordText.text = Nike1.substr(passlen2, 4);

    if (passlen == correctpasslen)
    {
            if (CurrentPassword == CorrectPassword)
		{
			DoPasswordFunction();
		}
            else
		{
			c.thePassword.children[0].fade = 0.25;
			c.thePassword.children[0].SetTranslation(1.00, 0.3570, -100.000000);
			c.thePassword.children[0].SetAlpha(0);
			thePasswordLayer.transparency = 1;
			thePasswordJoystick.isBound = false;
			previousControlType.isBound = true;
		}
    }
}

function DoPasswordFunction()
{
	var c = thePasswordInline.children[0];
	c.thePassword.children[0].fade = 0.25;
	c.thePassword.children[0].SetTranslation(1.00, 0.3570, -100.000000);
	c.thePassword.children[0].SetAlpha(0);
	thePasswordLayer.transparency = 1;
	thePasswordJoystick.isBound = false;
	previousControlType.isBound = true;
	NikePassword();
}
