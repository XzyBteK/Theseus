function GeneraleMT(ecran)
{
	if( ecran == "controlpanel")
	{
		var c = theControlPanelInline.children[0];
		if (MatGen != "")
		{
			c.GenMat01.name = MatGen;
			c.GenMat02.name = MatGen;
			c.GenMat03.name = MatGen;
			c.GenMat04.name = MatGen;
		}
		if (TexGen != "")
		{
			c.GenTex01.url = TexGen+".xbx";
			c.GenTex02.url = TexGen+".xbx";
			c.GenTex03.url = TexGen+".xbx";
			c.GenTex04.url = TexGen+".xbx";
		}
	}
	else if( ecran == "message")
	{
		var c = theMessageInline.children[0];
		if(ConfigSysteme[19] == "Original")
			c.BackgroundPanel.url = "Pmess.xbx";
		else if(ConfigSysteme[19] == "Verre")
			c.BackgroundPanel.url = "Fond.xbx";

		if (MatGen != "")
		{
			c.GenMat01.name = MatGen;
			c.GenMat02.name = MatGen;
			c.GenMat05.name = MatGen;
			c.GenMat06.name = MatGen;
		}
		if (TexGen != "")
		{
			c.GenTex01.url = TexGen+".xbx";
			c.GenTex02.url = TexGen+".xbx";
			c.GenTex05.url = TexGen+".xbx";
			c.GenTex06.url = TexGen+".xbx";
		}
	}
	else if( ecran == "keyboard")
	{
		var c = theKeyboardTransform.children[0].children[0];
		if(ConfigSysteme[19] == "Original")
			c.BackgroundPanel.url = "Pkeyb.xbx";
		else if(ConfigSysteme[19] == "Verre")
			c.BackgroundPanel.url = "Fond.xbx";

		if (MatGen != "")
		{
			c.GenMat01.name = MatGen;
			c.GenMat02.name = MatGen;
		}
		if (TexGen != "")
		{
			c.GenTex01.url = TexGen+".xbx";
			c.GenTex02.url = TexGen+".xbx";
		}
		MatTmp = ReadValue("KeyMat", "Keyboard", "Skins\\"+Systeme[4]+"\\Skin.ini");
		TexTmp = ReadValue("KeyTex", "Keyboard", "Skins\\"+Systeme[4]+"\\Skin.ini");
		if (MatTmp != "")
			c.KeyMat.name = MatTmp;
		if (TexTmp != "")
			c.KeyTex.url = TexTmp+".xbx";
	}
	else if( ecran == "Jkeyboard")
	{
		if(ConfigSysteme[19] == "Original")
			c.BackgroundPanel.url = "Pkeyb.xbx";
		else if(ConfigSysteme[19] == "Verre")
			c.BackgroundPanel.url = "Fond.xbx";

		var c = theJapaneseKeyboardTransform.children[0].children[0];
		if (MatGen != "")
		{
			c.GenMat01.name = MatGen;
			c.GenMat02.name = MatGen;
		}
		if (TexGen != "")
		{
			c.GenTex01.url = TexGen+".xbx";
			c.GenTex02.url = TexGen+".xbx";
		}
	}
	else if( ecran == "memoryx")
	{
		var c = theGameBoardInline.children[0];
		if (MatGen != "")
		{
			c.GenMat01.name = MatGen;
			c.GenMat02.name = MatGen;
		}
		if (TexGen != "")
		{
			c.GenTex01.url = TexGen+".xbx";
			c.GenTex02.url = TexGen+".xbx";
		}
	}
	else if( ecran == "Password")
	{
		var c = thePasswordInline.children[0];
		if(ConfigSysteme[19] == "Original")
			c.BackgroundPanel.url = "Pmess.xbx";
		else if(ConfigSysteme[19] == "Verre")
			c.BackgroundPanel.url = "Fond.xbx";

		if (MatGen != "")
		{
			c.GenMat01.name = MatGen;
			c.GenMat02.name = MatGen;
			c.GenMat03.name = MatGen;
			c.GenMat04.name = MatGen;
			c.GenMat05.name = MatGen;
		}
		if (TexGen != "")
		{
			c.GenTex01.url = TexGen+".xbx";
			c.GenTex02.url = TexGen+".xbx";
			c.GenTex03.url = TexGen+".xbx";
			c.GenTex04.url = TexGen+".xbx";
			c.GenTex05.url = TexGen+".xbx";
		}
	}
}
function AffMainMenu()
{
	var c = theMainMenu.children[0].children[0];
	var x = 60;
	var i = 0;

	for( i = 0; i < 9; i = i + 1)
	{
		c.MainMenuPanneau.children[i].SetTranslation(CoordX(x,RingScale), CoordY(x,RingScale), 102);
		x = x - 15;
	}
	for( i = NbMainMenu; i < 9; i = i + 1)
	{
		c.MainMenuPanneau.children[i].visible = false;
	}
	nCurMainMenuItem = ReturnInteger(ReadValue(1, "ConfigMenusMainMenu", "Datas\\Config\\ConfigMenusMainMenu.xbc")) - 1;
	if (nCurMainMenuItem > NbMainMenu - 1 | nCurMainMenuItem == -1)
	{
		if (NbMainMenu == 0)
			nCurMainMenuItem = 0;
		else if (NbMainMenu == 1)
			nCurMainMenuItem = 1;
		else if (NbMainMenu == 2)
			nCurMainMenuItem = 1;
		else if (NbMainMenu == 3)
			nCurMainMenuItem = 2;
		else if (NbMainMenu == 4)
			nCurMainMenuItem = 2;
		else if (NbMainMenu > 4)
			nCurMainMenuItem = 3;

	}
	nCurMainMenuScroll = 0;
	if (nCurMainMenuItem < 5)
		PosMainMenu = -60 + (nCurMainMenuItem * 15);
	else if (nCurMainMenuItem > 4)
		PosMainMenu = 0;

	c.theMenuItems.SetRotation(0, 0, 1, PosMainMenu * 6.283 / 360);
	OptionMenu();
}
