					if (ApparenceMainMenu[22] == "xboxbg5" & NbBackground > 4)
					{
						myBackgroundList.children[5].isBound = true;
						curentbackground = 5;
					}
					if (ApparenceMainMenu[22] == "xboxbg6" & NbBackground > 5)
					{
						myBackgroundList.children[6].isBound = true;
						curentbackground = 6;
					}
					if (ApparenceMainMenu[22] == "xboxbg7" & NbBackground > 6)
					{
						myBackgroundList.children[7].isBound = true;
						curentbackground = 7;
					}
					if (ApparenceMainMenu[22] == "xboxbg8" & NbBackground > 7)
					{
						myBackgroundList.children[8].isBound = true;
						curentbackground = 8;
					}
					if (ApparenceMainMenu[22] == "xboxbg9" & NbBackground > 8)
					{
						myBackgroundList.children[9].isBound = true;
						curentbackground = 9;
					}
					if (ApparenceMainMenu[22] == "xboxbg10" & NbBackground > 9)
					{
						myBackgroundList.children[10].isBound = true;
						curentbackground = 10;
					}
				}
			}
		}
		else
		{
			myBackgroundList.children[0].isBound = true;
		}
		if( ConfigMusic[1] == "oui")
		{
			if( ConfigMusic[3] == "0")
				BGMalwayson = true;
			else
				BGMalwayson = false;

			BGMon = true;
		}
		Materiaux();
	}
	lang = theConfig.GetLanguage();
}
function AffTitreMusique()
{
	var ttm = ReturnInteger(ConfigMusic[8]);
	var c = thePanel.children[0].children[0];
	c.theNowPlaying.fade = 1.0;
	c.theNowPlaying.SetAlpha(1);
	c.theNowPlaying2.fade = 1.0;
	c.theNowPlaying2.SetAlpha(1);
	c.theNowPlaying3.fade = 1.0;
	c.theNowPlaying3.SetAlpha(1);
	c.theNowPlaying.SetScale(ttm, ttm, 10.0);
	c.theNowPlaying2.SetScale(ttm, ttm, 10.0);
	c.theNowPlaying3.SetScale(ttm, ttm, 10.0);
	if (ConfigMusic[7] == "bd")
	{
		var w = theMainMenu.children[0].children[0];
		var posx = 150.0 + VideoMode;
		var posxx = 35.0 + VideoMode;
		w.select.fade = 1.0;
		w.select.SetTranslation(posxx, -222.000000, -36.470001);
		c.theNowPlaying.SetTranslation(posx, -110.0 + ttm * 2, 4.0);
		c.theNowPlaying2.SetTranslation(posx, -110.0 + ttm, 4.0);
		c.theNowPlaying3.SetTranslation(posx, -110.0, 4.0);
		c.theNowPlaying_text.justify = "end";
		c.theNowPlaying_text2.justify = "end";
		c.theNowPlaying_text3.justify = "end";
	}
	if (ConfigMusic[7] == "bg")
	{
		var posx = -165.0 - VideoMode;
		c.theNowPlaying.SetTranslation(posx, -110.0 + ttm * 2, 4.0);
		c.theNowPlaying2.SetTranslation(posx, -110.0 + ttm, 4.0);
		c.theNowPlaying3.SetTranslation(posx, -110.0, 4.0);
		c.theNowPlaying_text.justify = "left";
		c.theNowPlaying_text2.justify = "left";
		c.theNowPlaying_text3.justify = "left";
	}
	if (ConfigMusic[7] == "hg")
	{
		var posx = -165.0 - VideoMode;
		c.theNowPlaying.SetTranslation(posx, 105.0, 4.0);
		c.theNowPlaying2.SetTranslation(posx, 105.0 - ttm, 4.0);
		c.theNowPlaying3.SetTranslation(posx, 105.0 - ttm * 2, 4.0);
		c.theNowPlaying_text.justify = "left";
		c.theNowPlaying_text2.justify = "left";
		c.theNowPlaying_text3.justify = "left";
	}
	if (ConfigMusic[7] == "hd")
	{
		var posx = 150.0 + VideoMode;
		c.theNowPlaying.SetTranslation(posx, 105.0, 4.0);
		c.theNowPlaying2.SetTranslation(posx, 105.0 - ttm, 4.0);
		c.theNowPlaying3.SetTranslation(posx, 105.0 - ttm * 2, 4.0);
		c.theNowPlaying_text.justify = "end";
		c.theNowPlaying_text2.justify = "end";
		c.theNowPlaying_text3.justify = "end";
	}
}
function SetStatusText(str)
{
    thePanel.children[0].children[0].Volume_text.text = str;
    if (str != "")
    {
        thePanel.children[0].children[0].Volume.SetAlpha(1);
        thePanel.children[0].children[0].Volume.DisappearAfter(2);
    }
}
function Photo()
{
	theConfig.screenshot();
}
function AfficheInfosXbox()
{
	var c = thePanel.children[0].children[0];
	c.ReseauTxt.fade = 1.0;

	if (ConfigSysteme[9] != "hg" & ConfigMusic[7] != "hg")
	{
		var posx = -130.0 - VideoMode;
		c.ReseauTxt.SetTranslation(posx, 105.0, 4.0);
	}
	else if (ConfigSysteme[9] != "hd" & ConfigMusic[7] != "hd")
	{
		var posx = 130 + VideoMode;
		c.ReseauTxt.SetTranslation(posx, 105.0, 4.0);
	}
	else if (ConfigSysteme[9] != "bg" & ConfigMusic[7] != "bg")
	{
		var posx = -130 - VideoMode;
		c.ReseauTxt.SetTranslation(posx, -105.0, 4.0);
	}
}
function CelsiusToF(tempC)
{
	var a = tempC;
	var b = a.indexOf("°");
	var c = ReturnInteger(a.substring(0,b));
	var d = Math.round((c / (5 / 9)) + 32);
	return d;
}
function InfoXboxHard()
{
	thePanel.children[0].children[0].Reseau_text.text = "IP:"+IPStatus+"\r"+theConfig.GetXBOXVersion()+"\rEncoder:"+theConfig.GetENCODER();
}
function AnimSelect()
{
	if ( g_theMainMenuLoaded == true)
	{
		var w = theMainMenu.children[0].children[0];
		w.select.fade = 1;
		if ( ConfigSysteme[9] == "bd" & bClockVisable == false)
			w.select.SetTranslation(162 + VideoMode, -219, -36.47);
		else if ( ConfigMusic[7] == "bd" & affsound == 0)
			w.select.SetTranslation(162 + VideoMode, -219, -36.47);
		else if ( ConfigSysteme[9] == "bd" & bClockVisable == true & ConfigSysteme[5] == "tHc")
			w.select.SetTranslation(45 + VideoMode, -219, -36.47);
		else if ( ConfigSysteme[9] == "bd" & bClockVisable == true & ConfigSysteme[5] == "text")
			w.select.SetTranslation(65 + VideoMode, -219, -36.47);
		else if ( ConfigMusic[7] == "bd" & affsound == 1)
			w.select.SetTranslation(45 + VideoMode, -219, -36.47);

		AffSelect = false;
	}
}
function CoordX(angle,rayon)
{
	var a = angle;
	var b = rayon;
	var x = b;
	if (a != 0)
		x = Math.cos(a*3.14159265/180)*b;

	return x;
}
function CoordY(angle,rayon)
{
	var a = angle;
	var b = rayon;
	var y = 0;
	if (a != 0)
		y = Math.sin(a*3.14159265/180)*b;

	return y;
}
function OptionsLayer()
{
	var c = thePanel.children[0].children[0];
	c.theMainMenuClock.SetAlpha(0);
	c.heure.SetAlpha(0);
	c.date.SetAlpha(0);
	if(ConfigSysteme[19] == "Original")
		c.FondClock.url = "PtHc.xbx";
	else if(ConfigSysteme[19] == "Verre")
		c.FondClock.url = "Fond.xbx";

	if (ConfigSysteme[9] == "bd")
	{
		var posx = 130 + VideoMode;
		c.heure.SetTranslation(posx, -200.0, 4.0);
		c.date.SetTranslation(posx, -210.0, 4.0);
		c.theMainMenuClock.SetRotation(2, 0, 0, -3);
		c.theMainMenuClock.SetTranslation(285.900002, -100.261000, -40.399994);
	}
	if (ConfigSysteme[9] == "bg")
	{
		var posx = -145 - VideoMode;
		c.heure.SetTranslation(posx, -200.0, 4.0);
		c.date.SetTranslation(posx, -210.0, 4.0);
		c.theMainMenuClock.SetRotation(2, 0, 0, 3);
		c.theMainMenuClock.SetTranslation(285.900002, -100.261000, -40.399994);
	}
	if (ConfigSysteme[9] == "hd")
	{
		var posx = 130 + VideoMode;
		c.heure.SetTranslation(posx, 170.0, 4.0);
		c.date.SetTranslation(posx, 160.0, 4.0);
		c.theMainMenuClock.SetRotation(2, 0, 0, 3);
		c.theMainMenuClock.SetTranslation(285.900002, 59.261000, -40.399994);
	}
	if (ConfigSysteme[9] == "hg")
	{
		var posx = -145 - VideoMode;
		c.heure.SetTranslation(posx, 170.0, 4.0);
		c.date.SetTranslation(posx, 160.0, 4.0);
		c.theMainMenuClock.SetRotation(2, 0, 0, 3);
		c.theMainMenuClock.SetTranslation(285.900002, 59.261000, -40.399994);
	}

	if (ConfigSysteme[4] == "oui")
	{
		ShowClock();
	}
	else
	{
		HideClock();
	}
	AffTitreMusique();
	PanelMateriaux();
	if(ConfigSysteme[16]=="oui")
	{
		if (theConfig.GetNETWORKSTATUS() == "Network Cable Not Connected :(")
			IPStatus = "  //";
		else
			IPStatus = AdresseIP;

		InfoXboxHard();
		InfosXbox = true;
	}
	else
	{
		thePanel.children[0].children[0].Reseau_text.text = "";
		InfosXbox = false;
	}
		AfficheInfosXbox();
}
