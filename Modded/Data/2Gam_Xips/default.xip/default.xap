function UpdateDate()
{
	var d = new Date;
	nClockHour = d.getHours();
	nClockMinute = d.getMinutes();
	nClockSeconds = d.getSeconds();
	if (b24hour == false)
	{
		nClockAMPM = "AM";
		if (nClockHour >= 12)
		{
			nClockHour = nClockHour - 12;
			nClockAMPM = "PM";
		}
		if (nClockHour == 0)
			nClockHour = 12;
	}

	nClockDay = d.getDate();
	nClockMonth = d.getMonth() + 1;
	nClockYear = d.getFullYear();

	if (nClockHour < 10)
		nClockHour = "0" + nClockHour;
	if (nClockMinute < 10)
		nClockMinute = "0" + nClockMinute;
	if (nClockSeconds < 10)
		nClockSeconds = "0" + nClockSeconds;
	if (nClockDay < 10)
		nClockDay = "0" + nClockDay;
	if (nClockMonth < 10)
		nClockMonth = "0" + nClockMonth;

	if(ConfigSysteme[7] == "date")
	{
		Heure_Text = "";
		Date_Text = nClockDay+"/"+nClockMonth+"/"+nClockYear;
	}
	else if(ConfigSysteme[7] == "heure")
	{
		if (b24hour == false)
			Heure_Text = nClockHour+":"+nClockMinute+":"+nClockSeconds+" "+nClockAMPM;
		else
			Heure_Text = nClockHour+":"+nClockMinute+":"+nClockSeconds;

		Date_Text = "";
	}
	else if(ConfigSysteme[7] == "total")
	{
		if (b24hour == false)
			Heure_Text = nClockHour+":"+nClockMinute+":"+nClockSeconds+" "+nClockAMPM;
		else
			Heure_Text = nClockHour+":"+nClockMinute+":"+nClockSeconds;

		Date_Text = nClockDay+"/"+nClockMonth+"/"+nClockYear;
	}
	var w = thePanel.children[0].children[0];
	w.heure_text.text = Heure_Text;
	w.heuretHc.text = Date_Text+" "+Heure_Text;
	w.date_text.text = Date_Text;
}

function loadBackground() 
{
	if (NbBackground == 0)
	{
		myBackgroundList.children[0].isBound = true;
		return;
	}
	if (NbBackground == 1)
	{
		myBackgroundList.children[1].isBound = true;
		curentbackground = 1;
		return;
	}
	if (NbBackground == 2)
	{
		background = Math.round(Math.random() * 1) + 1;
	}
	if (NbBackground == 3)
	{
		background = Math.round(Math.random() * 2) + 1;
	}
	if (NbBackground == 4)
	{
		background = Math.round(Math.random() * 3) + 1;
	}
	if (NbBackground == 5)
	{
		background = Math.round(Math.random() * 4) + 1;
	}
	if (NbBackground == 6)
	{
		background = Math.round(Math.random() * 5) + 1;
	}
	if (NbBackground == 7)
	{
		background = Math.round(Math.random() * 6) + 1;
	}
	if (NbBackground == 8)
	{
		background = Math.round(Math.random() * 7) + 1;
	}
	if (NbBackground == 9)
	{
		background = Math.round(Math.random() * 8) + 1;
	}
	if (NbBackground == 10)
	{
		background = Math.round(Math.random() * 9) + 1;
	}
	testbackground();
}

function testbackground()
{
	
	if( background == curentbackground | background == 0)
	{
		loadBackground();
	}
	else
	{
		if ( DVDLaunch != true)
			myBackgroundList.children[background].isBound = true;

		curentbackground = background;
		BackgroundUpdate = 0;
	} 
}

function Action(ac,style)
{
	theCDExpand.Play();
	var lgt = ac.length();
	if( ac.substring(lgt-5,lgt) == "_2GAM")
	{
		action = ac.substring(0,lgt-5);
		if( shift != "" & action != "NextBackground" & action != "ShowHideClock" & action != "AffTitre" & action != "MusicSaver" & action != "EjectLoad")
		{
			onleft = false;
			onright = false;
			AfficheShift();
		}

		if( style == "Menu" & ApparenceMenusDD[1] == "1")
		{sty = 2;}
		if( style == "Menu" & ApparenceMenusDD[1] == "2")
		{sty = 5;}
		if( style == "Menu2" & ApparenceMenusDD[1] == "1")
		{sty = 2;}
		if( style == "Menu2" & ApparenceMenusDD[1] == "2")
		{sty = 5;}

		if( (action == "ShutDown" | action == "Reboot" | action == "ChangeSkins") & style == "Menu" )
		{sty = 2;}
		if( (action == "ShutDown" | action == "Reboot" | action == "ChangeSkins") & style == "Bouton")
		{sty = 6;}
		if( MenuBoutons == true)
		{
			if( action == "MusicSaver" | action == "GoToMusic" | action == "GoToMemory" | action == "GoToSettings" | action == "GoToMenuDD" | action.substring(0,15) == "MenuLancementDD")
			{
				return;
			}
		}
		NumAction = 1;
		for(var i = 1; i < Nbaction + 1; i = i + 1)
		{
			if( ac == ActionsPassword[NumAction])
			{
				TestPassword().Goto;
			}
			NumAction = NumAction + 3;
		}
		if (action.substring(0,15) == "MenuLancementDD")
		{
			MenuLancementDD().Goto;
		}
		LanceAction();
		return;
	}
	if( style == "Bouton")
	{
		sty = 1;
		NumAppli = 1;
		Numapplipass = 1;
		for(var i = 1; i < Nbappli + 1; i = i + 1)
		{
			if( ac == Applications[NumAppli])
			{
				for(var ii=1; ii < Nbapplipassword + 1; ii = ii + 1)
				{
					lng=ac.length();
					ind=ac.indexOf("¤");
					nom=ac.substring(0,ind);
					dos=ac.substring(ind+1,lng);
					if( dos == ApplicationsPassword[Numapplipass] | nom == ApplicationsPassword[Numapplipass])
					{
						TestPassword().Goto;
					}
					Numapplipass = Numapplipass + 3;
				}
				LanceAppli(Applications[NumAppli + 1], Applications[NumAppli + 2], Applications[NumAppli + 3]).Goto;
			}
			NumAppli = NumAppli + 4;
		}
	}
	if( style == "Menu")
	{
		sty = 3;
		NumAppli = 1;
		Numapplipass = 1;
		for(var i = 1; i < Nbappli + 1; i = i + 1)
		{
			if( ac == Applications[NumAppli])
			{
				for(var ii=1; ii < Nbapplipassword + 1; ii = ii + 1)
				{
					lng=ac.length();
					ind=ac.indexOf("¤");
					nom=ac.substring(0,ind);
					dos=ac.substring(ind+1,lng);
					if( dos == ApplicationsPassword[Numapplipass] | nom == ApplicationsPassword[Numapplipass])
					{
						TestPassword().Goto;
					}
					Numapplipass = Numapplipass + 3;
				}
				LanceAppli(Applications[NumAppli + 1], Applications[NumAppli + 2], Applications[NumAppli + 3]).Goto;
			}
			NumAppli = NumAppli + 4;
		}
	}
	if( style == "Disque")
	{
		sty = 4;
		Numapplipass = 1;
		for(var i = MenuDeb; i < MenuDeb+taille; i = i + 1)
		{
			if( ac == ScanneDD[i*4])
			{
				for(var ii=1; ii < Nbapplipassword + 1; ii = ii + 1)
				{
					lng=ac.length();
					ind=ac.indexOf("¤");
					nom=ac.substring(0,ind);
					dos=ac.substring(ind+1,lng);
					if( dos == ApplicationsPassword[Numapplipass] | nom == ApplicationsPassword[Numapplipass])
					{
						NumAppli = i * 4;
						TestPassword().Goto;
					}
					Numapplipass = Numapplipass + 3;
				}
				LanceAppli(ScanneDD[i*4 + 1], ScanneDD[i*4 + 2], ScanneDD[i*4 + 3]).Goto;
			}
			NumAppli = i * 4;
		}
	}
	return;
}
function TestPassword()
{
	var pas;
	onleft = false;
	onright = false;
	AfficheShift();

	if (ConfigSysteme[3]=="keyb")
	{
		pas = 1;
	}
	else if (ConfigSysteme[3]=="nike")
	{
		pas = 2;
	}

	if ( sty == 1)
	{
		Password = ApplicationsPassword[Numapplipass + pas];
	}
	if (sty == 2 | sty == 6)
	{
		Password = ActionsPassword[NumAction + pas];
	}
	if ( sty == 3)
	{
		Password = ApplicationsPassword[Numapplipass + pas];
	}
	if ( sty == 4)
	{
		Password = ApplicationsPassword[Numapplipass + pas];
	}
	if ( sty == 5)
	{
		Password = ActionsPassword[NumAction + pas];
	}

	if (ConfigSysteme[3]=="keyb")
	{
		Pass = " ";
		var txt = ReadValue(1, "default", "Datas\\Langues\\"+lang+".ini");
		ShowKeyboard(txt,Pass,"ConfPassword()","");
	}
	else if (ConfigSysteme[3]=="nike")
	{
		CorrectPassword = Password;
		GoPassword();
	}
}
function NikePassword()
{
	strKeyboardEdit = CorrectPassword;
	ConfPassword();
}
function ConfPassword()
{
	Pass = strKeyboardEdit;
	if( Password != Pass)
	{
		var txt = ReadValue(2, "default", "Datas\\Langues\\"+lang+".ini");
		TellUser(txt,"");
	}
	if( Password == Pass & sty == 1)
	{
		LanceAppli(Applications[NumAppli + 1], Applications[NumAppli + 2], Applications[NumAppli + 3]).Goto;
	}
	if( Password == Pass & (sty == 2 | sty == 6 | sty == 5))
	{
		if (action.substring(0,15) == "MenuLancementDD")
		{
			MenuLancementDD().Goto;
		}
		LanceAction();
	}
	if( Password == Pass & sty == 3)
	{
		LanceAppli(Applications[NumAppli + 1], Applications[NumAppli + 2], Applications[NumAppli + 3]).Goto;
	}
	if( Password == Pass & sty == 4)
	{
		LanceAppli(ScanneDD[NumAppli+1], ScanneDD[NumAppli+2], ScanneDD[NumAppli+3]).Goto;
	}
}
function LanceAction()
{
	if( sty == 6 & action == "ShutDown" & ConfigSysteme[2] == "oui" )
	{
		ConfShutDown();
		return;
	}
	if( sty == 6 & action == "Reboot" & ConfigSysteme[2] == "oui" )
	{
		ConfReboot();
		return;
	}
	if( sty == 6 & action == "ChangeSkins" & ConfigSysteme[2] == "oui" )
	{
		ConfSwitchSkins();
		return;
	}

	if( action == "ChangeSkins" & sty == 6)
		{action = "SwitchSkins";}

	if( action == "ChangeSkins" & sty == 2)
		{action = "GoToSkinsPanel";}


	if( musicsaver == false | (musicsaver == true & (action == "ShowHideClock" | action == "AffTitre" | action == "MusicSaver")))
	eval(action + "()");
}
