		SSaver = tmpSaver + 1;
	}
	function On6()
	{
		SSaver = 0;
		Action("ChangeSkins_2GAM","Bouton");
	}
    }

    function OnActivate()
    {
      CurrentViewpoint = theMainMenuViewpoint;
      CurrentAltViewpoint = theMainMenuAlternateViewpoint;
	previousControlType = theMainMenuJoy;
	MenuBoutons = false;
	theMainMenuViewpoint.isBound = true;
    }
    behavior
    {
	sleep 0.1;
	if (children[0].children.length() > 0)
	{
		if (theMainMenu.visible | DVDLaunch == true)
            {
			if (theDiscDrive.discType == "Video")
			{
				DvdType = "Video";
			}

			Launcher = "MainMenu";
            }
	}
	if (TextMenuScroll == true & ConfigMenusMainMenu[2] == "oui")
	{
		ScrollText();
	}
    }
}
function ScrollText()
{
	TextMenu = NumTextMenu.geometry.text;
	var lgt = TextMenu.length();
	NumTextMenu.geometry.text = TextMenu.substring(1,lgt)+TextMenu.substring(0,1);
}
