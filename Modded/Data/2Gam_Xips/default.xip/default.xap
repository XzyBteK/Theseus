function StartGameBoardView()
{
	bInGameBoardView = true;
	if (CurrentViewpoint == theMainMenuViewpoint)
		ShowMusicSaver();
}
function StopGameBoardView()
{
	if (CurrentViewpoint == theMainMenuViewpoint)
		HideMusicSaver();
}
function StopGameBoard()
{
	bInGameBoardView = false;
	theGameBoardLayer.transparency = 1;
      theGameBoardInline.children[0].theGameBoardDisplay.fade = 1;
      theGameBoardInline.children[0].theGameBoardDisplay.SetAlpha(0);
      theGameBoardInline.children[0].theGameBoardDisplay.SetTranslation(0,-550,-60);
      theGameBoardInline.children[0].theGameBoardDisplay.SetRotation(1,0,0,3.17);
	StopGameBoardView();
}
function MemoryX()
{
      theGameBoardLayer.visible = true;
	theGameBoardLayer.transparency = 0.30;
      theGameBoardInline.children[0].theGameBoardDisplay.fade = 1;
      theGameBoardInline.children[0].theGameBoardDisplay.SetAlpha(1);
      theGameBoardInline.children[0].theGameBoardDisplay.SetTranslation(-47.5,47.5,-20);
      theGameBoardInline.children[0].theGameBoardDisplay.SetRotation(-0.0001,0,0,0.54);
      theGameBoardControlsInline.children[0].InitializeGame();
  	thePlayerPanelIn.Play();
  	StartGameBoardView();
}
