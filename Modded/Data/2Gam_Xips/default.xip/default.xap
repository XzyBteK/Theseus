function GetScannDD2()
{
	if (theDiscDrive.discType != "Video")
	{
		var FileExists = theConfig.NtFileExists( "X:\\2GAM.data\\Datas\\ScannDD.xbx" );
		if ( FileExists == true )
		{
			var info = new Settings;
			info.file = "X:\\2GAM.data\\Datas\\ScannDD.xbx";
			info.section = "default";
			Temp = info.GetValue("Config");
			if (ConfigNP != Temp)
				FileExists = false;

		}
		if (g_bPanelDisplayed == false & (Launcher != "MainMenu" | FileExists == false))
		{
			Temp = ReadValue(84, "default", "Datas\\Langues\\"+lang+".ini");
			BlockUser(Temp);
		}
		if (DDStart > 1)
		{

			if ( FileExists == false | GetDD == true)
			{
				ScannDD();
			}
			else
			{
				var info = new Settings;
				info.file = "X:\\2GAM.data\\Datas\\ScannDD.xbx";
				info.section = "default";
				Nbmenudd = ReturnInteger(info.GetValue("Nbmenudd"));
				info.section = "MenuDD";
				for(var g = 1; g < Nbmenudd + 1; g = g + 1)
				{
					MenusDD[g] = info.GetValue(g);
				}
				info.section = "TailleDD";
				for(var g2 = 1; g2 < Nbmenudd + 1; g2 = g2 + 1)
				{
					TailleDD[g2] = ReturnInteger(info.GetValue(g2));
				}
				for(var g3 = 1; g3 < Nbmenudd + 1; g3 = g3 + 1)
				{
					num = num + TailleDD[g3];
				}
				info.section = "ScanneDD";
				for(var g4 = 0; g4 < num ; g4 = g4 + 1)
				{
					ScanneDD[g4] = info.GetValue(g4);
				}
			}
			ClosePopup();
			SetDD = true;
		}
		AffSpheremap();
	}
	else
	{
		SetDD = true;
	}
}
function EjectLoad()
{
	if( StatutT == false)
	{
		theConfig.Eject();
		StatutT = true;
	}
	else
	{
		theConfig.Load();
		StatutT = false;
	}
}
function CompteMenuDD()
{
	var cmdd = 1;
	var tmdd = " ";
	var nbsdd = " ";
	if (ConfigNP == "novice")
	{
		var tmp = ReadValue("Nombre de Section DD", "default", "config.ini");
		Nbmenudd = ReturnInteger(tmp);
		for(var gn = 1; gn < Nbmenudd + 1; gn = gn + 1)
		{
			tmdd = ReadValue("Nom", "Section" + gn, "config.ini");
			MenusDD[gn] = tmdd;
		}
		for(var x = 1; x < Nbmenudd + 1; x = x + 1)
		{
			var nb = 0;
			for(var xx = 1; xx < 120; xx = xx + 1)
			{
				nbsdd = ReadValue("Patch" + xx, "Section" + x, "config.ini");
				if( nbsdd != "")
				{
					nb = nb + 1;
				}
				else
				{
					xx = 120;
				}
			}
			MenusDD[Nbmenudd + x] = nb;
		}
	}
	else
	{
		for(var g = 1; g < cmdd + 1; g = g + 1)
		{
			tmdd = ReadValue(1, "MenuLancementDD_" + g + "_2GAM", "Datas\\Config\\MenuLancementDD.xbc");
			if (tmdd != "")
			{
				MenusDD[g] = tmdd;
				cmdd = cmdd + 1;
				Nbmenudd = Nbmenudd + 1;
			}
		}
		for(var x = 1; x < Nbmenudd + 1; x = x + 1)
		{
			var nb = 0;
			for(var xx = 2; xx < 120; xx = xx + 1)
			{
				nbsdd = ReadValue(xx, "MenuLancementDD_" + x + "_2GAM", "Datas\\Config\\MenuLancementDD.xbc");
				if( nbsdd != "")
				{
					nb = nb + 1;
				}
				else
				{
					xx = 120;
				}
			}
			MenusDD[Nbmenudd + x] = nb/2;
		}
	}
}
function AjoutDvd()
{
	var temp = new Array;
	temp[1] = ReadValue(16, "default", "Datas\\Langues\\"+lang+".ini");
	for (var g = 1; g < Nbmenudd + 1; g = g + 1)
	{
		temp[g + 1] = MenusDD[g];
	}
	for (var h = 1; h < Nbmenudd + 1; h = h + 1)
	{
		temp[h + Nbmenudd + 1] = MenusDD[h + Nbmenudd];
	}
	Nbmenudd = Nbmenudd + 1;
	for (var i = 1; i < (Nbmenudd * 2); i = i + 1)
	{
		MenusDD[i] = temp[i];
	}
	AjDvd = true;
}
function RetireDvd()
{
	var temp = new Array;
	for (var g = 1; g < Nbmenudd; g = g + 1)
	{
		temp[g] = MenusDD[g + 1];
	}
	for (var h = Nbmenudd; h < (Nbmenudd * 2) - 1; h = h + 1)
	{
		temp[h] = MenusDD[h + 1];
	}
	Nbmenudd = Nbmenudd - 1;
	for (var i = 1; i < (Nbmenudd * 2) + 1; i = i + 1)
	{
		MenusDD[i] = temp[i];
	}
	AjDvd = false;
}

DEF theHDDMonitor MemoryMonitor

function ShowFreeSpaceOn(drive)
{
	var a = drive;
	var b = theHDDMonitor.GetTotalFreeBlocks(a);
	var c = b * 16;
	return c;
}

function ShowTotalSpaceOn(drive)
{
	var a = drive;
	var b = theHDDMonitor.GetFreeTotalRatio(a);
	var c = theHDDMonitor.GetTotalFreeBlocks(a);
	var d = c * 16;
	var e = 0;
	if( b > 0)
	{
		e = d / b;
	}
	return e;
}

function CalculSpace()
{
	var nbconf2;
	var nbconf3;
	var nbconf4;
	var nomb;
	var lgt;
	DD = 8;
	for (var ii = 1; ii < 4; ii = ii + 1)
	{
		freespace = ShowFreeSpaceOn(DD);

		DDType = ReadValue(90, "default", "Datas\\Langues\\"+lang+".ini");
		DDSpace[ii] = freespace + ".00" + DDType;
		if (freespace > 1024)
		{
			if (freespace >= 1024*1024)
			{
				nomb = (freespace / 1024)/1024;
				DDType = ReadValue(88, "default", "Datas\\Langues\\"+lang+".ini");
			}
			else if (freespace < 1024*1024 & freespace > 1024)
			{
				nomb = freespace / 1024;
				DDType = ReadValue(89, "default", "Datas\\Langues\\"+lang+".ini");
			}

			nbconf2 = Math.round(nomb);
			if (nbconf2 > nomb)
				nbconf2 = nbconf2 - 1;

			nbconf3 = Math.round((((nomb / nbconf2)-1)*nbconf2)*100);
			nbconf4 = (((nomb / nbconf2)-1)*nbconf2)*100;
			if (nbconf3 > nbconf4)
				nbconf3 = nbconf3 - 1;

			DDSpace[ii] = nbconf2+"."+nbconf3+DDType;
		}
		totalspace = ShowTotalSpaceOn(DD);

		DDType = ReadValue(90, "default", "Datas\\Langues\\"+lang+".ini");
		DDSpace[ii+3] = totalspace + ".00" + DDType;
		if (totalspace > 1024)
		{
			if (totalspace >= 1024*1024)
			{
				nomb = (totalspace / 1024)/1024;
				DDType = ReadValue(88, "default", "Datas\\Langues\\"+lang+".ini");
			}
			else if (totalspace < 1048576 & totalspace > 1024)
			{
				nomb = totalspace / 1024;
				DDType = ReadValue(89, "default", "Datas\\Langues\\"+lang+".ini");
			}

			nbconf2 = Math.round(nomb);
			if (nbconf2 > nomb)
				nbconf2 = nbconf2 - 1;

			nbconf3 = Math.round((((nomb / nbconf2)-1)*nbconf2)*100);
			DDSpace[ii+3] = nbconf2+"."+nbconf3+DDType;
		}
		DD = DD + 1;
	}
}

