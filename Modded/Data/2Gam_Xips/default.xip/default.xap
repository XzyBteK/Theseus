{
	var txt = ReadValue(34, "default", "Datas\\Langues\\"+lang+".ini");
	AskQuestion(txt, "SwitchSkins()", "", 0);
}
function ConfShutDown()
{
	var txt = ReadValue(7, "default", "Datas\\Langues\\"+lang+".ini");
	AskQuestion(txt, "ShutDown()", "", 0);
}
