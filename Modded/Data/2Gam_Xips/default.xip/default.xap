function MenuLancementDD()
{
	magicnumber = ReturnInteger(action.substring(action.length()-(action.length()-16),action.length()));

	if (magicnumber == 0)
	{
		ExecDvd();
	}
	else
	{
		if( sty == 5)
		{
			MenuSubDD = true;
			if(Launcher == "MainMenu" | Launcher == "MenuConfig")
				GoToMenuDD();
			else
				return;
		}
		else if( sty == 2)
		{
			GoToMenuDD02();
		}
	}
}
////////////////////////////////////////////////////////////////////////////
function UpdateMainMenu()
{
	if (NbMainMenu == 0 | NbMainMenu == 1)
		return;

	var c = theMainMenu.children[0].children[0];
	if (UMMenu == true)
	{
		if (nCurMainMenuMouvUp == false)
		{
			RotMainMenu = RotMainMenu + 15;
			nCurMainMenuItem = nCurMainMenuItem + 1;
		}
		if (nCurMainMenuMouvUp == true)
		{
			RotMainMenu = RotMainMenu - 15;
			nCurMainMenuItem = nCurMainMenuItem - 1;
		}
		c.theMenuItems.SetRotation(0, 0, 1, (PosMainMenu + RotMainMenu) * 6.283 / 360);
		if (nCurMainMenuItem + 4 > 8 & nCurMainMenuMouvUp == false)
			nCurMainMenuPos = nCurMainMenuPos + 1;

		if (nCurMainMenuItem + 4 > 8 & nCurMainMenuItem + 4 < NbMainMenu & nCurMainMenuMouvUp == false)
		{
			var cc = -60 - (nCurMainMenuPos * 15);
			c.MainMenuPanneau.children[nCurMainMenuScroll].SetTranslation(CoordX(cc,RingScale), CoordY(cc,RingScale), 102);
			c.MainMenuPanneau.children[nCurMainMenuScroll].children[0].SetAlpha(0.01);
			nCurMainMenuValue[nCurMainMenuScroll] = nCurMainMenuItem + 4;
		}
		if (nCurMainMenuItem + 4 > 8 & nCurMainMenuMouvUp == false)
		{
			nCurMainMenuScroll = nCurMainMenuScroll + 1;
			if ( nCurMainMenuScroll > 8)
				nCurMainMenuScroll = 0;

		}
		if (nCurMainMenuItem - 4 > -1 & nCurMainMenuMouvUp == true)
		{
			nCurMainMenuPos = nCurMainMenuPos - 1;
			nCurMainMenuScroll = nCurMainMenuScroll - 1;
			if ( nCurMainMenuScroll < 0)
				nCurMainMenuScroll = 8;

			var cc = 60 - (nCurMainMenuPos * 15);
			c.MainMenuPanneau.children[nCurMainMenuScroll].SetTranslation(CoordX(cc,RingScale), CoordY(cc,RingScale), 102);
			c.MainMenuPanneau.children[nCurMainMenuScroll].children[0].SetAlpha(1);
			nCurMainMenuValue[nCurMainMenuScroll] = nCurMainMenuItem - 4;
		}
	}
	for(var i = 0; i < 9; i = i + 1)
	{
		var cc = nCurMainMenuValue[i];
		c.MainMenuPanneau.children[i].children[0].SetRotation(0, 1, 0, (PosMainMenu + RotMainMenu) * 6.283 / 360);
		c.MainMenuPanneau.children[i].children[0].children[1].children[1].children[1].children[12].children[0].appearance.material.name = PodMenuMat[cc];
		c.MainMenuPanneau.children[i].children[0].children[1].children[1].children[1].children[12].children[0].appearance.texture.url = "";
		c.MainMenuPanneau.children[i].children[0].children[1].children[1].children[1].children[14].children[0].children[0].geometry.text = TitreMenu[cc];

		if ( cc < nCurMainMenuItem - 4  | cc > nCurMainMenuItem + 4 )
			c.MainMenuPanneau.children[i].children[0].SetAlpha(0);
		else if ( cc == nCurMainMenuItem - 4  | cc == nCurMainMenuItem + 4 )
			c.MainMenuPanneau.children[i].children[0].SetAlpha(0.01);
		else if ( cc == nCurMainMenuItem - 3 | cc == nCurMainMenuItem + 3 )
			c.MainMenuPanneau.children[i].children[0].SetAlpha(0.2);
		else if ( cc > nCurMainMenuItem - 3 | cc < nCurMainMenuItem + 3 )
		{
			c.MainMenuPanneau.children[i].children[0].SetAlpha(1);
			c.MainMenuPanneau.children[i].children[0].children[1].children[1].children[1].children[12].children[0].appearance.material.name = PodMenuMat[cc];
			c.MainMenuPanneau.children[i].children[0].children[1].children[1].children[1].children[12].children[0].appearance.texture.url = PodMenuTex[cc];
		}

		if ( cc == nCurMainMenuItem )
		{
			c.MainMenuPanneau.children[i].children[0].children[1].children[1].children[1].children[9].SetAlpha(MenuOnAlpha[cc]);
			c.MainMenuPanneau.children[i].children[0].children[1].children[1].children[1].children[9].children[0].appearance.material.name = MenuOnMat[cc];
			c.MainMenuPanneau.children[i].children[0].children[1].children[1].children[1].children[9].children[0].appearance.texture.url = MenuOnTex[cc];
			c.MainMenuPanneau.children[i].children[0].children[1].children[1].children[1].children[13].visible = true;
			c.MainMenuPanneau.children[i].children[0].children[1].children[1].children[1].children[14].children[0].children[0].appearance.material.name = MenuOnTextMat[cc];
			NumTextMenu = c.MainMenuPanneau.children[i].children[0].children[1].children[1].children[1].children[14].children[0].children[0];
			TextMenuScroll = true;
		}
		else
		{
			c.MainMenuPanneau.children[i].children[0].children[1].children[1].children[1].children[9].SetAlpha(MenuOffAlpha[cc]);
			c.MainMenuPanneau.children[i].children[0].children[1].children[1].children[1].children[9].children[0].appearance.material.name = MenuOffMat[cc];
			c.MainMenuPanneau.children[i].children[0].children[1].children[1].children[1].children[9].children[0].appearance.texture.url = MenuOffTex[cc];
			c.MainMenuPanneau.children[i].children[0].children[1].children[1].children[1].children[13].visible = false;
			c.MainMenuPanneau.children[i].children[0].children[1].children[1].children[1].children[14].children[0].children[0].appearance.material.name = MenuOffTextMat[cc];
		}
	}
}
