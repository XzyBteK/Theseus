DEF theScreenSaver ScreenSaver
{
	function OnStart()
	{
		theScreen.brightness = 0.1;
	}

	function OnEnd()
	{
		theScreen.brightness = 1;
	}
}

NavigationInfo
{
    type "sample"
    headlight false
}

DEF theConfig Config
    behavior
    {
	sleep 0.1;
	if ( theConfig.GetVideoMode() == 0 | theConfig.GetVideoMode() == 1)
		VideoMode = 0;

	if ( theConfig.GetVideoMode() == 2)
		VideoMode = 50;

	if (LaunchDVD == false & g_theMainMenuLoaded == true & (ControlPanelOK == true | ControlPanelBGM == true) & (PanelOK == true | bMessageLayer == true) & SSaverPanelOK == true )
	{
		if ( SVideoMode != theConfig.GetVideoMode())
		{
			SVideoMode = theConfig.GetVideoMode();
			if (bClockVisable == true & DVDLaunch == false)
				ShowClock();

			AffTitreMusique();
			if (InfosXbox == true)
				AfficheInfosXbox();
		}
		if (ConfigSysteme[18] == "oui" & ConfigSysteme[21] == "F")
		{
			thePanel.children[0].children[0].Temp_text.text = "CPU: "+CelsiusToF(theConfig.CPUTemp())+" °F   System: "+CelsiusToF(theConfig.SYSTemp())+" °F";
		}
		else if (ConfigSysteme[18] == "oui" & ConfigSysteme[21] == "C")
		{
			thePanel.children[0].children[0].Temp_text.text = "CPU: "+theConfig.CPUTemp()+"   System: "+theConfig.SYSTemp();
		}
		else
		{
			thePanel.children[0].children[0].Temp_text.text = "";
		}

		if (BGMon == true & AmbientAudio == true)
			DisableAmbientAudio();
		else if (BGMon == false & AmbientAudio == false)
			EnableAmbientAudio();

		if (DvdType != "" & DisqueType == "" & SetDD == true)
		{
			DisqueInside();
		}
		if(DVDLaunch == false)
		{
			if((SSaverPanelView == false) & (musicsaver == false) & (tmpSaver > 0) & (g_bKeyboardDisplayed == false))
			{
				SSaver = SSaver + 0.1;
				if( SSaver >= tmpSaver)
				{
					StartSSaverPanel();
				}
			}
		}

		if (bClockVisable == true)
		{
			UpdateDate();
		}
		if (theControlPanelControlsInline.children[0].theBGMusicPlayer.transportMode == 1 & ControlPanelBGM == true & bMessageLayer == true)
			theControlPanelControlsInline.children[0].incrementBGMtext();

		if (ControlPanelOut == true)
			theControlPanelControlsInline.children[0].UpdateTrackTime();

		if (ControlPanelOK == true )
		{
			if( BGMon == true & theControlPanelControlsInline.children[0].theBGMusicCollection.GetSoundtrackCount() > 0)
			{
//				DisableAmbientAudio();
				theControlPanelControlsInline.children[0].MusicPlayerStart();
			}
			else if( BGMon == false | theControlPanelControlsInline.children[0].theBGMusicCollection.GetSoundtrackCount() == 0)
			{
				theControlPanelControlsInline.children[0].setBGMdisplay();
				BGMon = false;
//				EnableAmbientAudio();
			}
			if (ConfigSysteme[20] == "oui")
				AudiovizuBack.visible = true;
			else
				AudiovizuBack.visible = false;

			ControlPanelOK = false;
			ControlPanelBGM = true;
		}
		if ( PanelOK == true)
		{
			OptionsLayer();
			PanelOK = false;
			bMessageLayer = true;
			BlockUser("");
			ClosePopup();
		}
		if (theConfig.GetNETWORKSTATUS() == "Network Cable Not Connected :(" & IPStatus != "  //" & ConfigSysteme[16]=="oui")
		{
			IPStatus = "  //";
			InfoXboxHard();
		}
		else if (theConfig.GetNETWORKSTATUS() != "Network Cable Not Connected :(" & IPStatus == "  //" & ConfigSysteme[16]=="oui")
		{
			IPStatus = AdresseIP;
			InfoXboxHard();
		}
		if (AffSelect == true)
			AnimSelect();

		if (SetDD == false)
		{
			GetScannDD2();
			DDStart = DDStart + 0.1;
		}
	}
}
function GetLanguage()
{
    return theConfig.GetLanguage();
}

function SetLanguage(nLanguage)
{
    return theConfig.SetLanguage(nLanguage);
}

function ClosePopup()
{
    if (g_bKeyboardDisplayed)
    {
        CloseKeyboard();
    }

    if (g_bPanelDisplayed)
    {
        CloseMessage();
    }
}
DEF theDVDPlayerInline Inline
{
    visible false
    url "dvd.xap"

    function onLoad()
    {
        theDVDPlayerInline.children[0].theDVDLevel.GoTo();
    }
}


DEF theDiscDrive DiscDrive
{
    function OnDiscRemoved()
    {
	DisqueType = "";
	DvdInside = false;
	if (AjDvd == true)
	{
		RetireDvd();
	}
        if (theDVDPlayerInline.visible)
        {
            bShowDVDStopBackground = false;
            theDVDPlayerInline.children[0].theDVDPlayer.stop();
            theDVDPlayerInline.children[0].ClearOnScreenInfo();

            if (g_bPanelDisplayed)
            {
                CloseMessage();
            }
		launch(Systeme[1]+".xbe",ExePath);
        }
        else if (theMusicInline.visible)
        {
            var c = theMusicInline.children[0];

            ClosePopup();

            if (c.musicSelect != 0) // Not Audio CD
            {
                return;
            }

            if (c.theMusicPlayMenu.visible)
            {
                // Update track in the player
                c.DoMusicStop();
                c.InitPlaylist();
                c.UpdateTrackList();
            }
            else if (c.theMusicCopyMenu.visible)
            {
                c.theMusicCollection.error = 3; // Disc ejected
                c.OnMusicCopyComplete();
            }
            else if (c.theMusicMenu.visible)
            {
                // Update numbers of tracks and total time
                c.UpdateMusicMetaData();
            }
        }
        else
        {
            CloseMessage();
        }
    }

    function OnDiscInserted()
    {
	DvdType = discType;
    }
}
function DisqueInside()
{
	DisqueType = DvdType;
	DvdType = "";
	if (DisqueType == "Title" | DisqueType == "unknown" | DisqueType == "DIVX")
	{
		if (DvdInside == false)
		{
			AjoutDvd();
		}
		DvdInside = true;
	}
	if ((DisqueType == "Audio" & ConfigSysteme[10] == "non") | (DisqueType == "Title" & ConfigSysteme[13] == "non") | (DisqueType == "unknown" & ConfigSysteme[14] == "non"))
	{
		LaunchDvd = false;
	}
	else if ((DisqueType == "Audio" & ConfigSysteme[10] == "oui") | DisqueType == "Video" | (DisqueType == "Title" & ConfigSysteme[13] == "oui") | (DisqueType == "unknown" & ConfigSysteme[14] == "oui"))
	{
		IntExt();
	}
	else if ((DisqueType == "Audio" & ConfigSysteme[10] == "demande") | (DisqueType == "Title" & ConfigSysteme[13] == "demande") | (DisqueType == "unknown" & ConfigSysteme[14] == "demande"))
	{
		QuestLance();
	}
}

function QuestLance()
{
	var nbl;
	if (SSaverPanelView == true)
	{
		theSSaverPanelLayer.visible = false;
		theSSaverPanelLayer.transparency = 1;
		SSaverPanelView = false;
		SSaver = 0;
	}
	if (DisqueType == "Audio")
	{
		nbl = 13;
	}
	if (DisqueType == "Title")
	{
		nbl = 14;
	}
	if (DisqueType == "unknown")
	{
		nbl = 15;
	}
	if(bMessageLayer == true)
	{
		SSaver = 0;
		var txt = ReadValue(nbl, "default", "Datas\\Langues\\"+lang+".ini");
		AskQuestion(txt, "IntExt()", "", 0);
	}
	else
	{
		DvdType = DisqueType;
		DisqueType = "";
		LaunchDvd = false;
	}
}
function IntExt()
{
	if (DisqueType == "Audio" & ConfigSysteme[11] == "interne")
	{
            if (theMusicInline.visible == false)
            {
                ClosePopup();
                StartCDPlayer();
                return;
            }

            var c = theMusicInline.children[0];

            if (c.theMusicPlayMenu.visible) // We are in the music play menu
            {
                if (c.musicSelect == 0) // Already in audio CD player
                {
                    if (c.bMusicMenuVisible)
                    {
                        c.theMusicPlayMenu.GoTo();
                        c.StartMusicPlayer();
                        c.DoMusicPlayPause();
                    }
                    else
                    {
                        c.DoMusicStop();
                        c.InitPlaylist();
                        c.UpdateTrackList();
                        if (c.visualizerViewpoint.isBound)
                            c.DoMusicPlayPause();
                    }
                }
                else if (c.theMusicPlayer.transportMode != 1) // Let's play the disc if no soundtrack is playing
                {
                    bGoToCDPlayer = true;
                    EnableInput(false);
                    c.theMusicMenu.GoBackTo();
                }
            }
            else if (c.theMusicMenu.visible == true)
            {
                ClosePopup();
                bGoToCDPlayer = true;
                EnableInput(false);
                c.StartMusicLevel();
            }
            else
            {
                ClosePopup();
                bGoToCDPlayer = true;
                EnableInput(false);
                c.theMusicMenu.GoTo();
            }
	}
	else if (DisqueType == "Video" & ConfigSysteme[12] == "interne")
	{
		if (DVDLaunch == true)
			StartDVDPlayer();
		else
		{
			g_nRec = 1;
			theLauncherLevel.GoTo();
		}
	}
	else if (DisqueType == "Video" & ConfigSysteme[12] != "interne")
	{
		g_nRec = 2;
		theLauncherLevel.GoTo();
	}
	else if (DisqueType == "Title")
	{
		g_nRec = 3;
		theLauncherLevel.GoTo();
	}
	else if (DisqueType == "Audio" & ConfigSysteme[11] != "interne")
	{
		Action(ConfigSysteme[11],"Menu");
	}
	else if (DisqueType == "unknown")
	{
		Action(ConfigSysteme[15],"Menu");
	}
	LaunchDvd = false;
}

function StartDVDPlayer()
{
	EnableInput(true);
	LaunchDVD = true;
	log("Starting the DVD player!");
	theDVDPlayerInline.visible = true;
}

function StartCDPlayer()
{
	Launcher = "MainMenu";
	log("Should start the CD player now!");
	bGoToCDPlayer = true;
	EnableInput(false); // music.xap will re-enable it again if bGoToCDPlay is true
	GoToMusic();
	LaunchDvd = false;
}

