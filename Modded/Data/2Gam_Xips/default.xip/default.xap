    bForceSetTimeZone = theConfig.ForceSetTimeZone();
    bForceSetClock = theConfig.ForceSetClock();

	var c = ReadValue(17, "default", "Datas\\Config\\ConfigSysteme.xbc");
	var d = ReturnInteger(c);
	if ( d == 0)
		d = 30;

	theConfig.FanSpeed(d);
	if (theDiscDrive.discType == "Video")
		DVDLaunch = true;

    if ((bForceSetLanguage + bForceSetTimeZone + bForceSetClock) != false)
    {
        bForceSetLanguage = false;//turn all force sets to false
        bForceSetTimeZone = false;
        bForceSetClock = false;
        var d = new Date(2000, 1, 1, 0, 0);// create a new date, year ****, mo 0-11, day 0-30, hour 24hr, min 0-59 
        d.SetSystemClock(); // set this time as the system time
    }
	theScreenSaver.enabled = false;
	GetDashSettings();
}
DEF theLauncherLevel Level
{
    function OnArrival()
    {
        DisableAmbientAudio();
        BlockMemoryUnitEnumeration();
        ClosePopup();
		g_bAboutToReboot = true;
	if( theConfig.GetVideoMode() == 2 )
		myBackgroundList.children[12].isBound = true;
	else
		myBackgroundList.children[11].isBound = true;
    }

    behavior
    {
        sleep 1.1;

        if (g_bAboutToReboot)
        {
            if (g_nRec == 1)
                launch(Systeme[1]+".xbe",ExePath);
            else if (g_nRec == 2)
                Action(ConfigSysteme[12],"Menu");
            else if (g_nRec == 3)
			launch("default.xbe","\\Device\\CdRom0");
            else if (g_nRec == 4)
			Action(ConfigSysteme[15],"Menu");
        }
    }

    function OnActivate()
    {
        DisableAmbientAudio();
        BlockMemoryUnitEnumeration();
        ClosePopup();
        EnableInput(false);
        
	if( theConfig.GetVideoMode() == 2 )
		myBackgroundList.children[12].isBound = true;
	else
		myBackgroundList.children[11].isBound = true;
    }
}
function BlockMemoryUnitInsert()
{
    if (theMemoryInline.Visible)
    {
        theMemoryInline.children[0].theMemoryMonitor.blockInsertion = true;
    }
}

function UnblockMemoryUnitInsert()
{
    if (theMemoryInline.Visible)
    {
        theMemoryInline.children[0].theMemoryMonitor.blockInsertion = false;
    }
}

function BlockMemoryUnitEnumeration()
{
    if (theMemoryInline.Visible)
    {
        theMemoryInline.children[0].theMemoryMonitor.enumerationOn = false;
    }
}

function UnblockMemoryUnitEnumeration()
{
    if (theMemoryInline.Visible)
    {
        theMemoryInline.children[0].theMemoryMonitor.enumerationOn = false;
    }
}

