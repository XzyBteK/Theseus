function ReadValue(x, sectionconf2, chemin)
{
	var a = x;
	var info = new Settings;
	info.file = "X:\\2GAM.data\\" + chemin;
	info.section = sectionconf2;
	var c = info.GetValue(a);
	return c;
}

function SaveSetting(x,y,sectionsave2, chemin)
{
	var a = x;
	var b = y;
	var info = new Settings;
	info.file = pathdash + chemin;
	info.section = sectionsave2;
	var c = info.SetValue(a, b);
}

function SaveDashSettings()
{
	for(var g = 1; g < 160; g = g + 1)
	{
		SaveSetting(g, ScanneDD[g], "default", "disque.ini");
	}
}

function ReturnInteger(x)
{
	var a = x;
	var b = Math.abs(a);
	if(a.charCodeAt(0) == 45)
	{
		var c = b * 2;
		b = b - c;
	}
	return b;
}

function GetDashSettings()
{
	pathdash = "P:\\Dash2Gam\\2GAM.data\\";
	BackgroundUpdate = 1;
	Nbappli = 0;
	Nbapplipassword = 0;
	Nbaction = 0;
	Nbmenuconfig = 0;
	Nbmenudd = 0;
	ConfigNP = "pro";
	var g;
	for( g = 1; g < 120; g = g + 1)
	{
		Temp = ReadValue(g, "Systeme", "config_pro.ini");
		if (Temp != "")
			Systeme[g] = Temp;
		else
			g = 120;
	}
	for( g = 1; g < 120; g = g + 1)
	{
		Temp = ReadValue(g, "default", "Datas\\Config\\ConfigSysteme.xbc");
		if (Temp != "")
			ConfigSysteme[g] = Temp;
		else
			g = 120;
	}
	for( g = 1; g < 120; g = g + 1)
	{
		Temp = ReadValue(g, "default", "Datas\\Config\\ScreenSaver.xbc");
		if (Temp != "")
			ScreenSaver[g] = Temp;
		else
			g = 120;
	}
	for( g = 1; g < 120; g = g + 1)
	{
		Temp = ReadValue(g, "default", "Datas\\Config\\ConfigMusic.xbc");
		if (Temp != "")
			ConfigMusic[g] = Temp;
		else
			g = 120;
	}
	for( g = 1; g < 120; g = g + 1)
	{
