{
    function OnADown()
    {
	SSaver = 0;
      UpdateMessageButtonHighlight();
	if(onleft == false  & onright == false)
	{
     		if (nCurMessageButton != -1)
     		{
      	    	PlaySoundA();
      	     	if (nCurMessageButton == 0)
				OnQuestionYes();
      	     	else
      	     	OnQuestionNo();
     		}
	}
	if(onleft == true  & onright == false)
	{
		if ( ConfigBoutonsMainMenu[8] == "Photo_2GAM")
