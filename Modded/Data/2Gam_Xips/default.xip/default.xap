function updatetitre()
{
	var i = 0;
	var xx = 0;
	var zx = 0;
	if( NbMainMenu < 9)
		xx = 9;
	else
		xx = NbMainMenu;

	for ( i = 0; i < xx; i = i + 1)
	{
		TitreMenu[i] = " ";
		if( nCurMainMenuItem < 5)
		{
			nCurMainMenuValue[i] = i;
		}
		else if( nCurMainMenuItem > 4 & (nCurMainMenuItem + 4) < NbMainMenu)
		{
			zx = i + (nCurMainMenuItem - 4);
			nCurMainMenuValue[i] = zx;
		}
		else if(nCurMainMenuItem + 5 > NbMainMenu)
		{
			if (NbMainMenu < 9)
			{
				RotMainMenu = (nCurMainMenuItem - (NbMainMenu - 3))* 15;
				nCurMainMenuScroll = nCurMainMenuItem - (NbMainMenu - 3);
				nCurMainMenuPos = nCurMainMenuScroll;
				zx = i;
			}
			if (NbMainMenu > 8)
			{
				RotMainMenu = (nCurMainMenuItem - (NbMainMenu - 5))* 15;
				nCurMainMenuScroll = nCurMainMenuItem - (NbMainMenu - 5);
				nCurMainMenuPos = nCurMainMenuScroll;
				zx = i + (NbMainMenu - 9);
			}
			nCurMainMenuValue[i] = zx;
		}
	}
	UpdateTitreMenu();
}
function UpdateTitreMenu()
{
	var lgt = 0;
	var lgtt = 0;
	var i = 0;
	var ii = 3;
	for ( i = 0; i < NbMainMenu; i = i + 1)
	{
		if( ConfigMenusMainMenu[ii] == "... Menu Musiques ...")
			TitreMenu[i] = ReadValue(61, "default", "Datas\\Langues\\"+lang+".ini");
		else if( ConfigMenusMainMenu[ii] == "... Menu Memoire ...")
			TitreMenu[i] = ReadValue(62, "default", "Datas\\Langues\\"+lang+".ini");
		else if( ConfigMenusMainMenu[ii] == "... Menu Disque Dur ...")
			TitreMenu[i] = ReadValue(63, "default", "Datas\\Langues\\"+lang+".ini");
		else if( ConfigMenusMainMenu[ii] == "... Menu Configuration ...")
			TitreMenu[i] = ReadValue(64, "default", "Datas\\Langues\\"+lang+".ini");
		else
			TitreMenu[i] = ConfigMenusMainMenu[ii];

		ii = ii + 2;
		TitreMenu[i] = TitreMenu[i] + " ";
	}
	UpdateMainMenu();
}
function ScannSkins()
{
	NbSkins = 0;
	NSkins[0]="Neant";
	for(Temp = 0; Temp < 9; Temp = Temp + 1)
	{
		SkinInfo[Temp] = " ";
		SkinCreat[Temp] = " ";
		NSkins[Temp]=" ";
	}
	var c = new Folder;
	c.path = "P:\\Dash2Gam\\2GAM.data\\Skins";
	var cL = c.subFolders.length();
	if(cL > 0)
	{
		for(var cLo = 0; cLo < cL; cLo = cLo + 1)
		{
			var dossier = c.subFolders[cLo].name;
			var testpath = "P:\\Dash2Gam\\2GAM.data\\Skins\\" + dossier;
			var FileExists = theConfig.NtFileExists( testpath + "\\Skin.ini" );
			if ( FileExists == true )
			{
				NbSkins = NbSkins + 1; 
				SkinInfo[NbSkins] = "";
				SkinCreat[NbSkins] = "";
				NSkins[NbSkins] = dossier;
				Temp = ReadValue("Auteur", "default", "Skins\\"+NSkins[NbSkins]+"\\Skin.ini");
				if (Temp != "")
					SkinInfo[NbSkins] = Temp;

				Temp = ReadValue("DateCreat", "default", "Skins\\"+NSkins[NbSkins]+"\\Skin.ini");
				if (Temp != "")
					SkinCreat[NbSkins] = Temp;

			}
 		}
	}
	SetSkins = true;
}
function ReadModeSkin()
{
	Temp = ReadValue("Skin", "default", "Datas\\data.xbc");
	if (Temp == "rnd")
	{
		Temp = ReadValue("Change", "default", "Datas\\data.xbc");
		if (Temp != "true")
			RndSkins();
		else
			SaveSetting("Change","false","default", "Datas\\data.xbc");
	}
	for (var a = 1; a < NbSkins + 1; a = a + 1)
	{
		if ( NSkins[a] == Systeme[4] )
			CurentSkin = a;
	}
	if (Temp == "cont")
	{
		Temp = ReadValue("Change", "default", "Datas\\data.xbc");
		if (Temp != "true")
			SwitchSkins();
		else
			SaveSetting("Change","false","default", "Datas\\data.xbc");
	}
}
function RndSkins() 
{
	Temp = Math.round(Math.random() * NbSkins) + 1;
	for (var a = 1; a < Temp  + 1; a = a + 1)
	{
		rndskin = Math.round(Math.random() * NbSkins) + 1;
	}
	TestSkin();
}

function TestSkin()
{
	if(NSkins[rndskin] == Systeme[4] & NbSkins > 1)
	{
		RndSkins();
	}
	else
	{
		SaveSetting("Change","true","default", "Datas\\data.xbc");
		CurSkinsPanelSelected = rndskin - 1;
		SkinsPanelItemScroll = 0;
		ChangeSkins();
	}
}
function SwitchSkins()
{
	SaveSetting("Change","true","default", "Datas\\data.xbc");
	CurentSkin = CurentSkin + 1;
	if ( CurentSkin > NbSkins )
		CurentSkin = 1;

	if ( NbSkins == 1 )
		return;

	CurSkinsPanelSelected =	CurentSkin - 1;
	SkinsPanelItemScroll = 0;
	ChangeSkins();
}
function ModeUnique()
{
	SaveSetting("Skin","fixe","default", "Datas\\data.xbc");
	ChangeSkins();
}

function ChangeSkins()
{
	var ledseq = "";
	Temp = NSkins[CurSkinsPanelSelected+1+SkinsPanelItemScroll];
	ledseq = ReadValue("Led", "default", "Skins\\"+Temp+"\\Skin.ini");
	if (ledseq == "")
		ledseq = SaveLed;

	SaveSetting("LedSequence",ledseq,"LED", "config_pro.ini");
	Temp = NSkins[CurSkinsPanelSelected+1+SkinsPanelItemScroll];
	SaveSetting(4,Temp,"Systeme", "config_pro.ini");
	Restart();
}
function ScannDD()
{
	var tt;
	var ttt;
	TailleDD[0] = 0;
	num = 0;
	for(var cn = 1; cn < Nbmenudd + 1; cn = cn + 1)
	{
		TailleDD[cn] = 0;
		taille = 0;
		tt = "";
		ttt = "";
		if (ConfigNP == "novice")
		{
			for(var i = 1; i < MenusDD[Nbmenudd + cn] + 1; i = i + 1)
			{
				tt = ReadValue("Patch" + i, "Section"+ cn, "config.ini");
				ttt = "default.xbe";
				ScannDDReadValues(tt,ttt);
			}
		}
		else
		{
			for(var i = 1; i < MenusDD[Nbmenudd + cn] + 1; i = i + 1)
			{
				var b = i * 2;
				tt = ReadValue(b, "MenuLancementDD_"+ cn + "_2GAM", "Datas\\Config\\MenuLancementDD.xbc");
				ttt = ReadValue(b + 1, "MenuLancementDD_"+ cn + "_2GAM", "Datas\\Config\\MenuLancementDD.xbc");
				if( ttt != "Applications" )
				{
					ScannDDReadValues(tt,ttt);
				}
				else if( ttt == "Applications" )
				{
					NumAppli = 1;
					for(var ii = 1; ii < Nbappli + 1; ii = ii + 1)
					{
						if( tt == Applications[NumAppli])
						{
							ScanneDD[num] = Applications[NumAppli];
							ScanneDD[num+1] = Applications[NumAppli + 1];
							ScanneDD[num+2] = Applications[NumAppli + 2];
							ScanneDD[num+3] = Applications[NumAppli + 3];
							num = num + 4;
							taille = taille + 1;
						}
						NumAppli = NumAppli + 4;
					}
				}
			}
		}
		TailleDD[cn] = taille*4;
	}
	var info = new Settings;
	info.file = "X:\\2GAM.data\\Datas\\ScannDD.xbx";
	info.section = "default";
	if (ConfigNP == "novice")
		var c = info.SetValue("Config", "novice");
	else
		var c = info.SetValue("Config", "pro");

	var c = info.SetValue("Nbmenudd", Nbmenudd);
	info.section = "MenuDD";
	for(var g = 1; g < Nbmenudd + 1; g = g + 1)
	{
		var c = info.SetValue(g, MenusDD[g]);
	}
	info.section = "TailleDD";
	for(var g2 = 1; g2 < Nbmenudd + 1; g2 = g2 + 1)
	{
		var c = info.SetValue(g2, TailleDD[g2]);
	}
	info.section = "ScanneDD";
	for(var g3 = 0; g3 < num ; g3 = g3 + 1)
	{
		var c = info.SetValue(g3, ScanneDD[g3]);
	}
}
DEF outils Filestools

function ScannDDReadValues(ww,xx)
{
	var tailleC;
	var tailleE;
	var tailleF;
	var tailleG; 
	tailleC = 0;
	tailleE = 0;
	tailleF = 0;
	tailleG = 0;
	var tt;
	tt = "";
	var fD = ww;
	var exec = xx;
	var c = new Folder;
	c.path = "C:\\" + fD;
	var cL = c.subFolders.length();
	    if(cL > 0)
	    {
	 	for(var cLo = 0; cLo < cL; cLo = cLo + 1)
	 	{
			var dossier = c.subFolders[cLo].name;
			var testpath = "C:\\" + fD + "\\" + dossier;
			var FileExists = theConfig.NtFileExists( testpath + "\\" + exec );
			if ( FileExists == true )
			{
				tt = outils.GetXBETitle("C:\\" + fD + "\\" + dossier +"\\" + exec);
                        NetDossier(tt);
				ScanneDD[num] = netdossier+"¤"+dossier;
				ScanneDD[num+1] = "C:";
				ScanneDD[num+2] = fD + "\\" + c.subFolders[cLo].name;
	 			ScanneDD[num+3] = exec;
				num = num + 4;
				tailleC=tailleC+1; 
			}
	 	}
	    }
	var e = new Folder;
	e.path = "E:\\" + fD;
	var eL = e.subFolders.length();
	    if(eL > 0)
	    {
	 	for(var eLo = 0; eLo < eL; eLo = eLo + 1)
	 	{
			var dossier = e.subFolders[eLo].name;
			var testpath = "E:\\" + fD + "\\" + dossier;
			var FileExists = theConfig.NtFileExists( testpath + "\\" + exec );
			if ( FileExists == true )
			{	                                
			      tt = outils.GetXBETitle("E:\\" + fD + "\\" + dossier +"\\" + exec);
                        NetDossier(tt);                       	                                
                        ScanneDD[num] = netdossier+"¤"+dossier;
				ScanneDD[num+1] = "E:";
				ScanneDD[num+2] = fD + "\\" + e.subFolders[eLo].name;
	 			ScanneDD[num+3] = exec;
			      num = num + 4;
				tailleE=tailleE+1; 
                       }
	 	}
	    }
	var f = new Folder;
	f.path = "F:\\" + fD;
	var fL = f.subFolders.length();
	    if(fL > 0)
	    {
	 	for(var fLo = 0; fLo < fL; fLo = fLo + 1)
	 	{
			var dossier = f.subFolders[fLo].name;
			var testpath = "F:\\" + fD + "\\" + dossier;
			var FileExists = theConfig.NtFileExists( testpath + "\\" + exec );
			if ( FileExists == true )
			{
				tt = outils.GetXBETitle("F:\\" + fD + "\\" + dossier +"\\" + exec);
                        NetDossier(tt);
				ScanneDD[num] = netdossier+"¤"+dossier;
				ScanneDD[num+1] = "F:";
				ScanneDD[num+2] = fD + "\\" + f.subFolders[fLo].name;
	 			ScanneDD[num+3] = exec;
				num = num + 4;
				tailleF=tailleF+1;
			}
	 	}
	    }
	var g = new Folder;
	g.path = "G:\\" + fD;
	var gL = g.subFolders.length();
	    if(gL > 0)
	    {
	 	for(var gLo = 0; gLo < gL; gLo = gLo + 1)
	 	{
			var dossier = g.subFolders[gLo].name;
			var testpath = "G:\\" + fD + "\\" + dossier;
			var FileExists = theConfig.NtFileExists( testpath + "\\" + exec );
			if ( FileExists == true )
			{
				tt = outils.GetXBETitle("G:\\" + fD + "\\" + dossier +"\\" + exec);
                        NetDossier(tt);
				ScanneDD[num] = netdossier+"¤"+dossier;
				ScanneDD[num+1] = "G:";
				ScanneDD[num+2] = fD + "\\" + g.subFolders[gLo].name;
	 			ScanneDD[num+3] = exec;
				num = num + 4;
				tailleG=tailleG+1;
			}
	 	}
	    }
	taille = taille + tailleC + tailleE + tailleF + tailleG; 
	return taille;
}

function NetDossier(nom)
{
	var dossier = nom;
	netdossier = "";
	var lgt = dossier.length();
	for(var nd = 0; nd < lgt; nd = nd +1)
	{
		if ( dossier.substring(nd ,nd + 1) != "_")
		{
			netdossier = netdossier + dossier.substring(nd ,nd + 1);
		}
		else
		{
			netdossier = netdossier + " ";
		}
	}
	return netdossier;
}

