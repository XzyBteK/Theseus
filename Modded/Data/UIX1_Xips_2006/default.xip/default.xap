function ShowBgMesh1( bgMesh1 )
{



var info = new Settings;
 info.file = bgMesh1 + ".xbx";
info.section = "mesh1";
     var scale1x = info.GetValue("Scalex");
     var scale1y = info.GetValue("Scaley");
     var scale1z = info.GetValue("Scalez");
     var trans1x = info.GetValue("Transx");
     var trans1y = info.GetValue("Transy");
     var trans1z = info.GetValue("Transz");
     var sMaterial1 = info.GetValue("Material");
     var sMaterial1S = info.GetValue("MaterialS");
     var alpha1 = info.GetValue("Alpha");
     var rot11 = info.GetValue("Rot1");
     var rot12 = info.GetValue("Rot2");
     var rot13 = info.GetValue("Rot3");
     var rot14 = info.GetValue("Rot4");
info.section = "mesh3";
     var scale3x = info.GetValue("Scalex");
     var scale3y = info.GetValue("Scaley");
     var scale3z = info.GetValue("Scalez");
     var trans3x = info.GetValue("Transx");
     var trans3y = info.GetValue("Transy");
     var trans3z = info.GetValue("Transz");
     var sMaterial3 = info.GetValue("Material");
     var sMaterial3S = info.GetValue("MaterialS");
     var alpha3 = info.GetValue("Alpha");
     var rot31 = info.GetValue("Rot1");
     var rot32 = info.GetValue("Rot2");
     var rot33 = info.GetValue("Rot3");
     var rot34 = info.GetValue("Rot4");

info.section = "mesh5";
     var scale5x = info.GetValue("Scalex");
     var scale5y = info.GetValue("Scaley");
     var scale5z = info.GetValue("Scalez");
     var trans5x = info.GetValue("Transx");
     var trans5y = info.GetValue("Transy");
     var trans5z = info.GetValue("Transz");
     var sMaterial5 = info.GetValue("Material");
     var sMaterial5S = info.GetValue("MaterialS");
     var alpha5 = info.GetValue("Alpha");
     var rot51 = info.GetValue("Rot1");
     var rot52 = info.GetValue("Rot2");
     var rot53 = info.GetValue("Rot3");
     var rot54 = info.GetValue("Rot4");




var x = theMainMenu.children[0].children[0];
x.theMesh_a1.children[0].children[1].children[0].appearance.material.name = sMaterial1S;
x.theMesh_a1.children[0].children[0].children[0].appearance.material.name = sMaterial1;
x.theMesh_a3.children[0].children[1].children[0].appearance.material.name = sMaterial3S;
x.theMesh_a3.children[0].children[0].children[0].appearance.material.name = sMaterial3;
x.theMesh_a5.children[0].children[1].children[0].appearance.material.name = sMaterial5S;
x.theMesh_a5.children[0].children[0].children[0].appearance.material.name = sMaterial5;
x.theMesh_a1.children[0].children[1].children[0].geometry.url = bgMesh1 + "_sides.xm";
x.theMesh_a1.children[0].children[0].children[0].geometry.url = bgMesh1 + ".xm";
x.theMesh_a3.children[0].children[1].children[0].geometry.url = bgMesh1 + "_sides.xm";
x.theMesh_a3.children[0].children[0].children[0].geometry.url = bgMesh1 + ".xm";
x.theMesh_a5.children[0].children[1].children[0].geometry.url = bgMesh1 + "_sides.xm";
x.theMesh_a5.children[0].children[0].children[0].geometry.url = bgMesh1 + ".xm";
x.theMesh_a1.SetScale(scale1x, scale1y, scale1z);
x.theMesh_a3.SetScale(scale3x, scale3y, scale3z);
x.theMesh_a5.SetScale(scale5x, scale5y, scale5z);
x.theMesh_a1.SetRotation(rot11, rot12, rot13, rot14);
x.theMesh_a3.SetRotation(rot31, rot32, rot33, rot34);
x.theMesh_a5.SetRotation(rot51, rot52, rot53, rot54);
x.theMesh_a1.fade = 1.0;
x.theMesh_a3.fade = 1.0;
x.theMesh_a5.fade = 1.0;
x.theMesh_a1.SetTranslation(trans1x, trans1y, trans1z);
x.theMesh_a3.SetTranslation(trans3x, trans3y, trans3z);
x.theMesh_a5.SetTranslation(trans5x, trans5y, trans5z);
x.theMesh_a1.fade = 0.75;
x.theMesh_a3.fade = 0.75;
x.theMesh_a5.fade = 0.75;
x.theMesh_a1.SetAlpha(alpha1);
x.theMesh_a3.SetAlpha(alpha3);
x.theMesh_a5.SetAlpha(alpha5);

thePlayerPanelOut.Play();
 }

