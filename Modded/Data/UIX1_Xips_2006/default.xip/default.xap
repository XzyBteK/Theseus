    var c = theFileManagerLayerInline.children[0];
    c.MessagePanel.SetRotation(0, 0, 1, 1.5);
    c.MessagePanel.SetAlpha(0.0);
    theFileManagerJoystick.isBound = false;
    theFileManagerLayer.transparency = 1;
