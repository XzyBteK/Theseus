function EnableAudio()
{
    if( musicOnBoot == true )
    {  
        StartBackGroundMusicPlayer(); 
        musicOnBoot = false;
    }
    else if( musicOnBoot == false )
    {
        if( theMusicPlayer.transportMode == 1 ) { return; }
        else { EnableAmbientAudio(); }
    }
}

