function InGo( x )
{
var f_gb_mb = x / 1000;
var f_gb = Math.round(f_gb_mb);
if ( f_gb > f_gb_mb ) { f_gb = f_gb - 1; }
var f_mb = (f_gb_mb - f_gb) * 100;
var f_mb_r = Math.round(f_mb);
if (f_mb_r < 10) { return f_gb + ".0" + f_mb_r; }
else { return f_gb + "." + f_mb_r; }
}
function ChangeTheOrb(orb, sMaterial)
{
       var c = theMainMenu.children[0].children[0];
       c.Modded_Orb.visible = false;
       c.Stock_Orb.visible = false;
       c.cellorb.visible = false;
       c.gasorb.visible = false;
       c.gasorb.children[0].children[0].geometry.url = orb;
       if (sMaterial != "")
       {
           c.gasorb.children[0].children[0].appearance.material.name = sMaterial;
       }
       c.gasorb.visible = true;
}


