DEF theScreenSaver ScreenSaver
{
	function OnStart()
	{
		theScreen.brightness = 0.1;
		if(thcorb | btHcScreenSaver)
		{
			StartScreenSaverView();
		}
	}
	
	function OnEnd()
	{
		theScreen.brightness = 1;
		bManualScreenSaverView = false;
		if(thcorb | btHcScreenSaver)
		{
			StopScreenSaverView();
		}
	}
	function OnDelay2() {StartScreenSaverView();}
	function OnDelay3() {StartScreenSaverView();}
}

