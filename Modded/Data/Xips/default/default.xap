}

DEF theDVDPlayerInline Inline
{
	visible false
	url "dvd.xap"

	function onLoad()
	{
		theDVDPlayerInline.children[0].theDVDLevel.GoTo();
	}
}

DEF theDiscDrive DiscDrive
{
	function OnDiscRemoved()
	{
		if (theDVDPlayerInline.visible)
		{
			bShowDVDStopBackground = false;
			theDVDPlayerInline.children[0].theDVDPlayer.stop();
			theDVDPlayerInline.children[0].ClearOnScreenInfo();

			if (g_bPanelDisplayed)
			{
				CloseMessage();
			}

			theLauncherLevel.GoTo();
			return;
		}
		else if (theMusicInline.visible)
		{
			var c = theMusicInline.children[0];
			
			ClosePopup();
			
			if (c.musicSelect != 0) // Not Audio CD
			{
				return;
			}
			
			if (c.theMusicPlayMenu.visible)
			{
				// Update track in the player
				c.DoMusicStop();
				c.InitPlaylist();
				c.UpdateTrackList();
			}
			else if (c.theMusicCopyMenu.visible)
			{
				c.theMusicCollection.error = 3; // Disc ejected
				c.OnMusicCopyComplete();
			}
			else if (c.theMusicMenu.visible)
			{
				// Update numbers of tracks and total time
				c.UpdateMusicMetaData();
			}
		}
		else
		{
			var strYesFunction = strMessageYesFunction;
			if (strYesFunction != "")
				eval(strYesFunction);

			CloseMessage();
		}
	}
	
	function OnDiscInserted()
	{
		var a = GetSavedBooleanValue("default","AutoLaunchMedia");
		if(a == true)
		{
			AutoLaunch();
		}
		else
		{
			var stra;
			if(theDiscDrive.discType == "Audio")
			{
				stra = Translate("AUTOLAUNCH_AUDIO_ASK");
			}
			else if(theDiscDrive.discType == "Video")
			{
				stra = Translate("AUTOLAUNCH_VIDEO_ASK");
			}
			else if(theDiscDrive.discType == "Title")
			{
				stra = Translate("AUTOLAUNCH_TITLE_ASK");
			}
			else if(theDiscDrive.discType == "unknown")
			{
				stra = Translate("AUTOLAUNCH_UNKN_ASK");
			}
			AskQuestion(stra,"theDiscDrive.AutoLaunch()","",1);
		}
	}
	
	function AutoLaunch()
	{
		if (discType == "Audio")
		{
			LogOff();   // PS Bug #33608 You are still seen as Online when playing an Audio CD
						// PS Bug #33611 You can hear Live Now notification sounds while playing Audio CD

			if (theMusicInline.visible == false)
			{
				ClosePopup();
				nCurMainMenuItem = nMusicButton;   // select music when backing up
				StartCDPlayer();
				return;
			}

			var c = theMusicInline.children[0];

			if (c.theMusicPlayMenu.visible) // We are in the music play menu
			{
				if (c.musicSelect == 0) // Already in audio CD player
				{
					if (c.bMusicMenuVisible)
					{
						c.theMusicPlayMenu.GoTo();
						c.StartMusicPlayer();
						c.DoMusicPlayPause();
					}
					else
					{
						c.DoMusicStop();
						c.InitPlaylist();
						c.UpdateTrackList();
						if (c.visualizerViewpoint.isBound)
							c.DoMusicPlayPause();
					}
				}
				else if (c.theMusicPlayer.transportMode != 1) // Let's play the disc if no soundtrack is playing
				{
					bGoToCDPlayer = true;
					EnableInput(false);
					c.theMusicMenu.GoBackTo();
				}
			}
			else if (c.theMusicMenu.visible == true)
			{
				ClosePopup();
				bGoToCDPlayer = true;
				EnableInput(false);
				c.StartMusicLevel();
			}
			else
			{
				ClosePopup();
				bGoToCDPlayer = true;
				EnableInput(false);
				c.theMusicMenu.GoTo();
			}
		}
		else if (discType == "Video")
		{
			theLauncherLevel.GoTo();
		}
		else if (discType == "Title")
		{
			theLauncherLevel.GoTo();
		}
		else if (discType == "unknown")
		{
			BlockUser("ERROR MESSAGE 1");
		}
	}
}

function StartDVDPlayer()
{
	log("Starting the DVD player!");
	theDVDPlayerInline.visible = true;
}

function StartCDPlayer()
{
	log("Should start the CD player now!");
	bGoToCDPlayer = true;
	EnableInput(false); // music.xap will re-enable it again if bGoToCDPlay is true
	GoToMusic();
}

DEF theTranslator Translator
DEF theOverlayAlert OverlayAlert

function ShowAlert(msg)
{
	theOverlayAlert.Show(msg);
}

function Translate(text)
{
	var MatchWord = text.toUpperCase();
	if(theConfig.NtFileExists("\\Device\\Harddisk0\\Partition2\\UIX Configs\\xlate.ini"))
	{
		var Languages = new Array( "ENGLISH","JAPANESE","DEUTSCH","FRANCAIS","ESPANOL","ITALIANO","KOREAN","CHINESE","PORTUGUAS");
		var index = Math.max(0,theConfig.GetLanguage() - 1);
		XlateFile.section = Languages[index];
		var xlate = XlateFile.GetValue(MatchWord);
		if(xlate == "") xlate = XlateFile.GetValue(text);
		if(xlate != "") return ParseEscapedChars(xlate);
	}
	else
	{
		if(MatchWord == "MEMORY") { return "Memory"; }
		else if(MatchWord == "MUSIC") { return "Music"; }
		else if(MatchWord == "LAUNCHER") { return "Launcher"; }
		else if(MatchWord == "INSIGNIA") { return "Insignia"; }
		else if(MatchWord == "CONFIGURATION") { return "UIX Settings"; }
		else if(MatchWord == "SKINS") { return "Skins"; }
		else if(MatchWord == "CLOCK") { return "Clock"; }
		else if(MatchWord == "LANGUAGE") { return "Language"; }
		else if(MatchWord == "AUDIO") { return "Audio"; }
		else if(MatchWord == "VIDEO") { return "Video"; }
		else if(MatchWord == "NETWORK") { return "Network"; }
		else if(MatchWord == "LIVE TODAY") { return "Live Today"; }
		else if(MatchWord == "PARENTAL CONTROL") { return "Parental Control"; }
		else if(MatchWord == "AUTO OFF") { return "Auto Off"; }
		else if(MatchWord == "SYSTEM INFO") { return "System Info"; }
		else if(MatchWord == "AUTOLAUNCH_AUDIO_ASK") { return "\nAn Audio CD has been inserted.\n\nDo you wish to play it?"; }
		else if(MatchWord == "AUTOLAUNCH_VIDEO_ASK") { return "\nA DVD movie has been inserted.\n\nDo you wish to watch it?"; }
		else if(MatchWord == "AUTOLAUNCH_TITLE_ASK") { return "\nAn Xbox title has been inserted.\n\nDo you wish to launch it?"; }
		else if(MatchWord == "AUTOLAUNCH_UNKN_ASK") { return "\nAn Unknown disk type has been inserted.\n\nDo you wish to try to launch it and see what happens??"; }
		else if(MatchWord == "ASSIGNED_QUICKLAUNCH") { return "Selected item assigned to QuickLaunch"; }
		else if(MatchWord == "INDEXING_PARTITION") { return "Indexing the harddisk's extended partitions. This could take several seconds.\n\nPlease Wait..."; }
		else if(MatchWord == "SETTINGS_CHANGED") { return "You will need to reload before the new settings will take effect.\n\nWould you like to reload now?"; }
		else if(MatchWord == "POWER_OFF") { return "This will power off the Xbox.\n\nDo you wish to continue?"; }
	}
	return theTranslator.Translate(text);
}

var unicode;
function ParseEscapedChars(sText)
{
	var Chars = new Array("\\n","\\t","\\u");
	for(var x = 0; x < Chars.length; x = x + 1)
	{
		if(sText.indexOf(Chars[x]) >= 0)
		{
			var arrTemp = Split(sText,Chars[x]);
			var sRet;
			if(arrTemp.length > 0)
			{
				sRet = arrTemp[0];
				for(var i = 1; i < arrTemp.length; i = i + 1)
				{
					if(x == 0) { sRet = sRet + "\n" + arrTemp[i];}
					else if(x == 1) { sRet = sRet + "\t" + arrTemp[i]; }
					else if(x == 2) 
					{
						var tmp = "\\u" + arrTemp[i].substr(0,4);
						eval("unicode = \"" + tmp + "\"");
						sRet = sRet + unicode + arrTemp[i].substr(4);
					}
				}
				return sRet;
			}
		}
	}
	return sText;
}

