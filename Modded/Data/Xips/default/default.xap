		c.MainMenu_Test_MemoryPanel.SetRotation(-0.987000, -0.108000, 0.072000, -1.556000);
	}
	else if(nMainMenuPanelsFloatPhase == 6)
	{
		c.theMainMenuClock.SetRotation(0.014000, -0.030000, -1.000000, 0.030000);
		c.theMainMenuInfo2.SetRotation(-0.992500, -0.092000, 0.066000, -1.572000);
		c.MainMenu_Test_MemoryPanel.SetRotation(-0.989000, -0.105000, 0.058000, -1.560000);
	}
	else if(nMainMenuPanelsFloatPhase == 7)
	{
		c.theMainMenuClock.SetRotation(0.007000, -0.015000, -1.000000, 0.025000);
		c.theMainMenuInfo2.SetRotation(-0.993100, -0.090000, 0.067000, -1.574000);
		c.MainMenu_Test_MemoryPanel.SetRotation(-0.991000, -0.096000, 0.064000, -1.568000);
	}
	else if(nMainMenuPanelsFloatPhase == 8)
	{
		c.theMainMenuClock.SetRotation(0, 0, -1000.1, 0.02);
		c.theMainMenuInfo2.SetRotation(-0.993700, -0.088440, 0.068970, -1.576000);
