	}
	else if(nMainMenuPanelsFloatPhase == 9)
	{
		c.theMainMenuClock.SetRotation(-0.009000, 0.006000, -1.000000, 0.015000);
		c.theMainMenuInfo2.SetRotation(-0.994300, -0.086000, 0.067000, -1.578000);
		c.MainMenu_Test_MemoryPanel.SetRotation(-0.996000, -0.081000, 0.064000, -1.584000);
	}
	else if(nMainMenuPanelsFloatPhase == 10)
	{
		c.theMainMenuClock.SetRotation(-0.018000, 0.012000, -1.000000, 0.010000);
