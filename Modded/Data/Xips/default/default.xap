		c.MainMenu_Test_MemoryPanel.SetRotation(-0.999000, -0.064000, 0.052000, -1.604000);
	}
	else if(nMainMenuPanelsFloatPhase == 13)
	{
		c.theMainMenuClock.SetRotation(-0.023000, 0.025000, -0.999500, 0.005000);
