function initialize()
{
	sBuildDate = "250605"; //Date of commit YYMMDD
	bLaunchItem = false;
	bExecuteFile = false;
	bHDDInitialize = false;
	bHDDInitializing = false;
	bHDDInitialized = false;
	RightThumb = false;
	LeftThumb = false;
	LeftTrigger = false;
	RightTrigger = false;
	bBackToSettings = false;
	bBackToDVDPlayer = false;
	bGoToCDPlayer = false;
	bBackToLauncher = false;
	bShowErrorPanel = false;
	bShowLegalInfo = false;
	bShowInvalidDisc = false;
	//bShowInvalidDiscWithNav = false;
	bShowNoDongleMessage = false;
	bOutOfBoxFlow = false;
	bMainMenuAttractFinish = false;
	bBgMusicPanelTextScroll = false;
	nBgMusicPanelTextScrollTick = 0;
	BgMusicPanelTextNode = "";
	nMainMenuPanelsFloatTick = 0;
	nMainMenuPanelsFloatPhase = 0;
	nMainMenuPanelsSpinTick = 0;
	nMainMenuPanelsSpinPhase = 0;
	bMainMenuPanelsSpinActive = false;
	nMainMenuDateSpinTick = 0;
	nMainMenuDateSpinPhase = 0;
	bMainMenuDateSpinActive = false;
	nMainMenuPanelSelection = 1;
	nClockInfoPanelPage = 1;
	bManualScreenSaverView = false;
	nMusicButton = 1;
	nXOLineButton = 2;
	nCurMainMenuItem = 2; // start with music selected
	g_bKeyboardDisplayed = false;
	g_bPanelDisplayed = false;
	g_bAboutToReboot = false;
	//g_bAboutToRebootToOnline = false;
	//g_bAboutToLaunchGame = false;
	bShowDVDStopBackground = true;
	bCleanupSpecifiedDrive = false;
	nSettingArea = 0;
	nTime = 1.4;
	g_nRec = 0;
	strMessageYesFunction = "";
	strMessageNoFunction = "";
	strKeyboardDoneFunction = "";
	strKeyboardCancelFunction = "";
	g_theMainMenuLoaded = false;
	g_theMessageLayerLoaded = false;
	g_nCurrentAccountSelected = 0;
	strEntryPointInternalDestination = "";
	g_bLiveTodayFadeIn = false;
	g_nLastActivePort = 0;
	g_bFirstSignIn = false;
	g_bResetDiscDeferredNotification = false;
	g_bLeaveDriveLocked = false;
	g_bLeaveMemoryUnitsBlocked = false;
	version = new Settings;
	ConfigFile = new Settings;
	CacheFile = new Settings;
	XlateFile = new Settings;
	IconFile = new Settings;
	TitleNamesFile = new Settings;
	version.file = "C:\\version";
	version.SetValue("version","0.5." + sBuildDate);
	ConfigFile.file = "C:\\UIX Configs\\config.ini";
	CacheFile.file = "C:\\UIX Configs\\cache.ini";
	XlateFile.file = "C:\\UIX Configs\\xlate.ini";
	IconFile.file = "C:\\UIX Configs\\icons.ini";
	TitleNamesFile.file = "C:\\UIX Configs\\TitleNames.ini";

	thcorb = (GetSavedValue("default","MainOrbStyle") == "tHc");
	ShowInsignia = GetSavedBooleanValue("default","ShowInsignia");
	btHcScreenSaver = GetSavedBooleanValue("default","UsetHcScreenSaver");
	bUseMainMenuAttract = GetSavedBooleanValue("default","UseMainMenuAttract");
	bUseUnderlay = GetSavedBooleanValue("default","UseListUnderlay");
	bSkinExists = theConfig.NtFileExists("\\Device\\Harddisk0\\Partition2\\xboxdashdata.185ead00\\Skin.xip");
	bPresence = theConfig.NtFileExists("\\Device\\Harddisk0\\Partition2\\Discord Presence\\Discord.xbe");
	bPresenceEnabled = GetSavedBooleanValue("DiscordPresence","PresenceEnabled");
	if(bPresence){
		if(GetSavedValue("DiscordPresence","PresenceEnabled") == "") SetSavedBooleanValue("DiscordPresence","PresenceEnabled",false);
		Discord = new Settings;
		Discord.file = "C:\\Discord Presence\\shortcut.ini";
		Discord.section = "Shortcut";
		var currentPath = Discord.GetValue("Path");
		var sDashboard = "c:\\xboxdash.xbe";
		if (theConfig.NtFileExists("\\Device\\Harddisk0\\Partition2\\xb0xdash.xbe")) sDashboard = "c:\\xb0xdash.xbe";
		if(bPresenceEnabled & currentPath.toLowerCase() != sDashboard) 
		{
			Discord.SetValue("Path",sDashboard); 
			launch("Discord.xbe","\\Device\\Harddisk0\\Partition2\\Discord Presence"); 
		}
	}
	if(GetSavedValue("ShowInSettings","Configuration") == "") SetSavedBooleanValue("ShowInSettings","Configuration",true);
	if(GetSavedValue("ShowInSettings","StartFTP") == "") SetSavedBooleanValue("ShowInSettings","StartFTP",false);
	if(GetSavedValue("ShowInSettings","Reboot") == "") SetSavedBooleanValue("ShowInSettings","Reboot",true);
	if(GetSavedValue("ShowInSettings","Shutdown") == "") SetSavedBooleanValue("ShowInSettings","Shutdown",true);
	ShowMemoryInSettings = GetSavedBooleanValue("ShowInSettings","Memory");
	ShowMusicInSettings = GetSavedBooleanValue("ShowInSettings","Music");
	ShowXOnlineInSettings = GetSavedBooleanValue("ShowInSettings","XOnline");
	ShowLauncherInSettings = GetSavedBooleanValue("ShowInSettings","Launcher");
	ShowConfigInSettings = GetSavedBooleanValue("ShowInSettings","Configuration");
	ShowStartFTPInSettings = GetSavedBooleanValue("ShowInSettings","StartFTP");
	ShowRebootInSettings = GetSavedBooleanValue("ShowInSettings","Reboot");
	ShowShutdownInSettings = GetSavedBooleanValue("ShowInSettings","Shutdown");
	
	DriveLocations = new Array("C:\\","E:\\");
	PartitionLocations = new Array("\\Device\\Harddisk0\\Partition2\\","\\Device\\Harddisk0\\Partition1\\");
	bPartitionScanCompleted = GetSavedBooleanValue("ExtendedPartitions","PartitionScanCompleted");
	if(bPartitionScanCompleted)
	{
		bPartitionScanCompleted = theConfig.NtFileExists("C:\\UIX Configs\\cache.ini");
		if(bPartitionScanCompleted)
		{
			nPartitions = StringToNumber(GetSavedValue("ExtendedPartitions","Partitions"));
			bHasExtendedPartition = nPartitions > 0;
			if(nPartitions & 1) { PartitionLocations[PartitionLocations.length] = "\\Device\\Harddisk0\\Partition6\\"; DriveLocations[DriveLocations.length] = "F:\\"; }
			if(nPartitions & 2) { PartitionLocations[PartitionLocations.length] = "\\Device\\Harddisk0\\Partition7\\"; DriveLocations[DriveLocations.length] = "G:\\"; }
			if(nPartitions & 4) { PartitionLocations[PartitionLocations.length] = "\\Device\\Harddisk1\\Partition6\\"; DriveLocations[DriveLocations.length] = "H:\\"; }
			if(nPartitions & 8) { PartitionLocations[PartitionLocations.length] = "\\Device\\Harddisk1\\Partition7\\"; DriveLocations[DriveLocations.length] = "I:\\"; }
			if(nPartitions & 16) { PartitionLocations[PartitionLocations.length] = "\\Device\\Harddisk1\\Partition1\\"; DriveLocations[DriveLocations.length] = "R:\\"; }
		}
	}

	theAmbientSound0.Play();
	theAmbientSound1.Play();
	theAmbientSound2.Play();
	
	var nLanguage = theConfig.GetLanguage();
	if (nLanguage != 0) nLanguage = nLanguage - 1;
	theTranslator.SetLanguage(nLanguage);
	
	if(bSkinExists)
	{
		theTranslator.SetLanguage(0); //Bootloop if language is not English when loading skin.
		GoToSkin();
	}
	else
	{
		MainInitPart2();
	} 
}

function MainInitPart2()
{
	var nLanguage = theConfig.GetLanguage();
	if (nLanguage != 0) nLanguage = nLanguage - 1;
	theTranslator.SetLanguage(nLanguage);
	
	// Figure out if we need to display 3, 4, or 5 items on the main menu
	g_TotalMenuItems = GetSavedValue("MainMenu","MainMenuItems");
	GetMainMenuButtons();
	
	//bAcceptedLegalInfo = theConfig.GetAcceptedLegalInfo();
	bForceSetLanguage = theConfig.ForceSetLanguage();
	bForceSetTimeZone = theConfig.ForceSetTimeZone();
	bForceSetClock = theConfig.ForceSetClock();
	

	
	MainInitPart3();
}

function MainInitPart3()
{
	var reason = theConfig.GetLaunchReason();
	if(reason.length() > 0) bUseMainMenuAttract = false;
	if (reason == "Error")
	{
		EnableInput(true);
		theMainMenu.GoTo();
		EnableAmbientAudio();
		bShowErrorPanel = true;
	}
	else if (reason == "Memory")
	{
		if (theConfig.CanDriveBeCleanup(theConfig.GetLaunchParameter1()))
		{
			bCleanupSpecifiedDrive = true;
		}

		bBackToLauncher = true;
		EnableInput(true);
		EnableAmbientAudio();
		GoToMemory();
	}
	else if (reason == "Settings")
	{
		bBackToLauncher = true;
		nSettingArea = theConfig.GetLaunchParameter1();
		EnableInput(true);
		EnableAmbientAudio();
		GoToSettings();
	}
	else if (reason == "Music")
	{
		bBackToLauncher = true;
		EnableInput(true);
		EnableAmbientAudio();
		GoToMusic();
	}
	else if (theDiscDrive.discType == "Video")
	{
		EnableInput(true);
		StartDVDPlayer();
	}
	else if (theDiscDrive.discType == "Audio")
	{
		nCurMainMenuItem = 1; // select music when backing up
		StartCDPlayer();
	}
	else
	{
		EnableInput(true);

		if (theDiscDrive.discType == "unknown")
			bShowInvalidDisc = true;
		theMainMenu.GoTo();
		EnableAmbientAudio();
	}
}

function StartScreenSaverView()
{
	if(CurrentViewpoint == theMainMenuViewpoint)
	{
		if (theMainMenu.children.length() == 0) return;
		var c = theMainMenu.children[0].children[0];
		c.theMenuItems.SetAlpha(0);
		c.select.SetAlpha(0);
		c.theMainMenuClock.visible = false;
		c.theMainMenuInfo2.visible = false;
		c.MainMenu_Test_MemoryPanel.visible = false;
		c.theMainMenuLevel.fade = 100;
		var x = GetRandomInteger(3);
		if(x == 0)
		{
			c.theMainMenuLevel.SetTranslation( 30, -104, 4 );
		}
		else if(x == 1)
		{
			c.theMainMenuLevel.SetTranslation( 74, -46, -14 );
			c.theMainMenuLevel.SetRotation( -0.0006, 0, 0.00005, 0.314159 );
		}
		else
		{
			c.theMainMenuLevel.SetTranslation( -24, -36, -262 );
			c.theMainMenuLevel.SetRotation( -0.001, 0.0003, 0.0003, 0.314159 );
		}
		theMainMenuWaver.rpm = 2.25;
		theScreen.brightness = 0.8;
		EnableCurrentAlternateViewpoint();
	}
	// Inline children[] is empty until the user navigates into the launcher
	// scene, so guard the deref. & is bitwise (no short-circuit) in this VM,
	// so the length check has to be a separate if.
	else if (theLauncherInline.children.length() > 0)
	{
		if(CurrentViewpoint == theLauncherInline.children[0].LauncherViewpoint | CurrentViewpoint == theLauncherInline.children[0].theTitleListViewpoint)
		{
			var c = theLauncherInline.children[0].theLauncher.children[0].children[0];
			c.back1.SetAlpha(0);
			c.select1.SetAlpha(0);
			c.refresh.SetAlpha(0);
			c.recent.SetAlpha(0);
			theScreen.brightness = 0.8;
			theLauncherInline.children[0].theLauncherWaver.rpm = 2.25;
			EnableCurrentAlternateViewpoint();
		}
	}
}

function StopScreenSaverView()
{
	bManualScreenSaverView = false;

	if(CurrentViewpoint == theMainMenuViewpoint)
	{
		if (theMainMenu.children.length() == 0) return;
		var c = theMainMenu.children[0].children[0];
		c.theMainMenuLevel.fade = 0.25;
		c.theMainMenuLevel.SetRotation(0,0,0,0);
		c.theMainMenuLevel.SetTranslation(0,0,0);
		c.theMenuItems.SetAlpha(1);
		c.select.SetAlpha(1);
		c.theMainMenuClock.visible = true;
		ApplyMainMenuPanelSelection();
		theMainMenuWaver.rpm = 0.75;
		DisableCurrentAlternateViewpoint();
	}
	else if (theLauncherInline.children.length() > 0)
	{
		if(CurrentViewpoint == theLauncherInline.children[0].LauncherViewpoint | CurrentViewpoint == theLauncherInline.children[0].theTitleListViewpoint)
		{
			var c = theLauncherInline.children[0].theLauncher.children[0].children[0];
			c.back1.SetAlpha(1);
			c.select1.SetAlpha(1);
			c.refresh.SetAlpha(1);
			c.recent.SetAlpha(1);
			c.GM_L2_Arm01_03.SetAlpha(1);
			c.audio_panel.SetAlpha(1);
			DisableCurrentAlternateViewpoint();
			theLauncherInline.children[0].theLauncherWaver.rpm = 0.75;
		}
	}
}

function ToggleManualScreenSaverView()
{
	if(bManualScreenSaverView)
	{
		StopScreenSaverView();
		bManualScreenSaverView = false;
	}
	else
	{
		StartScreenSaverView();
		bManualScreenSaverView = true;
	}
}

// Japanese Keyboard////////////////////////////////////////////////////////

DEF theJapaneseKeyboardLayer Layer
{
	visible false
	transparency 1
	fade 0.25
	
	viewpoint Viewpoint
	{
		fieldOfView 1.2
		position 10 9 145
	}
	
	children
	[
		DEF theJapaneseKeyboardTransform Transform
		{
			fade 0.25
			//          fade 1
			scale 0 0 0
			children
			[
				Inline
				{
					preload true
					url "JKeyboard/default.xap"
				}
			]
		}
	]
}

////////////////////////////////////////////////////////////////////////////

var strKeyboardTitle, strKeyboardEdit;
var strKeyboardDoneFunction, strKeyboardCancelFunction;

DEF theKeyboardLayer Layer
{
	visible false
	transparency 1
	fade 0.25
	
	viewpoint Viewpoint
	{
		fieldOfView 1.2
		position 10 6 150
	}
	
	children
	[
		DEF theKeyboardTransform Transform
		{
			fade 0.25
			//          fade 1
			scale 0 0 0
			children
			[
				Inline
				{
					preload true
					url "Keyboard/default.xap"
				}
			]
		}
	]
}

function KeyboardDone()
{
	var strDoneFunction = strKeyboardDoneFunction;
	
	CloseKeyboard();
	
	if (strDoneFunction != "")
		eval(strDoneFunction);
}

function KeyboardCancel()
{
	var strCancelFunction = strKeyboardCancelFunction;
	
	CloseKeyboard();
	
	if (strCancelFunction != "")
		eval(strCancelFunction);
}

function CloseKeyboard()
{
	if (g_bKeyboardDisplayed == false)
	{
		return;
	}
	
	var nKeyboardLanguage = theConfig.GetLanguage();
	if (nKeyboardLanguage == 2)  // Japanese Language
	{
		var c = theJapaneseKeyboardTransform.children[0].children[0];
		
		// Re-Enable asterisk formatting for our text panels
		c.theJKeyboard.SetAsteriskFormattingState( g_PrevAsteriskFormattingState );
		
		strKeyboardEdit = c.theJKeyboard.string;
		c.theJKeyboardJoystick.isBound = false;
		
		theJapaneseKeyboardTransform.SetScale(0, 0, 0);
		theJapaneseKeyboardTransform.SetAlpha(0);
		theJapaneseKeyboardLayer.transparency = 1;
	}
	else
	{
		var c = theKeyboardTransform.children[0].children[0];
		
		// Re-Enable asterisk formatting for our text panels
		c.theKeyboard.SetAsteriskFormattingState( g_PrevAsteriskFormattingState );
		
		strKeyboardEdit = c.theKeyboard.string;
		c.theKeyboardJoystick.isBound = false;
		
		theKeyboardTransform.SetScale(0, 0, 0);
		theKeyboardTransform.SetAlpha(0);
		theKeyboardLayer.transparency = 1;
	}
	
	//strKeyboardTitle = "";
	strKeyboardDoneFunction = "";
	strKeyboardCancelFunction = "";
	
	if (theDiscDrive.locked)
	{
		theDiscDrive.locked = false;
	}
	UnblockMemoryUnitInsert();
	
	g_bKeyboardDisplayed = false;
}

var g_PrevAsteriskFormattingState;
function ShowKeyboard(strTitle, strEdit, strDoneFunction, strCancelFunction)
{
	theDiscDrive.locked = true;
	BlockMemoryUnitInsert();
	
	strKeyboardTitle = strTitle;
	strKeyboardEdit = strEdit;
	strKeyboardDoneFunction = strDoneFunction;
	strKeyboardCancelFunction = strCancelFunction;
	
	var nKeyboardLanguage = theConfig.GetLanguage();
	if (nKeyboardLanguage == 2)  // Japanese Language
	{
		var c = theJapaneseKeyboardTransform.children[0].children[0];
		
		// Disable asterisk formatting for our keyboard display
		g_PrevAsteriskFormattingState = c.theJKeyboard.GetAsteriskFormattingState();
		c.theJKeyboard.SetAsteriskFormattingState( false );
		
		c.theJKeyboard.selectKey( 8, 10 );        // Default the key selection to the DONE key
		c.theJKeyboard.string = "";
		c.theJKeyboard.string = strKeyboardEdit;
		c.theJKeyboard.shift = 0;
		c.theJKeyboard.caps = 0;
		c.theJKeyboard.jmode = 0;
		
		c.theKeyboardTitle.text = strKeyboardTitle;
		if (g_bKeyboardDisplayed == false)
		{
			c.theJKeyboardJoystick.isBound = true;
		}
		
		theJapaneseKeyboardLayer.visible = true;
		theJapaneseKeyboardLayer.transparency = 0.25;
		theJapaneseKeyboardTransform.SetScale(1, 1, 1);
		theJapaneseKeyboardTransform.SetAlpha(1);
	}
	else
	{
		var c = theKeyboardTransform.children[0].children[0];
		
		// Disable asterisk formatting for our keyboard display
		g_PrevAsteriskFormattingState = c.theKeyboard.GetAsteriskFormattingState();
		c.theKeyboard.SetAsteriskFormattingState( false );
		
		c.theKeyboard.selectKey( 0, 0 );        // Default the key selection to the DONE key
		c.theKeyboard.string = "";
		c.theKeyboard.string = strKeyboardEdit;
		c.theKeyboard.shift = 0;
		c.theKeyboard.caps = 0;
		c.theKeyboard.mode = 0;
		
		c.theKeyboardTitle.text = strKeyboardTitle;
		if (g_bKeyboardDisplayed == false)
		{
			c.theKeyboardJoystick.isBound = true;
		}
		
		theKeyboardLayer.visible = true;
		theKeyboardLayer.transparency = 0.25;
		theKeyboardTransform.SetScale(1, 1, 1);
		theKeyboardTransform.SetAlpha(1);
	}
	
	g_bKeyboardDisplayed = true;
}

