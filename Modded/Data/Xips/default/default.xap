		c.theMainMenuClock.SetRotation(-0.014000, 0.030000, -1.000000, 0.010000);
		c.theMainMenuInfo2.SetRotation(-0.994900, -0.084000, 0.071000, -1.580000);
		c.MainMenu_Test_MemoryPanel.SetRotation(-0.998000, -0.074000, 0.082000, -1.592000);
	}
	else
	{
		c.theMainMenuClock.SetRotation(-0.007000, 0.015000, -1.000000, 0.015000);
		c.theMainMenuInfo2.SetRotation(-0.994300, -0.086000, 0.070000, -1.578000);
		c.MainMenu_Test_MemoryPanel.SetRotation(-0.996000, -0.081000, 0.076000, -1.584000);
	}
}

function SetMainMenuPanelsSpinRotation(nAngle)
{
	var c = theMainMenu.children[0].children[0];
	c.theMainMenuInfo2.SetRotation(1, 1, 0, nAngle);
	c.MainMenu_Test_MemoryPanel.SetRotation(1, 1, 0, nAngle);
}

function SetMainMenuDateSpinRotation(nAngle)
{
	var c = theMainMenu.children[0].children[0];
	c.theMainMenuClock.SetRotation(1, 1, 0, nAngle);
}

function AnimateMainMenuPanelsSpin()
{
	if(g_theMainMenuLoaded != true) { return; }
	if(CurrentViewpoint != theMainMenuViewpoint) { return; }
	if(theMainMenu.children.length() == 0) { return; }
	if(bMainMenuAttractFinish) { return; }

	var nAngle = nMainMenuPanelsSpinPhase * 0.196350;
	SetMainMenuPanelsSpinRotation(nAngle);

	nMainMenuPanelsSpinPhase = nMainMenuPanelsSpinPhase + 1;
	if(nMainMenuPanelsSpinPhase > 32)
	{
		nMainMenuPanelsSpinPhase = 0;
		bMainMenuPanelsSpinActive = false;
		nMainMenuPanelsFloatPhase = 15;
		FloatMainMenuPanels();
	}
}

function AnimateMainMenuDateSpin()
{
	if(g_theMainMenuLoaded != true) { return; }
	if(CurrentViewpoint != theMainMenuViewpoint) { return; }
	if(theMainMenu.children.length() == 0) { return; }
	if(bMainMenuAttractFinish) { return; }

	var nAngle = nMainMenuDateSpinPhase * 0.196350;
	SetMainMenuDateSpinRotation(nAngle);

	nMainMenuDateSpinPhase = nMainMenuDateSpinPhase + 1;
	if(nMainMenuDateSpinPhase > 32)
	{
		nMainMenuDateSpinPhase = 0;
		bMainMenuDateSpinActive = false;
		nMainMenuPanelsFloatPhase = 15;
		FloatMainMenuPanels();
	}
}

function AnimateMainMenuDateCoinSpin()
{
	if(g_theMainMenuLoaded != true) { return; }
	if(CurrentViewpoint != theMainMenuViewpoint) { return; }
	if(theMainMenu.children.length() == 0) { return; }
	if(bMainMenuAttractFinish) { return; }

	var c = theMainMenu.children[0].children[0];
	var nProgress = nMainMenuDateSpinPhase / 100;
	var nEase = 1 - ((1 - nProgress) * (1 - nProgress) * (1 - nProgress));
	var nRawAngle = 37.699112 * nEase;
	var nAngle = nRawAngle - (Math.floor(nRawAngle / 6.283185) * 6.283185);
	var nPivotOffset = 65;

	c.theMainMenuClock.SetRotation(0, 1, 0, nAngle);
	c.theMainMenuClock.SetTranslation(230.1900002 + (nPivotOffset * (1 - Math.cos(nAngle))), -197.261000, -240.399994 - (nPivotOffset * Math.sin(nAngle)));

	nMainMenuDateSpinPhase = nMainMenuDateSpinPhase + 1;
	if(nMainMenuDateSpinPhase > 100)
	{
		c.theMainMenuClock.SetTranslation(230.1900002, -197.261000, -240.399994);
		nMainMenuDateSpinPhase = 0;
		bMainMenuDateSpinActive = false;
		nMainMenuPanelsFloatPhase = 15;
		FloatMainMenuPanels();
	}
}

function FormatFreeSpace(x)
{
	var f_gb_mb = x / 1000;
	var f_gb = Math.round(f_gb_mb);
	if(f_gb > f_gb_mb) { f_gb = f_gb - 1; }
	var f_mb = (f_gb_mb - f_gb) * 100;
	var f_mb_r = Math.round(f_mb);
	if(f_mb_r < 10) { return f_gb + ".0" + f_mb_r + " Go"; }
	return f_gb + "." + f_mb_r + " Go";
}

function GetClockPanelValue(nValue)
{
	if(nValue == 1) { return theConfig.GetXboxIP(); }
	if(nValue == 2) { return FormatFreeSpace(theHardDrive.GetFreeSpace("E:\\")); }
	if(nValue == 3) { return FormatFreeSpace(theHardDrive.GetFreeSpace("F:\\")); }
	if(nValue == 4) { return FormatFreeSpace(theHardDrive.GetFreeSpace("G:\\")); }
	if(nValue == 5) { return theConfig.GetROMVersion(); }
	if(nValue == 6) { return theConfig.GetXdashVersion(); }
	if(nValue == 7) { return Math.round(theConfig.GetInternalTemp()) + " C       " + Math.round(theConfig.GetCPUTemp()) + " C"; }
	if(nValue == 8) { return theConfig.GetFanSpeed() * 2 + "%"; }
	return "N/A";
}

function SetClockPanelText(sTopText, sBotText, sMainText)
{
	if(theMainMenu.children.length() == 0) { return; }
	var c = theMainMenu.children[0].children[0];
	c.Clock_panel_header_text.text = sTopText;
	c.Clock_panel_support_03_text.text = sBotText;
	c.theClock_text.children[0].children[0].geometry.text = sMainText;
}

function UpdateClockInfoPanel()
{
	if(g_theMainMenuLoaded != true) { return; }
	if(theMainMenu.children.length() == 0) { return; }

	if(nClockInfoPanelPage < 1) { nClockInfoPanelPage = 9; }
	if(nClockInfoPanelPage > 9) { nClockInfoPanelPage = 1; }

	if(nClockInfoPanelPage == 1)
	{
		SetClockPanelText("DATE", "TIME", "<clock>");
	}
	else if(nClockInfoPanelPage == 2)
	{
		SetClockPanelText("IP", "", GetClockPanelValue(1));
	}
	else if(nClockInfoPanelPage == 3)
	{
		SetClockPanelText("E:", "FREE", GetClockPanelValue(2));
	}
	else if(nClockInfoPanelPage == 4)
	{
		SetClockPanelText("F:", "FREE", GetClockPanelValue(3));
	}
	else if(nClockInfoPanelPage == 5)
	{
		SetClockPanelText("G:", "FREE", GetClockPanelValue(4));
	}
	else if(nClockInfoPanelPage == 6)
	{
		SetClockPanelText("BIOS", "", GetClockPanelValue(5));
	}
	else if(nClockInfoPanelPage == 7)
	{
		SetClockPanelText("DASH", "", GetClockPanelValue(6));
	}
	else if(nClockInfoPanelPage == 8)
	{
		SetClockPanelText("MB TEMP", "CPU", GetClockPanelValue(7));
	}
	else if(nClockInfoPanelPage == 9)
	{
		SetClockPanelText("FAN SPEED", "", GetClockPanelValue(8));
	}
}

function NextClockInfoPanel()
{
	nClockInfoPanelPage = nClockInfoPanelPage + 1;
	UpdateClockInfoPanel();
}

function PrevClockInfoPanel()
{
	nClockInfoPanelPage = nClockInfoPanelPage - 1;
	UpdateClockInfoPanel();
}

DEF theMainMenu Level
{
	archive "MainMenu5.xip"
	unloadable false
	
	children
	[
