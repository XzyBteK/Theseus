}

////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////// Added Functions for HDD Menu
////////////////////////////////////////////////////////////////////////////////////////////////////////////////
function FillMenuList(x) // search Y:\, C:\, N:\ and O:\ for a relative path's contents to use to fill a menu
{
	var RelativePath = Split(x,";");
	var TitleList = new Array(0);
	for(var i = 0; i < DriveLocations.length; i = i + 1)
	{
		for(var ix = 0; ix < RelativePath.length; ix = ix + 1)
		{
			var c = new Folder; //def a new folder
			c.path = DriveLocations[i] + RelativePath[ix]; //def it's path
			var cSize = c.subFolders.length(); //find the number of subfolders in it
			if(cSize > 0)
			{
				for(var cLoop = 0; cLoop < cSize; cLoop = cLoop + 1)
				{
					launchPath = PartitionLocations[i] + RelativePath[ix] + "\\" + c.subFolders[cLoop].name;
					launchXbe = "default.xbe";
					if(theConfig.NtFileExists(launchPath + "\\" + launchXbe))
					{
						TitleList[TitleList.length] = c.subFolders[cLoop].name + ";" + i + ";" + ix;
					}                
				}
			}
		}  
	}
	TitleList = TitleList.sort();
	return TitleList; //return the array
}

function GetAllTitles()
{
	var TitleList = new Array;
	var cTitles = new Array;
	for(var i = 0; i < 8; i = i + 1)
	{
		var cValue = GetSavedValue("LauncherMenu","Title" + i);
		if(cValue != "")
		{
			var x = 1;
			CacheFile.section = "Cache";
			cTitles = Split(CacheFile.GetValue(cValue),"|");
			while(cTitles.length == 25)
			{
				TitleList = TitleList.concat(cTitles);
				cTitles = Split(CacheFile.GetValue(cValue + "-" + x),"|");
				x = x + 1;
			}
			TitleList = TitleList.concat(cTitles);
		}    
	}
	TitleList = TitleList.sort();
	return TitleList;
}

DEF theLaunchGameLevel Level
{
	function OnArrival()
	{
		DisableAmbientAudio();
		BlockMemoryUnitEnumeration();
		ClosePopup();

		g_bAboutToLaunchGame = true;
		// Bind the proper background image
		if( theConfig.GetVideoMode() == 2 )
			theXboxLogo16x9Background.isBound = true;
		else
			theXboxLogo4x3Background.isBound = true;
	}
	behavior
	{
		sleep 1.1;

		if(g_bAboutToLaunchGame)
		{
			if(bPresence & bPresenceEnabled)
			{
				var PathArray = new Array;
				var Slice = new Array;
				PathArray = Split(launchPath,"\\");
				Slice = PathArray.slice(4,PathArray.length);
				Discord.SetValue("Path",GetDrivePath(PathArray[2],PathArray[3]) + Slice.join("\\") + "\\" + launchXbe);
				launch("Discord.xbe", "\\Device\\Harddisk0\\Partition2\\Discord Presence");
			}
			else
			{
				launch(launchXbe, launchPath);
			}

			// Xbox reboots inside launch() so the next line never runs.
			// On desktop, launch() returns and the behavior block would
			// re-evaluate this if branch every cycle, repeatedly firing
			// the launcher. Clear the flag so we only launch once.
			g_bAboutToLaunchGame = false;
		}
	}

	function OnActivate()
	{
		DisableAmbientAudio();
		BlockMemoryUnitEnumeration();
		ClosePopup();
		//EnableInput(false);

		//theScreenSaver.enabled = true;
		if( theConfig.GetVideoMode() == 2 )
			theXboxLogo16x9Background.isBound = true;
		else
			theXboxLogo4x3Background.isBound = true;
	}
}

function QuickLaunch(x)
{
	LeftTrigger  = false;
	RightTrigger = false;
	
	var button = x;
	var a = GetSavedValue("QuickLaunch","QuickLaunch" + button);
	if (a == "") 
	{
		return;
	}
	else
	{
		ExecuteFile(a);
	}
}

function ExecuteFile(sPath)
{
	var a = sPath;
	var b = a.substr(0,a.indexOf(":"));
	var c = a.indexOf("\\");
	var d = a.lastIndexOf("\\");
	var e = a.substr(c , d - c);
	var ExtendedPartition = false;
	
	launchXbe = a.substr(d + 1);
	
	if(b.toUpperCase() == "C") { launchPath = "\\Device\\Harddisk0\\Partition2" + e; }
	else if(b.toUpperCase() == "E") { launchPath = "\\Device\\Harddisk0\\Partition1" + e; }
	else if(b.toUpperCase() == "F") { launchPath = "\\Device\\Harddisk0\\Partition6" + e; ExtendedPartition = true; }
	else if(b.toUpperCase() == "G") { launchPath = "\\Device\\Harddisk0\\Partition7" + e; ExtendedPartition = true; }
	else if(b.toUpperCase() == "R") { launchPath = "\\Device\\Harddisk1\\Partition1" + e; }
	else if(b.toUpperCase() == "H") { launchPath = "\\Device\\Harddisk1\\Partition6" + e; ExtendedPartition = true; }
	else if(b.toUpperCase() == "I") { launchPath = "\\Device\\Harddisk1\\Partition7" + e; ExtendedPartition = true; }
	else return;
	
	if(ExtendedPartition & bHDDInitialized == false)
	{
		bExecuteFile = true;
		bHDDInitialize = true;
	}
	else if(theConfig.NtFileExists(launchPath + "\\" + launchXbe)) 
	{
		theMainMenu.children[0].children[0].theMainMenuLevel.visible = false;
		theLaunchGameLevel.GoTo();
	}
}

function RescanPartitions()
{
	DriveLocations = new Array("C:\\","E:\\");
	PartitionLocations = new Array("\\Device\\Harddisk0\\Partition2\\","\\Device\\Harddisk0\\Partition1\\");
	bPartitionScanCompleted = false;
	bHDDInitialized = false;
	bHDDInitialize = true;
}

function ScanPartitions()
{
	var Drives = new Array("F:\\","G:\\","H:\\","I:\\","R:\\");
	var Locations = new Array("\\Device\\Harddisk0\\Partition6\\","\\Device\\Harddisk0\\Partition7\\","\\Device\\Harddisk1\\Partition6\\","\\Device\\Harddisk1\\Partition7\\","\\Device\\Harddisk1\\Partition1\\");
	nPartitions = 0;
	for(var i = 0; i < Drives.length; i = i + 1)
	{
		var Test = new Folder;
		var TestFile = new Settings;
		var nFolders;
		var nFiles;
		var nTotal;
		var sDrive = Drives[i];
		var Flag = 1 << i;
		
		Test.path = sDrive.indexOf("\\");
		nFolders = Test.subFolders.length();
		nFiles = Test.files.length();
		nTotal = nFolders + nFiles;
		if(nTotal > 0)
		{
			nPartitions = nPartitions | Flag;
			DriveLocations[DriveLocations.length] = Drives[i];
			PartitionLocations[PartitionLocations.length] = Locations[i];
		}
		else
		{
			TestFile.file = Drives[i] + "-DeleteMe-";
			TestFile.SetValue("Dummy","true");
			if(theConfig.NtFileExists(Locations[i] + "-DeleteMe-"))
			{
				nPartitions = nPartitions | Flag;
				DriveLocations[DriveLocations.length] = Drives[i];
				PartitionLocations[PartitionLocations.length] = Locations[i];
			}
		}
	}
	
	bPartitionScanCompleted = true;
	bHasExtendedPartition = nPartitions > 0;
	SetSavedValue("ExtendedPartitions","Partitions",nPartitions);
	SetSavedBooleanValue("ExtendedPartitions","PartitionScanCompleted",bPartitionScanCompleted);
	RefreshCache();
}

function RefreshCache()
{
	var arrMenuNames = new Array;
	var arrMenuPaths = new Array;
	var cTitles = new Array;
	for (var i = 0; i < 8; i = i + 1)
	{
		var v = GetSavedValue("LauncherMenu", "Title" + i);
		if(v != "") 
		{
			arrMenuNames[arrMenuNames.length] = v;
			arrMenuPaths[arrMenuPaths.length] = GetSavedValue("LauncherMenu", "Path" + i);
		}
	}
	for (var x = 0; x < arrMenuNames.length; x = x + 1)
	{
		CacheFile.section = "Cache";
		// Clear previous segments if they exist.
		var idx = 1;
		while(CacheFile.GetValue(arrMenuNames[x] + "-" + idx) != "") 
		{
			CacheFile.SetValue(arrMenuNames[x] + "-" + idx, "");
			idx = idx + 1;
		}
		var cache;
		cTitles = FillMenuList(arrMenuPaths[x]);
		// Segment Titles more than 25
		if(cTitles.length > 25)
		{
			var indx = 1;
			for(var ptr = 0; ptr < cTitles.length; ptr = ptr + 25)
			{
				var cnt = 25;
				var Segment = new Array;
				if(ptr + cnt > cTitles.length) cnt = cTitles.length - ptr;
				Segment = cTitles.slice(ptr,ptr + cnt);
				cache = Segment.join("|");
				if(ptr == 0){ CacheFile.SetValue(arrMenuNames[x], cache); }
				else { CacheFile.SetValue(arrMenuNames[x] + "-" + indx, cache); indx = indx + 1; }    
			}
		}
		else
		{
			cache = cTitles.join("|");
			CacheFile.SetValue(arrMenuNames[x], cache);
		}
	}
}

