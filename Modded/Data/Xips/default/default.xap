var nCurMainMenuItem;

function UpdateMainMenu()
{
	// Adjust for a 3, 4, or 5 button menu
	if( g_TotalMenuItems == "5" )
	{
		// Update our 5 button menu
		Update5ButtonMainMenu();
	}
	else if( g_TotalMenuItems == "4" )
	{
		// Update our 4 button menu
		Update4ButtonMainMenu();
	}
	else
	{
		// Update our 3 button menu
		Update3ButtonMainMenu();
	}
}

