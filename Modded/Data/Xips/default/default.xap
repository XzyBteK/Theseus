		c.SettingsTextMaterial.name = "NavType";
	}
	else if (nCurMainMenuItem == 2) // Xbox Live Button
	{
		c.game_select_pod_inner04.visible = true;
		
		if( thcorb == false ) { c.Rotating_Large_X.SetRotation(0, 0, 1, 0.25); }
		c.theMenuItems.SetRotation(0, 0, 1, 0.25);
		
		c.theMemoryItem.SetRotation(0, 1, 0, 0.25);
		c.theMusicItem.SetRotation(0, 1, 0, 0.25);
		c.theOnlineItem.SetRotation(0, 1, 0, 0.25);
		c.theSettingsItem.SetRotation(0, 1, 0, 0.25);
		
		c.MemoryPanelMaterial.name = "FlatSurfaces2sided";
		c.MusicPanelMaterial.name = "FlatSurfaces2sided";
		c.OnlinePanelMaterial.name = "GameHilite";
		c.SettingsPanelMaterial.name = "FlatSurfaces2sided";
		
		c.MemoryTextMaterial.name = "NavType";
		c.MusicTextMaterial.name = "NavType";
		c.OnlineTextMaterial.name = "HilightedType";
		c.SettingsTextMaterial.name = "NavType";
	}
	else if (nCurMainMenuItem == 3) // Launcher Button
	{
		// This should never happen in a 4 button menu config
		// This code is purly defensive.  If there is a bug, this could help prevent bad behavior
		
		// NOTE: This is still bad though, as it would most likely prevent the user from reaching
		// the settings area
		
		nCurMainMenuItem = 2;
		UpdateMainMenu();        
	}
	else if (nCurMainMenuItem == 4) // Settings Button
	{
		c.game_select_pod_inner05.visible = true;
		
		if( thcorb == false ) { c.Rotating_Large_X.SetRotation(0, 0, 1, 0.50); }
		c.theMenuItems.SetRotation(0, 0, 1, 0.50);
		
		c.theMemoryItem.SetRotation(0, 1, 0, 0.50);
		c.theMusicItem.SetRotation(0, 1, 0, 0.50);
		c.theOnlineItem.SetRotation(0, 1, 0, 0.50);
		c.theSettingsItem.SetRotation(0, 1, 0, 0.50);
		
		c.MemoryPanelMaterial.name = "FlatSurfaces2sided";
		c.MusicPanelMaterial.name = "FlatSurfaces2sided";
		c.OnlinePanelMaterial.name = "FlatSurfaces2sided";
		c.SettingsPanelMaterial.name = "GameHilite";
		
		c.MemoryTextMaterial.name = "NavType";
		c.MusicTextMaterial.name = "NavType";
		c.OnlineTextMaterial.name = "NavType";
		c.SettingsTextMaterial.name = "HilightedType";
	}
}

function Update3ButtonMainMenu()
{
	var c = theMainMenu.children[0].children[0];
	
	c.game_select_pod_inner02.visible = false;      // Memory Flashing Orb
	c.game_select_pod_inner.visible = false;        // Music Flashing Orb
	c.game_select_pod_inner05.visible = false;      // Settings Flashing Orb
	
	if (nCurMainMenuItem == 0)  // Memory Button
	{
		c.game_select_pod_inner02.visible = true;
		
		if( thcorb == false ) { c.Rotating_Large_X.SetRotation(0, 0, 1, -0.45); }
		c.theMenuItems.SetRotation(0, 0, 1, -0.45);
		
		c.theMemoryItem.SetRotation(0, 1, 0, -0.45);
		c.theMusicItem.SetRotation(0, 1, 0, -0.45);
		c.theSettingsItem.SetRotation(0, 1, 0, -0.45);
		
		c.MemoryPanelMaterial.name = "GameHilite";
		c.MusicPanelMaterial.name = "FlatSurfaces2sided";
		c.SettingsPanelMaterial.name = "FlatSurfaces2sided";
		
		c.MemoryTextMaterial.name = "HilightedType";
		c.MusicTextMaterial.name = "NavType";
		c.SettingsTextMaterial.name = "NavType";
		
	}
	else if (nCurMainMenuItem == 1)  // Music Button (Default position)
	{
		c.game_select_pod_inner.visible = true;
		
		if( thcorb == false ) { c.Rotating_Large_X.SetRotation(0, 0, 1, 0.0); }
		c.theMenuItems.SetRotation(0, 0, 1, 0.0);
		
		c.theMemoryItem.SetRotation(0, 1, 0, 0.0);
		c.theMusicItem.SetRotation(0, 1, 0, 0.0);
		c.theSettingsItem.SetRotation(0, 1, 0, 0.0);
		
		c.MemoryPanelMaterial.name = "FlatSurfaces2sided";
		c.MusicPanelMaterial.name = "GameHilite";
		c.SettingsPanelMaterial.name = "FlatSurfaces2sided";
		
		c.MemoryTextMaterial.name = "NavType";
		c.MusicTextMaterial.name = "HilightedType";
		c.SettingsTextMaterial.name = "NavType";
	}
	else if (nCurMainMenuItem == 2 | nCurMainMenuItem == 3 ) // Xbox Live Button or Launcher Button
	{
		// This should never happen in a 3 button menu config
		// This code is purly defensive.  If there is a bug, this could help prevent bad behavior
		
		// NOTE: This is still bad though, as it would most likely prevent the user from reaching
		// the settings area
		
		nCurMainMenuItem = 1;
		UpdateMainMenu();
	}
	else if (nCurMainMenuItem == 4) // Settings Button
	{
		c.game_select_pod_inner05.visible = true;
		
		if( thcorb == false ) { c.Rotating_Large_X.SetRotation(0, 0, 1, 0.45); }
		c.theMenuItems.SetRotation(0, 0, 1, 0.45);
		
		c.theMemoryItem.SetRotation(0, 1, 0, 0.45);
		c.theMusicItem.SetRotation(0, 1, 0, 0.45);
		c.theSettingsItem.SetRotation(0, 1, 0, 0.45);
		
		c.MemoryPanelMaterial.name = "FlatSurfaces2sided";
		c.MusicPanelMaterial.name = "FlatSurfaces2sided";
		c.SettingsPanelMaterial.name = "GameHilite";
		
		c.MemoryTextMaterial.name = "NavType";
		c.MusicTextMaterial.name = "NavType";
		c.SettingsTextMaterial.name = "HilightedType";
	}
}

function GetMainMenuButtons()
{
	Button1Text = Translate(GetSavedValue("MainMenu","Button1Text"));
	if(Button1Text == Translate("XONLINE")) { nXOLineButton = 0; if(ShowInsignia) Button1Text = Translate("INSIGNIA"); }
	if(Button1Text == Translate("MUSIC")) { nMusicButton = 0; }
	Button2Text = Translate(GetSavedValue("MainMenu","Button2Text"));
	if(Button2Text == Translate("XONLINE")) { nXOLineButton = 1; if(ShowInsignia) Button2Text = Translate("INSIGNIA"); }
	if(Button2Text == Translate("MUSIC")) { nMusicButton = 1; }
	Button3Text = Translate(GetSavedValue("MainMenu","Button3Text"));
	if(Button3Text == Translate("XONLINE")) { nXOLineButton = 2; if(ShowInsignia) Button3Text = Translate("INSIGNIA"); }
	if(Button3Text == Translate("MUSIC")) { nMusicButton = 2; }
	Button4Text = Translate(GetSavedValue("MainMenu","Button4Text"));
	if(Button4Text == Translate("XONLINE")) { nXOLineButton = 3; if(ShowInsignia) Button4Text = Translate("INSIGNIA"); }
	if(Button4Text == Translate("MUSIC")) { nMusicButton = 3; }
}

function SetButtonText()
{
	var c = theMainMenu.children[0].children[0];
	c.MainMenuButton1_Text.text = Button1Text;
	c.MainMenuButton2_Text.text = Button2Text;
	c.MainMenuButton3_Text.text = Button3Text;
	c.MainMenuButton4_Text.text = Button4Text;
	c.MainMenuButton5_Text.text = theTranslator.Translate("settings");
}

function GetOrbName()
{
	var n = GetSavedValue("Dashboard Settings","Current Orb");
	if(n == "") { return ""; }
	return "Q:\\Orbs\\" + n + "\\" + n;
}

function GetOrb()
{
	var a = GetSavedValue("Dashboard Settings","Use Custom Orb");
	if(a.toLowerCase() == "true") { customorb = true; }
	else { customorb = false; }
}

function ChangeTheOrb(e)
{
	var c = theMainMenu.children[0].children[0];
	c.Main_pod_backing01.visible = false;
	c.Main_pod_backing02.visible = false;
	c.gasorb.visible = false;
	c.gasorb.children[0].children[0].geometry.url = e;
	c.gasorb.visible = true;
}

function ApplyOrb()
{
	var c = theMainMenu.children[0].children[0];

	thcorb = (GetSavedValue("default","MainOrbStyle") == "tHc");
	if(thcorb == true)
	{
		c.Main_pod_backing01.visible = false;
		c.Main_pod_backing02.visible = true;
	}
	else
	{
		c.Main_pod_backing01.visible = true;
		c.Main_pod_backing02.visible = false;
	}
	c.gasorb.visible = false;

	GetOrb();
	if(customorb == true)
	{
		var OrbName = GetOrbName();
		if(OrbName == "") { return; }

		var info = new Settings;
		info.file = OrbName + ".xbx";
		info.section = "Orb";
		var scalex = info.GetValue("Scalex");
		var scaley = info.GetValue("Scaley");
		var scalez = info.GetValue("Scalez");
		if((scalex != "") & (scaley != "") & (scalez != ""))
		{
			c.gasorb.SetScale(scalex, scaley, scalez);
		}
		c.Rotating_Large_X.fade = 0.43;
		theConfig.FlushMeshCache();
		ChangeTheOrb(OrbName + ".xm");
	}
	else
	{
		c.Rotating_Large_X.fade = 0.25;
	}
}

function GetMenuOrbName(OrbName)
{
	if(OrbName == "") { return ""; }

	var OrbFolder = new Folder;
	OrbFolder.path = "Q:\\orbs\\" + OrbName;
	for(var i = 0; i < OrbFolder.files.length(); i = i + 1)
	{
		if(OrbFolder.files[i].type.toLowerCase() == "xm")
		{
			return "Q:\\Orbs\\" + OrbName + "\\" + OrbFolder.files[i].name;
		}
	}
	return "";
}

function ApplyMenuOrbToNode(c, SettingName, MenuOrb, OrbChildIndex)
{
	var OrbName = GetSavedValue("Orb Settings",SettingName);
	var OrbFile = GetMenuOrbName(OrbName);
	if(OrbFile == "") { return; }

	var info = new Settings;
	info.file = OrbFile + ".xbx";
	info.section = "MENU Orbs";
	var scalex = info.GetValue("Scalex");
	var scaley = info.GetValue("Scaley");
	var scalez = info.GetValue("Scalez");
	var material = info.GetValue("Material");

	if((scalex == "") | (scaley == "") | (scalez == ""))
	{
		info.section = "HD Orbs";
		scalex = info.GetValue("Scalex");
		scaley = info.GetValue("Scaley");
		scalez = info.GetValue("Scalez");
		if(material == "") { material = info.GetValue("Material"); }
	}

	var OrbRef = MenuOrb.children[OrbChildIndex].children[0];
	OrbRef.visible = false;
	if(material != "") { OrbRef.children[0].appearance.material.name = material; }
	OrbRef.children[0].geometry.url = OrbFile + ".xm";
	if((scalex != "") & (scaley != "") & (scalez != ""))
	{
		OrbRef.SetScale(scalex * 0.045, scaley * 0.045, scalez * 0.045);
	}
	OrbRef.visible = true;
}

function ApplyMenuOrbs()
{
	var c = theMainMenu.children[0].children[0];
	theConfig.FlushMeshCache();
	ApplyMenuOrbToNode(c,"Memory Orb",c.game_select_pod_inner02,1);
	ApplyMenuOrbToNode(c,"Music Orb",c.game_select_pod_inner,0);
	ApplyMenuOrbToNode(c,"Online Orb",c.game_select_pod_inner04,0);
	ApplyMenuOrbToNode(c,"Launcher Orb",c.game_select_pod_inner03,0);
	ApplyMenuOrbToNode(c,"Settings Orb",c.game_select_pod_inner05,0);
}

function ReloadOrb()
{
	if(g_theMainMenuLoaded != true) { return; }
	ApplyOrb();
}

function ApplyMainMenuPanelSelection()
{
	if(g_theMainMenuLoaded != true) { return; }
	if(theMainMenu.children.length() == 0) { return; }

	var c = theMainMenu.children[0].children[0];

	if(nMainMenuPanelSelection == 2)
	{
		c.theMainMenuInfo2.visible = false;
		c.MainMenu_Test_MemoryPanel.visible = true;
	}
	else
	{
		nMainMenuPanelSelection = 1;
		c.theMainMenuInfo2.visible = true;
		c.MainMenu_Test_MemoryPanel.visible = false;
	}
}

function ToggleMainMenuPanelSelection()
{
	if(nMainMenuPanelSelection == 1)
	{
		nMainMenuPanelSelection = 2;
	}
	else
	{
		nMainMenuPanelSelection = 1;
	}

	ApplyMainMenuPanelSelection();
}

function nada()
{
}

function MainMenuAttract()
{
	var a = 0;
	var c = theMainMenu.children[0].children[0];
	EnableInput(false);
	c.theMainMenuLevel.fade = a;
	c.Rotating_Large_X.fade = a;
	c.ring.fade = a; 
	c.main_pod.fade = a; 
	c.select.visible = false;
	
	c.theMainMenuLevel.SetRotation(-1,-5.1,0,3.141593);
	c.theMainMenuLevel.SetTranslation(0,0,-400);
	c.Rotating_Large_X.SetTranslation(-900,500,20);
	c.ring.SetTranslation(400,0,-180);
	c.main_pod.SetTranslation(-400,13.4,-300);
	
	a = 2;
	c.theMainMenuLevel.fade = a;
	c.Rotating_Large_X.fade = a;
	c.ring.fade = a; 
	c.main_pod.fade = a; 
	c.Main_pod_backing01.fade = a; 
	c.Main_pod_backing02.fade = a; 
	
	c.theMainMenuLevel.SetRotation(0,0,0,0);
	c.theMainMenuLevel.SetTranslation(0,0,0);
	c.Rotating_Large_X.SetTranslation(0,0,0);
	c.ring.SetTranslation(-57.980000,-13.690000,-84.760002);
	c.main_pod.SetTranslation(-61.689999,-13.400000,0.337400);
	bMainMenuAttractFinish = true;
	//SetBackgroundMeshType();
}

function FloatMainMenuPanels()
{
	if(g_theMainMenuLoaded != true) { return; }
	if(CurrentViewpoint != theMainMenuViewpoint) { return; }
	if(theMainMenu.children.length() == 0) { return; }
	if(bMainMenuAttractFinish) { return; }

	var c = theMainMenu.children[0].children[0];
	if(c.theMainMenuClock.visible != true) { return; }
	if((c.theMainMenuInfo2.visible != true) & (c.MainMenu_Test_MemoryPanel.visible != true)) { return; }

	c.theMainMenuClock.fade = 0.9;
	c.theMainMenuInfo2.fade = 0.9;
	c.MainMenu_Test_MemoryPanel.fade = 0.9;

	nMainMenuPanelsFloatPhase = nMainMenuPanelsFloatPhase + 1;
	if(nMainMenuPanelsFloatPhase > 15) { nMainMenuPanelsFloatPhase = 0; }

	if(nMainMenuPanelsFloatPhase == 0)
	{
		c.theMainMenuClock.SetRotation(0, 0, -1000.1, 0.02);
		c.theMainMenuInfo2.SetRotation(-0.993700, -0.088440, 0.068970, -1.576000);
		c.MainMenu_Test_MemoryPanel.SetRotation(-0.993700, -0.088440, 0.068970, -1.576000);
	}
	else if(nMainMenuPanelsFloatPhase == 1)
	{
		c.theMainMenuClock.SetRotation(0.009000, -0.006000, -1.000000, 0.025000);
		c.theMainMenuInfo2.SetRotation(-0.993100, -0.090000, 0.070000, -1.574000);
		c.MainMenu_Test_MemoryPanel.SetRotation(-0.991000, -0.095000, 0.074000, -1.570000);
	}
	else if(nMainMenuPanelsFloatPhase == 2)
	{
		c.theMainMenuClock.SetRotation(0.018000, -0.012000, -1.000000, 0.030000);
		c.theMainMenuInfo2.SetRotation(-0.992500, -0.092000, 0.071000, -1.572000);
		c.MainMenu_Test_MemoryPanel.SetRotation(-0.989000, -0.101000, 0.078000, -1.564000);
	}
	else if(nMainMenuPanelsFloatPhase == 3)
	{
		c.theMainMenuClock.SetRotation(0.025000, -0.016000, -0.999500, 0.035000);
		c.theMainMenuInfo2.SetRotation(-0.991900, -0.094000, 0.072000, -1.570000);
		c.MainMenu_Test_MemoryPanel.SetRotation(-0.987000, -0.106000, 0.082000, -1.558000);
	}
	else if(nMainMenuPanelsFloatPhase == 4)
	{
		c.theMainMenuClock.SetRotation(0.032000, -0.020000, -0.999000, 0.040000);
