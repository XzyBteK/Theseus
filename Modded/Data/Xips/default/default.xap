	path DEF theMainMenuViewpoint Viewpoint
	{
		fieldOfView 1.300000
		orientation -0.177400 -0.983500 -0.036250 -0.045440
		position 11.180000 -32.299999 174.300003
		jump false
	}
	
	control DEF joy Joystick
	{
		function OnADown()
		{
			theMainMenu.children[0].children[0].select_pod_HL.children[0].appearance.material.param = 1;
			
			PlaySoundA();
			if ((RightTrigger == true) & (LeftTrigger == true)) { QuickLaunch("A"); return;}
			if (nCurMainMenuItem == 0)  // Memory Button
			{
				theGamesMenuIn.Play();
				eval(Button1Action);
			}
			else if (nCurMainMenuItem == 1) // Music Button
			{
				theMusicMenuIn.Play();
				eval(Button2Action);
			}
			else if (nCurMainMenuItem == 2) // Xbox Live Button
			{
				theGamesMenuIn.Play();      // TODO: Get final sound
				eval(Button3Action);        // Enter LiveToday
			}
			else if (nCurMainMenuItem == 3) // Launcher Button
			{
				theGamesMenuIn.Play();
				eval(Button4Action);
			}

			else if (nCurMainMenuItem == 4) // Settings Button
			{
				theSettingsMenuIn.Play();
				GoToSettings();
			}
		}
		function OnBDown()
		{
			if ((RightTrigger == true) & (LeftTrigger == true)) { QuickLaunch("B"); return;}
		
			if (theMusicInline.visible)
			{
				var m = theMusicInline.children[0];
			
				m.nPlayCursor = m.nPlayCursor + 1;
			
				if (m.nPlayCursor >= m.playlist.length)
					m.nPlayCursor = 0;
			
				m.PlayCurrentSong();
				//UpdateBgMusicTrackText();
				UpdateBgMusicPanelText();
			}
		}
			function OnXDown()
			{
				ToggleMainMenuPanelSelection();
				return;

				// TEST PANEL: ancien comportement X garde ici pour restauration.
				//ToggleManualScreenSaverView();
				//return;
				//if ((RightTrigger == true) & (LeftTrigger == true)) { QuickLaunch("X"); return;}
				//
				//if (theMusicInline.visible)
				//{
				//var m = theMusicInline.children[0];
				//
				//m.nPlayCursor = m.nPlayCursor - 1;
				//
				//if (m.nPlayCursor < 0)
				//	m.nPlayCursor = m.playlist.length - 1;
				//
				//m.PlayCurrentSong();
				//	//UpdateBgMusicTrackText();
				//	UpdateBgMusicPanelText();
				//}
			}
		function OnYDown()
		{
			if ((RightTrigger == true) & (LeftTrigger == true)) { QuickLaunch("Y"); return;}
		
			if (theMusicInline.visible)
			{
				var m = theMusicInline.children[0];
		
				if (m.theMusicPlayer.transportMode == 1)
				{
					m.DoMusicPlayPause();
				}
				else if (m.theMusicPlayer.transportMode == 2)
				{
					m.DoMusicPlayPause();
				}
				else
				{
					ResumeBackGroundMusic();
				}
			}
			else
			{
				ResumeBackGroundMusic();
			}
			}
			function OnRightDown()
			{
				RightTrigger = true;
				if(LeftTrigger != true) { NextClockInfoPanel(); }
			}
			function OnRightUp() { RightTrigger = false; }
			function OnLeftDown()
			{
				LeftTrigger = true;
				if(RightTrigger != true) { PrevClockInfoPanel(); }
			}
			function OnLeftUp() { LeftTrigger = false; }
			function OnLeftThumbDown()
			{
				ToggleManualScreenSaverView();
			}
			function OnMoveUp()
			{
			if (nCurMainMenuItem > 0)
			{
				nCurMainMenuItem = nCurMainMenuItem - 1;
				
				// Determine if we should skip the online button
				if( g_TotalMenuItems == "3" )
				{
					// If we would be on the Xbox Live Button, let's skip over it
					if( nCurMainMenuItem == 3) nCurMainMenuItem = nCurMainMenuItem - 2;
				}
				if( g_TotalMenuItems == "4"  )
				{
					// If we would be on the Launcher Button, let's skip over it
					if( nCurMainMenuItem == 3 ) nCurMainMenuItem = nCurMainMenuItem - 1;
				}                  
				theMainMenuBackward.Play();
				UpdateMainMenu();
			}
		}
		
		function OnMoveDown()
		{
			if (nCurMainMenuItem < 4)
			{
				nCurMainMenuItem = nCurMainMenuItem + 1;
				
				// Determine if we should skip the online button
				if( g_TotalMenuItems == "3" )
				{
					// If we would be on the Xbox Live Button, let's skip over it
					if( nCurMainMenuItem == 2 ) nCurMainMenuItem = nCurMainMenuItem + 2;
				}
				if( g_TotalMenuItems == "4"  )
				{
					// If we would be on the Launcher Button, let's skip over it
					if( nCurMainMenuItem == 3 ) nCurMainMenuItem = nCurMainMenuItem + 1;
				}                
				theMainMenuForward.Play();
				UpdateMainMenu();
			}
		}
		
		function OnMoveRight()
		{
			if (theMusicInline.visible)
				NextSoundtrack();
		}
		
		function OnMoveLeft()
		{
			if (theMusicInline.visible)
				PrevSoundtrack();
		}

		function OnKeyVerified()
		{
			//theConfig.ToggleNoisyCamera();
			if(ButtonYXAction != "Nothing")
			{
				PlaySoundA();
				if(ButtonYXAction == "GoToMusic()")
				{
					theMusicMenuIn.Play();
				}
				else if(ButtonYXAction != "ToggleNoisyCam()")
				{ 
					theGamesMenuIn.Play(); 
				}
				eval(ButtonYXAction);
			}
		}
	}
	
		behavior
		{
			sleep nTime;
			nTime = 0.1;

			if(bBgMusicPanelTextScroll)
			{
				nBgMusicPanelTextScrollTick = nBgMusicPanelTextScrollTick + 1;
				if(nBgMusicPanelTextScrollTick >= 3)
				{
					nBgMusicPanelTextScrollTick = 0;
					ScrollBgMusicPanelText();
				}
			}

			nMainMenuPanelsSpinTick = nMainMenuPanelsSpinTick + 1;
			if((nMainMenuPanelsSpinTick >= 600) & (bMainMenuPanelsSpinActive != true))
			{
				nMainMenuPanelsSpinTick = 0;
				nMainMenuPanelsSpinPhase = 0;
				bMainMenuPanelsSpinActive = true;
			}

			nMainMenuDateSpinTick = nMainMenuDateSpinTick + 1;
			if((nMainMenuDateSpinTick >= 200) & (bMainMenuDateSpinActive != true))
			{
				nMainMenuDateSpinTick = 0;
				nMainMenuDateSpinPhase = 0;
				bMainMenuDateSpinActive = true;
			}

			if(bMainMenuPanelsSpinActive)
			{
				AnimateMainMenuPanelsSpin();
			}

			if(bMainMenuDateSpinActive)
			{
				AnimateMainMenuDateCoinSpin();
			}

			if((bMainMenuPanelsSpinActive != true) & (bMainMenuDateSpinActive != true))
			{
				nMainMenuPanelsFloatTick = nMainMenuPanelsFloatTick + 1;
				if(nMainMenuPanelsFloatTick >= 4)
				{
					nMainMenuPanelsFloatTick = 0;
					FloatMainMenuPanels();
				}
			}

			if(bHDDInitialize)
			{
			if(bLaunchItem | bExecuteFile)
			{
				if(bExecuteFile) 
				{ 
					theMainMenu.children[0].children[0].theMainMenuLevel.visible = false; 
					theMainMenu.shell.alpha = 0;
				}
				else 
				{ 
					theLauncherInline.children[0].theLauncher.children[0].children[0].theWholeThing.visible = false;
					theLauncherInline.children[0].theLauncher.shell.alpha = 0;
				}
				// Bind the proper background image
				if( theConfig.GetVideoMode() == 2 )
				{ theXboxLogo16x9Background.isBound = true; }
				else { theXboxLogo4x3Background.isBound = true; }
				nTime = 1.6;
			}
			else
			{
				BlockUser(Translate("INDEXING_PARTITION"));
				nTime = 1.1;
			}
			bHDDInitialize = false;
			bHDDInitializing = true;
		}
		else if(bHDDInitializing)
		{
			if(bPartitionScanCompleted == false)
			{
				ScanPartitions();
			}
			else if(bRefreshCache)
			{
				bRefreshCache = false;
				theLauncherInline.children[0].RefreshTitleList();
			}
			else if(bExecuteFile)
			{
				if (theConfig.NtFileExists(launchPath + "\\" + launchXbe)) 
				{
					theMainMenu.children[0].children[0].theMainMenuLevel.alpha = 0;
					theLaunchGameLevel.GoTo();
				}
				else {Reload();}
				bExecuteFile = false;
			}
			else if(bLaunchItem)
			{
				bHDDInitialized = true;
				theLauncherInline.children[0].LaunchItem(sLocation,sFolder);
				bLaunchItem = false;
			}
			else if(bLoadDir)
			{
				bHDDInitialized = true;
				theLauncherInline.children[0].LoadDir();
				bLoadDir = false;
			}
			bHDDInitializing = false;
			bHDDInitialized = true;
			CloseMessage();
		}
		else if(bPartitionScanCompleted == false)
		{
			bHDDInitialize = true;
		}
		else if(bMainMenuAttractFinish & theMainMenu.children[0].children[0].theMainMenuLevel.moving == false)
		{
			EnableInput(true);
			bMainMenuAttractFinish = false;
			theMainMenu.children[0].children[0].select.visible = true;
			theMainMenu.children[0].children[0].Rotating_Large_X.fade = 0.25;
		}
	}

	function OnActivate()
	{
		CurrentViewpoint = theMainMenuViewpoint;
		CurrentAltViewpoint = theMainMenuAlternateViewpoint;
		EnableAmbientAudio();
		if( g_theMainMenuLoaded )
		{
			UpdateMainMenu();
		}
	}
	
	function OnArrival()
	{
		theSkinBackground.isBound = true;
		if( false == bAcceptedLegalInfo )
		{
			//
			// We need to pop up the dialog displaying the legal information to the user
			//
			
			bShowLegalInfo = true;
			DisplayWaitingMessage();
		}
		if (g_bPanelDisplayed == true)
		{
			theMessageJoystick.isBound = true;
		}
	}
}

function ResumeBackGroundMusic()
{
	if (theMusicInline.visible == false)
	{
		theMusicInline.visible = true;
		return;
	}

	var m = theMusicInline.children[0];

	if (m.theMusicPlayer.transportMode == 1)
	{
		UpdateBgMusicPanelText();
		return;
	}

	if (m.theMusicPlayer.transportMode == 2)
	{
		m.DoMusicPlayPause();
		UpdateBgMusicPanelText();
		return;
	}

	if (m.musicSelect <= 0)
	{
		m.musicSelect = 1;
		m.musicButton = 1;
		m.musicScroll = 0;
		m.nPlayCursor = 0;
	}

	m.InitPlaylist();
	m.PlayCurrentSong();
	UpdateBgMusicPanelText();
}

function AdjustBgMusicSoundtrackList()
{
	var m = theMusicInline.children[0];
	var musicCount = m.theMusicCollection.GetSoundtrackCount() + 1; // plus 1 for audio cd

	if ((musicCount <= 8) + (m.musicSelect < 8))
	{
		m.musicButton = m.musicSelect;
		m.musicScroll = 0;
	}
	else
	{
		if (m.musicSelect >= (musicCount - 8))
		{
			m.musicButton = 8 + m.musicSelect - musicCount;
			m.musicScroll = musicCount - 8;
		}
		else
		{
			m.musicButton = 0;
			m.musicScroll = m.musicSelect;
		}
	}
}

function NextSoundtrack()
{
	var m = theMusicInline.children[0];
	var count = m.theMusicCollection.GetSoundtrackCount();

	if (count <= 0)
		return;

	m.musicSelect = m.musicSelect + 1;

	if (m.musicSelect > count)
		m.musicSelect = 1;

	AdjustBgMusicSoundtrackList();
	m.nPlayCursor = 0;

	m.InitPlaylist();
	m.PlayCurrentSong();
	UpdateBgMusicPanelText();
}
function PrevSoundtrack()
{
	var m = theMusicInline.children[0];
	var count = m.theMusicCollection.GetSoundtrackCount();

	if (count <= 0)
		return;

	m.musicSelect = m.musicSelect - 1;

	if (m.musicSelect < 1)
		m.musicSelect = count;

	AdjustBgMusicSoundtrackList();
	m.nPlayCursor = 0;

	m.InitPlaylist();
	m.PlayCurrentSong();
	UpdateBgMusicPanelText();
}
function UpdateBgMusicTrackText()
{
	if (theMusicInline.visible == false)
		return;

	var m = theMusicInline.children[0];

	if (m.musicSelect <= 0)
		return;

	if (m.playlist.length == 0)
		return;

	var nSoundtrack = m.musicSelect - 1;
	var nSong = m.playlist[m.nPlayCursor];
	var strName = m.theMusicCollection.GetSoundtrackSongName(nSoundtrack, nSong);

	if (strName == "")
		strName = "Track " + (nSong + 1);

	theMainMenu.children[0].children[0].MainMenuButton2_Text.text = strName;
}
function UpdateBgMusicPanelText()
{
    if (theMusicInline.visible == false)
        return;

    var m = theMusicInline.children[0];

    if (m.musicSelect <= 0)
        return;

    if (m.playlist.length == 0)
        return;

    var nSoundtrack = m.musicSelect - 1;
    var nSong = m.playlist[m.nPlayCursor];

    var strName = m.theMusicCollection.GetSoundtrackSongName(nSoundtrack, nSong);

    if (strName == "")
        strName = "Track " + (nSong + 1);

    var c = theMainMenu.children[0].children[0];

    c.Info2_panel_header_text.text = "Artist";
    c.Info2_panel_support_03_text.text = "Title";
    BgMusicPanelTextNode = c.theInfo2_text.children[0].children[0].children[0];
    BgMusicPanelTextNode.geometry.text = strName + "    ";
    bBgMusicPanelTextScroll = true;
    ApplyMainMenuPanelSelection();
}

function ScrollBgMusicPanelText()
{
    var strText = BgMusicPanelTextNode.geometry.text;
    var nLength = strText.length();

    if(nLength > 18)
    {
        BgMusicPanelTextNode.geometry.text = strText.substring(1,nLength)+strText.substring(0,1);
    }
}

