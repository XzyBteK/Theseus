}

function GetSavedBooleanValue(x,y) 
{
	var a = x;
	var b = y;
	ConfigFile.section = a;
	var c = ConfigFile.GetValue(b);
	if(c.toLowerCase() == "true")
	{
		return true;
	}
	else
	{
		return false;
	}
}

function SetSavedBooleanValue(x,y,z) 
{
	var a = x;
	var b = y;
	var c = z;
	ConfigFile.section = a;
	if(c)
	{
		ConfigFile.SetValue(b,"true");
	}
	else
	{
		ConfigFile.SetValue(b,"false");
	}
}
function GetDrivePath(x,y)
{
	if(x == "Harddisk0" & y == "Partition2") return "C:\\";
	if(x == "Harddisk0" & y == "Partition1") return "E:\\";
	if(x == "Harddisk0" & y == "Partition6") return "F:\\";
	if(x == "Harddisk0" & y == "Partition7") return "G:\\";
	if(x == "Harddisk1" & y == "Partition1") return "R:\\";
	if(x == "Harddisk1" & y == "Partition6") return "H:\\";
	if(x == "Harddisk1" & y == "Partition7") return "I:\\";
}

