function parseTrans(translation,parameter) //A function to return the requested parameter from translation values.
{
	var TransParameter = Split(NumberToString(translation)," "); //convert the Translation numbers to an array of strings.
	if(parameter.toUpperCase() == "X") 
	{
		return StringToNumber(TransParameter[0]); //convert back to number before returning the value
	} 
	else if(parameter.toUpperCase() == "Y") 
	{
		return StringToNumber(TransParameter[1]); 
	} 
	else if(parameter.toUpperCase() == "Z") 
	{
		return StringToNumber(TransParameter[2]); 
	}
}

function StringToNumber( thestring )
{
	var tempstring = thestring;
	var theNumber = Math.abs(tempstring);
	if(tempstring.charCodeAt(0) == 45) theNumber = theNumber * -1;
	return theNumber;
}

function NumberToString(x)
{
	theNumberToString.children[0].geometry.text = x;
	var b = theNumberToString.children[0].geometry.text;
	return b;
}

DEF theNumberToString Transform
{
	visible false
	children
	[
		Shape
		{
			appearance MaxMaterial { name "ItemsType" }
			geometry Text { font "Body" width -15 translate false text ""}
		}
	]
}

function GetRandomInteger(max) 
{
	return Math.floor(Math.random() * max);
}

function Modulo(x,y)
{
	var a = Math.floor(x / y);
	return (x - (a * y));
}

function Split(str,Delimiter)
{
	var arrReturn = new Array;
	if(str.length() == 0) return arrReturn;
	var x = str;
	var i = 0;
	while( x.indexOf(Delimiter) >= 0 )
	{
		arrReturn[i] = x.substr(0,x.indexOf(Delimiter));
		x = x.substr(x.indexOf(Delimiter) + Delimiter.length());
		i = i + 1;
	}
	arrReturn[i] = x;
	return arrReturn;
}

