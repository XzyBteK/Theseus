						var c = children[0];
						c.button_yes.visible = false;
						c.button_no.visible = false;
						c.button_center.visible = false;
						c.slider_slot.visible = false;
						c.slider.visible = false;
						
						g_theMessageLayerLoaded = true;
						
						DisplayWaitingMessage();
